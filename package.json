{
  "name": "telex-site",
  "version": "1.0.0",
  "description": "Site web TELEX - Télévision étudiante",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "install-deps": "npm install express ejs sqlite3 express-session bcryptjs morgan",
    "setup": "npm run install-deps && echo '✅ Installation terminée'",
    "check": "node check-structure.js",
    "heroku-postbuild": "npm install",
    "deploy-simafri": "chmod +x simafri-deploy.sh && ./simafri-deploy.sh"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.2",
    "nodemon": "^3.1.4",
    "sqlite3": "^5.1.7"
  },
  "keywords": [
    "telex",
    "tv",
    "étudiant",
    "média",
    "node22",
    "simafri"
  ],
  "author": "TELEX Team",
  "license": "MIT"
}
