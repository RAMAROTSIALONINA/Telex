{
  "name": "telex-site",
  "version": "1.0.0",
  "description": "Site web TELEX - Télévision étudiante",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "install-deps": "npm install express ejs sqlite3 express-session bcryptjs morgan",
    "setup": "npm run install-deps && echo '✅ Installation terminée'",
    "check": "node check-structure.js",
