<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Planification des Programmes - Admin TELEX</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --info-red: #E63946;
            --info-red-light: #F4A2A2;
            --decryptage-yellow: #FFB347;
            --decryptage-yellow-light: #FFD700;
            --debat-pink: #FF8A65;
            --debat-pink-light: #FFAB91;
            --societe-gray: #6C757D;
            --societe-gray-light: #ADB5BD;
            --education-blue: #4A90E2;
            --education-blue-light: #7B9ED6;
            --jeunesse-blue: #4CAF50;
            --jeunesse-blue-light: #66BB6A;
            --environnement-green: #28A745;
            --environnement-green-light: #6AB04C;
            --culture-violet: #9B59B6;
            --culture-violet-light: #BB8FCE;
            --economie-cyan: #17A2B8;
            --economie-cyan-light: #6ED4E0;
            --sport-orange: #F39C12;
            --sport-orange-light: #F7B731;
        }

        body {
            background: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding-bottom: 2rem;
        }

        .admin-header {
            background: linear-gradient(135deg, var(--telex-blue) 0%, var(--telex-light) 100%);
            color: white;
            padding: 2rem 0;
            margin-bottom: 2rem;
        }

        .table {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }

        .table thead th {
            background: var(--telex-blue);
            color: white;
            border: none;
            padding: 1rem;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
        }

        .badge {
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-weight: 500;
        }

        .badge-information { background: linear-gradient(135deg, var(--info-red), var(--info-red-light)); color: white; }
        .badge-decryptage { background: linear-gradient(135deg, var(--decryptage-yellow), var(--decryptage-yellow-light)); color: white; }
        .badge-debats { background: linear-gradient(135deg, var(--debat-pink), var(--debat-pink-light)); color: white; }
        .badge-societe { background: linear-gradient(135deg, var(--societe-gray), var(--societe-gray-light)); color: white; }
        .badge-education { background: linear-gradient(135deg, var(--education-blue), var(--education-blue-light)); color: white; }
        .badge-jeunesse { background: linear-gradient(135deg, var(--jeunesse-blue), var(--jeunesse-blue-light)); color: white; }
        .badge-environnement { background: linear-gradient(135deg, var(--environnement-green), var(--environnement-green-light)); color: white; }
        .badge-culture { background: linear-gradient(135deg, var(--culture-violet), var(--culture-violet-light)); color: white; }
        .badge-economie { background: linear-gradient(135deg, var(--economie-cyan), var(--economie-cyan-light)); color: white; }
        .badge-sport { background: linear-gradient(135deg, var(--sport-orange), var(--sport-orange-light)); color: white; }
        .badge-default { background: #6c757d; color: white; }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
        }

        .btn-action {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            border: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            color: white;
        }

        .btn-edit {
            background: #007bff;
        }

        .btn-edit:hover {
            background: #0056b3;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,123,255,0.3);
        }

        .btn-delete {
            background: #dc3545;
        }

        .btn-delete:hover {
            background: #c82333;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(220,53,69,0.3);
        }

        .add-program-btn {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: var(--telex-red);
            color: white;
            border: none;
            box-shadow: 0 4px 20px rgba(230, 57, 70, 0.3);
            font-size: 1.5rem;
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .add-program-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 30px rgba(230, 57, 70, 0.4);
        }

        .color-legend {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            margin-top: 2rem;
        }

        .legend-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--telex-blue);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
        }

        .legend-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1rem;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .legend-color {
            width: 30px;
            height: 30px;
            border-radius: 6px;
        }

        .legend-label {
            font-size: 0.9rem;
            color: #2c3e50;
        }

        /* Modal styles */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: white;
            border-radius: 12px;
            padding: 2rem;
            max-width: 500px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
            color: #2c3e50;
        }

        .form-control, .form-select {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 1rem;
        }

        .form-control:focus, .form-select:focus {
            outline: none;
            border-color: var(--telex-red);
            box-shadow: 0 0 0 2px rgba(230, 57, 70, 0.2);
        }

        .modal-actions {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            margin-top: 1.5rem;
        }

        .btn-cancel {
            background: #6c757d;
            color: white;
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-cancel:hover {
            background: #5a6268;
        }

        .btn-save {
            background: var(--telex-red);
            color: white;
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-save:hover {
            background: #c82333;
        }

        .btn-delete-confirm {
            background: #dc3545;
            color: white;
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-delete-confirm:hover {
            background: #c82333;
        }

        .alert {
            padding: 1rem;
            border-radius: 6px;
            margin-bottom: 1rem;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .alert-warning {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffeeba;
        }

        .text-center {
            text-align: center;
        }

        .mt-4 {
            margin-top: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="admin-header">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1><i class="fas fa-calendar-alt me-3"></i>Grille des Programmes TELEX</h1>
                    <p class="mb-0">Programmation hebdomadaire des émissions</p>
                </div>
                <a href="/admin/programs" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-2"></i>Retour aux Programmes
                </a>
            </div>
        </div>
    </div>

    <div class="container">
        <!-- Grille des programmes - Tableau récapitulatif -->
        <div class="table-responsive">
            <table class="table table-bordered" id="programsTable">
                <thead class="table-dark">
                    <tr>
                        <th>Jour</th>
                        <th>Heure</th>
                        <th>Émission</th>
                        <th>Type</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="programsTableBody">
                    <!-- Les programmes seront chargés dynamiquement ici -->
                </tbody>
            </table>
        </div>
        
        <!-- Légende des types de programmes -->
        <div class="color-legend">
            <div class="legend-title">
                <i class="fas fa-palette me-2"></i>
                Légende des programmes
            </div>
            <div class="legend-grid">
                <div class="legend-item">
                    <div class="legend-color" style="background: linear-gradient(135deg, var(--info-red), var(--info-red-light));"></div>
                    <span class="legend-label">Information</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: linear-gradient(135deg, var(--decryptage-yellow), var(--decryptage-yellow-light));"></div>
                    <span class="legend-label">Décryptage</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: linear-gradient(135deg, var(--debat-pink), var(--debat-pink-light));"></div>
                    <span class="legend-label">Débat</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: linear-gradient(135deg, var(--societe-gray), var(--societe-gray-light));"></div>
                    <span class="legend-label">Sociétal</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: linear-gradient(135deg, var(--education-blue), var(--education-blue-light));"></div>
                    <span class="legend-label">Éducatif</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: linear-gradient(135deg, var(--jeunesse-blue), var(--jeunesse-blue-light));"></div>
                    <span class="legend-label">Jeunesse</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: linear-gradient(135deg, var(--environnement-green), var(--environnement-green-light));"></div>
                    <span class="legend-label">Environnement</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: linear-gradient(135deg, var(--culture-violet), var(--culture-violet-light));"></div>
                    <span class="legend-label">Culture</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: linear-gradient(135deg, var(--economie-cyan), var(--economie-cyan-light));"></div>
                    <span class="legend-label">Économie</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: linear-gradient(135deg, var(--sport-orange), var(--sport-orange-light));"></div>
                    <span class="legend-label">Sport</span>
                </div>
            </div>
        </div>
    </div>

    <button class="add-program-btn" onclick="showAddModal()">
        <i class="fas fa-plus"></i>
    </button>

    <!-- Modal d'édition/ajout -->
    <div id="programModal" class="modal">
        <div class="modal-content">
            <h3 id="modalTitle"><i class="fas fa-edit me-2"></i>Modifier le programme</h3>
            <form id="programForm">
                <input type="hidden" id="programId">
                <input type="hidden" id="originalJour">
                <input type="hidden" id="originalHeure">
                
                <div class="form-group">
                    <label for="programJour">Jour</label>
                    <select id="programJour" class="form-select" required>
                        <option value="">Sélectionner un jour</option>
                        <option value="Lundi">Lundi</option>
                        <option value="Mardi">Mardi</option>
                        <option value="Mercredi">Mercredi</option>
                        <option value="Jeudi">Jeudi</option>
                        <option value="Vendredi">Vendredi</option>
                        <option value="Samedi">Samedi</option>
                        <option value="Dimanche">Dimanche</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="programHeure">Heure</label>
                    <input type="time" id="programHeure" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label for="programEmission">Titre de l'émission</label>
                    <input type="text" id="programEmission" class="form-control" placeholder="Ex: TELEX Actus" required>
                </div>
                
                <div class="form-group">
                    <label for="programType">Type de programme</label>
                    <select id="programType" class="form-select" required>
                        <option value="">Sélectionner un type</option>
                        <option value="Information">Information</option>
                        <option value="Décryptage">Décryptage</option>
                        <option value="Débat">Débat</option>
                        <option value="Sociétal">Sociétal</option>
                        <option value="Éducatif">Éducatif</option>
                        <option value="Jeunesse">Jeunesse</option>
                        <option value="Environnement">Environnement</option>
                        <option value="Culture">Culture</option>
                        <option value="Économie">Économie</option>
                        <option value="Sport">Sport</option>
                    </select>
                </div>
                
                <div class="modal-actions">
                    <button type="button" class="btn-cancel" onclick="closeModal()">Annuler</button>
                    <button type="submit" class="btn-save" id="saveButton">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal de confirmation de suppression -->
    <div id="deleteModal" class="modal">
        <div class="modal-content">
            <h3><i class="fas fa-trash me-2" style="color: #dc3545;"></i>Confirmer la suppression</h3>
            <p id="deleteMessage">Êtes-vous sûr de vouloir supprimer ce programme ?</p>
            <p id="deleteDetails" class="text-muted"></p>
            
            <div class="modal-actions">
                <button type="button" class="btn-cancel" onclick="closeDeleteModal()">Annuler</button>
                <button type="button" class="btn-delete-confirm" onclick="confirmDelete()">Supprimer</button>
            </div>
        </div>
    </div>

    <!-- Alert container -->
    <div id="alertContainer" style="position: fixed; top: 20px; right: 20px; z-index: 3000;"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let programs = [];
        let currentDeleteId = null;
        let currentEditId = null;

        // Charger les programmes depuis la base de données
        async function loadPrograms() {
            try {
                const response = await fetch('/admin/schedule/api/programs', {
                    credentials: 'include'
                });
                const data = await response.json();
                
                if (data.success) {
                    programs = data.programs;
                    console.log('📥 Programmes chargés:', programs);
                    console.log('📝 Types des ID:', programs.map(p => ({ id: p.id, type: typeof p.id })));
                    displayPrograms();
                } else {
                    showAlert('Erreur lors du chargement des programmes', 'error');
                }
            } catch (error) {
                console.error('Erreur:', error);
                showAlert('Erreur serveur lors du chargement', 'error');
            }
        }

        // Fonction pour afficher les programmes dans le tableau
        function displayPrograms() {
            const tbody = document.getElementById('programsTableBody');
            tbody.innerHTML = '';
            
            // Trier les programmes par jour et heure
            const joursOrder = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi', 'Dimanche'];
            
            // Grouper par jour
            const programsByJour = {};
            joursOrder.forEach(jour => {
                programsByJour[jour] = [];
            });
            
            programs.forEach(program => {
                if (programsByJour[program.jour]) {
                    programsByJour[program.jour].push(program);
                } else {
                    programsByJour[program.jour] = [program];
                }
            });
            
            // Trier les programmes de chaque jour par heure
            Object.keys(programsByJour).forEach(jour => {
                programsByJour[jour].sort((a, b) => {
                    // Gérer les valeurs null/undefined
                    const timeA = a.heure || '00:00';
                    const timeB = b.heure || '00:00';
                    return timeA.localeCompare(timeB);
                });
            });
            
            // Afficher les programmes
            joursOrder.forEach(jour => {
                const jourPrograms = programsByJour[jour] || [];
                
                if (jourPrograms.length === 0) {
                    // Afficher une ligne pour les jours sans programme
                    tbody.innerHTML += `
                        <tr>
                            <td>${jour}</td>
                            <td colspan="4" class="text-center text-muted">
                                <i class="fas fa-calendar-times me-2"></i>
                                Aucun programme programmé
                            </td>
                        </tr>
                    `;
                } else {
                    jourPrograms.forEach((program, index) => {
                        tbody.innerHTML += `
                            <tr data-program-id="${program.id}">
                                <td>${index === 0 ? jour : ''}</td>
                                <td>${program.heure}</td>
                                <td>${program.emission}</td>
                                <td><span class="badge badge-${program.typeClass}">${program.type}</span></td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn-action btn-edit" data-program-id="${program.id}" title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn-action btn-delete" data-program-id="${program.id}" title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        `;
                    });
                }
            });
            
            // Configurer les écouteurs d'événements
            setupEventListeners();
        }

        // Fonction pour réinitialiser les écouteurs d'événements
        function setupEventListeners() {
            // Supprimer les anciens écouteurs
            document.querySelectorAll('.btn-edit').forEach(btn => {
                btn.replaceWith(btn.cloneNode(true));
            });
            document.querySelectorAll('.btn-delete').forEach(btn => {
                btn.replaceWith(btn.cloneNode(true));
            });
            
            // Ajouter les nouveaux écouteurs
            document.querySelectorAll('.btn-edit').forEach(btn => {
                btn.addEventListener('click', function() {
                    const programId = this.getAttribute('data-program-id');
                    editProgram(programId);
                });
            });
            
            document.querySelectorAll('.btn-delete').forEach(btn => {
                btn.addEventListener('click', function() {
                    const programId = this.getAttribute('data-program-id');
                    deleteProgram(programId);
                });
            });
        }

        // Fonction pour ouvrir le modal d'ajout
        function showAddModal() {
            currentEditId = null;
            document.getElementById('modalTitle').innerHTML = '<i class="fas fa-plus me-2"></i>Ajouter un programme';
            document.getElementById('programForm').reset();
            document.getElementById('programId').value = '';
            document.getElementById('saveButton').textContent = 'Ajouter';
            document.getElementById('programModal').style.display = 'flex';
        }

        // Fonction pour éditer un programme
        function editProgram(id) {
            console.log('🔧 editProgram appelé avec ID:', id, 'type:', typeof id);
            const program = programs.find(p => p.id == id || p.id == parseInt(id) || p.id == id.toString());
            console.log('🔍 Programme trouvé:', program);
            if (program) {
                currentEditId = id;
                document.getElementById('modalTitle').innerHTML = '<i class="fas fa-edit me-2"></i>Modifier le programme';
                document.getElementById('programId').value = program.id;
                document.getElementById('originalJour').value = program.jour;
                document.getElementById('originalHeure').value = program.heure;
                document.getElementById('programJour').value = program.jour;
                document.getElementById('programHeure').value = program.heure;
                document.getElementById('programEmission').value = program.emission;
                document.getElementById('programType').value = program.type;
                document.getElementById('saveButton').textContent = 'Enregistrer';
                document.getElementById('programModal').style.display = 'flex';
            } else {
                console.error('❌ Programme non trouvé pour ID:', id);
                console.error('🔍 Programmes disponibles:', programs.map(p => ({ id: p.id, type: typeof p.id })));
            }
        }

        // Fonction pour supprimer un programme (ouvrir le modal de confirmation)
        function deleteProgram(id) {
            console.log('🗑️ deleteProgram appelé avec ID:', id, 'type:', typeof id);
            console.log('🔍 Tableau programmes actuel:', programs.map(p => ({ id: p.id, type: typeof p.id, emission: p.emission })));
            
            const program = programs.find(p => p.id == id || p.id == parseInt(id) || p.id == id.toString());
            console.log('🔍 Programme trouvé:', program);
            
            // Vérifier si c'est un ID généré localement (non numérique ou undefined)
            if (!id || id === 'undefined' || isNaN(parseInt(id))) {
                console.error('❌ ID invalide pour suppression:', id);
                showAlert('Ce programme ne peut pas être supprimé car il n\'a pas d\'ID valide. Veuillez actualiser la page.', 'error');
                return;
            }
            
            if (program) {
                currentDeleteId = id;
                document.getElementById('deleteDetails').textContent = `${program.jour} à ${program.heure} - ${program.emission}`;
                document.getElementById('deleteModal').style.display = 'flex';
            } else {
                console.error('❌ Programme non trouvé pour ID:', id);
                console.error('🔍 Programmes disponibles:', programs.map(p => ({ id: p.id, type: typeof p.id, emission: p.emission })));
                showAlert('Programme non trouvé. Veuillez actualiser la page.', 'error');
            }
        }

        // Fonction pour confirmer la suppression
        async function confirmDelete() {
            if (currentDeleteId) {
                console.log('🗑️ confirmDelete appelé avec ID:', currentDeleteId, 'type:', typeof currentDeleteId);
                try {
                    // Appeler l'API pour supprimer le programme
                    const response = await fetch(`/admin/schedule/program/${currentDeleteId}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        credentials: 'include'
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        // Supprimer le programme du tableau local avec comparaison flexible
                        const initialLength = programs.length;
                        programs = programs.filter(p => p.id != currentDeleteId); // Utiliser != au lieu de !==
                        console.log('🗑️ Suppression du programme - Avant:', initialLength, 'Après:', programs.length);
                        
                        // Synchroniser avec la base de données pour s'assurer que tout est cohérent
                        setTimeout(() => {
                            syncPrograms();
                        }, 500);
                        
                        // Afficher un message de succès
                        showAlert('Programme supprimé avec succès', 'success');
                        
                        // Fermer le modal
                        closeDeleteModal();
                        currentDeleteId = null;
                    } else {
                        showAlert('Erreur lors de la suppression: ' + (data.error || 'Erreur inconnue'), 'error');
                    }
                } catch (error) {
                    console.error('Erreur:', error);
                    showAlert('Erreur serveur lors de la suppression', 'error');
                }
            }
        }

        // Fonction pour fermer le modal d'édition/ajout
        function closeModal() {
            document.getElementById('programModal').style.display = 'none';
        }

        // Fonction pour fermer le modal de suppression
        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
            currentDeleteId = null;
        }

        // Fonction pour générer un ID unique
        function generateId() {
            return Date.now().toString(36) + Math.random().toString(36).substr(2);
        }

        // Fonction pour obtenir la classe CSS du type
        function getTypeClass(type) {
            const typeMap = {
                'Information': 'information',
                'Décryptage': 'decryptage',
                'Débat': 'debats',
                'Sociétal': 'societe',
                'Éducatif': 'education',
                'Jeunesse': 'jeunesse',
                'Environnement': 'environnement',
                'Culture': 'culture',
                'Économie': 'economie',
                'Sport': 'sport'
            };
            return typeMap[type] || 'default';
        }

        // Fonction pour vérifier si un programme existe déjà (même jour et même heure)
        function programExists(jour, heure, excludeId = null) {
            return programs.some(p => 
                p.jour === jour && 
                p.heure === heure && 
                (excludeId ? p.id !== excludeId : true)
            );
        }

        // Gestionnaire de soumission du formulaire
        document.getElementById('programForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const jour = document.getElementById('programJour').value;
            const heure = document.getElementById('programHeure').value;
            const emission = document.getElementById('programEmission').value;
            const type = document.getElementById('programType').value;
            
            // Validation
            if (!jour || !heure || !emission || !type) {
                showAlert('Veuillez remplir tous les champs', 'error');
                return;
            }
            
            const typeClass = getTypeClass(type);
            const programId = document.getElementById('programId').value;
            
            try {
                if (programId) {
                    // Mode édition - Appeler l'API PUT
                    const originalJour = document.getElementById('originalJour').value;
                    const originalHeure = document.getElementById('originalHeure').value;
                    
                    // Vérifier si on change le jour ou l'heure
                    if (jour !== originalJour || heure !== originalHeure) {
                        if (programExists(jour, heure, programId)) {
                            showAlert('Un programme existe déjà à ce jour et cette heure', 'error');
                            return;
                        }
                    }
                    
                    const response = await fetch(`/admin/schedule/program/${programId}`, {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            title: emission,
                            type: type,
                            time: heure,
                            presenter: 'TELEX',
                            isActive: true,
                            date: new Date().toISOString().split('T')[0],
                            jour: jour
                        }),
                        credentials: 'include'
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        // Mettre à jour le programme dans le tableau local avec comparaison flexible
                        const index = programs.findIndex(p => p.id == programId); // Utiliser == au lieu de ===
                        if (index !== -1) {
                            programs[index] = {
                                ...programs[index],
                                jour,
                                heure,
                                emission,
                                type,
                                typeClass
                            };
                            console.log('✅ Programme modifié:', programs[index]);
                        }
                        showAlert('Programme modifié avec succès', 'success');
                    } else {
                        showAlert('Erreur lors de la modification: ' + (data.error || 'Erreur inconnue'), 'error');
                        return;
                    }
                } else {
                    // Mode ajout - Appeler l'API POST
                    // Vérifier si un programme existe déjà à ce jour et cette heure
                    if (programExists(jour, heure)) {
                        showAlert('Un programme existe déjà à ce jour et cette heure', 'error');
                        return;
                    }
                    
                    const response = await fetch('/admin/schedule/program', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            title: emission,
                            type: type,
                            time: heure,
                            presenter: 'TELEX',
                            isActive: true,
                            date: new Date().toISOString().split('T')[0],
                            jour: jour
                        }),
                        credentials: 'include'
                    });
                    
                    const data = await response.json();
                    console.log('🔍 DEBUG - Réponse API ajout:', data);
                    
                    if (data.success) {
                        // Ajouter le nouveau programme au tableau local
                        const newProgram = {
                            id: data.id, // Utiliser systématiquement l'ID retourné par l'API
                            jour,
                            heure,
                            emission,
                            type,
                            typeClass
                        };
                        
                        // Validation de l'ID
                        if (!data.id || data.id === 'undefined' || isNaN(parseInt(data.id))) {
                            console.error('❌ ID invalide retourné par l\'API:', data.id);
                            showAlert('Erreur lors de l\'ajout: ID invalide retourné par le serveur', 'error');
                            return;
                        }
                        
                        programs.push(newProgram);
                        console.log('✅ Programme ajouté avec ID:', data.id, 'type:', typeof data.id, newProgram);
                        console.log('📊 Tableau programmes après ajout:', programs.map(p => ({ id: p.id, type: typeof p.id, emission: p.emission })));
                        showAlert('Programme ajouté avec succès', 'success');
                    } else {
                        showAlert('Erreur lors de l\'ajout: ' + (data.error || 'Erreur inconnue'), 'error');
                        return;
                    }
                }
                
                // Synchroniser avec la base de données pour s'assurer que tout est cohérent
                setTimeout(() => {
                    syncPrograms();
                }, 500);
                
                // Fermer le modal
                closeModal();
            } catch (error) {
                console.error('Erreur:', error);
                showAlert('Erreur serveur lors de l\'enregistrement', 'error');
            }
        });

        // Fonction pour afficher une alerte
        function showAlert(message, type) {
            const alertContainer = document.getElementById('alertContainer');
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type === 'success' ? 'success' : 'error'}`;
            alertDiv.innerHTML = `
                <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
                ${message}
            `;
            
            alertContainer.appendChild(alertDiv);
            
            setTimeout(() => {
                alertDiv.remove();
            }, 3000);
        }

        // Fonction pour synchroniser les programmes avec la base de données
        async function syncPrograms() {
            console.log('🔄 Synchronisation des programmes avec la base de données...');
            try {
                const response = await fetch('/admin/schedule/api/programs', {
                    credentials: 'include'
                });
                const data = await response.json();
                
                if (data.success) {
                    programs = data.programs;
                    console.log('✅ Programmes synchronisés:', programs.length);
                    displayPrograms();
                    setupEventListeners();
                } else {
                    console.error('❌ Erreur de synchronisation:', data);
                }
            } catch (error) {
                console.error('❌ Erreur lors de la synchronisation:', error);
            }
        }

        // Fonction pour nettoyer les programmes invalides et recharger depuis la base
        function cleanupAndReload() {
            console.log('🧹 Nettoyage des programmes invalides...');
            // Filtrer les programmes qui ont des ID valides (numériques)
            const validPrograms = programs.filter(p => !isNaN(parseInt(p.id)));
            console.log('📊 Programmes valides:', validPrograms.length, 'sur', programs.length);
            
            if (validPrograms.length !== programs.length) {
                showAlert('Nettoyage des programmes locaux non sauvegardés', 'info');
            }
            
            // Recharger depuis la base de données
            loadPrograms();
        }

        // Fermer les modals en cliquant en dehors
        window.onclick = function(event) {
            const editModal = document.getElementById('programModal');
            const deleteModal = document.getElementById('deleteModal');
            
            if (event.target === editModal) {
                closeModal();
            }
            if (event.target === deleteModal) {
                closeDeleteModal();
            }
        };

        // Charger les programmes au chargement de la page
        document.addEventListener('DOMContentLoaded', function() {
            loadPrograms();
            // Nettoyer les programmes invalides après le chargement
            setTimeout(cleanupAndReload, 1000);
        });

        // Initialiser l'affichage
        displayPrograms();
    </script>
</body>
</html>