    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ===== VARIABLES GLOBALES =====
        let uploadedImage = null;
        let uploadedVideo = null;

        // ===== INITIALISATION =====
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Page Nouveau Programme TELEX chargée');
            
            // Initialiser les composants
            initializeMediaTypeSelector();
            initializeUploadAreas();
            toggleBroadcastFields();
        });

        // ===== SÉLECTEUR TYPE MÉDIA =====
        function initializeMediaTypeSelector() {
            const mediaTypeRadios = document.querySelectorAll('input[name="media_type"]');
            const imageSection = document.getElementById('imageSection');
            const videoSection = document.getElementById('videoSection');

            mediaTypeRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    // Masquer toutes les sections
                    imageSection.style.display = 'none';
                    videoSection.style.display = 'none';
                    
                    // Réinitialiser les fichiers uploadés
                    if (this.value !== 'image') {
                        removeImage();
                    }
                    if (this.value !== 'video') {
                        removeVideo();
                    }
                    
                    // Afficher la section correspondante
                    if (this.value === 'image') {
                        imageSection.style.display = 'block';
                    } else if (this.value === 'video') {
                        videoSection.style.display = 'block';
                    }
                });
            });
        }

        // ===== ZONES D'UPLOAD =====
        function initializeUploadAreas() {
            // Upload d'image
            const imageUploadArea = document.getElementById('imageUploadArea');
            const imageFileInput = document.getElementById('image_file');

            if (imageUploadArea && imageFileInput) {
                imageUploadArea.addEventListener('click', () => imageFileInput.click());

                imageUploadArea.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    imageUploadArea.style.borderColor = 'var(--telex-blue)';
                    imageUploadArea.style.background = '#e3f2fd';
                });

                imageUploadArea.addEventListener('dragleave', (e) => {
                    e.preventDefault();
                    imageUploadArea.style.borderColor = '#cbd5e1';
                    imageUploadArea.style.background = 'linear-gradient(135deg, #ffffff, #f8fafc)';
                });

                imageUploadArea.addEventListener('drop', (e) => {
                    e.preventDefault();
                    imageUploadArea.style.borderColor = '#cbd5e1';
                    imageUploadArea.style.background = 'linear-gradient(135deg, #ffffff, #f8fafc)';

                    const files = e.dataTransfer.files;
                    if (files.length > 0) {
                        handleImageFile(files[0]);
                    }
                });

                imageFileInput.addEventListener('change', (e) => {
                    if (e.target.files.length > 0) {
                        handleImageFile(e.target.files[0]);
                    }
                });
            }

            // Upload de vidéo
            const videoUploadArea = document.getElementById('videoUploadArea');
            const videoFileInput = document.getElementById('video_file');

            if (videoUploadArea && videoFileInput) {
                videoUploadArea.addEventListener('click', () => videoFileInput.click());

                videoUploadArea.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    videoUploadArea.style.borderColor = 'var(--telex-blue)';
                    videoUploadArea.style.background = '#e3f2fd';
                });

                videoUploadArea.addEventListener('dragleave', (e) => {
                    e.preventDefault();
                    videoUploadArea.style.borderColor = '#cbd5e1';
                    videoUploadArea.style.background = 'linear-gradient(135deg, #ffffff, #f8fafc)';
                });

                videoUploadArea.addEventListener('drop', (e) => {
                    e.preventDefault();
                    videoUploadArea.style.borderColor = '#cbd5e1';
                    videoUploadArea.style.background = 'linear-gradient(135deg, #ffffff, #f8fafc)';

                    const files = e.dataTransfer.files;
                    if (files.length > 0) {
                        handleVideoFile(files[0]);
                    }
                });

                videoFileInput.addEventListener('change', (e) => {
                    if (e.target.files.length > 0) {
                        handleVideoFile(e.target.files[0]);
                    }
                });
            }

            // URL de vidéo
            const videoUrlInput = document.getElementById('video_url');
            if (videoUrlInput) {
                videoUrlInput.addEventListener('input', (e) => {
                    const url = e.target.value.trim();
                    if (url) {
                        // Désactiver l'upload de fichier
                        if (videoFileInput) videoFileInput.disabled = true;
                        showVideoPreview(url);
                    } else {
                        // Réactiver l'upload de fichier
                        if (videoFileInput) videoFileInput.disabled = false;
                        hideVideoPreview();
                    }
                });
            }
        }

        // ===== GESTION IMAGE =====
        function handleImageFile(file) {
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
            if (!allowedTypes.includes(file.type)) {
                alert('Format non supporté. Utilisez JPG, PNG, GIF ou WebP.');
                return;
            }

            if (file.size > 50 * 1024 * 1024) {
                alert('L\'image ne doit pas dépasser 50MB.');
                return;
            }

            uploadedImage = file;
            showImagePreview(file);
        }

        function showImagePreview(file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const imagePreview = document.getElementById('imagePreview');
                const imagePreviewContainer = document.getElementById('imagePreviewContainer');

                imagePreviewContainer.innerHTML = `<img src="${e.target.result}" alt="Prévisualisation" class="preview-image">`;
                imagePreview.style.display = 'block';
            };
            reader.readAsDataURL(file);
        }

        // ===== GESTION VIDÉO =====
        function handleVideoFile(file) {
            const allowedTypes = ['video/mp4', 'video/webm', 'video/ogg', 'video/quicktime', 'video/x-msvideo'];
            if (!allowedTypes.includes(file.type)) {
                alert('Format non supporté. Utilisez MP4, WebM, OGG, MOV ou AVI.');
                return;
            }

            if (file.size > 1000 * 1024 * 1024) {
                alert('La vidéo ne doit pas dépasser 1000MB.');
                return;
            }

            uploadedVideo = file;
            
            // Vider l'URL
            const videoUrlInput = document.getElementById('video_url');
            if (videoUrlInput) videoUrlInput.value = '';
            
            showVideoPreview(file);
        }

        function showVideoPreview(fileOrUrl) {
            const videoPreview = document.getElementById('videoPreview');
            const videoPreviewContainer = document.getElementById('videoPreviewContainer');

            videoPreview.style.display = 'block';

            if (fileOrUrl instanceof File) {
                // Fichier vidéo
                const reader = new FileReader();
                reader.onload = function(e) {
                    videoPreviewContainer.innerHTML = `
                        <video class="preview-video" controls preload="metadata">
                            <source src="${e.target.result}" type="${fileOrUrl.type}">
                            Votre navigateur ne supporte pas la lecture de vidéos.
                        </video>
                        <div class="remove-media">
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeVideo()">
                                <i class="fas fa-trash me-1"></i>Supprimer la vidéo
                            </button>
                        </div>
                    `;
                };
                reader.readAsDataURL(fileOrUrl);
            } else {
                // URL ou YouTube/Vimeo
                if (fileOrUrl.includes('youtube.com') || fileOrUrl.includes('youtu.be')) {
                    const videoId = fileOrUrl.includes('youtube.com')
                        ? fileOrUrl.split('v=')[1]?.split('&')[0]
                        : fileOrUrl.split('youtu.be/')[1]?.split('?')[0];

                    videoPreviewContainer.innerHTML = `
                        <div class="video-thumbnail" onclick="window.open('${fileOrUrl}', '_blank')">
                            <img src="https://img.youtube.com/vi/${videoId}/hqdefault.jpg" alt="Miniature YouTube" class="video-thumbnail-img">
                            <div class="video-overlay">
                                <i class="fab fa-youtube fa-3x text-white"></i>
                            </div>
                        </div>
                        <div class="remove-media">
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeVideo()">
                                <i class="fas fa-trash me-1"></i>Supprimer la vidéo
                            </button>
                        </div>
                    `;
                } else if (fileOrUrl.includes('vimeo.com')) {
                    videoPreviewContainer.innerHTML = `
                        <div class="vimeo-placeholder" onclick="window.open('${fileOrUrl}', '_blank')">
                            <i class="fab fa-vimeo fa-4x"></i>
                            <p class="mt-2 mb-0">Voir sur Vimeo</p>
                        </div>
                        <div class="remove-media">
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeVideo()">
                                <i class="fas fa-trash me-1"></i>Supprimer la vidéo
                            </button>
                        </div>
                    `;
                } else {
                    videoPreviewContainer.innerHTML = `
                        <video class="preview-video" controls preload="metadata">
                            <source src="${fileOrUrl}" type="video/mp4">
                            <source src="${fileOrUrl}" type="video/webm">
                            <source src="${fileOrUrl}" type="video/ogg">
                            Votre navigateur ne supporte pas la lecture de vidéos.
                        </video>
                        <div class="remove-media">
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeVideo()">
                                <i class="fas fa-trash me-1"></i>Supprimer la vidéo
                            </button>
                        </div>
                    `;
                }
            }
        }

        function hideVideoPreview() {
            const videoPreview = document.getElementById('videoPreview');
            if (videoPreview) videoPreview.style.display = 'none';
        }

        // ===== SUPPRESSIONS =====
        function removeImage() {
            uploadedImage = null;
            const imageFileInput = document.getElementById('image_file');
            if (imageFileInput) imageFileInput.value = '';
            
            const imagePreview = document.getElementById('imagePreview');
            if (imagePreview) imagePreview.style.display = 'none';
            
            const imagePreviewContainer = document.getElementById('imagePreviewContainer');
            if (imagePreviewContainer) imagePreviewContainer.innerHTML = '';
        }

        function removeVideo() {
            uploadedVideo = null;
            
            const videoFileInput = document.getElementById('video_file');
            if (videoFileInput) {
                videoFileInput.value = '';
                videoFileInput.disabled = false;
            }
            
            const videoUrlInput = document.getElementById('video_url');
            if (videoUrlInput) videoUrlInput.value = '';
            
            hideVideoPreview();
            
            const videoPreviewContainer = document.getElementById('videoPreviewContainer');
            if (videoPreviewContainer) videoPreviewContainer.innerHTML = '';
        }

        // ===== TYPE DE DIFFUSION =====
        window.toggleBroadcastFields = function() {
            const broadcastType = document.getElementById('broadcast_type').value;
            const announcementFields = document.getElementById('announcement_fields');
            const liveFields = document.getElementById('live_fields');
            const programDate = document.getElementById('program_date');
            const scheduleTime = document.getElementById('schedule_time');

            // Masquer tous les champs conditionnels
            announcementFields.classList.remove('show');
            liveFields.classList.remove('show');

            // Réinitialiser les champs
            if (programDate) {
                programDate.required = false;
                programDate.disabled = false;
            }
            if (scheduleTime) {
                scheduleTime.required = false;
                scheduleTime.disabled = false;
            }

            switch(broadcastType) {
                case 'live':
                    liveFields.classList.add('show');
                    // Pour les programmes live, la date et heure sont optionnelles
                    break;
                case 'announcement':
                    announcementFields.classList.add('show');
                    // Pour les annonces, la date et heure sont optionnelles
                    break;
            }
        };

        // ===== FONCTIONS GLOBALES =====
        window.removeImage = removeImage;
        window.removeVideo = removeVideo;
    </script>

    <script>
        function openSidebar() {
            document.querySelector('.sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('show');
        }
        function closeSidebar() {
            document.querySelector('.sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }
    </script></body>

</html>