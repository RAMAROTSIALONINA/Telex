                                </small>
                            </div>
                            
                            <!-- Prévisualisation vidéo -->
                            <div id="videoPreview" class="mt-3" style="display: none;">
                                <div class="preview-card">
                                    <p class="small mb-2"><strong>Vidéo sélectionnée :</strong></p>
                                    <div id="videoPreviewContainer"></div>
