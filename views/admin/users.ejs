<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --sidebar-width: 280px;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
        }
        
        /* Sidebar */
        .sidebar { 
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%); 
            color: white; 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }
        
        .sidebar-brand {
            padding: 25px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(0, 0, 0, 0.1);
        }
        
        .sidebar-brand img {
            max-width: 120px;
            height: auto;
            max-height: 60px;
            margin-bottom: 15px;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
        }
        
        .sidebar-brand h3 {
            font-weight: 700;
            font-size: 1.5rem;
            margin-bottom: 5px;
        }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .nav-item {
            margin-bottom: 8px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 14px 18px;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s;
            font-weight: 500;
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateX(5px);
        }
        
        .nav-link.active {
            background: rgba(230, 57, 70, 0.15);
            color: white;
        }
        
        .nav-link i {
            width: 24px;
            font-size: 1.1rem;
            margin-right: 12px;
        }
        
        /* Main Content */
        .main-content { 
            margin-left: var(--sidebar-width); 
            padding: 30px;
            min-height: 100vh;
        }
        
        /* Top Bar */
        .top-bar {
            background: white;
            padding: 25px 30px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .page-title {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .page-logo {
            height: 40px;
            width: auto;
            opacity: 0.9;
        }
        
        .page-title h1 {
            font-weight: 700;
            color: var(--telex-blue);
            font-size: 1.8rem;
            margin-bottom: 5px;
        }
        
        .page-title p {
            color: #64748b;
            font-size: 1rem;
            margin: 0;
        }
        
        .top-actions {
            display: flex;
            gap: 15px;
            align-items: center;
        }
        
        .btn-telex {
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 10px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            font-weight: 600;
            transition: all 0.3s;
        }
        
        .btn-telex:hover {
            transform: translateY(-3px);
            color: white;
        }
        
        /* User Cards */
        .user-card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            margin-bottom: 20px;
            transition: all 0.3s;
        }
        
        .user-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
        }
        
        .user-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--telex-blue), var(--telex-red));
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.5rem;
            margin-right: 20px;
        }
        
        .user-info h5 {
            color: var(--telex-blue);
            margin-bottom: 5px;
        }
        
        .user-info p {
            color: #64748b;
            margin-bottom: 3px;
            font-size: 0.9rem;
        }
        
        .user-role {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-top: 5px;
        }
        
        .role-superadmin { background: #DC2626; color: white; }
        .role-admin { background: #1D4ED8; color: white; }
        .role-editor { background: #7C3AED; color: white; }
        .role-viewer { background: #10B981; color: white; }
        
        .user-status {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 5px;
        }
        
        .status-active { background: #10B981; }
        .status-inactive { background: #EF4444; }
        
        .user-actions {
            display: flex;
            gap: 10px;
        }
        
        .btn-action {
            padding: 8px 12px;
            border-radius: 8px;
            border: none;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-edit {
            background: var(--telex-blue);
            color: white;
        }
        
        .btn-delete {
            background: #EF4444;
            color: white;
        }
        
        .btn-action:hover {
            transform: translateY(-2px);
        }
        
        /* Add User Button */
        .add-user-btn {
            background: linear-gradient(135deg, #10B981, #047857);
            color: white;
            border: none;
            padding: 15px 25px;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 30px;
            transition: all 0.3s;
        }
        
        .add-user-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 18px rgba(16, 185, 129, 0.3);
        }
        
        /* Alert Messages */
        .alert-message {
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .alert-success {
            background: #D1FAE5;
            color: #047857;
            border-left: 4px solid #10B981;
        }
        
        .alert-error {
            background: #FEE2E2;
            color: #DC2626;
            border-left: 4px solid #EF4444;
        }
        
        @media (max-width: 992px) {
            .sidebar {
                width: 70px;
            }
            
            .sidebar-brand h3,
            .sidebar-brand img {
                display: none;
            }
            
            .nav-link span {
                display: none;
            }
            
            .main-content {
                margin-left: 70px;
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-brand">
            <img src="/images/11.png" alt="TELEX">
            <h3>Telex Admin</h3>
        </div>
        
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/news" class="nav-link">
                    <i class="fas fa-newspaper"></i>
                    <span>Actualités</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/programs" class="nav-link">
                    <i class="fas fa-tv"></i>
                    <span>Programmes</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/baume-de-la-foi" class="nav-link">
                    <i class="fas fa-cross"></i>
                    <span>Baume de la Foi</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/contacts" class="nav-link">
                    <i class="fas fa-envelope"></i>
                    <span>Messages</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/gallery" class="nav-link">
                    <i class="fas fa-images"></i>
                    <span>Galerie</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/settings" class="nav-link">
                    <i class="fas fa-cog"></i>
                    <span>Paramètres</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/users" class="nav-link active">
                    <i class="fas fa-users"></i>
                    <span>Utilisateurs</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/logout" class="nav-link">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Déconnexion</span>
                </a>
            </div>
        </nav>
    </div>
    
    <!-- Main Content -->
    <div class="main-content">
        <!-- Top bar -->
        <div class="top-bar">
            <div class="page-title">
                <img src="/images/Telex.png" alt="TELEX" class="page-logo">
                <div>
                    <h1>Gestion des Utilisateurs</h1>
                    <p>Gérez les comptes administrateurs et leurs permissions</p>
                </div>
            </div>
            <div class="top-actions">
                <a href="/admin/dashboard" class="btn btn-telex">
                    <i class="fas fa-arrow-left me-2"></i>Retour au Dashboard
                </a>
            </div>
        </div>
        
        <!-- Flash Messages -->
        <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert-message alert-success">
            <i class="fas fa-check-circle"></i>
            <span><%= success_msg %></span>
        </div>
        <% } %>
        
        <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert-message alert-error">
            <i class="fas fa-exclamation-triangle"></i>
            <span><%= error_msg %></span>
        </div>
        <% } %>
        
        <!-- Add User Button -->
        <button class="add-user-btn" onclick="window.location.href='/admin/users/new'">
            <i class="fas fa-user-plus"></i>
            Ajouter un nouvel utilisateur
        </button>
        
        <!-- Users List -->
        <% if (users && users.length > 0) { %>
            <div class="users-list">
                <% users.forEach(user => { %>
                <div class="user-card">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <div style="display: flex; align-items: center;">
                            <div class="user-avatar">
                                <%= user.username.charAt(0).toUpperCase() %>
                            </div>
                            <div class="user-info">
                                <h5><%= user.username %></h5>
                                <p><i class="fas fa-envelope me-1"></i><%= user.email || 'Non spécifié' %></p>
                                <p><i class="fas fa-user me-1"></i><%= user.full_name || 'Nom complet non spécifié' %></p>
                                <div>
                                    <span class="user-role role-<%= user.role %>">
                                        <%= user.role %>
                                    </span>
                                    <span class="ms-3">
                                        <span class="user-status status-<%= user.is_active ? 'active' : 'inactive' %>"></span>
                                        <%= user.is_active ? 'Actif' : 'Inactif' %>
                                    </span>
                                </div>
                                <p class="mt-2 text-muted small">
                                    <i class="fas fa-calendar me-1"></i>Créé le: <%= new Date(user.created_at).toLocaleDateString('fr-FR') %>
                                    <% if (user.last_login) { %>
                                    <br><i class="fas fa-sign-in-alt me-1"></i>Dernière connexion: <%= new Date(user.last_login).toLocaleDateString('fr-FR') %>
                                    <% } %>
                                </p>
                            </div>
                        </div>
                        <div class="user-actions">
                            <button class="btn-action btn-edit" 
                                    onclick="window.location.href='/admin/users/edit/<%= user.id %>'">
                                <i class="fas fa-edit me-1"></i>Éditer
                            </button>
                            <% if (user.id !== userSession.id) { %>
                            <button class="btn-action btn-delete" 
                                    onclick="confirmDeleteUser('<%= user.id %>', '<%= user.username %>')">
                                <i class="fas fa-trash me-1"></i>Supprimer
                            </button>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        <% } else { %>
        <div style="text-align: center; padding: 50px 20px;">
            <i class="fas fa-users fa-3x text-muted mb-3"></i>
            <h4 style="color: var(--telex-blue);">Aucun utilisateur trouvé</h4>
            <p style="color: #64748b;">Commencez par créer un nouvel utilisateur</p>
        </div>
        <% } %>
        
        <!-- User Count -->
        <div style="margin-top: 30px; text-align: center; color: #64748b;">
            <p><%= users ? users.length : 0 %> utilisateur(s) au total</p>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Fonction globale pour confirmer la suppression d'utilisateur
        function confirmDeleteUser(userId, username) {
            if (confirm(`Êtes-vous sûr de vouloir supprimer l'utilisateur "${username}" ?\n\nCette action est irréversible et supprimera définitivement le compte.`)) {
                window.location.href = `/admin/users/delete/${userId}`;
            }
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-close alerts after 5 seconds
            const alerts = document.querySelectorAll('.alert-message');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.opacity = '0';
                    alert.style.transition = 'opacity 0.5s';
                    setTimeout(() => alert.remove(), 500);
                }, 5000);
            });
        });
    </script>
</body>
</html>