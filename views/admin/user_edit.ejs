<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: #f8f9fa;
            min-height: 100vh;
            padding: 20px;
        }
        
        .user-form-container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .form-header {
            background: linear-gradient(135deg, #1D3557, #457B9D);
            color: white;
            padding: 25px 30px;
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        .form-header img {
            width: 50px;
            height: auto;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
        }
        
        .form-header-content {
            flex: 1;
        }
        
        .form-body {
            padding: 30px;
        }
        
        .form-section {
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #e9ecef;
        }
        
        .form-section h5 {
            color: #1D3557;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #E63946;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .password-note {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            border-left: 4px solid #10B981;
            margin-top: 20px;
        }
        
        .btn-telex {
            background: linear-gradient(135deg, #E63946, #ff6b6b);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s;
        }
        
        .btn-telex:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.3);
        }
        
        .btn-outline-telex {
            border: 2px solid #1D3557;
            color: #1D3557;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s;
        }
        
        .btn-outline-telex:hover {
            background: #1D3557;
            color: white;
        }
        
        .form-control:focus {
            border-color: #E63946;
            box-shadow: 0 0 0 0.2rem rgba(230, 57, 70, 0.25);
        }
        
        .form-check-input:checked {
            background-color: #E63946;
            border-color: #E63946;
        }
    </style>
</head>
<body>
    <div class="user-form-container">
        <div class="form-header">
            <img src="/images/Telex.png" alt="TELEX">
            <div class="form-header-content">
                <h3 class="mb-0">
                    <i class="fas fa-user-edit me-2"></i>
                    <%= userData ? 'Éditer l\'utilisateur' : 'Nouvel utilisateur' %>
                </h3>
                <p class="mb-0 mt-2 opacity-75">
                    <%= userData ? userData.username : 'Création d\'un nouveau compte administrateur' %>
                </p>
            </div>
        </div>
        
        <div class="form-body">
            <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <%= error_msg %>
            </div>
            <% } %>
            
            <form method="POST" action="/admin/users/save">
                <% if (userData) { %>
                <input type="hidden" name="id" value="<%= userData.id %>">
                <% } %>
                
                <!-- Informations de base -->
                <div class="form-section">
                    <h5><i class="fas fa-user-circle"></i> Informations personnelles</h5>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nom d'utilisateur *</label>
                            <input type="text" 
                                   class="form-control" 
                                   name="username" 
                                   value="<%= userData ? userData.username : '' %>"
                                   required
                                   <%= userData ? 'readonly' : '' %>>
                            <small class="text-muted">Unique, ne peut pas être modifié après création</small>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email *</label>
                            <input type="email" 
                                   class="form-control" 
                                   name="email" 
                                   value="<%= userData ? userData.email : '' %>"
                                   required>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Nom complet</label>
                        <input type="text" 
                               class="form-control" 
                               name="full_name" 
                               value="<%= userData ? userData.full_name : '' %>"
                               placeholder="Optionnel">
                    </div>
                </div>
                
                <!-- Rôle et statut -->
                <div class="form-section">
                    <h5><i class="fas fa-user-tag"></i> Rôle et permissions</h5>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Rôle *</label>
                            <select class="form-select" name="role" required>
                                <% roles.forEach(role => { %>
                                <option value="<%= role %>" 
                                        <%= userData && userData.role === role ? 'selected' : '' %>>
                                    <%= role.charAt(0).toUpperCase() + role.slice(1) %>
                                </option>
                                <% }) %>
                            </select>
                            <small class="text-muted">
                                superadmin: Accès complet<br>
                                admin: Administration standard<br>
                                editor: Édition seulement<br>
                                viewer: Consultation seulement
                            </small>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Statut du compte</label>
                            <div class="form-check form-switch mt-3">
                                <input class="form-check-input" 
                                       type="checkbox" 
                                       name="is_active" 
                                       id="is_active"
                                       <%= !userData || userData.is_active ? 'checked' : '' %>>
                                <label class="form-check-label" for="is_active">
                                    Compte actif
                                </label>
                            </div>
                            <small class="text-muted">Désactivez pour empêcher la connexion</small>
                        </div>
                    </div>
                </div>
                
                <!-- Mot de passe -->
                <div class="form-section">
                    <h5><i class="fas fa-key"></i> Mot de passe</h5>
                    
                    <% if (userData) { %>
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Laissez les champs de mot de passe vides pour conserver le mot de passe actuel
                    </div>
                    <% } %>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <% if (userData) { %>Nouveau mot de passe<% } else { %>Mot de passe *<% } %>
                            </label>
                            <input type="password" 
                                   class="form-control" 
                                   name="password" 
                                   minlength="6"
                                   <%= !userData ? 'required' : '' %>
                                   placeholder="<%= userData ? 'Laisser vide pour ne pas changer' : 'Minimum 6 caractères' %>">
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <% if (userData) { %>Confirmer le nouveau mot de passe<% } else { %>Confirmer le mot de passe *<% } %>
                            </label>
                            <input type="password" 
                                   class="form-control" 
                                   name="confirm_password"
                                   minlength="6"
                                   <%= !userData ? 'required' : '' %>
                                   placeholder="<%= userData ? 'Laisser vide pour ne pas changer' : 'Répétez le mot de passe' %>">
                        </div>
                    </div>
                    
                    <% if (!userData) { %>
                    <div class="password-note">
                        <i class="fas fa-shield-alt me-2"></i>
                        <strong>Recommandations de sécurité :</strong>
                        <ul class="mb-0 mt-2">
                            <li>Minimum 6 caractères</li>
                            <li>Utilisez des majuscules, minuscules et chiffres</li>
                            <li>Évitez les mots de passe courants</li>
                        </ul>
                    </div>
                    <% } %>
                </div>
                
                <!-- Boutons d'action -->
                <div class="d-flex justify-content-between mt-5">
                    <a href="/admin/users" class="btn btn-outline-telex">
                        <i class="fas fa-arrow-left me-2"></i>Annuler
                    </a>
                    <button type="submit" class="btn btn-telex">
                        <i class="fas fa-save me-2"></i>
                        <%= userData ? 'Mettre à jour' : 'Créer l\'utilisateur' %>
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('form');
            
            form.addEventListener('submit', function(e) {
                const password = this.querySelector('[name="password"]');
                const confirm = this.querySelector('[name="confirm_password"]');
                
                // Si un mot de passe est fourni, le valider
                if (password.value) {
                    if (password.value.length < 6) {
                        e.preventDefault();
                        alert('Le mot de passe doit contenir au moins 6 caractères');
                        password.focus();
                        return false;
                    }
                    
                    if (password.value !== confirm.value) {
                        e.preventDefault();
                        alert('Les mots de passe ne correspondent pas');
                        confirm.focus();
                        return false;
                    }
                }
                
                // Désactiver le bouton pendant l'envoi
                const submitBtn = this.querySelector('button[type="submit"]');
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Enregistrement...';
                submitBtn.disabled = true;
                
                return true;
            });
        });
    </script>
</body>
</html>