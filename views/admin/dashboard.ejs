    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Test simple pour vérifier que JavaScript fonctionne
        console.log('🚀 Dashboard JavaScript chargé avec succès');
        console.log('📊 Stats disponibles:', <%- JSON.stringify(stats) %>);
        
        // Test Chart.js
        if (typeof Chart !== 'undefined') {
            console.log('✅ Chart.js est bien chargé');
        } else {
            console.error('❌ Chart.js n\'est pas chargé');
        }
        
        // Test simple de création de graphique
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🔧 DOM chargé, test de graphique...');
            
            // Créer un canvas de test
            const testCanvas = document.createElement('canvas');
            testCanvas.id = 'test-chart';
            testCanvas.style.display = 'none';
            document.body.appendChild(testCanvas);
            
            // Essayer de créer un graphique simple
            try {
                const testChart = new Chart(testCanvas, {
                    type: 'line',
                    data: {
                        labels: ['Test'],
                        datasets: [{
                            data: [42]
                        }]
                    }
                });
                console.log('✅ Test Chart.js réussi');
                testChart.destroy();
                document.body.removeChild(testCanvas);
            } catch (error) {
                console.error('❌ Erreur test Chart.js:', error);
            }
        });
        
        // Fonction pour afficher les statistiques du Baume de la Foi
        window.showBaumeStats = function(event) {
            if (event) event.preventDefault();

            // Bug fix 1 : réutiliser le modal existant plutôt qu'en créer un nouveau
            const existingModal = document.getElementById('statsModal');
            if (existingModal) {
                bootstrap.Modal.getOrCreateInstance(existingModal).show();
                setTimeout(() => loadBaumeStatsModal(), 300);
                return;
            }

            // Créer une modale pour afficher les statistiques
            const modal = document.createElement('div');
            modal.id = 'statsModal';
            modal.className = 'modal fade';
            modal.innerHTML = `
                <style>
                /* ── Stats Modal ── */
                #statsModal .sm-dialog { max-width: 960px; }
                #statsModal .sm-content {
                    border: none; border-radius: 18px; overflow: hidden;
                    box-shadow: 0 24px 60px rgba(0,0,0,.18);
                }
                #statsModal .sm-header {
                    background: linear-gradient(135deg, #1D3557 0%, #274b80 100%);
                    padding: 20px 24px 16px;
                    display: flex; align-items: center; justify-content: space-between;
                }
                #statsModal .sm-header-left { display: flex; align-items: center; gap: 12px; }
                #statsModal .sm-logo { height: 36px; border-radius: 6px; }
                #statsModal .sm-title { color:#fff; font-size:1.05rem; font-weight:700; margin:0; line-height:1.2; }
                #statsModal .sm-sub   { color:rgba(255,255,255,.55); font-size:.75rem; margin:0; }
                #statsModal .sm-close {
                    background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.2);
                    color:#fff; border-radius:8px; width:32px; height:32px;
                    display:flex; align-items:center; justify-content:center;
                    cursor:pointer; font-size:.8rem; transition: background .15s;
                }
                #statsModal .sm-close:hover { background: rgba(255,255,255,.28); }

                /* Type tabs */
                #statsModal .sm-tabs {
                    background: #f8fafc; border-bottom: 1px solid #e2e8f0;
                    padding: 12px 20px; display: flex; gap: 6px; flex-wrap: wrap; align-items: center;
                }
                #statsModal .sm-tab {
                    padding: 6px 14px; border-radius: 20px; font-size: .8rem; font-weight: 600;
                    border: 1.5px solid #e2e8f0; background: white; color: #64748b;
                    cursor: pointer; transition: all .15s; user-select: none;
                    display: inline-flex; align-items: center; gap: 5px;
                }
                #statsModal .sm-tab:hover { border-color: #cbd5e1; color: #1D3557; }
                #statsModal .sm-tab.active-news     { background:#eff6ff; border-color:#3B82F6; color:#1D4ED8; }
                #statsModal .sm-tab.active-programs { background:#fffbeb; border-color:#F59E0B; color:#D97706; }
                #statsModal .sm-tab.active-baume    { background:#fdf4ff; border-color:#a855f7; color:#7C3AED; }
                #statsModal .sm-tab.active-visitors { background:#eef2ff; border-color:#6366f1; color:#4338CA; }
                #statsModal .sm-tab-sep { flex: 1; }
                #statsModal .sm-date-row {
                    display: flex; align-items: center; gap: 6px; font-size: .8rem;
                }
                #statsModal .sm-date-row label { color:#64748b; font-weight:600; white-space:nowrap; }
                #statsModal .sm-date-row input[type=date] {
                    border: 1px solid #e2e8f0; border-radius: 7px; padding: 4px 8px;
                    font-size: .79rem; color: #1e293b; outline: none;
                }
                #statsModal .sm-date-row input[type=date]:focus { border-color: #3B82F6; }
                #statsModal .sm-btn-apply {
                    background: #1D3557; color:#fff; border:none; border-radius:7px;
                    padding: 5px 12px; font-size:.78rem; font-weight:600; cursor:pointer;
                    transition: background .15s;
                }
                #statsModal .sm-btn-apply:hover { background: #274b80; }
                #statsModal .sm-btn-reset {
                    background: white; color:#64748b; border: 1px solid #e2e8f0;
                    border-radius:7px; padding:5px 10px; font-size:.78rem; cursor:pointer;
                    transition: border-color .15s;
                }
                #statsModal .sm-btn-reset:hover { border-color:#94a3b8; }

                /* KPI row */
                #statsModal .sm-kpi-row {
                    display: flex; gap: 10px; padding: 14px 20px;
                    background: white; border-bottom: 1px solid #f1f5f9;
                    flex-wrap: wrap;
                }
                #statsModal .sm-kpi {
                    flex: 1; min-width: 120px; background: #f8fafc;
                    border: 1px solid #e2e8f0; border-radius: 10px;
                    padding: 10px 14px;
                }
                #statsModal .sm-kpi-val { font-size: 1.3rem; font-weight: 700; color: #1D3557; line-height: 1; }
                #statsModal .sm-kpi-lbl { font-size: .72rem; color: #94a3b8; margin-top: 2px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }

                /* Chart area */
                #statsModal .sm-body { padding: 16px 20px; background: #f8fafc; }
                #statsModal .sm-card {
                    background: white; border-radius: 12px; border: 1px solid #e2e8f0;
                    overflow: hidden; margin-bottom: 12px;
                }
                #statsModal .sm-card-head {
                    padding: 12px 18px; border-bottom: 1px solid #f1f5f9;
                    display: flex; align-items: center; gap: 8px;
                }
                #statsModal .sm-card-head-dot {
                    width: 8px; height: 8px; border-radius: 50%; background: #3B82F6; flex-shrink: 0;
                }
                #statsModal .sm-card-title { font-size: .86rem; font-weight: 700; color: #1D3557; margin: 0; }
                #statsModal .sm-card-sub   { font-size: .74rem; color: #94a3b8; margin: 0 0 0 auto; }
                #statsModal .sm-chart-wrap { padding: 16px 16px 8px; height: 340px; position: relative; }

                /* Detail table */
                #statsModal .sm-table { width: 100%; border-collapse: collapse; font-size: .83rem; }
                #statsModal .sm-table th {
                    padding: 9px 14px; background: #f8fafc; color: #64748b;
                    font-size: .7rem; font-weight: 700; text-transform: uppercase;
                    letter-spacing: .06em; border-bottom: 1px solid #e2e8f0;
                }
                #statsModal .sm-table td { padding: 11px 14px; border-bottom: 1px solid #f1f5f9; color: #334155; }
                #statsModal .sm-table tr:last-child td { border-bottom: none; font-weight: 700; background: #f8fafc; }
                #statsModal .sm-type-dot {
                    display: inline-flex; align-items: center; gap: 8px;
                }
                #statsModal .sm-type-dot span {
                    width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0;
                }

                /* Footer */
                #statsModal .sm-footer {
                    padding: 12px 20px; background: white; border-top: 1px solid #e2e8f0;
                    display: flex; align-items: center; justify-content: space-between;
                }
                #statsModal .sm-footer-note { font-size:.75rem; color:#94a3b8; }
                #statsModal .sm-footer-btns { display:flex; gap:8px; }
                #statsModal .sm-btn-close {
                    background: #f1f5f9; color:#475569; border:none; border-radius:8px;
                    padding:8px 16px; font-size:.83rem; font-weight:600; cursor:pointer;
                    transition: background .15s;
                }
                #statsModal .sm-btn-close:hover { background: #e2e8f0; }
                #statsModal .sm-btn-refresh {
                    background: #1D3557; color:#fff; border:none; border-radius:8px;
                    padding:8px 16px; font-size:.83rem; font-weight:600; cursor:pointer;
                    display:flex; align-items:center; gap:6px; transition: background .15s;
                }
                #statsModal .sm-btn-refresh:hover { background: #274b80; }
                </style>

                <div class="modal-dialog sm-dialog">
                    <div class="modal-content sm-content">

                        <!-- Header -->
                        <div class="sm-header">
                            <div class="sm-header-left">
                                <img src="/images/Telex.png" alt="Telex" class="sm-logo">
                                <div>
                                    <p class="sm-title"><i class="fas fa-chart-bar me-2" style="opacity:.8"></i>Statistiques</p>
                                    <p class="sm-sub">Vue d'ensemble de l'activité</p>
                                </div>
                            </div>
                            <button class="sm-close" data-bs-dismiss="modal" title="Fermer">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>

                        <!-- Type tabs + date filter -->
                        <div class="sm-tabs">
                            <button class="sm-tab active-news" data-type="news"     onclick="smSwitchTab(this,'news')">    <i class="fas fa-newspaper"></i> Actualités</button>
                            <button class="sm-tab"             data-type="programs" onclick="smSwitchTab(this,'programs')"><i class="fas fa-tv"></i> Programmes</button>
                            <button class="sm-tab"             data-type="baume"    onclick="smSwitchTab(this,'baume')">   <i class="fas fa-cross"></i> Baume de la Foi</button>
                            <button class="sm-tab"             data-type="visitors" onclick="smSwitchTab(this,'visitors')"><i class="fas fa-users"></i> Visiteurs</button>
                            <span class="sm-tab-sep"></span>
                            <div class="sm-date-row">
                                <label><i class="fas fa-calendar-alt me-1"></i>Du</label>
                                <input type="date" id="startDate">
                                <label>au</label>
                                <input type="date" id="endDate">
                                <button class="sm-btn-apply" onclick="applyDateFilter()"><i class="fas fa-filter me-1"></i>Appliquer</button>
                                <button class="sm-btn-reset" onclick="resetDateFilter()" title="Réinitialiser"><i class="fas fa-undo"></i></button>
                            </div>
                        </div>

                        <!-- KPI row -->
                        <div class="sm-kpi-row" id="sm-kpi-row">
                            <div class="sm-kpi"><div class="sm-kpi-val" id="kpi-total">—</div><div class="sm-kpi-lbl">Publications</div></div>
                            <div class="sm-kpi"><div class="sm-kpi-val" id="kpi-views">—</div><div class="sm-kpi-lbl">Vues totales</div></div>
                            <div class="sm-kpi"><div class="sm-kpi-val" id="kpi-avg">—</div><div class="sm-kpi-lbl">Moy. vues / pub.</div></div>
                            <div class="sm-kpi"><div class="sm-kpi-val" id="kpi-period">30j</div><div class="sm-kpi-lbl">Période</div></div>
                        </div>

                        <!-- Body -->
                        <div class="sm-body">

                            <!-- Graphique -->
                            <div class="sm-card">
                                <div class="sm-card-head">
                                    <span class="sm-card-head-dot" id="sm-dot"></span>
                                    <p class="sm-card-title">Évolution des vues — <span id="chart-title">Actualités</span></p>
                                    <p class="sm-card-sub" id="sm-chart-sub">30 derniers jours</p>
                                </div>
                                <div class="sm-chart-wrap">
                                    <canvas id="modalUnifiedChart"></canvas>
                                </div>
                            </div>

                            <!-- Tableau détail -->
                            <div class="sm-card">
                                <div class="sm-card-head">
                                    <span class="sm-card-head-dot" style="background:#10B981"></span>
                                    <p class="sm-card-title">Détail des contenus</p>
                                </div>
                                <div style="padding:0 4px 4px">
                                    <div id="baume-details-table">
                                        <div style="text-align:center;padding:28px 0">
                                            <div class="spinner-border text-primary" role="status" style="width:1.4rem;height:1.4rem;border-width:.2em"></div>
                                            <p style="margin-top:10px;color:#94a3b8;font-size:.82rem">Chargement…</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div><!-- /.sm-body -->

                        <!-- Footer -->
                        <div class="sm-footer">
                            <span class="sm-footer-note"><i class="fas fa-info-circle me-1"></i>Données en temps réel depuis la base</span>
                            <div class="sm-footer-btns">
                                <button class="sm-btn-close" data-bs-dismiss="modal">Fermer</button>
                                <button class="sm-btn-refresh" onclick="refreshBaumeStatsModal()">
                                    <i class="fas fa-sync-alt"></i>Actualiser
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            `;
            
            // Ajouter la modale au body
            document.body.appendChild(modal);
            
            // Initialiser Bootstrap modal
            const bootstrapModal = new bootstrap.Modal(modal);
            
            // Afficher la modale
            bootstrapModal.show();
            
            // Attendre que la modal soit complètement affichée avant d'initialiser
            setTimeout(() => {
                loadBaumeStatsModal();
            }, 500);
        }
        
        // Fonction pour charger les statistiques dans la modale
        function loadBaumeStatsModal() {
            // Bug fix 4 : initialiser currentStatsData depuis les données EJS avant loadBaumeDetailsTable
            currentStatsData.baumePrieres     = <%- JSON.stringify(stats.baumePrieres || 0) %>;
            currentStatsData.baumeReflexions  = <%- JSON.stringify(stats.baumeReflexions || 0) %>;
            currentStatsData.baumeTemoignages = <%- JSON.stringify(stats.baumeTemoignages || 0) %>;
            currentStatsData.baumeTotalViews  = <%- JSON.stringify(stats.baumeTotalViews || 0) %>;

            // Déclencher le graphique + tableau avec le type actif
            handleChartTypeChange({ target: { value: window.currentStatsType || 'news' } });
        }
        
        // Fonction pour mettre à jour les compteurs dans la modale
        function updateModalCounters(stats) {
            // Les compteurs dans la modale n'existent plus, on utilise seulement les données pour le graphique
