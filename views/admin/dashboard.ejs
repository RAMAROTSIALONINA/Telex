        // Générer toutes les dates entre startDate et endDate
        function generateDateRange(startDateStr, endDateStr) {
            const dates = [];
            const start = new Date(startDateStr);
            const end = new Date(endDateStr);
            
            // Limiter à 30 jours maximum pour éviter un graphique trop chargé
            const maxDays = 30;
            const diffTime = Math.abs(end - start);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            
            if (diffDays > maxDays) {
                console.log(`⚠️ Période trop longue (${diffDays} jours), limitation à ${maxDays} jours`);
                end.setDate(start.getDate() + maxDays - 1);
            }
            
            for (let date = new Date(start); date <= end; date.setDate(date.getDate() + 1)) {
                dates.push(new Date(date));
            }
            
            return dates;
        }
        
