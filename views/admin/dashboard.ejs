                    ? new Date(pub.created_at).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' })
                    : '—';
                const title = (pub.title || 'Sans titre').length > 55
                    ? (pub.title || 'Sans titre').slice(0, 55) + '…'
