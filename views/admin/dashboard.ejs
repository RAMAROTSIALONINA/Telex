            const startDate = document.getElementById('startDate')?.value || thirtyDaysAgo;
            const endDate   = document.getElementById('endDate')?.value   || today;

            // Bug fix 2 : appeler getVisitorData pour les visiteurs
            if (selectedType === 'visitors') {
