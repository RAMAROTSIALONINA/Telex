        // Mise à jour des KPI dans le modal
        function updateSmKpi(publications, type) {
            const total = publications.length;
            const views = publications.reduce((s, p) => s + (p.views || 0), 0);
            const avg   = total > 0 ? Math.round(views / total) : 0;

            const kpiTotal  = document.getElementById('kpi-total');
            const kpiViews  = document.getElementById('kpi-views');
            const kpiAvg    = document.getElementById('kpi-avg');

            if (kpiTotal) kpiTotal.textContent = formatNumber(total);
            if (kpiViews) kpiViews.textContent = formatNumber(views);
            if (kpiAvg)   kpiAvg.textContent   = formatNumber(avg);

            // Couleur du dot selon le type
            const dotColors = { news:'#3B82F6', programs:'#F59E0B', baume:'#a855f7', visitors:'#6366f1' };
            const dot = document.getElementById('sm-dot');
            if (dot) dot.style.background = dotColors[type] || '#3B82F6';
        }
        
        // Fonction pour formater les nombres avec K, M, B
        function formatNumber(num) {
            if (num >= 1000000000) {
                return (num / 1000000000).toFixed(1).replace(/\.0$/, '') + 'B';
            }
            if (num >= 1000000) {
                return (num / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
            }
            if (num >= 1000) {
                return (num / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
            }
            return num.toString();
        }

        // Variables globales pour éviter les boucles infinies
        let isLoadingBaumeStats = false;
        let timeInterval = null;
        let clickHandlerInitialized = false;
        let baumeRetryCount = 0;
        const MAX_BAUME_RETRIES = 3;
        
        // Variable globale pour suivre les graphiques de la modale
        let modalChartInstance = null;
        
        // Fonction pour formater les statistiques au chargement
        function formatDashboardStats() {
            // Formater les Vues Totales des actualités (dans la carte Actualités)
            const newsViewsInlineElement = document.getElementById('total-news-views-inline');
            if (newsViewsInlineElement) {
                const newsViews = parseInt(newsViewsInlineElement.textContent);
                newsViewsInlineElement.textContent = formatNumber(newsViews);
            }
            
            // Formater les Vues Totales des programmes (dans la carte Programmes)
            const programsViewsInlineElement = document.getElementById('total-programs-views-inline');
            if (programsViewsInlineElement) {
                const programsViews = parseInt(programsViewsInlineElement.textContent);
                programsViewsInlineElement.textContent = formatNumber(programsViews);
            }
            
            // Formater les visiteurs (cookies)
            const visitorsElement = document.getElementById('visitors-count');
            if (visitorsElement) {
                const visitors = parseInt(visitorsElement.textContent);
                visitorsElement.textContent = formatNumber(visitors);
                
                // Mettre à jour la description
                const visitorsDescElement = document.getElementById('visitors-description');
                if (visitorsDescElement) {
                    visitorsDescElement.textContent = visitors > 0 ? formatNumber(visitors) + ' visiteurs' : 'Aucun visiteur';
                }
            }
            
            // Formater les vues totales du Baume de la Foi
            const baumeViewsElement = document.getElementById('baume-total-views');
            if (baumeViewsElement) {
                const baumeViews = parseInt(baumeViewsElement.textContent);
                baumeViewsElement.textContent = formatNumber(baumeViews);
            }
        }
        
        // Appliquer le formatage au chargement de la page
        document.addEventListener('DOMContentLoaded', function() {
            formatDashboardStats();
        });
        
        // Fonction pour récupérer les données dynamiques (remplacer les données simulées)
        async function fetchEvolutionData() {
            try {
                const response = await fetch('/admin/api/stats/evolution');
                
                // Vérifier si la réponse est OK (200-299)
                if (!response.ok) {
                    console.log('⚠️ API non disponible, utilisation des données par défaut');
                    return {
                        labels: ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Jun'],
                        actualites: [12, 19, 15, 25, 22, 30],
                        programmes: [8, 12, 10, 18, 15, 20],
                        visiteurs: [150, 280, 320, 450, 380, 520]
                    };
                }
                
                const contentType = response.headers.get('content-type');
                if (!contentType || !contentType.includes('application/json')) {
                    console.log('⚠️ Réponse non-JSON, utilisation des données par défaut');
