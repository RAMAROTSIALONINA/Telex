    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Test simple pour vérifier que JavaScript fonctionne
        console.log('🚀 Dashboard JavaScript chargé avec succès');
        console.log('📊 Stats disponibles:', <%- JSON.stringify(stats) %>);
        
        // Test Chart.js
        if (typeof Chart !== 'undefined') {
            console.log('✅ Chart.js est bien chargé');
        } else {
            console.error('❌ Chart.js n\'est pas chargé');
        }
        
        // Test simple de création de graphique
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🔧 DOM chargé, test de graphique...');
            
            // Créer un canvas de test
            const testCanvas = document.createElement('canvas');
            testCanvas.id = 'test-chart';
            testCanvas.style.display = 'none';
            document.body.appendChild(testCanvas);
            
            // Essayer de créer un graphique simple
            try {
                const testChart = new Chart(testCanvas, {
                    type: 'line',
                    data: {
                        labels: ['Test'],
                        datasets: [{
                            data: [42]
                        }]
                    }
                });
                console.log('✅ Test Chart.js réussi');
                testChart.destroy();
                document.body.removeChild(testCanvas);
            } catch (error) {
                console.error('❌ Erreur test Chart.js:', error);
            }
        });
        
        // Déclarer la fonction showBaumeStats pour s'assurer qu'elle est accessible globalement
        var showBaumeStats;
        
        // Fonction pour afficher les statistiques du Baume de la Foi
        window.showBaumeStats = function(event) {
            event.preventDefault();
            
            // Éviter les initialisations multiples
            if (isInitializingCharts) {
                console.log('⚠️ Initialisation déjà en cours...');
                return;
            }
            
            // Créer une modale pour afficher les statistiques
            const modal = document.createElement('div');
            modal.className = 'modal fade';
            modal.innerHTML = `
                <div class="modal-dialog modal-xl">
                    <div class="modal-content" style="min-height: 85vh;">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title mb-0">
                                <i class="fas fa-chart-bar me-2"></i>
                                Statistiques Complètes
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal">
                            </button>
                        </div>
                        <div class="modal-body p-4">
                            <!-- Section Filtres et Contrôles -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <div class="card border-0 shadow-sm">
                                        <div class="card-body">
                                            <div class="row align-items-center">
                                                <div class="col-md-4">
                                                    <h6 class="mb-3 mb-md-0">
                                                        <i class="fas fa-chart-line me-2 text-primary"></i>
                                                        <span id="chart-title">Actualités</span>
                                                    </h6>
                                                </div>
                                                <div class="col-md-8">
                                                    <div class="row g-2 align-items-center">
                                                        <div class="col-auto">
                                                            <label class="form-label mb-0 me-2 fw-semibold">
                                                                <i class="fas fa-calendar-alt me-1"></i>
                                                                Période :
                                                            </label>
                                                        </div>
                                                        <div class="col-auto">
                                                            <input type="date" class="form-control form-control-sm" id="startDate" style="width: 130px;">
                                                        </div>
                                                        <div class="col-auto">
                                                            <span class="text-muted">au</span>
                                                        </div>
                                                        <div class="col-auto">
                                                            <input type="date" class="form-control form-control-sm" id="endDate" style="width: 130px;">
                                                        </div>
                                                        <div class="col-auto">
                                                            <button class="btn btn-primary btn-sm" onclick="applyDateFilter()">
                                                                <i class="fas fa-filter me-1"></i>
                                                                Appliquer
                                                            </button>
                                                        </div>
                                                        <div class="col-auto">
                                                            <button class="btn btn-outline-secondary btn-sm" onclick="resetDateFilter()">
                                                                <i class="fas fa-undo me-1"></i>
                                                                Réinitialiser
                                                            </button>
                                                        </div>
                                                        <div class="col-auto">
                                                            <select class="form-select form-select-sm" id="chartTypeSelector" style="width: 180px;">
                                                                <option value="news" selected>📰 Actualités</option>
                                                                <option value="programs">📺 Programmes</option>
                                                                <option value="baume">✝️ Baume de la Foi</option>
                                                                <option value="visitors">👥 Visiteurs</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Section Graphique Principal -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <div class="card border-0 shadow-sm">
                                        <div class="card-header bg-light border-0">
                                            <h6 class="mb-0 text-dark">
                                                <i class="fas fa-chart-area me-2 text-primary"></i>
                                                Évolution des vues
                                            </h6>
                                        </div>
                                        <div class="card-body p-4">
                                            <div class="chart-container" style="height: 450px; position: relative;">
                                                <canvas id="modalUnifiedChart"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Section Tableau Détaillé -->
                            <div class="row">
                                <div class="col-12">
                                    <div class="card border-0 shadow-sm">
                                        <div class="card-header bg-light border-0">
                                            <h6 class="mb-0 text-dark">
                                                <i class="fas fa-table me-2 text-info"></i>
                                                Détail des contenus
                                            </h6>
                                        </div>
                                        <div class="card-body p-4">
                                            <div id="baume-details-table">
                                                <div class="text-center py-4">
                                                    <div class="spinner-border text-primary" role="status">
                                                        <span class="visually-hidden">Chargement...</span>
                                                    </div>
                                                    <p class="mt-3 text-muted">Chargement des détails...</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer bg-light">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                <i class="fas fa-times me-2"></i>Fermer
                            </button>
                            <button type="button" class="btn btn-primary" onclick="refreshBaumeStatsModal()">
                                <i class="fas fa-sync-alt me-2"></i>
                                Actualiser
                            </button>
                        </div>
                    </div>
                </div>
            `;
            
            // Ajouter la modale au body
            document.body.appendChild(modal);
            
            // Initialiser Bootstrap modal
            const bootstrapModal = new bootstrap.Modal(modal);
            
            // Afficher la modale
            bootstrapModal.show();
            
            // Attendre que la modal soit complètement affichée avant d'initialiser
            setTimeout(() => {
                loadBaumeStatsModal();
            }, 500);
        }
        
        // Fonction pour charger les statistiques dans la modale
        function loadBaumeStatsModal() {
            console.log('🔍 Chargement des statistiques du Baume de la Foi...');
            
            // Utiliser les données déjà disponibles depuis le dashboard
            const stats = {
                baumePrieres: <%- JSON.stringify(stats.baumePrieres || 0) %>,
                baumeReflexions: <%- JSON.stringify(stats.baumeReflexions || 0) %>,
                baumeTemoignages: <%- JSON.stringify(stats.baumeTemoignages || 0) %>,
                baumeTotalViews: <%- JSON.stringify(stats.baumeTotalViews || 0) %>
            };
            
            console.log('📊 Données du Baume:', stats);
            
            // Mettre à jour les compteurs
            updateModalCounters(stats);
            
            // Créer les graphiques
            createBaumeCharts(stats);
            
            // Charger le tableau détaillé
            loadBaumeDetailsTable();
        }
        
        // Fonction pour mettre à jour les compteurs dans la modale
        function updateModalCounters(stats) {
            // Les compteurs dans la modale n'existent plus, on utilise seulement les données pour le graphique
            console.log('📊 Mise à jour des données pour la modale:', stats);
        }
        
        // Variables globales pour stocker les données actuelles
        let currentStatsData = {
            totalNews: 0,
            totalNewsViews: 0,
            totalPrograms: 0,
            totalProgramsViews: 0,
            baumePrieres: 0,
            baumeReflexions: 0,
            baumeTemoignages: 0,
            baumeTotalViews: 0
        };
        
        // Variable pour éviter les initialisations multiples
        let isInitializingCharts = false;
        
        // Fonction pour récupérer les publications les plus vues selon la période
        async function getTopPublications(type, startDate, endDate) {
            try {
                console.log(`📊 Appel API pour publications: type=${type}, startDate=${startDate}, endDate=${endDate}`);
                
                // Essayer d'appeler l'API réelle
                const response = await fetch(`/admin/api/top-publications?type=${type}&startDate=${startDate}&endDate=${endDate}`);
                const data = await response.json();
                
                console.log(`📊 Réponse API reçue:`, data);
                
                if (data.success && data.publications && data.publications.length > 0) {
                    console.log(`✅ ${data.publications.length} publications réelles trouvées`);
                    // Ajouter un indicateur que ce sont des données réelles
                    return {
                        publications: data.publications,
                        source: 'database'
                    };
                } else {
                    console.log(`⚠️ Aucune publication réelle trouvée pour ${type} sur la période ${startDate} - ${endDate}`);
                    // Retourner un tableau vide au lieu de données de test
                    return {
                        publications: [],
                        source: 'database',
                        message: data.message || `Aucune publication ${type} trouvée pour cette période`
                    };
                }
                
            } catch (error) {
                console.error('❌ Erreur getTopPublications:', error);
                
                // En cas d'erreur réseau, générer des données de test
                console.log('⚠️ Erreur API, génération de données de test locales');
                
                let testPublications = [];
                const start = new Date(startDate);
                const end = new Date(endDate);
                const daysDiff = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
                
                if (type === 'news') {
                    const newsCount = Math.min(Math.max(2, Math.floor(daysDiff / 2)), 5);
                    for (let i = 0; i < newsCount; i++) {
                        const date = new Date(start);
                        date.setDate(start.getDate() + Math.floor(i * daysDiff / newsCount));
                        testPublications.push({
                            title: `Actualité: Développement ${i + 1}`,
                            views: Math.floor(Math.random() * 400) + 100,
                            created_at: date.toISOString().split('T')[0] + ' 12:00:00'
                        });
                    }
                } else if (type === 'programs') {
                    const programCount = Math.min(Math.max(1, Math.floor(daysDiff / 3)), 3);
                    for (let i = 0; i < programCount; i++) {
                        const date = new Date(start);
                        date.setDate(start.getDate() + Math.floor(i * daysDiff / programCount));
                        testPublications.push({
                            title: `Programme: Session ${i + 1}`,
                            views: Math.floor(Math.random() * 300) + 150,
                            created_at: date.toISOString().split('T')[0] + ' 12:00:00'
                        });
                    }
                } else if (type === 'baume') {
                    const baumeCount = Math.min(Math.max(2, Math.floor(daysDiff / 2)), 4);
                    const categories = ['Prières', 'Réflexions', 'Témoignages'];
                    for (let i = 0; i < baumeCount; i++) {
                        const date = new Date(start);
                        date.setDate(start.getDate() + Math.floor(i * daysDiff / baumeCount));
                        const category = categories[i % categories.length];
                        testPublications.push({
                            title: `${category}: Contenu spirituel ${i + 1}`,
                            views: Math.floor(Math.random() * 250) + 80,
                            created_at: date.toISOString().split('T')[0] + ' 12:00:00',
