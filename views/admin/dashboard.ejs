        // Fonction pour générer les données de visiteurs par jour
        async function getVisitorData(startDate, endDate) {
            try {
                console.log(`👥 Appel API pour visiteurs: startDate=${startDate}, endDate=${endDate}`);
                
                // Appeler l'API réelle pour les visiteurs
                const response = await fetch(`/admin/api/visitors?startDate=${startDate}&endDate=${endDate}`);
                const data = await response.json();
                
                console.log(`👥 Réponse API visiteurs reçue:`, data);
                
                if (data.success && data.visitors && data.visitors.length > 0) {
                    console.log(`✅ ${data.visitors.length} jours avec données visiteurs réelles trouvées`);
                    return {
                        labels: data.labels,
                        views: data.visitors,
                        totalVisitors: data.totalVisitors,
                        avgVisitors: data.avgVisitors,
                        totalUniqueVisitors: data.totalUniqueVisitors,
                        totalPageViews: data.totalPageViews,
                        dailyStats: data.dailyStats || data.rawData || [],
                        source: 'database'
                    };
                } else {
                    console.log(`⚠️ Aucune donnée visiteur réelle trouvée, utilisation des données de test`);
                    
                    // Générer des données de test en secours
                    const allDates = generateDateRange(startDate, endDate);
                    const labels = [];
                    const views = [];
                    const dailyStats = [];
                    
                    allDates.forEach(date => {
                        const dateStr = date.toLocaleDateString('fr-FR', { 
                            day: '2-digit', 
                            month: 'short', 
                            year: 'numeric' 
                        });
                        labels.push(dateStr);
                        
                        // Générer un nombre aléatoire de visiteurs pour chaque jour
                        const randomVisitors = Math.floor(Math.random() * 500) + 50; // Entre 50 et 550 visiteurs
                        views.push(randomVisitors);
                        
                        // Ajouter aux données détaillées
                        dailyStats.push({
                            date: date.toISOString().split('T')[0],
                            visitors: randomVisitors,
                            uniqueVisitors: Math.floor(randomVisitors * 0.8), // 80% sont uniques
                            pageViews: Math.floor(randomVisitors * 2.5), // 2.5 pages vues par visiteur
                            bounceRate: Math.random() * 30 + 20, // 20-50%
                            avgSessionDuration: Math.random() * 180 + 60 // 60-240 secondes
                        });
                    });
                    
                    console.log(`👥 ${labels.length} jours avec données visiteurs de test générées`);
                    
                    return {
                        labels: labels,
                        views: views,
                        totalVisitors: views.reduce((sum, v) => sum + v, 0),
                        avgVisitors: Math.round(views.reduce((sum, v) => sum + v, 0) / views.length),
                        totalUniqueVisitors: Math.floor(views.reduce((sum, v) => sum + v, 0) * 0.8),
                        totalPageViews: Math.floor(views.reduce((sum, v) => sum + v, 0) * 2.5),
                        dailyStats: dailyStats,
                        source: 'generated'
                    };
                }
                
            } catch (error) {
                console.error('❌ Erreur getVisitorData:', error);
                
                // En cas d'erreur réseau, générer des données de test
                console.log('⚠️ Erreur API visiteurs, génération de données de test locales');
                
                const allDates = generateDateRange(startDate, endDate);
                const labels = allDates.map(date => date.toLocaleDateString('fr-FR', { 
                    day: '2-digit', 
                    month: 'short', 
                    year: 'numeric' 
                }));
                const views = allDates.map(() => Math.floor(Math.random() * 200) + 20);
                const dailyStats = allDates.map(date => ({
                    date: date.toISOString().split('T')[0],
                    visitors: Math.floor(Math.random() * 200) + 20,
                    uniqueVisitors: Math.floor(Math.random() * 160) + 16,
                    pageViews: Math.floor(Math.random() * 500) + 50,
                    bounceRate: Math.random() * 30 + 20,
                    avgSessionDuration: Math.random() * 180 + 60
                }));
                
                return {
                    labels: labels,
                    views: views,
                    totalVisitors: views.reduce((sum, v) => sum + v, 0),
                    avgVisitors: Math.round(views.reduce((sum, v) => sum + v, 0) / views.length),
                    totalUniqueVisitors: Math.floor(views.reduce((sum, v) => sum + v, 0) * 0.8),
                    totalPageViews: Math.floor(views.reduce((sum, v) => sum + v, 0) * 2.5),
                    dailyStats: dailyStats,
