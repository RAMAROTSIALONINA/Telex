                        <div class="alert alert-info mb-3">
                            <i class="fas fa-info-circle me-2"></i>
                            Statistiques des visiteurs pour la période : <strong>${formatDate(startDate)} - ${formatDate(endDate)}</strong>
                            ${visitorData.source === 'database' ? '<span class="badge bg-success ms-2">Données réelles</span>' : '<span class="badge bg-warning ms-2">Données simulées</span>'}
                        </div>
                        
                        <!-- Statistiques agrégées -->
                        <div class="row mb-4">
                            <div class="col-md-3">
                                <div class="card bg-primary text-white">
                                    <div class="card-body text-center">
                                        <h5 class="card-title">${formatNumber(totalVisitors)}</h5>
                                        <p class="card-text mb-0">Total Visiteurs</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-success text-white">
                                    <div class="card-body text-center">
                                        <h5 class="card-title">${formatNumber(avgVisitors)}</h5>
                                        <p class="card-text mb-0">Moyenne/Jour</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-info text-white">
                                    <div class="card-body text-center">
                                        <h5 class="card-title">${formatNumber(visitorData.totalUniqueVisitors || 0)}</h5>
                                        <p class="card-text mb-0">Visiteurs Uniques</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card bg-warning text-white">
                                    <div class="card-body text-center">
                                        <h5 class="card-title">${formatNumber(visitorData.totalPageViews || 0)}</h5>
                                        <p class="card-text mb-0">Pages Vues</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Tableau détaillé par jour -->
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Visiteurs</th>
                                        <th>Visiteurs Uniques</th>
                                        <th>Pages Vues</th>
                                        <th>Taux Rebond</th>
                                        <th>Durée Session</th>
                                    </tr>
                                </thead>
                                <tbody>
                    `;
                    
                    // Ajouter les données journalières
                    if (visitorData.rawData && visitorData.rawData.length > 0) {
                        visitorData.rawData.forEach((day, index) => {
                            tableHTML += `
                                <tr>
                                    <td>${formatDate(day.date)}</td>
                                    <td>${formatNumber(day.visitors)}</td>
                                    <td>${formatNumber(day.uniqueVisitors)}</td>
                                    <td>${formatNumber(day.pageViews)}</td>
                                    <td>${day.bounceRate ? day.bounceRate.toFixed(1) + '%' : 'N/A'}</td>
                                    <td>${day.avgSessionDuration ? Math.round(day.avgSessionDuration) + 's' : 'N/A'}</td>
                                </tr>
                            `;
                        });
                    } else if (visitorData.dailyStats && visitorData.dailyStats.length > 0) {
                        visitorData.dailyStats.forEach((day, index) => {
                            tableHTML += `
                                <tr>
                                    <td>${formatDate(day.date)}</td>
                                    <td>${formatNumber(day.visitors || 0)}</td>
                                    <td>${formatNumber(day.uniqueVisitors || 0)}</td>
                                    <td>${formatNumber(day.pageViews || 0)}</td>
                                    <td>${day.bounceRate ? day.bounceRate.toFixed(1) + '%' : 'N/A'}</td>
                                    <td>${day.avgSessionDuration ? Math.round(day.avgSessionDuration) + 's' : 'N/A'}</td>
                                </tr>
                            `;
                        });
                    } else {
                        tableHTML += `
                            <tr>
                                <td colspan="6" class="text-center text-muted">Aucune donnée détaillée disponible</td>
                            </tr>
                        `;
                    }
                    
                    tableHTML += `
                                </tbody>
                            </table>
                        </div>
                    `;
                    
                    tableContainer.innerHTML = tableHTML;
                } else {
                    // Pour les autres types (news, programs, baume), afficher le tableau des contenus avec les visiteurs
                    const topPublications = await getTopPublications(currentType, startDate, endDate);
                    const publications = topPublications.publications || [];
                    
                    let tableHTML = `
                        <div class="alert alert-info mb-3">
                            <i class="fas fa-info-circle me-2"></i>
                            Détail des contenus pour la période : <strong>${formatDate(startDate)} - ${formatDate(endDate)}</strong>
                            ${topPublications.source === 'database' ? '<span class="badge bg-success ms-2">Données réelles</span>' : '<span class="badge bg-warning ms-2">Données simulées</span>'}
                        </div>
                        
                        <!-- Carte de statistique des visiteurs -->
                        <div class="row mb-4">
                            <div class="col-md-12">
                                <div class="card bg-light border-primary">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-md-8">
                                                <h5 class="card-title mb-1">
                                                    <i class="fas fa-users me-2 text-primary"></i>
                                                    Total des Visiteurs (Cookies) pour cette période
                                                </h5>
                                                <p class="card-text text-muted mb-0">
                                                    Nombre total de visiteurs enregistrés via les cookies
                                                </p>
                                            </div>
                                            <div class="col-md-4 text-end">
                                                <h2 class="mb-0 text-primary">
                                                    ${formatNumber(totalVisitors)}
                                                </h2>
                                                <small class="text-muted">
                                                    ${visitorData.source === 'database' ? '<i class="fas fa-check-circle text-success"></i> Données réelles' : '<i class="fas fa-database text-warning"></i> Données simulées'}
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Tableau des contenus -->
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Titre</th>
                                        <th>Type</th>
                                        <th>Date</th>
                                        <th>Vues</th>
                                        <th>Catégorie</th>
                                    </tr>
                                </thead>
                                <tbody>
                    `;
                    
                    if (publications.length > 0) {
                        // Trier les publications par date décroissante (plus récent d'abord)
                        publications.sort((a, b) => {
                            const dateA = new Date(a.created_at);
                            const dateB = new Date(b.created_at);
                            return dateB - dateA; // Plus récent d'abord
                        });
                        
                        publications.forEach((pub, index) => {
                            const typeIcon = currentType === 'news' ? 'fa-newspaper text-primary' : 
                                           currentType === 'programs' ? 'fa-tv text-success' : 
                                           'fa-cross text-danger';
                            
                            const typeName = currentType === 'news' ? 'Actualité' : 
                                           currentType === 'programs' ? 'Programme' : 
                                           'Baume';
                            
                            const categoryName = pub.category || pub.theme || 'Non catégorisé';
                            
                            tableHTML += `
                                <tr>
                                    <td>
                                        <i class="fas ${typeIcon} me-2"></i>
                                        ${pub.title || 'Sans titre'}
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">${typeName}</span>
                                    </td>
                                    <td>${pub.created_at ? formatDate(pub.created_at.split('T')[0]) : 'Date inconnue'}</td>
                                    <td>${formatNumber(pub.views || 0)}</td>
                                    <td>
                                        <small class="text-muted">${categoryName}</small>
                                    </td>
                                </tr>
                            `;
                        });
                    } else {
                        tableHTML += `
                            <tr>
                                <td colspan="5" class="text-center text-muted">
                                    <i class="fas fa-inbox me-2"></i>
                                    Aucun contenu trouvé pour cette période
                                </td>
                            </tr>
                        `;
                    }
                    
                    // Ajouter une ligne de résumé
                    const totalContentViews = publications.reduce((sum, pub) => sum + (pub.views || 0), 0);
                    tableHTML += `
                                <tr class="table-primary fw-bold">
                                    <td colspan="3">
                                        <i class="fas fa-chart-bar me-2"></i>
                                        Total (${publications.length} contenus)
                                    </td>
                                    <td>${formatNumber(totalContentViews)}</td>
                                    <td>-</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    `;
                    
                    tableContainer.innerHTML = tableHTML;
                }
            }
        }
        
        function resetDateFilter() {
            document.getElementById('startDate').value = '';
            document.getElementById('endDate').value = '';
            // Recharge le graphique + tableau sur les 30 derniers jours avec le type actif
            handleChartTypeChange({ target: { value: window.currentStatsType || 'news' } });
        }
        
        function loadFilteredStats(startDate, endDate) {
            // Afficher un indicateur de chargement
            const chartContainer = document.querySelector('.chart-container');
            if (chartContainer) {
                chartContainer.innerHTML = '<div class="text-center py-5"><i class="fas fa-spinner fa-spin fa-2x text-primary"></i><p class="mt-3">Chargement des données filtrées...</p></div>';
            }
            
            // Simuler un appel API pour récupérer les données filtrées
            setTimeout(() => {
                console.log(`📊 Données filtrées pour la période ${startDate} - ${endDate}`);
                
                // Calculer les données filtrées selon la période
                const filteredData = calculateFilteredData(startDate, endDate);
                
                // Restaurer le canvas du graphique
                if (chartContainer) {
                    chartContainer.innerHTML = '<canvas id="modalUnifiedChart"></canvas>';
                }
                
                // Recharger le graphique avec les données filtrées
                setTimeout(() => {
                    updateChartWithFilteredData(filteredData);
                    // Mettre à jour le tableau détaillé avec les données filtrées
                    updateTableWithFilteredData(filteredData);
                }, 100);
            }, 1000);
        }
        
        function calculateFilteredData(startDate, endDate) {
            // Utiliser les données réelles du dashboard
            const baseData = {
                news: {
                    total: currentStatsData.totalNews,
                    views: currentStatsData.totalNewsViews,
                    dailyAvg: currentStatsData.totalNews > 0 ? Math.round(currentStatsData.totalNewsViews / currentStatsData.totalNews) : 0
                },
                programs: {
                    total: currentStatsData.totalPrograms,
                    views: currentStatsData.totalProgramsViews,
                    dailyAvg: currentStatsData.totalPrograms > 0 ? Math.round(currentStatsData.totalProgramsViews / currentStatsData.totalPrograms) : 0
                },
                baume: {
                    total: currentStatsData.baumePrieres + currentStatsData.baumeReflexions + currentStatsData.baumeTemoignages,
                    views: currentStatsData.baumeTotalViews,
                    dailyAvg: (currentStatsData.baumePrieres + currentStatsData.baumeReflexions + currentStatsData.baumeTemoignages) > 0 ? 
                        Math.round(currentStatsData.baumeTotalViews / (currentStatsData.baumePrieres + currentStatsData.baumeReflexions + currentStatsData.baumeTemoignages)) : 0
                }
            };
            
            // Calculer le nombre de jours dans la période
            const start = new Date(startDate);
            const end = new Date(endDate);
            const daysDiff = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
            
            // Simuler des données filtrées (proportionnelles à la période)
            const periodRatio = Math.min(daysDiff / 30, 1); // Ratio par rapport à un mois
            
            return {
                news: {
                    total: Math.round(baseData.news.total * periodRatio),
                    views: Math.round(baseData.news.views * periodRatio),
                    dailyAvg: baseData.news.dailyAvg
                },
                programs: {
                    total: Math.round(baseData.programs.total * periodRatio),
                    views: Math.round(baseData.programs.views * periodRatio),
                    dailyAvg: baseData.programs.dailyAvg
                },
                baume: {
                    total: Math.round(baseData.baume.total * periodRatio),
                    views: Math.round(baseData.baume.views * periodRatio),
                    dailyAvg: baseData.baume.dailyAvg
                },
                period: `${formatDate(startDate)} - ${formatDate(endDate)}`,
                days: daysDiff
            };
        }
        
        function updateChartWithFilteredData(filteredData) {
            const selectedType = window.currentStatsType || 'news';
            const chartTitle = document.getElementById('chart-title');
            
            let data, label, color, bgColor;
            
            if (selectedType === 'news') {
                data = [filteredData.news.total, filteredData.news.views];
                label = 'Actualités';
                color = 'rgba(59, 130, 246, 1)';
                bgColor = 'rgba(59, 130, 246, 0.2)';
                chartTitle.textContent = `Actualités (${filteredData.period})`;
            } else if (selectedType === 'programs') {
                data = [filteredData.programs.total, filteredData.programs.views];
                label = 'Programmes';
                color = 'rgba(245, 158, 11, 1)';
                bgColor = 'rgba(245, 158, 11, 0.2)';
                chartTitle.textContent = `Programmes (${filteredData.period})`;
            } else if (selectedType === 'baume') {
                data = [filteredData.baume.total, filteredData.baume.views];
                label = 'Baume de la Foi';
                color = 'rgba(239, 68, 68, 1)';
                bgColor = 'rgba(239, 68, 68, 0.2)';
                chartTitle.textContent = `Baume de la Foi (${filteredData.period})`;
            } else if (selectedType === 'all') {
                data = [filteredData.news.total + filteredData.programs.total + filteredData.baume.total, filteredData.news.views + filteredData.programs.views + filteredData.baume.views];
                label = 'Tous les contenus';
                color = 'rgba(0, 0, 0, 1)';
                bgColor = 'rgba(0, 0, 0, 0.2)';
                chartTitle.textContent = `Tous les contenus (${filteredData.period})`;
            }
            
            // Créer ou mettre à jour le graphique
            const ctx = document.getElementById('modalUnifiedChart');
            if (ctx) {
                // Détruire le graphique existant s'il y en a un
                if (modalChartInstance) {
                    modalChartInstance.destroy();
                    modalChartInstance = null;
                }
                
                // Nettoyer également tous les graphiques qui pourraient être attachés à ce canvas
                const existingCharts = Chart.getChart(ctx);
                if (existingCharts) {
                    existingCharts.destroy();
                }
                
                // Attendre un peu pour s'assurer que le canvas est propre
                setTimeout(() => {
                    modalChartInstance = new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: ['Publications', 'Vues totales'],
                            datasets: [{
                                label: label,
                                data: data,
                                backgroundColor: bgColor,
                                borderColor: color,
                                borderWidth: 3,
                                fill: true,
                                tension: 0.4,
                                pointBackgroundColor: color,
                                pointBorderColor: '#fff',
                                pointBorderWidth: 2,
                                pointRadius: 6,
                                pointHoverRadius: 8
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: 'bottom',
                                    labels: {
                                        padding: 15,
                                        font: { size: 12 }
                                    }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            const value = formatNumber(context.parsed.y);
                                            const total = context.dataIndex === 0 ? 
                                                (selectedType === 'news' ? filteredData.news.total : 
                                                 selectedType === 'programs' ? filteredData.programs.total : 
                                                 filteredData.baume.total) :
                                                (selectedType === 'news' ? filteredData.news.views : 
                                                 selectedType === 'programs' ? filteredData.programs.views : 
                                                 filteredData.baume.views);
                                            const percentage = total > 0 ? Math.round((context.parsed.y / (context.dataIndex === 0 ? 
                                                (filteredData.news.total + filteredData.news.views) :
                                                (filteredData.programs.total + filteredData.programs.views))) * 100) : 0;
                                            return context.label + ': ' + value + ` (${percentage}%)`;
                                        }
                                    }
                                }
                            }
                        }
                    });
                }, 50);
            }
        }
        
        function updateTableWithFilteredData(filteredData) {
            const tableContainer = document.getElementById('baume-details-table');
            if (tableContainer) {
                const totalContent = filteredData.news.total + filteredData.programs.total + filteredData.baume.total;
                const totalViews = filteredData.news.views + filteredData.programs.views + filteredData.baume.views;
                
                let tableHTML = `
                    <div class="alert alert-info mb-3">
                        <i class="fas fa-info-circle me-2"></i>
                        Statistiques pour la période : <strong>${filteredData.period}</strong> (${filteredData.days} jours)
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Type de contenu</th>
                                    <th>Nombre</th>
                                    <th>Pourcentage</th>
                                    <th>Vues totales</th>
                                    <th>Moyenne vues</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><i class="fas fa-newspaper me-2 text-primary"></i> Actualités</td>
                                    <td>${filteredData.news.total}</td>
                                    <td>${totalContent > 0 ? Math.round((filteredData.news.total / totalContent) * 100) : 0}%</td>
                                    <td>${formatNumber(filteredData.news.views)}</td>
                                    <td>${filteredData.news.total > 0 ? formatNumber(Math.round(filteredData.news.views / filteredData.news.total)) : 'N/A'}</td>
                                </tr>
                                <tr>
                                    <td><i class="fas fa-tv me-2 text-success"></i> Programmes</td>
                                    <td>${filteredData.programs.total}</td>
                                    <td>${totalContent > 0 ? Math.round((filteredData.programs.total / totalContent) * 100) : 0}%</td>
                                    <td>${formatNumber(filteredData.programs.views)}</td>
                                    <td>${filteredData.programs.total > 0 ? formatNumber(Math.round(filteredData.programs.views / filteredData.programs.total)) : 'N/A'}</td>
                                </tr>
                                <tr>
                                    <td><i class="fas fa-cross me-2 text-danger"></i> Baume de la Foi</td>
                                    <td>${filteredData.baume.total}</td>
                                    <td>${totalContent > 0 ? Math.round((filteredData.baume.total / totalContent) * 100) : 0}%</td>
                                    <td>${formatNumber(filteredData.baume.views)}</td>
                                    <td>${filteredData.baume.total > 0 ? formatNumber(Math.round(filteredData.baume.views / filteredData.baume.total)) : 'N/A'}</td>
                                </tr>
                                <tr class="table-primary fw-bold">
                                    <td><i class="fas fa-chart-bar me-2 text-dark"></i> Total période</td>
                                    <td>${totalContent}</td>
                                    <td>100%</td>
                                    <td>${formatNumber(totalViews)}</td>
                                    <td>${totalContent > 0 ? formatNumber(Math.round(totalViews / totalContent)) : 'N/A'}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                `;
                
                tableContainer.innerHTML = tableHTML;
            }
        }
        
        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
        }
        
        // Initialiser les dates par défaut (30 derniers jours)
        function initializeDateFilters() {
            const today = new Date();
            const thirtyDaysAgo = new Date(today.getTime() - (30 * 24 * 60 * 60 * 1000));
            
            const startDateInput = document.getElementById('startDate');
            const endDateInput = document.getElementById('endDate');
            
            if (startDateInput && endDateInput) {
                startDateInput.value = thirtyDaysAgo.toISOString().split('T')[0];
                endDateInput.value = today.toISOString().split('T')[0];
            }
        }
        
        // Initialiser au chargement de la page
        document.addEventListener('DOMContentLoaded', function() {
            initializeDateFilters();
        });

    </script>

    <script>
        function openSidebar() {
            document.querySelector('.sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('show');
        }
        function closeSidebar() {
            document.querySelector('.sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }

        // Live clock + header date
        (function updateClock() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
            const dateStr = now.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });
            const ct = document.getElementById('current-time');
            const hd = document.getElementById('header-date');
            if (ct) ct.textContent = timeStr;
            if (hd) hd.textContent = dateStr;
            setTimeout(updateClock, 30000);
        })();
    </script></body>
</html>