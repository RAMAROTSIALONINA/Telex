        // Fonction pour générer les options des listes déroulantes selon les spécifications
        function generateValueOptions(period) {
            const now = new Date();
            let options = '';
            
            switch(period) {
                case 'day':
                    // TOUS les jours depuis le début 2026
                    const startDate2026 = new Date('2026-01-01');
                    const daysDiff = Math.floor((now - startDate2026) / (1000 * 60 * 60 * 24));
                    
                    for (let i = 0; i <= daysDiff; i++) {
                        const date = new Date(startDate2026);
                        date.setDate(startDate2026.getDate() + i);
                        const day = date.getDate();
                        const monthNames = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 
                                         'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'];
                        const month = monthNames[date.getMonth()];
                        const year = date.getFullYear();
                        const dateStr = date.toISOString().split('T')[0];
                        options += `<option value="${dateStr}">${day} ${month} ${year}</option>`;
                    }
                    break;
                    
                case 'week':
                    // TOUTES les semaines depuis le début 2026
                    const startWeek2026 = new Date('2026-01-01');
                    const weeksDiff = Math.floor((now - startWeek2026) / (1000 * 60 * 60 * 24 * 7));
                    
                    options += '<option value="0">Semaine actuelle</option>';
                    for (let i = 1; i <= weeksDiff; i++) {
                        options += `<option value="${i}">Semaine -${i}</option>`;
                    }
                    break;
                    
                case 'month':
                    // TOUS les mois depuis janvier 2026
                    const startMonth2026 = new Date('2026-01-01');
                    const monthsDiff = (now.getFullYear() - 2026) * 12 + (now.getMonth() + 1);
                    
                    for (let i = 0; i < monthsDiff; i++) {
                        const date = new Date(startMonth2026);
                        date.setMonth(startMonth2026.getMonth() + i);
                        const monthNames = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 
                                         'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'];
                        const month = monthNames[date.getMonth()];
                        const year = date.getFullYear();
                        const dateStr = `${year}-${(date.getMonth() + 1).toString().padStart(2, '0')}-01`;
                        options += `<option value="${dateStr}">${month} ${year}</option>`;
                    }
                    break;
                    
                case 'year':
                    // TOUTES les années depuis 2026 jusqu'à l'année actuelle
                    const currentYear = now.getFullYear();
                    for (let year = currentYear; year >= 2026; year--) {
                        options += `<option value="${year}">${year}</option>`;
                    }
                    break;
            }
            
            return options;
        }
        
        // Fonction pour mettre à jour les options de la deuxième liste déroulante
        function updateValueSelect(periodSelectId, valueSelectId) {
            const periodSelect = document.getElementById(periodSelectId);
            const valueSelect = document.getElementById(valueSelectId);
            
            console.log('🔍 updateValueSelect appelé avec:', periodSelectId, valueSelectId);
            console.log('📋 periodSelect:', periodSelect, 'valueSelect:', valueSelect);
            
            if (!periodSelect || !valueSelect) {
                console.log('❌ Éléments non trouvés');
                return;
            }
            
            const period = periodSelect.value;
            console.log('📅 Période sélectionnée:', period);
            
            if (period) {
                if (period === 'day') {
                    // Pour les jours, utiliser un calendrier au lieu d'une liste déroulante
                    valueSelect.style.display = 'none';
                    
                    // Créer ou afficher un input date
                    let dateInput = document.getElementById(valueSelectId.replace('Select', 'Date'));
                    if (!dateInput) {
                        dateInput = document.createElement('input');
                        dateInput.type = 'date';
                        dateInput.id = valueSelectId.replace('Select', 'Date');
                        dateInput.className = 'form-control form-control-sm';
                        dateInput.style.width = 'auto';
                        dateInput.style.maxWidth = '200px';
                        dateInput.onchange = function() {
                            if (periodSelectId === 'statsPeriodSelect') {
                                currentStatsValue = this.value;
                                updateGeneralChart();
                            } else if (periodSelectId === 'overviewPeriodSelect') {
                                currentOverviewValue = this.value;
                                updateOverviewChart();
                            }
                        };
                        
                        // Insérer après le select
                        valueSelect.parentNode.insertBefore(dateInput, valueSelect.nextSibling);
                    }
                    
                    // Définir la valeur par défaut (aujourd'hui)
                    const today = new Date().toISOString().split('T')[0];
                    dateInput.value = today;
                    dateInput.style.display = 'inline-block';
                    
                    // Mettre à jour la variable globale
                    if (periodSelectId === 'statsPeriodSelect') {
                        currentStatsValue = today;
                    } else if (periodSelectId === 'overviewPeriodSelect') {
                        currentOverviewValue = today;
                    }
                    
                    // Définir les limites du calendrier (depuis 2026 jusqu'à aujourd'hui)
                    dateInput.min = '2026-01-01';
                    dateInput.max = today;
                    
                } else {
                    // Cacher le calendrier s'il existe
                    const dateInput = document.getElementById(valueSelectId.replace('Select', 'Date'));
                    if (dateInput) {
                        dateInput.style.display = 'none';
                    }
                    
                    // Afficher et remplir la deuxième liste déroulante pour les autres périodes
                    valueSelect.style.display = 'block';
                    const options = generateValueOptions(period);
                    console.log('📝 Options générées:', options);
                    valueSelect.innerHTML = options;
                }
            } else {
                // Cacher les deux éléments
                valueSelect.style.display = 'none';
                const dateInput = document.getElementById(valueSelectId.replace('Select', 'Date'));
                if (dateInput) {
                    dateInput.style.display = 'none';
                }
            }
        }
        
