        // Fonction pour récupérer les publications les plus vues selon la période
        async function getTopPublications(type, startDate, endDate) {
            try {
                console.log(`📊 Appel API pour publications: type=${type}, startDate=${startDate}, endDate=${endDate}`);
                
                // Essayer d'appeler l'API réelle
                const response = await fetch(`/admin/api/top-publications?type=${type}&startDate=${startDate}&endDate=${endDate}`);
                const data = await response.json();
                
                console.log(`📊 Réponse API reçue:`, data);
                
                if (data.success && data.publications && data.publications.length > 0) {
                    console.log(`✅ ${data.publications.length} publications réelles trouvées`);
                    // Ajouter un indicateur que ce sont des données réelles
                    return {
                        publications: data.publications,
                        source: 'database'
                    };
                } else {
                    console.log(`⚠️ Aucune publication réelle trouvée pour ${type} sur la période ${startDate} - ${endDate}`);
                    // Retourner un tableau vide au lieu de données de test
                    return {
                        publications: [],
                        source: 'database',
                        message: data.message || `Aucune publication ${type} trouvée pour cette période`
                    };
                }
                
            } catch (error) {
                console.error('❌ Erreur getTopPublications:', error);
                return { publications: [], source: 'error' };
            }
        }

        // Fonction pour générer les données de visiteurs par jour
        async function getVisitorData(startDate, endDate) {
            try {
                console.log(`👥 Appel API pour visiteurs: startDate=${startDate}, endDate=${endDate}`);
                
                // Appeler l'API réelle pour les visiteurs
                const response = await fetch(`/admin/api/visitors?startDate=${startDate}&endDate=${endDate}`);
                const data = await response.json();
                
                console.log(`👥 Réponse API visiteurs reçue:`, data);
                
                if (data.success) {
                    console.log(`✅ Données visiteurs réelles reçues`);
                    return {
                        labels: data.labels || [],
                        views: data.visitors || [],
                        totalVisitors: data.totalVisitors || 0,
                        avgVisitors: data.avgVisitors || 0,
                        totalUniqueVisitors: data.totalUniqueVisitors || 0,
                        source: 'database'
                    };
                } else {
                    console.warn(`⚠️ API visiteurs: ${data.message || 'pas de données'}`);
                    return { labels: [], views: [], totalVisitors: 0, avgVisitors: 0, totalUniqueVisitors: 0, source: 'empty' };
                }
                
            } catch (error) {
                console.error('❌ Erreur getVisitorData:', error);
                return { labels: [], views: [], totalVisitors: 0, avgVisitors: 0, totalUniqueVisitors: 0, source: 'error' };
            }
        }

