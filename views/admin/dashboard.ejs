<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --telex-light-blue: #457B9D;
            --sidebar-width: 280px;
            --transition-speed: 0.3s;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
            color: #334155;
        }
        
        /* Sidebar améliorée */
        .sidebar { 
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%); 
            color: white; 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }
        
        .sidebar-brand {
            padding: 25px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(0, 0, 0, 0.1);
            position: relative;
            overflow: hidden;
        }
        
        /* Logo TELEX dans la sidebar */
        .sidebar-logo {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        
        .sidebar-logo img {
            max-width: 180px;
            height: auto;
            margin-bottom: 15px;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
            transition: transform 0.3s ease;
        }
        
        .sidebar-logo img:hover {
            transform: scale(1.05);
        }
        
        .sidebar-logo .brand-text {
            color: white;
            font-weight: 700;
            font-size: 1.8rem;
            margin-bottom: 5px;
            letter-spacing: 0.5px;
        }
        
        .sidebar-logo .version {
            font-size: 0.85rem;
            opacity: 0.8;
            font-weight: 300;
            color: var(--telex-light);
        }
        
        /* Logo watermark discret */
        .logo-watermark {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 999;
            opacity: 0.15;
            pointer-events: none;
            max-width: 150px;
            animation: float 6s ease-in-out infinite;
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-10px) rotate(0.5deg); }
        }
        
        .user-info {
            padding: 20px;
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.05);
            margin: 15px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all var(--transition-speed);
        }
        
        .user-info:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }
        
        .user-avatar {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.2rem;
            margin-right: 15px;
            box-shadow: 0 4px 10px rgba(230, 57, 70, 0.3);
        }
        
        .user-details h5 {
            font-weight: 600;
            margin-bottom: 3px;
            font-size: 1rem;
        }
        
        .user-details small {
            opacity: 0.8;
            font-size: 0.8rem;
            display: block;
        }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .sidebar-nav::-webkit-scrollbar {
            width: 5px;
        }
        
        .sidebar-nav::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 10px;
        }
        
        .nav-item {
            margin-bottom: 8px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 14px 18px;
            text-decoration: none;
            border-radius: 10px;
            transition: all var(--transition-speed);
            font-weight: 500;
            position: relative;
            overflow: hidden;
        }
        
        .nav-link::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 4px;
            background: var(--telex-red);
            transform: translateX(-10px);
            transition: transform var(--transition-speed);
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateX(5px);
        }
        
        .nav-link:hover::before {
            transform: translateX(0);
        }
        
        .nav-link.active {
            background: rgba(230, 57, 70, 0.15);
            color: white;
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.2);
        }
        
        .nav-link.active::before {
            transform: translateX(0);
        }
        
        .nav-link i {
            width: 24px;
            font-size: 1.1rem;
            margin-right: 12px;
            text-align: center;
        }
        
        .nav-link.logout {
            color: #ff9e9e;
            margin-top: 20px;
        }
        
        .nav-link.logout:hover {
            background: rgba(255, 107, 107, 0.1);
            color: #ff6b6b;
        }
        
        /* Main Content */
        .main-content { 
            margin-left: var(--sidebar-width); 
            padding: 30px;
            min-height: 100vh;
            animation: fadeIn 0.5s ease-out;
            position: relative;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* Top Bar améliorée */
        .top-bar {
            background: white;
            padding: 25px 30px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            animation: slideDown 0.4s ease-out;
            position: relative;
            overflow: hidden;
        }
        
        .top-bar::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--telex-red), var(--telex-blue));
        }
        
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .page-title h1 {
            font-weight: 700;
            color: var(--telex-blue);
            font-size: 1.8rem;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .telex-mini-logo {
            height: 32px;
            width: auto;
            vertical-align: middle;
        }
        
        .top-bar p {
            color: #64748b;
            font-size: 1rem;
            margin: 0;
            padding-left: 42px;
        }
        
        .btn-telex {
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 10px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.3);
        }
        
        .btn-telex:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 18px rgba(230, 57, 70, 0.4);
            color: white;
        }
        
        /* Logo dans le header */
        .header-logo-container {
            position: absolute;
            right: 30px;
            top: 50%;
            transform: translateY(-50%);
            opacity: 0.1;
            pointer-events: none;
        }
        
        .header-logo {
            height: 80px;
            width: auto;
        }
        
        /* Stat Cards améliorées */
        .stat-card { 
            background: white; 
            border-radius: 16px; 
            padding: 25px; 
            margin-bottom: 25px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08); 
            text-align: center;
            transition: all 0.3s;
            border: 1px solid rgba(0, 0, 0, 0.05);
            height: 100%;
            animation: fadeInUp 0.5s ease-out;
            animation-fill-mode: both;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 180px;
        }
        
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--telex-red);
            transform: scaleX(0);
            transition: transform 0.3s ease;
            transform-origin: left;
        }
        
        .stat-card:hover::before {
            transform: scaleX(1);
        }
        
        .stat-card:nth-child(1) { animation-delay: 0.1s; }
        .stat-card:nth-child(2) { animation-delay: 0.2s; }
        .stat-card:nth-child(3) { animation-delay: 0.3s; }
        .stat-card:nth-child(4) { animation-delay: 0.4s; }
        
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .stat-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
        }
        
        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 1.5rem;
            color: white;
        }
        
        .stat-icon.news { background: linear-gradient(135deg, #3B82F6, #1D4ED8); }
        .stat-icon.programs { background: linear-gradient(135deg, #10B981, #047857); }
        .stat-icon.contacts { background: linear-gradient(135deg, #8B5CF6, #7C3AED); }
        .stat-icon.gallery { background: linear-gradient(135deg, #6366f1, #8b5cf6); }
        .stat-icon.cookies {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
        }
        .stat-icon.baume {
            background: linear-gradient(135deg, #8e44ad, #9b59b6);
        }
        .stat-icon.neutral {
            background: none;
            border: none;
        }
        
        .stat-number { 
            font-size: 2.8rem; 
            font-weight: 800; 
            color: var(--telex-blue); 
            margin-bottom: 5px;
            line-height: 1;
        }
        
        .stat-card h5 {
            font-weight: 600;
            color: #475569;
            margin-bottom: 10px;
            font-size: 1.1rem;
        }
        
        .stat-description {
            color: #94a3b8;
            font-size: 0.9rem;
            margin-top: 10px;
        }
        
        /* Logo dans le fond des cartes de stats */
        .stat-card-logo {
            position: absolute;
            bottom: 10px;
            right: 10px;
            opacity: 0.05;
            width: 60px;
            height: auto;
            pointer-events: none;
        }
        
        /* Cards améliorées */
        .dashboard-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            border: none;
            margin-bottom: 30px;
            animation: fadeIn 0.6s ease-out;
            position: relative;
            overflow: hidden;
        }
        
        .dashboard-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--telex-blue), var(--telex-red));
        }
        
        .dashboard-card .card-header {
            background: none;
            border-bottom: 1px solid #f1f5f9;
            padding: 20px 25px;
            border-radius: 16px 16px 0 0;
        }
        
        .dashboard-card .card-title {
            font-weight: 700;
            color: var(--telex-blue);
            margin: 0;
            font-size: 1.3rem;
        }
        
        .dashboard-card .card-body {
            padding: 25px;
        }
        
        /* Quick Actions */
        .quick-action-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 25px 15px;
            border-radius: 12px;
            background: white;
            border: 2px solid #f1f5f9;
            color: var(--telex-blue);
            text-decoration: none;
            transition: all 0.3s;
            height: 100%;
            position: relative;
            overflow: hidden;
        }
        
        .quick-action-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--telex-blue);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        
        .quick-action-btn:hover::before {
            transform: scaleX(1);
        }
        
        .quick-action-btn:hover {
            transform: translateY(-5px);
            border-color: var(--telex-light);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        }
        
        .quick-action-btn i {
            font-size: 2rem;
            margin-bottom: 15px;
            color: var(--telex-blue);
        }
        
        .quick-action-btn h6 {
            font-weight: 600;
            margin-bottom: 8px;
        }
        
        .quick-action-btn p {
            font-size: 0.85rem;
            color: #94a3b8;
            text-align: center;
            margin: 0;
        }
        
        /* Logo miniature dans les boutons d'action */
        .action-logo {
            position: absolute;
            bottom: 5px;
            right: 5px;
            width: 20px;
            height: auto;
            opacity: 0.1;
        }
        
        /* Recent Activity */
        .activity-item {
            display: flex;
            align-items: center;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 10px;
            background: #f8fafc;
            transition: all 0.3s;
        }
        
        .activity-item:hover {
            background: #f1f5f9;
            transform: translateX(5px);
        }
        
        .activity-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            font-size: 1rem;
            color: white;
            flex-shrink: 0;
        }
        
        .activity-icon.success { background: linear-gradient(135deg, #10B981, #047857); }
        .activity-icon.info { background: linear-gradient(135deg, #3B82F6, #1D4ED8); }
        .activity-icon.warning { background: linear-gradient(135deg, #F59E0B, #D97706); }
        
        .activity-content h6 {
            font-weight: 600;
            margin-bottom: 3px;
            font-size: 0.95rem;
        }
        
        .activity-content p {
            color: #64748b;
            font-size: 0.85rem;
            margin: 0;
        }
        
        /* Welcome Alert avec logo */
        .welcome-alert {
            background: linear-gradient(135deg, rgba(219, 234, 254, 0.8), rgba(224, 242, 254, 0.8));
            border: none;
            border-radius: 16px;
            padding: 25px 30px;
            border-left: 5px solid var(--telex-blue);
            animation: pulse 2s infinite;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }
        
        .welcome-alert::before {
            content: '';
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            width: 80px;
            height: 80px;
            background: url('/images/Telex.png') no-repeat center;
            background-size: contain;
            opacity: 0.1;
            pointer-events: none;
        }
        
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(29, 53, 87, 0.1); }
            70% { box-shadow: 0 0 0 10px rgba(29, 53, 87, 0); }
            100% { box-shadow: 0 0 0 0 rgba(29, 53, 87, 0); }
        }
        
        .welcome-alert i {
            color: var(--telex-blue);
            font-size: 1.8rem;
            margin-right: 20px;
            flex-shrink: 0;
        }
        
        .welcome-content h5 {
            font-weight: 700;
            color: var(--telex-blue);
            margin-bottom: 8px;
        }
        
        .welcome-content p {
            color: #475569;
            margin: 0;
        }
        
        /* Footer avec logo */
        .dashboard-footer {
            margin-top: 30px;
            padding: 20px;
            text-align: center;
            color: #64748b;
            font-size: 0.9rem;
            border-top: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }
        
        .footer-logo {
            height: 20px;
            width: auto;
            opacity: 0.6;
            transition: opacity 0.3s;
        }
        
        .footer-logo:hover {
            opacity: 1;
        }
        
        /* Responsive */
        @media (max-width: 992px) {
            .sidebar {
                width: 70px;
                overflow: hidden;
            }
            
            .sidebar-brand {
                padding: 15px 10px;
            }
            
            .sidebar-logo img {
                max-width: 50px;
                margin-bottom: 10px;
            }
            
            .sidebar-logo .brand-text,
            .sidebar-logo .version,
            .user-details,
            .nav-link span {
                display: none;
            }
            
            .user-info {
                justify-content: center;
                padding: 15px 10px;
                margin: 10px;
            }
            
            .user-avatar {
                margin-right: 0;
                width: 40px;
                height: 40px;
            }
            
            .nav-link {
                justify-content: center;
                padding: 15px;
            }
            
            .nav-link i {
                margin-right: 0;
                font-size: 1.2rem;
            }
            
            .main-content {
                margin-left: 70px;
                padding: 20px;
            }
            
            .header-logo-container {
                display: none;
            }
            
            .logo-watermark {
                display: none;
            }
        }
        
        @media (max-width: 768px) {
            .top-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            
            .stat-number {
                font-size: 2.2rem;
            }
            
            .quick-action-btn {
                padding: 20px 10px;
            }
            
            .page-title h1 {
                font-size: 1.5rem;
            }
            
            .telex-mini-logo {
                height: 24px;
            }
        }
        
        /* Loading animation */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
            margin-left: 10px;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Chart Containers */
        .chart-container {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .chart-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--telex-blue), var(--telex-red));
            transform: scaleX(0);
            transition: transform 0.3s ease;
            transform-origin: left;
        }
        
        .chart-container:hover::before {
            transform: scaleX(1);
        }
        
        .chart-container:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
        }
        
        .chart-container h6 {
            font-weight: 600;
            color: var(--telex-blue);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .chart-container canvas {
            max-width: 100%;
            height: auto !important;
        }

        /* Styles pour les statistiques détaillées du Baume de la Foi */
        .baume-stats-detail {
            display: flex;
            flex-direction: column;
            gap: 4px;
            font-size: 11px;
            line-height: 1.3;
        }

        .baume-stat-item {
            display: flex;
            align-items: center;
            gap: 4px;
            color: var(--text);
            font-size: 10px;
        }

        .baume-stat-item i {
            font-size: 9px;
            width: 12px;
            text-align: center;
        }

        .baume-stat-item.views-total {
            font-weight: 600;
            color: var(--telex-blue);
            margin-top: 2px;
            padding-top: 2px;
            border-top: 1px solid rgba(0,0,0,0.1);
        }

        .baume-stat-item.views-total i {
            color: var(--telex-blue);
        }
    </style>
</head>
<body>
    <!-- Logo Watermark -->
    <img src="/images/Telex.png" alt="TELEX" class="logo-watermark">
    
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-logo">
                <img src="/images/11.png" alt="Telex Logo">
                <div class="brand-text">Telex Admin</div>
            </div>
        </div>
        
        <div class="user-info">
            <div class="user-avatar">
                <%= user.username.charAt(0).toUpperCase() %>
            </div>
            <div class="user-details">
                <h5><%= user.username %></h5>
                <small>Administrateur</small>
            </div>
        </div>
        
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link active">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/news" class="nav-link">
                    <i class="fas fa-newspaper"></i>
                    <span>Actualités</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/programs" class="nav-link">
                    <i class="fas fa-tv"></i>
                    <span>Programmes</span>
                </a>
            </div>
            <div class="nav-item">
