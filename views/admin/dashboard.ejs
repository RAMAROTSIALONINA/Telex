<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --telex-light-blue: #457B9D;
            --sidebar-width: 280px;
            --transition-speed: 0.3s;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
            color: #334155;
        }
        
        /* Sidebar améliorée */
        .sidebar { 
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%); 
            color: white; 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
        }
        
        .sidebar:hover {
            box-shadow: 8px 0 25px rgba(0, 0, 0, 0.15);
        }
        
        /* ── Sidebar header (Option B) ── */
        .sb-header {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 20px 18px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }

        .sb-logo {
            height: 56px;
            width: auto;
            display: block;
            flex-shrink: 0;
        }
        
        /* ── User card ── */
        .user-card {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 12px 12px 4px;
            padding: 12px 14px;
            background: rgba(255,255,255,.05);
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,.08);
            transition: background .2s;
        }
        .user-card:hover { background: rgba(255,255,255,.09); }

        .user-avatar {
            width: 38px;
            height: 38px;
            background: var(--telex-red);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1rem;
            color: #fff;
            flex-shrink: 0;
        }

        .user-details { flex: 1; min-width: 0; }

        .user-details h5 {
            font-weight: 600;
            margin: 0 0 2px;
            font-size: .88rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-details small {
            color: rgba(255,255,255,.45);
            font-size: .75rem;
        }

        .online-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #22c55e;
            flex-shrink: 0;
            box-shadow: 0 0 0 2px rgba(34,197,94,.25);
        }
        
        /* ── Navigation ── */
        .sidebar-nav {
            flex: 1;
            padding: 8px 10px 4px;
            overflow-y: auto;
        }

        .sidebar-nav::-webkit-scrollbar { width: 4px; }
        .sidebar-nav::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,.15);
            border-radius: 4px;
        }

        .nav-section-label {
            font-size: .68rem;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: rgba(255,255,255,.28);
            padding: 14px 10px 5px;
        }

        .nav-item { margin-bottom: 2px; }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255,255,255,.6);
            padding: 10px 12px;
            text-decoration: none;
            border-radius: 9px;
            transition: background .18s, color .18s;
            font-size: .88rem;
            font-weight: 500;
            position: relative;
        }

        .nav-link i {
            width: 20px;
            font-size: 1rem;
            text-align: center;
            flex-shrink: 0;
        }

        .nav-link:hover {
            background: rgba(255,255,255,.08);
            color: #fff;
        }

        .nav-link.active {
            background: rgba(230,57,70,.15);
            color: #fff;
            font-weight: 600;
            border-left: 3px solid var(--telex-red);
            padding-left: 9px;
        }

        /* ── Sidebar footer (Paramètres + Déconnexion) ── */
        .sidebar-footer {
            padding: 8px 10px 12px;
            border-top: 1px solid rgba(255,255,255,.08);
        }

        .nav-link.logout {
            color: rgba(255,160,160,.7);
        }

        .nav-link.logout:hover {
            background: rgba(255,107,107,.1);
            color: #ff9e9e;
        }
        
        /* ── Main Content ── */
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 24px 28px;
            min-height: 100vh;
            background: #f1f5f9;
        }

        /* ── Dashboard Header Banner ── */
        .dash-header {
            background: linear-gradient(135deg, var(--telex-blue) 0%, #274b80 100%);
            border-radius: 16px;
            padding: 22px 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
            box-shadow: 0 4px 20px rgba(29,53,87,.22);
        }
        .dash-header-left { display: flex; align-items: center; gap: 16px; }
        .dash-logo { height: 44px; width: auto; border-radius: 8px; }
        .dash-title { font-size: 1.25rem; font-weight: 700; color: #fff; margin: 0 0 3px; }
        .dash-subtitle { font-size: .83rem; color: rgba(255,255,255,.6); margin: 0; }
        .dash-subtitle strong { color: rgba(255,255,255,.92); font-weight: 600; }
        .btn-view-site {
            background: rgba(255,255,255,.14);
            color: #fff;
            border: 1px solid rgba(255,255,255,.25);
            padding: 9px 18px;
            border-radius: 9px;
            text-decoration: none;
            font-size: .84rem;
            font-weight: 600;
            display: inline-flex; align-items: center; gap: 7px;
            transition: background .2s;
            white-space: nowrap;
        }
        .btn-view-site:hover { background: rgba(255,255,255,.25); color: #fff; }

        /* ── Section Labels ── */
        .section-label {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .09em;
            text-transform: uppercase;
            color: #94a3b8;
            margin-bottom: 10px;
            margin-top: 4px;
        }
        
        
        /* Stat Cards — layout horizontal */
        .stat-card {
            background: white;
            border-radius: 14px;
            padding: 16px 18px;
            margin-bottom: 20px;
            box-shadow: 0 2px 10px rgba(0,0,0,.06);
            transition: all 0.25s;
            border: 1px solid rgba(0,0,0,.06);
            border-left: 4px solid transparent;
            height: 100%;
            animation: fadeInUp 0.5s ease-out;
            animation-fill-mode: both;
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 14px;
        }

        .stat-card:nth-child(1) { animation-delay: 0.05s; border-left-color: #3B82F6; }
        .stat-card:nth-child(2) { animation-delay: 0.10s; border-left-color: #10B981; }
        .stat-card:nth-child(3) { animation-delay: 0.15s; border-left-color: #8B5CF6; }
        .stat-card:nth-child(4) { animation-delay: 0.20s; border-left-color: #e74c3c; }
        .stat-card:nth-child(5) { animation-delay: 0.25s; border-left-color: #6366f1; }
        .stat-card:nth-child(6) { animation-delay: 0.30s; border-left-color: #8e44ad; }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,.10);
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            color: white;
            flex-shrink: 0;
        }

        .stat-icon.news     { background: linear-gradient(135deg, #3B82F6, #1D4ED8); }
        .stat-icon.programs { background: linear-gradient(135deg, #10B981, #047857); }
        .stat-icon.contacts { background: linear-gradient(135deg, #8B5CF6, #7C3AED); }
        .stat-icon.gallery  { background: linear-gradient(135deg, #6366f1, #8b5cf6); }
        .stat-icon.cookies  { background: linear-gradient(135deg, #e74c3c, #c0392b); }
        .stat-icon.baume    { background: linear-gradient(135deg, #8e44ad, #9b59b6); }

        .stat-body {
            flex: 1;
            min-width: 0;
        }

        .stat-number {
            font-size: 1.9rem;
            font-weight: 800;
            color: var(--telex-blue);
            line-height: 1;
            margin-bottom: 2px;
        }

        .stat-card h5 {
            font-weight: 600;
            color: #475569;
            margin-bottom: 3px;
            font-size: .9rem;
        }

        .stat-description {
            color: #94a3b8;
            font-size: .78rem;
            line-height: 1.35;
        }
        
        /* ── Panel Cards ── */
        .panel {
            background: white;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 1px 6px rgba(0,0,0,.05);
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        .panel-header {
            padding: 15px 20px;
            border-bottom: 1px solid #f1f5f9;
            display: flex; align-items: center; justify-content: space-between;
        }
        .panel-title {
            font-size: .92rem; font-weight: 700; color: var(--telex-blue);
            display: flex; align-items: center; gap: 8px; margin: 0;
        }
        .panel-body { padding: 16px 18px; flex: 1; }

        /* ── Quick Actions list ── */
        .qa-list { display: flex; flex-direction: column; gap: 5px; }
        .qa-item {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 12px;
            border-radius: 9px;
            border: 1px solid #f1f5f9;
            background: #fafbfc;
            text-decoration: none;
            color: var(--telex-blue);
            transition: background .15s, border-color .15s, transform .15s;
            cursor: pointer;
        }
        .qa-item:hover {
            background: #eef2ff;
            border-color: #c7d2fe;
            color: var(--telex-blue);
            transform: translateX(3px);
        }
        .qa-icon {
            width: 36px; height: 36px; border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            font-size: .9rem; color: white; flex-shrink: 0;
        }
        .qa-icon.news     { background: linear-gradient(135deg,#3B82F6,#1D4ED8); }
        .qa-icon.programs { background: linear-gradient(135deg,#10B981,#047857); }
        .qa-icon.baume    { background: linear-gradient(135deg,#8e44ad,#9b59b6); }
        .qa-icon.stats    { background: linear-gradient(135deg,#0ea5e9,#0284c7); }
        .qa-icon.messages { background: linear-gradient(135deg,#8B5CF6,#7C3AED); }
        .qa-icon.settings { background: linear-gradient(135deg,#64748b,#475569); }
        .qa-info { flex: 1; min-width: 0; }
        .qa-label { font-size: .85rem; font-weight: 600; line-height: 1; margin-bottom: 1px; }
        .qa-sub   { font-size: .74rem; color: #94a3b8; }
        .qa-arrow { color: #cbd5e1; font-size: .72rem; flex-shrink: 0; transition: color .15s; }
        .qa-item:hover .qa-arrow { color: var(--telex-blue); }

        /* ── Activity Timeline ── */
        .act-list { display: flex; flex-direction: column; }
        .act-item {
            display: flex; gap: 12px; align-items: flex-start;
            padding: 11px 0;
            border-bottom: 1px solid #f8fafc;
        }
        .act-item:last-child { border-bottom: none; }
        .act-dot {
            width: 36px; height: 36px; border-radius: 9px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            font-size: .85rem; color: white;
        }
        .act-dot.green  { background: linear-gradient(135deg,#10B981,#047857); }
        .act-dot.blue   { background: linear-gradient(135deg,#3B82F6,#1D4ED8); }
        .act-dot.orange { background: linear-gradient(135deg,#F59E0B,#D97706); }
        .act-body { flex: 1; min-width: 0; padding-top: 2px; }
        .act-title { font-size: .85rem; font-weight: 600; color: var(--telex-blue); margin-bottom: 2px; }
        .act-sub   { font-size: .77rem; color: #94a3b8; line-height: 1.35; }

        /* ── Summary Banner ── */
        .summary-banner {
            background: linear-gradient(135deg,rgba(219,234,254,.6),rgba(224,242,254,.6));
            border: 1px solid #bfdbfe;
            border-radius: 12px;
            padding: 14px 18px;
            display: flex; align-items: center; gap: 12px;
            margin-top: 14px;
        }
        .summary-banner i { color: var(--telex-blue); font-size: 1.1rem; flex-shrink: 0; }
        .summary-banner p { font-size: .83rem; color: #475569; margin: 0; line-height: 1.45; }

        /* ── Dashboard Footer ── */
        .dash-footer {
            margin-top: 20px;
            padding: 12px 0;
            display: flex; align-items: center; justify-content: center; gap: 10px;
            color: #94a3b8;
            font-size: .78rem;
            border-top: 1px solid #e2e8f0;
        }
        .dash-footer img { height: 16px; opacity: .4; }
        
        /* Responsive */
        @media (max-width: 992px) {
            .sidebar {
                width: 70px;
                overflow: hidden;
            }

            .sb-header { padding: 12px 0; justify-content: center; gap: 0; }
            .sb-logo { height: 34px; }

            .user-card { margin: 8px 6px 4px; padding: 8px; justify-content: center; }
            .user-details, .online-dot { display: none; }
            .user-avatar { margin: 0; }

            .nav-section-label { display: none; }
            .nav-link span { display: none; }

            .nav-link {
                justify-content: center;
                padding: 11px 0;
                gap: 0;
                border-left: none !important;
                padding-left: 0 !important;
            }

            .nav-link.active {
                border-left: none;
                padding-left: 0;
                border-bottom: 2px solid var(--telex-red);
            }

            .nav-link i { font-size: 1.1rem; width: auto; }

            .sidebar-footer { padding: 6px 4px 10px; }
            
            .main-content {
                margin-left: 70px;
                padding: 20px;
            }
            
        }
        
        @media (max-width: 768px) {
            .stat-number { font-size: 2.2rem; }
            .dash-header { flex-direction: column; align-items: flex-start; gap: 12px; }
        }

        @media (max-width: 576px) {
            .sidebar {
                transform: translateX(-100%);
                width: var(--sidebar-width);
                z-index: 1050;
            }
            .sidebar.open { transform: translateX(0); }
            .main-content { margin-left: 0 !important; padding: 15px; }
            .dash-header { padding: 16px; border-radius: 12px; }
            .stat-number { font-size: 1.8rem; }
            .row > [class*="col-sm-6"] { flex: 0 0 50%; max-width: 50%; }
        }
        
        /* Loading animation */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
            margin-left: 10px;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Chart Containers */
        .chart-container {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .chart-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--telex-blue), var(--telex-red));
            transform: scaleX(0);
            transition: transform 0.3s ease;
            transform-origin: left;
        }
        
        .chart-container:hover::before {
            transform: scaleX(1);
        }
        
        .chart-container:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
        }
        
        .chart-container h6 {
            font-weight: 600;
            color: var(--telex-blue);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .chart-container canvas {
            max-width: 100%;
            height: auto !important;
        }

        /* Styles Baume de la Foi detail (modal) */
        .baume-stats-detail {
            display: flex;
            flex-direction: column;
            gap: 4px;
            font-size: 11px;
            line-height: 1.3;
        }

        .baume-stat-item {
            display: flex;
            align-items: center;
            gap: 4px;
            color: var(--text);
            font-size: 10px;
        }

        .baume-stat-item i {
            font-size: 9px;
            width: 12px;
            text-align: center;
        }

        .baume-stat-item.views-total {
            font-weight: 600;
            color: var(--telex-blue);
            margin-top: 2px;
            padding-top: 2px;
            border-top: 1px solid rgba(0,0,0,0.1);
        }

        .baume-stat-item.views-total i {
            color: var(--telex-blue);
        }
    
        /* ── Responsive mobile (<576px) ── */
        @media (max-width: 576px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform .3s ease;
                z-index: 1050;
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.45);
                z-index: 1040;
            }
            .sidebar-overlay.show { display: block; }
            .main-content { margin-left: 0 !important; }
            .mobile-menu-btn {
                display: flex !important;
            }
        }
        .mobile-menu-btn {
            display: none;
            position: fixed;
            top: 14px;
            left: 14px;
            z-index: 1060;
            background: var(--telex-blue, #1D3557);
            color: white;
            border: none;
            border-radius: 8px;
            width: 40px;
            height: 40px;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.25);
        }</style>
</head>
<body>
    <!-- Overlay mobile -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
    <button class="mobile-menu-btn" onclick="openSidebar()" aria-label="Ouvrir le menu">
        <i class="fas fa-bars"></i>
    </button>

    <!-- Sidebar -->
    <div class="sidebar">

        <!-- En-tête : monogramme T + nom + sous-titre -->
        <div class="sb-header">
            <img src="/images/Telex.png" alt="Telex" class="sb-logo">
        </div>

        <!-- Fiche utilisateur avec indicateur en ligne -->
        <!-- Navigation groupée -->
        <nav class="sidebar-nav">

            <!-- Lien direct Dashboard -->
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link active">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
            </div>

            <!-- Groupe : Contenu -->
            <div class="nav-section-label">Contenu</div>
            <div class="nav-item">
                <a href="/admin/news" class="nav-link">
                    <i class="fas fa-newspaper"></i>
                    <span>Actualités</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/programs" class="nav-link">
                    <i class="fas fa-tv"></i>
                    <span>Programmes</span>
                </a>
            </div>

            <!-- Groupe : Communauté -->
            <div class="nav-section-label">Communauté</div>
            <div class="nav-item">
                <a href="/admin/baume-de-la-foi" class="nav-link">
                    <i class="fas fa-cross"></i>
                    <span>Baume de la Foi</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/contacts" class="nav-link">
                    <i class="fas fa-envelope"></i>
                    <span>Messages</span>
                </a>
            </div>

            <!-- Groupe : Médias -->
            <div class="nav-section-label">Médias</div>
            <div class="nav-item">
                <a href="/admin/gallery" class="nav-link">
                    <i class="fas fa-images"></i>
                    <span>Galerie</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/album" class="nav-link">
                    <i class="fas fa-book"></i>
                    <span>Album</span>
                </a>
            </div>

        </nav>

        <!-- Footer sidebar : Paramètres + Déconnexion -->
        <div class="sidebar-footer">
            <div class="nav-item">
                <a href="/admin/settings" class="nav-link">
                    <i class="fas fa-cog"></i>
                    <span>Paramètres</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/logout" class="nav-link logout">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Déconnexion</span>
                </a>
            </div>
        </div>

    </div>
    
    <!-- Main Content -->
    <div class="main-content">
        <!-- Dashboard Header -->
        <div class="dash-header">
            <div class="dash-header-left">
                <img src="/images/Telex.png" alt="Telex" class="dash-logo">
                <div>
                    <p class="dash-title">Tableau de bord</p>
                    <p class="dash-subtitle">Bonjour <strong><%= user ? user.username : 'Admin' %></strong> &nbsp;·&nbsp; <span id="header-date"></span></p>
                </div>
            </div>
            <a href="/" class="btn-view-site" target="_blank">
                <i class="fas fa-external-link-alt"></i>Voir le site
            </a>
        </div>
        
        <!-- Section label -->
