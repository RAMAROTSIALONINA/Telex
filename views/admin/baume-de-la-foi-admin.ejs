    <script>
        // ===== FONCTIONS UTILITAIRES =====
        
        // Fonction pour formater les nombres avec K, M, B
        function formatNumber(num) {
            if (num >= 1000000000) {
                return (num / 1000000000).toFixed(1).replace(/\.0$/, '') + 'B';
            }
            if (num >= 1000000) {
                return (num / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
            }
            if (num >= 1000) {
                return (num / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
            }
            return num.toString();
        }

        // Fonction pour formater les vues dans les tableaux
        function formatBaumeViews() {
            // Formater les vues des prières
            const priereViewsElements = document.querySelectorAll('#prieres-table .views-number');
            priereViewsElements.forEach(element => {
                const views = parseInt(element.textContent);
                element.textContent = formatNumber(views);
            });

            // Formater les vues des réflexions
            const reflexionViewsElements = document.querySelectorAll('#reflexions-table .views-number');
            reflexionViewsElements.forEach(element => {
                const views = parseInt(element.textContent);
                element.textContent = formatNumber(views);
            });
        }

        // ===== VARIABLES GLOBALES =====
        let priereUploader = null;
        let reflexionUploader = null;
        let currentTemoignagesFilter = 'all';
        let currentTemoignagesPage = 1;
        const temoignagesPerPage = 20;

        // ===== CLASSE MEDIAUPLOADER =====
        class MediaUploader {
            constructor(uploadAreaId, inputId, previewId, videoPlayerId, imageId, infoId) {
                this.uploadArea = document.getElementById(uploadAreaId);
                this.input = document.getElementById(inputId);
                this.preview = document.getElementById(previewId);
                this.videoPlayer = document.getElementById(videoPlayerId);
                this.image = document.getElementById(imageId);
                this.info = document.getElementById(infoId);
                this.currentMediaType = 'image';
                
                this.init();
            }
            
            init() {
                if (!this.uploadArea || !this.input) {
                    console.error('❌ Éléments manquants pour MediaUploader');
                    return;
                }
                
                this.videoPlayer.style.display = 'none';
                this.image.style.display = 'none';
                this.preview.style.display = 'none';

                this.input.addEventListener('change', (e) => {
                    const file = e.target.files[0];
                    if (file) this.handleFile(file);
                });

                this.uploadArea.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    this.uploadArea.classList.add('dragover');
                });

                this.uploadArea.addEventListener('dragleave', (e) => {
                    e.preventDefault();
                    this.uploadArea.classList.remove('dragover');
                });

                this.uploadArea.addEventListener('drop', (e) => {
                    e.preventDefault();
                    this.uploadArea.classList.remove('dragover');
                    const file = e.dataTransfer.files[0];
                    if (file) this.handleFile(file);
                });
            }
            
            handleFile(file) {
                const isVideo = file.type.startsWith('video/');
                const isImage = file.type.startsWith('image/');
                
                if (!isVideo && !isImage) {
                    showNotification('Veuillez sélectionner un fichier vidéo ou image', 'error');
                    return;
                }
                
                this.currentMediaType = isVideo ? 'video' : 'image';
                
                const mediaTypeRadios = this.uploadArea.closest('form').querySelectorAll('input[name="media_type"]');
                mediaTypeRadios.forEach(radio => {
                    radio.checked = radio.value === this.currentMediaType;
                });
                
                if (isVideo) {
                    this.handleVideoFile(file);
                } else {
                    this.handleImageFile(file);
                }
            }
            
            handleVideoFile(file) {
                const url = URL.createObjectURL(file);
                
                this.videoPlayer.src = url;
                this.videoPlayer.style.display = 'block';
                this.videoPlayer.load();
                this.image.style.display = 'none';
                
                this.showPreview();
                this.showFileInfo(file);
            }
            
            handleImageFile(file) {
                const url = URL.createObjectURL(file);
                
                this.image.src = url;
                this.image.style.display = 'block';
                this.videoPlayer.style.display = 'none';
                
                this.showPreview();
                this.showFileInfo(file);
            }
            
            showPreview() {
                this.preview.style.display = 'block';
                this.preview.classList.add('active');
            }
            
            showFileInfo(file) {
                var icon = this.currentMediaType === 'video' ? 'fa-video' : 'fa-image';
                var color = this.currentMediaType === 'video' ? '#dc3545' : '#28a745';
                
                this.info.style.display = 'block';
                this.info.innerHTML = 
                    '<div style="padding: 10px; background: #e8f4fd; border-radius: 6px;">' +
                        '<i class="fas ' + icon + '" style="color: ' + color + '; margin-right: 8px;"></i>' +
                        '<span>' + file.name + ' (' + this.formatFileSize(file.size) + ')</span>' +
                    '</div>';
            }
            
            showExistingMedia(mediaUrl, mediaType) {
                if (!mediaUrl) {
                    console.warn('⚠️ Aucune URL média fournie pour showExistingMedia');
                    return;
                }
                
                // Nettoyer et valider l'URL
                mediaUrl = String(mediaUrl).trim();
                if (!mediaUrl || mediaUrl === 'undefined' || mediaUrl === 'null') {
                    console.warn('⚠️ URL média invalide:', mediaUrl);
                    return;
                }
                
                this.currentMediaType = mediaType || 'image';
                
                try {
                    if (this.currentMediaType === 'video') {
                        this.videoPlayer.src = mediaUrl;
                        this.videoPlayer.style.display = 'block';
                        this.videoPlayer.load();
                        this.image.style.display = 'none';
                    } else {
                        this.image.src = mediaUrl;
                        this.image.style.display = 'block';
                        this.videoPlayer.style.display = 'none';
                    }
                    
                    this.showPreview();
                    
                    var fileName = mediaUrl.split('/').pop() || 'fichier média';
                    var icon = this.currentMediaType === 'video' ? 'fa-video' : 'fa-image';
                    var color = this.currentMediaType === 'video' ? '#dc3545' : '#28a745';
                    
                    this.info.style.display = 'block';
                    this.info.innerHTML = 
                        '<div style="padding: 10px; background: #e8f4fd; border-radius: 6px;">' +
                            '<i class="fas ' + icon + '" style="color: ' + color + '; margin-right: 8px;"></i>' +
                            '<span>' + fileName + '</span>' +
                        '</div>';
                } catch (error) {
                    console.error('❌ Erreur lors de l\'affichage du média:', error);
                    this.info.style.display = 'block';
                    this.info.innerHTML = 
                        '<div style="padding: 10px; background: #f8d7da; border-radius: 6px;">' +
                            '<i class="fas fa-exclamation-triangle" style="color: #721c24; margin-right: 8px;"></i>' +
                            '<span>Erreur lors de l\'affichage du média</span>' +
                        '</div>';
                }
            }
            
            remove() {
                this.input.value = '';
                this.videoPlayer.src = '';
                this.videoPlayer.style.display = 'none';
                this.image.src = '';
                this.image.style.display = 'none';
                this.preview.style.display = 'none';
                this.preview.classList.remove('active');
                this.info.style.display = 'none';
                this.info.innerHTML = '';
                this.currentMediaType = 'image';
            }
            
            formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }
        }

        // ===== GESTION DES ONGLETS =====
        function switchTab(tabId) {
            if (!tabId) return;
            
            document.querySelectorAll('.submenu-item').forEach(tab => {
                tab.classList.remove('active');
            });
            
            document.querySelectorAll('.tab-content').forEach(content => {
                content.style.display = 'none';
            });
            
            const targetTab = document.querySelector(`[data-tab="${tabId}"]`);
            if (targetTab) {
                targetTab.classList.add('active');
            }
            
            const targetContent = document.getElementById(tabId);
            if (targetContent) {
                targetContent.style.display = 'block';
                targetContent.classList.add('fade-in');
                setTimeout(() => targetContent.classList.remove('fade-in'), 500);
                
                if (tabId === 'temoignages') {
                    setTimeout(() => loadTemoignages(), 100);
                }
            }
        }

        // ===== FILTRES DES TABLEAUX =====
        function filterTable(tableId, filter, statusColumnIndex) {
            const table = document.getElementById(tableId);
            if (!table) return;
            
            const rows = table.querySelectorAll('tbody tr');
            
            rows.forEach(row => {
                if (row.querySelector('.empty-state')) return;
                
                const statusCell = row.querySelector(`td:nth-child(${statusColumnIndex})`);
                if (!statusCell) return;
                
                const statusText = statusCell.textContent.toLowerCase();
                
                if (filter === 'all') {
                    row.style.display = '';
                } else if (filter === 'published') {
                    row.style.display = statusText.includes('publié') ? '' : 'none';
                } else if (filter === 'draft') {
                    row.style.display = statusText.includes('brouillon') ? '' : 'none';
                }
            });
        }

        // ===== MISE À JOUR DE L'INTERFACE MÉDIA =====
        function updateMediaInterface(formType, mediaType) {
            const uploadIcon = document.getElementById(`${formType}UploadIcon`);
            const uploadText = document.getElementById(`${formType}UploadText`);
            const uploadFormats = document.getElementById(`${formType}UploadFormats`);
            const mediaInput = document.getElementById(`${formType}MediaInput`);
            
            if (mediaType === 'image') {
                if (uploadIcon) uploadIcon.className = 'fas fa-image';
                if (uploadText) uploadText.textContent = 'Glissez-déposez votre image ou cliquez pour choisir';
                if (uploadFormats) uploadFormats.textContent = 'Formats acceptés: JPG, PNG, WebP, GIF (image)';
                if (mediaInput) mediaInput.accept = 'image/*';
            } else {
                if (uploadIcon) uploadIcon.className = 'fas fa-video';
                if (uploadText) uploadText.textContent = 'Glissez-déposez votre vidéo ou cliquez pour choisir';
                if (uploadFormats) uploadFormats.textContent = 'Formats acceptés: MP4, WebM, OGG, MOV (vidéo)';
                if (mediaInput) mediaInput.accept = 'video/mp4,video/webm,video/ogg,video/quicktime';
            }
        }

