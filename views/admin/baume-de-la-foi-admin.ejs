                    <div class="brand-text">Baume de la Foi</div>
                    <div class="brand-sub">Espace sacré</div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <a href="/admin/dashboard" class="nav-item">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/admin/news" class="nav-item">
                    <i class="fas fa-newspaper"></i>
                    <span>Actualités</span>
                </a>
                <a href="/admin/programs" class="nav-item">
                    <i class="fas fa-tv"></i>
                    <span>Programmes</span>
                </a>
                <a href="/admin/contacts" class="nav-item">
                    <i class="fas fa-envelope"></i>
                    <span>Messages</span>
                </a>
                <a href="/admin/gallery" class="nav-item">
                    <i class="fas fa-images"></i>
                    <span>Galerie</span>
                </a>
                <a href="/admin/footer" class="nav-item">
                    <i class="fas fa-globe"></i>
                    <span>Footer</span>
                </a>
                <a href="/admin/settings" class="nav-item">
                    <i class="fas fa-cog"></i>
                    <span>Paramètres</span>
                </a>
                
                <div class="separator"></div>
                
                <div class="nav-item with-submenu active">
                    <a href="/admin/baume-de-la-foi" class="nav-link-main">
                        <i class="fas fa-cross"></i>
                        <span>Baume de la Foi</span>
                    </a>
                    <div class="submenu">
                        <button class="submenu-item active" data-tab="dashboard">
                            <i class="fas fa-tachometer-alt"></i>
                            <span>Tableau de bord</span>
                        </button>
                        <button class="submenu-item" data-tab="prieres">
                            <i class="fas fa-pray"></i>
                            <span>Prières</span>
                        </button>
                        <button class="submenu-item" data-tab="temoignages">
                            <i class="fas fa-heart"></i>
                            <span>Témoignages</span>
                        </button>
                        <button class="submenu-item" data-tab="reflexions">
                            <i class="fas fa-book"></i>
                            <span>Réflexions</span>
                        </button>
                    </div>
                </div>
                
                <div class="separator"></div>
                
                <a href="/admin/logout" class="nav-item">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Déconnexion</span>
                </a>
            </nav>
        </aside>

        <!-- ===== MAIN CONTENT ===== -->
        <main class="admin-main">
            <!-- Top Bar -->
            <div class="top-bar">
                <div class="page-title">
                    <div class="brand-icon">
                        <i class="fas fa-spa"></i>
                    </div>
                    <div>
                        <h1>Baume de la Foi</h1>
                        <p>Administration des contenus spirituels</p>
                    </div>
                </div>
                <div class="top-actions">
                    <button class="btn btn-primary" onclick="refreshDashboardData()">
                        <i class="fas fa-sync-alt me-2"></i>Rafraîchir
                    </button>
                </div>
            </div>

            <!-- Statistics Dashboard -->
            <div class="stats-section">
                <div class="stats-grid">
                    <%
                        // Initialisation sécurisée des variables
                        const prieresList = typeof prieres !== 'undefined' && prieres ? prieres : [];
                        const reflexionsList = typeof reflexions !== 'undefined' && reflexions ? reflexions : [];
                        
                        const publishedPrieres = prieresList.filter(p => p && p.is_published).length;
                        const draftPrieres = prieresList.filter(p => p && !p.is_published).length;
                        const publishedReflexions = reflexionsList.filter(r => r && r.is_published).length;
                        const draftReflexions = reflexionsList.filter(r => r && !r.is_published).length;
                        const totalViews = (prieresList.reduce((sum, p) => sum + (p && p.views ? p.views : 0), 0) + 
                                        reflexionsList.reduce((sum, r) => sum + (r && r.views ? r.views : 0), 0)) || 0;
                    %>
                    
                    <div class="stat-card">
                        <div class="stat-info">
                            <div class="stat-number"><%= publishedPrieres + publishedReflexions %></div>
                            <div class="stat-label">Contenus Publiés</div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-check-circle"></i>
                        </div>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-info">
                            <div class="stat-number"><%= draftPrieres + draftReflexions %></div>
                            <div class="stat-label">Brouillons</div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-edit"></i>
                        </div>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-info">
                            <div class="stat-number"><%= prieresList.length %></div>
                            <div class="stat-label">Prières</div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-pray"></i>
                        </div>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-info">
                            <div class="stat-number"><%= reflexionsList.length %></div>
                            <div class="stat-label">Réflexions</div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-book"></i>
                        </div>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-info">
                            <div class="stat-number"><%= totalViews.toLocaleString() %></div>
                            <div class="stat-label">Vues Totales</div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-eye"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== TABLEAU DE BORD ===== -->
            <div id="dashboard" class="tab-content fade-in" style="display: block;">
                <div class="content-section">
                    <div class="section-header">
                        <div class="section-title">
                            <i class="fas fa-chart-line"></i>
                            <div>
                                <h2>Activité récente</h2>
                                <p>Les dernières interactions sur votre espace spirituel</p>
                            </div>
                        </div>
                        <button class="btn btn-secondary" onclick="exportData()">
                            <i class="fas fa-download"></i>
                            Exporter
                        </button>
                    </div>
                    
                    <div class="table-container">
                        <div class="section-header" style="border-bottom: none; padding-bottom: 0;">
                            <h3 style="margin: 0; color: var(--primary-dark);">
                                <i class="fas fa-pray me-2"></i>Prières récentes
                            </h3>
                            <div class="btn-group" id="prieres-status-filters">
                                <button class="btn btn-outline-primary active" data-status="all">Toutes</button>
                                <button class="btn btn-outline-success" data-status="published">Publiées</button>
                                <button class="btn btn-outline-secondary" data-status="draft">Brouillons</button>
                            </div>
                        </div>
                        <table class="modern-table" id="prieres-table">
                            <thead>
                                <tr>
                                    <th>Titre</th>
                                    <th>Catégorie</th>
                                    <th>Date</th>
                                    <th>Média</th>
                                    <th>Auteur</th>
                                    <th>Vues</th>
                                    <th>Statut</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (prieresList.length > 0) { %>
                                    <% prieresList.slice(0, 5).forEach(function(priere) { %>
                                        <tr data-id="<%= priere.id || '' %>">
                                            <td>
                                                <div class="table-title">
                                                    <%= priere.title || 'Titre non défini' %>
                                                    <small><%= (priere.content || '').substring(0, 50) + (priere.content && priere.content.length > 50 ? '...' : '') %></small>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge badge-info"><i class="fas fa-pray me-1"></i>Prière</span>
                                            </td>
                                            <td><%= priere.created_at ? new Date(priere.created_at).toLocaleDateString('fr-FR') : 'Date inconnue' %></td>
                                            <td>
                                                <% 
                                                let mediaHtml = '';
                                                if (priere.media_type === 'image' && priere.image_url) {
                                                    mediaHtml = '<i class="fas fa-image" style="color: #28a745;"></i> Image';
                                                } else if (priere.media_type === 'video' && priere.video_url) {
                                                    mediaHtml = '<i class="fas fa-video" style="color: #dc3545;"></i> Vidéo';
                                                } else if (priere.video_url) {
                                                    const videoExt = /\.(mp4|webm|ogg|mov|avi|mkv)$/i;
                                                    mediaHtml = priere.video_url.match(videoExt) 
                                                        ? '<i class="fas fa-video" style="color: #dc3545;"></i> Vidéo'
                                                        : '<i class="fas fa-image" style="color: #28a745;"></i> Image';
                                                } else if (priere.image_url) {
                                                    mediaHtml = '<i class="fas fa-image" style="color: #28a745;"></i> Image';
                                                } else {
                                                    mediaHtml = '<span style="color: #999;"><i class="fas fa-times"></i> Aucun</span>';
                                                }
                                                %>
                                                <small><%- mediaHtml %></small>
                                            </td>
                                            <td><%= priere.author || 'Baume de la Foi' %></td>
                                            <td>
                                                <div class="views-count">
                                                    <i class="fas fa-eye me-1"></i>
                                                    <span class="views-number"><%= priere.views || 0 %></span>
                                                </div>
                                            </td>
                                            <td>
                                                <% if (priere.is_published) { %>
                                                    <span class="badge badge-success"><i class="fas fa-circle me-1"></i>Publié</span>
                                                <% } else { %>
                                                    <span class="badge badge-warning"><i class="fas fa-clock me-1"></i>Brouillon</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <div class="table-actions">
                                                    <button class="table-btn edit-btn" data-id="<%= priere.id || '' %>" data-action="edit" data-type="priere" title="Modifier">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button class="table-btn delete-btn" data-id="<%= priere.id || '' %>" data-action="delete" data-type="priere" title="Supprimer">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center">
                                            <div class="empty-state">
                                                <i class="fas fa-pray"></i>
                                                <h4>Aucune prière</h4>
                                                <p>Commencez par créer votre première prière</p>
                                                <button class="btn btn-primary" onclick="switchTab('prieres')">
                                                    <i class="fas fa-plus"></i>
                                                    Créer une prière
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    
                    <div class="table-container">
                        <div class="section-header" style="border-bottom: none; padding-bottom: 0;">
                            <h3 style="margin: 0; color: var(--primary-dark);">
                                <i class="fas fa-book me-2"></i>Réflexions récentes
                            </h3>
                            <div class="btn-group" id="reflexions-status-filters">
                                <button class="btn btn-outline-primary active" data-status="all">Toutes</button>
                                <button class="btn btn-outline-success" data-status="published">Publiées</button>
                                <button class="btn btn-outline-secondary" data-status="draft">Brouillons</button>
                            </div>
                        </div>
                        <table class="modern-table" id="reflexions-table">
                            <thead>
                                <tr>
                                    <th>Titre</th>
                                    <th>Thème</th>
                                    <th>Date</th>
                                    <th>Média</th>
                                    <th>Auteur</th>
                                    <th>Vues</th>
                                    <th>Statut</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (reflexionsList.length > 0) { %>
                                    <% reflexionsList.slice(0, 5).forEach(function(reflexion) { %>
                                        <tr data-id="<%= reflexion.id || '' %>">
                                            <td>
                                                <div class="table-title">
                                                    <%= reflexion.title || 'Titre non défini' %>
                                                    <small><%= (reflexion.content || '').substring(0, 50) + (reflexion.content && reflexion.content.length > 50 ? '...' : '') %></small>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge badge-info"><i class="fas fa-book me-1"></i>Réflexion</span>
                                            </td>
                                            <td><%= reflexion.created_at ? new Date(reflexion.created_at).toLocaleDateString('fr-FR') : 'Date inconnue' %></td>
                                            <td>
                                                <% 
                                                let mediaHtml = '';
                                                if (reflexion.media_type === 'image' && reflexion.image_url) {
                                                    mediaHtml = '<i class="fas fa-image" style="color: #28a745;"></i> Image';
                                                } else if (reflexion.media_type === 'video' && reflexion.video_url) {
                                                    mediaHtml = '<i class="fas fa-video" style="color: #dc3545;"></i> Vidéo';
                                                } else if (reflexion.video_url) {
                                                    const videoExt = /\.(mp4|webm|ogg|mov|avi|mkv)$/i;
                                                    mediaHtml = reflexion.video_url.match(videoExt) 
                                                        ? '<i class="fas fa-video" style="color: #dc3545;"></i> Vidéo'
                                                        : '<i class="fas fa-image" style="color: #28a745;"></i> Image';
                                                } else if (reflexion.image_url) {
                                                    mediaHtml = '<i class="fas fa-image" style="color: #28a745;"></i> Image';
                                                } else {
                                                    mediaHtml = '<span style="color: #999;"><i class="fas fa-times"></i> Aucun</span>';
                                                }
                                                %>
                                                <small><%- mediaHtml %></small>
                                            </td>
                                            <td><%= reflexion.author || 'Baume de la Foi' %></td>
                                            <td>
                                                <div class="views-count">
                                                    <i class="fas fa-eye me-1"></i>
                                                    <span class="views-number"><%= reflexion.views || 0 %></span>
                                                </div>
                                            </td>
                                            <td>
                                                <% if (reflexion.is_published) { %>
                                                    <span class="badge badge-success"><i class="fas fa-circle me-1"></i>Publié</span>
                                                <% } else { %>
                                                    <span class="badge badge-warning"><i class="fas fa-clock me-1"></i>Brouillon</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <div class="table-actions">
                                                    <button class="table-btn edit-btn" data-id="<%= reflexion.id || '' %>" data-action="edit" data-type="reflexion" title="Modifier">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button class="table-btn delete-btn" data-id="<%= reflexion.id || '' %>" data-action="delete" data-type="reflexion" title="Supprimer">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center">
                                            <div class="empty-state">
                                                <i class="fas fa-book"></i>
                                                <h4>Aucune réflexion</h4>
                                                <p>Commencez par créer votre première réflexion</p>
                                                <button class="btn btn-primary" onclick="switchTab('reflexions')">
                                                    <i class="fas fa-plus"></i>
                                                    Créer une réflexion
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ===== GESTION DES PRIÈRES ===== -->
            <div id="prieres" class="tab-content fade-in" style="display: none;">
                <div class="content-section">
                    <div class="section-header">
                        <div class="section-title">
                            <i class="fas fa-pray"></i>
                            <div>
                                <h2>Créer une prière</h2>
                                <p>Ajoutez une nouvelle prière avec vidéo ou image</p>
                            </div>
                        </div>
                    </div>
                    
                    <form id="priereForm" enctype="multipart/form-data" method="POST" class="modern-form">
                        <input type="hidden" id="priereId" name="id" value="">
                        <input type="hidden" id="existingPriereVideoUrl" name="existing_video_url" value="">
                        <input type="hidden" id="existingPriereImageUrl" name="existing_image_url" value="">
                        <input type="hidden" id="existingPriereMediaType" name="existing_media_type" value="">
                        <input type="hidden" id="removePriereImage" name="remove_image" value="">
                        <input type="hidden" id="removePriereVideo" name="remove_video" value="">
                        
                        <div class="form-grid">
                            <div class="form-group full-width">
                                <label class="form-label">
                                    <i class="fas fa-heading"></i>
                                    Titre de la prière *
                                </label>
                                <input type="text" id="priereTitle" name="title" class="form-control" required placeholder="Ex: Prière de protection">
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-tag"></i>
                                    Catégorie
                                </label>
                                <select id="priereCategory" name="category" class="form-control">
                                    <option value="comfort">Réconfort</option>
                                    <option value="healing">Guérison</option>
                                    <option value="protection">Protection</option>
                                    <option value="peace">Paix</option>
                                    <option value="hope">Espérance</option>
                                </select>
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-user"></i>
                                    Auteur
                                </label>
                                <input type="text" name="author" class="form-control" value="Baume de la Foi" placeholder="Auteur">
                            </div>
                            
                            <div class="form-group full-width">
                                <label class="form-label">
                                    <i class="fas fa-align-left"></i>
                                    Contenu de la prière *
                                </label>
                                <textarea id="priereContent" name="content" class="form-control" rows="6" required placeholder="Rédigez le contenu de la prière..."></textarea>
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-bible"></i>
                                    Référence biblique
                                </label>
                                <input type="text" id="priereReference" name="reference" class="form-control" placeholder="Ex: Psaume 23:4">
                            </div>
                            
                            <div class="form-group full-width">
                                <label class="form-label">
                                    <i class="fas fa-photo-video"></i>
                                    Type de média
                                </label>
                                <div class="media-type-selector">
                                    <label class="media-option">
                                        <input type="radio" name="media_type" value="image" checked onchange="updateMediaInterface('priere', 'image')">
                                        <i class="fas fa-image"></i> Image
                                    </label>
                                    <label class="media-option">
                                        <input type="radio" name="media_type" value="video" onchange="updateMediaInterface('priere', 'video')">
                                        <i class="fas fa-video"></i> Vidéo
                                    </label>
                                </div>
                            </div>
                            
                            <div class="form-group full-width">
                                <label class="form-label">
                                    <i class="fas fa-upload"></i>
                                    Fichier média
