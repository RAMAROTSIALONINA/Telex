        // ===== GESTION DES ACTIONS (ÉDITION/SUPPRESSION) =====
        function handleTableAction(event) {
            const button = event.target.closest('.table-btn');
            if (!button) return;
            
            event.preventDefault();
            
            const id = button.dataset.id;
            const action = button.dataset.action;
            const type = button.dataset.type;
            const table = button.closest('table');
            
            if (!id || id === 'undefined') {
                showNotification('ID invalide', 'error');
                return;
            }
            
            if (action === 'edit') {
                if (type === 'priere') {
                    editPriere(id);
                } else if (type === 'reflexion') {
                    editReflexion(id);
                }
            } else if (action === 'delete') {
                if (type === 'priere') {
                    deletePriere(id);
                } else if (type === 'reflexion') {
                    deleteReflexion(id);
                }
            }
        }

