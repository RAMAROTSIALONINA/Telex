        function displayTemoignages(temoignages, append = false) {
            console.log('🎨 DISPLAY FUNCTION - Starting...');
            console.log('🎨 temoignages received:', temoignages.length);
            console.log('🎨 append mode:', append);
            console.log('🎨 currentTemoignagesFilter:', currentTemoignagesFilter);
            console.log('🎨 typeof temoignages:', typeof temoignages);
            console.log('🎨 isArray:', Array.isArray(temoignages));
            
            const tbody = document.querySelector('#temoignages-table tbody');
            if (!tbody) {
                console.log('❌ tbody not found!');
                return;
            }
            
            // Si ce n'est pas un ajout, vider le tableau
            if (!append) {
                console.log('🎨 Clearing tbody...');
                tbody.innerHTML = '';
                // Stocker tous les témoignages pour la pagination
                window.allTemoignagesAdmin = temoignages;
                console.log('🎨 Stored in window.allTemoignagesAdmin:', window.allTemoignagesAdmin.length);
            }
            
            const filtered = currentTemoignagesFilter === 'all' 
                ? temoignages 
                : temoignages.filter(t => t.status === currentTemoignagesFilter);
            
            console.log('🎨 Filter applied:', currentTemoignagesFilter);
            console.log('🎨 Original temoignages length:', temoignages.length);
            console.log('🎨 Filtered count:', filtered.length);
            console.log('🎨 Filtered temoignages IDs:', filtered.map(t => t.id));
            
            if (filtered.length === 0 && !append) {
                var emptyHtml = '<tr><td colspan="7" class="text-center"><div class="empty-state"><i class="fas fa-heart"></i><h4>Aucun témoignage</h4><p>' + (currentTemoignagesFilter === 'all' ? 'Aucun témoignage trouvé' : 'Aucun témoignage ' + (currentTemoignagesFilter === 'approved' ? 'approuvé' : currentTemoignagesFilter === 'pending' ? 'en attente' : 'rejeté')) + '</p></div></td></tr>';
                tbody.innerHTML = emptyHtml;
                return;
            }
            
            // Pagination : calculer les indices
            const startIndex = (currentTemoignagesPage - 1) * temoignagesPerPage;
            const endIndex = Math.min(startIndex + temoignagesPerPage, filtered.length);
            
            console.log('🎨 Pagination - Page:', currentTemoignagesPage, 'Start:', startIndex, 'End:', endIndex, 'Total:', filtered.length);
            
            var rowsHtml = '';
            
            for (let i = startIndex; i < endIndex; i++) {
                const t = filtered[i];
                if (i < startIndex + 10) { // Log only first 10 for debugging
                    console.log(`📝 Témoignage ${i + 1}:`, {
                        id: t.id,
                        status: t.status,
                        is_approved: t.is_approved,
                        author_name: t.author_name
                    });
                }
                
                rowsHtml += '<tr data-id="' + t.id + '">' +
                    '<td>' + new Date(t.created_at).toLocaleDateString('fr-FR') + '</td>' +
                    '<td><strong>' + (t.author_name || 'Anonyme') + '</strong></td>' +
                    '<td>' + (t.ville || '-') + '</td>' +
                    '<td>' + (t.content ? t.content.substring(0, 100) + (t.content.length > 100 ? '...' : '') : '-') + '</td>' +
                    '<td>' + (t.author_email || '-') + '</td>' +
                    '<td>' + getStatusBadge(t.status) + '</td>' +
                    '<td>' +
                        '<div class="table-actions">' +
                            '<button class="table-btn view-btn" onclick="viewTemoignage(' + t.id + ')" title="Voir"><i class="fas fa-eye"></i></button>' +
                            (t.status === 'pending' ? 
                                '<button class="table-btn approve-btn" onclick="approveTemoignage(' + t.id + ')" title="Approuver"><i class="fas fa-check"></i></button>' +
                                '<button class="table-btn reject-btn" onclick="rejectTemoignage(' + t.id + ')" title="Rejeter"><i class="fas fa-times"></i></button>' 
                                : '') +
                            '<button class="table-btn delete-btn" onclick="deleteTemoignage(' + t.id + ')" title="Supprimer"><i class="fas fa-trash"></i></button>' +
                        '</div>' +
                    '</td>' +
                '</tr>';
            }
            
            // Ajouter les nouvelles lignes
            if (append) {
                tbody.innerHTML += rowsHtml;
            } else {
                tbody.innerHTML = rowsHtml;
            }
            
            // Mettre à jour la pagination
            updateTemoignagesPagination(filtered.length);
                        
            console.log('✅ Generated HTML for', endIndex - startIndex, 'testimonials (total displayed:', tbody.children.length, ')');
        }

        
        // Fonction de recherche pour les témoignages
        function searchTemoignages() {
            const searchInput = document.getElementById('temoignages-search');
            if (!searchInput || !window.allTemoignagesAdmin) return;
            
            const searchTerm = searchInput.value.toLowerCase().trim();
            console.log('🔍 Searching for:', searchTerm);
            
            // Filtrer par statut ET par terme de recherche
            let filtered = currentTemoignagesFilter === 'all' 
                ? window.allTemoignagesAdmin 
                : window.allTemoignagesAdmin.filter(t => t.status === currentTemoignagesFilter);
            
            // Appliquer la recherche
            if (searchTerm) {
                filtered = filtered.filter(t => {
                    return t.author_name?.toLowerCase().includes(searchTerm) ||
                           t.author_email?.toLowerCase().includes(searchTerm) ||
                           t.ville?.toLowerCase().includes(searchTerm) ||
                           t.content?.toLowerCase().includes(searchTerm);
                });
            }
            
            console.log('🔍 Search results:', filtered.length, 'testimonials');
            displayTemoignages(filtered, false);
        }

        function getStatusBadge(status) {
            const badges = {
                'approved': '<span class="badge badge-success"><i class="fas fa-check-circle me-1"></i>Approuvé</span>',
                'pending': '<span class="badge badge-warning"><i class="fas fa-clock me-1"></i>En attente</span>',
                'rejected': '<span class="badge badge-secondary"><i class="fas fa-times-circle me-1"></i>Rejeté</span>'
            };
            return badges[status] || '<span class="badge badge-secondary">Inconnu</span>';
        }

        function updateTemoignagesStats(temoignages) {
            const total = temoignages.length;
            const approved = temoignages.filter(t => t.status === 'approved').length;
            const pending = temoignages.filter(t => t.status === 'pending').length;
            const rejected = temoignages.filter(t => t.status === 'rejected').length;
            
            document.getElementById('totalTemoignages').textContent = total;
            document.getElementById('approvedTemoignages').textContent = approved;
            document.getElementById('pendingTemoignages').textContent = pending;
            document.getElementById('rejectedTemoignages').textContent = rejected;
        }

