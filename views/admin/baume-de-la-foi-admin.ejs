        // ===== NOTIFICATIONS =====
        function showNotification(message, type) {
            var notification = document.createElement('div');
            notification.className = 'notification-toast ' + type;
            
            var icons = {
                success: 'check-circle',
                error: 'exclamation-circle',
                warning: 'exclamation-triangle',
                info: 'info-circle'
            };
            
            var iconClass = icons[type] || 'info-circle';
            
            notification.innerHTML = 
                '<i class="fas fa-' + iconClass + '"></i>' +
                '<span style="flex: 1;">' + message + '</span>' +
                '<button onclick="this.parentElement.remove()" style="background: none; border: none; color: var(--text-lighter); cursor: pointer;">' +
                    '<i class="fas fa-times"></i>' +
                '</button>';
            
            document.body.appendChild(notification);
            setTimeout(function() {
                if (notification.parentElement) {
                    notification.remove();
                }
            }, 5000);
        }

        // ===== GESTIONNAIRES DE FORMULAIRES =====
        async function handlePriereSubmit(e) {
            e.preventDefault();
            
            const form = e.target;
            const formData = new FormData(form);
            const idField = document.getElementById('priereId');
            const isUpdate = idField && idField.value && idField.value !== '';
            
            const submitBtn = document.getElementById('submitPriereBtn');
            const originalText = submitBtn.innerHTML;
            
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enregistrement...';
            submitBtn.disabled = true;
            
            try {
                const url = isUpdate ? form.action : '/api/baume/prieres';
                
                const response = await fetch(url, {
                    method: isUpdate ? 'PUT' : 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showNotification(result.message || 'Succès', 'success');
                    
                    if (!isUpdate) {
                        resetPriereForm();
                    }
                    
                    setTimeout(() => refreshDashboardData(), 1500);
                } else {
                    showNotification(result.error || 'Erreur', 'error');
                }
            } catch (error) {
                showNotification('Erreur: ' + error.message, 'error');
            } finally {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        }

        async function handleReflexionSubmit(e) {
            e.preventDefault();
            
            const form = e.target;
            const formData = new FormData(form);
            const idField = document.getElementById('reflexionId');
            const isUpdate = idField && idField.value && idField.value !== '';
            
            const submitBtn = document.getElementById('submitReflexionBtn');
            const originalText = submitBtn.innerHTML;
            
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enregistrement...';
            submitBtn.disabled = true;
            
            try {
                const url = isUpdate ? form.action : '/api/baume/reflexions';
                
                const response = await fetch(url, {
                    method: isUpdate ? 'PUT' : 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showNotification(result.message || 'Succès', 'success');
                    
                    if (!isUpdate) {
                        resetReflexionForm();
                    }
                    
                    setTimeout(() => refreshDashboardData(), 1500);
                } else {
                    showNotification(result.error || 'Erreur', 'error');
                }
            } catch (error) {
                showNotification('Erreur: ' + error.message, 'error');
            } finally {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        }

        // ===== INITIALISATION =====
        document.addEventListener('DOMContentLoaded', function() {
            // Initialiser les uploaders
            priereUploader = new MediaUploader(
                'priereUploadArea', 'priereMediaInput', 'priereMediaPreview',
                'priereMediaPlayer', 'priereMediaImage', 'priereMediaInfo'
            );
            
            reflexionUploader = new MediaUploader(
                'reflexionUploadArea', 'reflexionMediaInput', 'reflexionMediaPreview',
                'reflexionMediaPlayer', 'reflexionMediaImage', 'reflexionMediaInfo'
            );
            
            window.priereUploader = priereUploader;
            window.reflexionUploader = reflexionUploader;
            
            // Gestionnaire d'événements unifié pour les boutons de tableau
            document.addEventListener('click', handleTableAction);
            
            // Gestionnaires d'onglets
            document.querySelectorAll('.submenu-item[data-tab]').forEach(item => {
                item.addEventListener('click', function() {
                    switchTab(this.dataset.tab);
                });
            });
            
            // Filtres des prières
            const prieresFilters = document.getElementById('prieres-status-filters');
            if (prieresFilters) {
                prieresFilters.querySelectorAll('button').forEach(btn => {
                    btn.addEventListener('click', function() {
                        prieresFilters.querySelectorAll('button').forEach(b => b.classList.remove('active'));
                        this.classList.add('active');
                        filterTable('prieres-table', this.dataset.status, 6);
                    });
                });
            }
            
            // Filtres des réflexions
            const reflexionsFilters = document.getElementById('reflexions-status-filters');
            if (reflexionsFilters) {
                reflexionsFilters.querySelectorAll('button').forEach(btn => {
                    btn.addEventListener('click', function() {
                        reflexionsFilters.querySelectorAll('button').forEach(b => b.classList.remove('active'));
                        this.classList.add('active');
                        filterTable('reflexions-table', this.dataset.status, 6);
                    });
                });
            }
            
            // Filtres des témoignages
            const temoignagesFilters = document.getElementById('temoignages-filters');
            if (temoignagesFilters) {
                temoignagesFilters.querySelectorAll('button').forEach(btn => {
                    btn.addEventListener('click', function() {
                        temoignagesFilters.querySelectorAll('button').forEach(b => b.classList.remove('active'));
                        this.classList.add('active');
                        currentTemoignagesFilter = this.dataset.filter;
                        loadTemoignages();
                    });
                });
            }
            
            // Gestionnaire de recherche pour les témoignages
            const searchInput = document.getElementById('temoignages-search');
            if (searchInput) {
                let searchTimeout;
                searchInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(() => {
                        searchTemoignages();
                    }, 300); // Attendre 300ms après la fin de la saisie
                });
                
                searchInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        searchTemoignages();
                    }
                });
            }
            
            // Soumission des formulaires
            document.getElementById('priereForm').addEventListener('submit', handlePriereSubmit);
            document.getElementById('reflexionForm').addEventListener('submit', handleReflexionSubmit);
            
            // Animation des cartes
            document.querySelectorAll('.stat-card').forEach((card, i) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.5s ease-out';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, i * 100);
            });
            
            // Formater les vues avec K, M, B
            formatBaumeViews();
        });

        // Exposer les fonctions globalement
        window.switchTab = switchTab;
        window.updateMediaInterface = updateMediaInterface;
        window.removeImage = removeImage;
        window.removeVideo = removeVideo;
        window.removePriereMedia = removePriereMedia;
        window.removeReflexionMedia = removeReflexionMedia;
        window.resetPriereForm = resetPriereForm;
        window.resetReflexionForm = resetReflexionForm;
        window.refreshDashboardData = refreshDashboardData;
        window.exportData = exportData;
        window.viewTemoignage = viewTemoignage;
        window.approveTemoignage = approveTemoignage;
        window.rejectTemoignage = rejectTemoignage;
        window.deleteTemoignage = deleteTemoignage;
        window.showNotification = showNotification;

        // ===== FONCTIONS DE PAGINATION DES TÉMOIGNAGES =====
        function updateTemoignagesPagination(totalItems) {
            const totalPages = Math.ceil(totalItems / temoignagesPerPage);
            const paginationContainer = document.getElementById('temoignages-pagination');
            const paginationInfo = document.getElementById('temoignages-pagination-info');
            const prevBtn = document.getElementById('temoignages-prev-page');
            const nextBtn = document.getElementById('temoignages-next-page');
            const pageNumbers = document.getElementById('temoignages-page-numbers');
            
            console.log('🎨 Pagination update - Total:', totalItems, 'PerPage:', temoignagesPerPage, 'TotalPages:', totalPages);
            
            if (totalItems <= temoignagesPerPage) {
                // Masquer la pagination s'il n'y a pas assez d'éléments
                paginationContainer.style.display = 'none';
                return;
            }
            
            // Afficher la pagination
            paginationContainer.style.display = 'block';
            
            // Mettre à jour les infos
            const startItem = (currentTemoignagesPage - 1) * temoignagesPerPage + 1;
            const endItem = Math.min(currentTemoignagesPage * temoignagesPerPage, totalItems);
            paginationInfo.textContent = `Affichage de ${startItem}-${endItem} sur ${totalItems} témoignages`;
            
            // Activer/désactiver les boutons précédent/suivant
            prevBtn.disabled = currentTemoignagesPage === 1;
            nextBtn.disabled = currentTemoignagesPage === totalPages;
            
            // Générer les numéros de page
            pageNumbers.innerHTML = '';
            const maxVisiblePages = 5;
            let startPage = Math.max(1, currentTemoignagesPage - Math.floor(maxVisiblePages / 2));
            let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);
            
            if (endPage - startPage < maxVisiblePages - 1) {
                startPage = Math.max(1, endPage - maxVisiblePages + 1);
            }
            
            // Bouton première page si nécessaire
            if (startPage > 1) {
                pageNumbers.innerHTML += `<button class="btn btn-outline-primary btn-sm" onclick="goToTemoignagesPage(1)">1</button>`;
                if (startPage > 2) {
                    pageNumbers.innerHTML += `<span style="padding: 0 5px;">...</span>`;
                }
            }
            
            // Numéros de page
            for (let i = startPage; i <= endPage; i++) {
                const isActive = i === currentTemoignagesPage;
                const btnClass = isActive ? 'btn-primary' : 'btn-outline-primary';
                pageNumbers.innerHTML += `<button class="btn ${btnClass} btn-sm" onclick="goToTemoignagesPage(${i})">${i}</button>`;
            }
            
            // Bouton dernière page si nécessaire
            if (endPage < totalPages) {
                if (endPage < totalPages - 1) {
                    pageNumbers.innerHTML += `<span style="padding: 0 5px;">...</span>`;
                }
                pageNumbers.innerHTML += `<button class="btn btn-outline-primary btn-sm" onclick="goToTemoignagesPage(${totalPages})">${totalPages}</button>`;
            }
        }

        function changeTemoignagesPage(direction) {
            const filtered = currentTemoignagesFilter === 'all' 
                ? window.allTemoignagesAdmin 
                : window.allTemoignagesAdmin.filter(t => t.status === currentTemoignagesFilter);
            
            const totalPages = Math.ceil(filtered.length / temoignagesPerPage);
            const newPage = currentTemoignagesPage + direction;
            
            if (newPage >= 1 && newPage <= totalPages) {
                currentTemoignagesPage = newPage;
                displayTemoignages(window.allTemoignagesAdmin, false);
            }
        }

        function goToTemoignagesPage(page) {
            currentTemoignagesPage = page;
            displayTemoignages(window.allTemoignagesAdmin, false);
        }

        // Exposer les fonctions de pagination globalement
        window.changeTemoignagesPage = changeTemoignagesPage;
        window.goToTemoignagesPage = goToTemoignagesPage;
    </script>
    
