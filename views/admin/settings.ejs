<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --telex-light-blue: #457B9D;
            --sidebar-width: 280px;
            --transition-speed: 0.3s;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            color: #334155;
        }
        
        /* Sidebar */
        .sidebar { 
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%); 
            color: white; 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }
        
        /* ── Sidebar header Option B ── */
        .sb-header { display:flex; align-items:center; justify-content:center; padding:18px 16px; border-bottom:1px solid rgba(255,255,255,.08); transition:background .2s; }
        .sb-header:hover { background: rgba(255,255,255,.04); }
        .sb-logo { height:52px; width:auto; display:block; flex-shrink:0; }
        .nav-section-label { font-size:.68rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:rgba(255,255,255,.28); padding:14px 10px 5px; }
        .sidebar-footer { padding:8px 10px 12px; border-top:1px solid rgba(255,255,255,.08); }
        .nav-link.logout { color:rgba(255,160,160,.7); }
        .nav-link.logout:hover { background:rgba(255,107,107,.1); color:#ff9e9e; }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .nav-item {
            margin-bottom: 8px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 14px 18px;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s;
            font-weight: 500;
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateX(5px);
        }
        
        .nav-link.active {
            background: rgba(230, 57, 70, 0.15);
            color: white;
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.2);
        }
        
        .nav-link i {
            width: 24px;
            font-size: 1.1rem;
            margin-right: 12px;
            text-align: center;
        }
        
        /* Main Content */
        .main-content { 
            margin-left: var(--sidebar-width); 
            padding: 30px;
            min-height: 100vh;
            animation: fadeIn 0.5s ease-out;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* ── Dash Header ── */
        .dash-header { background:linear-gradient(135deg,#1D3557 0%,#2d4f7a 100%); padding:16px 28px; display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; }
        .dash-header-left { display:flex; align-items:center; gap:14px; }
        .dash-header-logo { height:44px; width:auto; object-fit:contain; }
        .dash-header-title { font-size:1.15rem; font-weight:700; color:#fff; line-height:1.3; }
        .dash-header-sub { font-size:.8rem; color:rgba(255,255,255,.65); margin-top:2px; }
        .dash-header-right { display:flex; align-items:center; gap:10px; }
        .btn-dash-back { display:inline-flex; align-items:center; gap:7px; background:rgba(255,255,255,.12); color:#fff; border:1px solid rgba(255,255,255,.2); border-radius:8px; padding:7px 14px; font-size:.85rem; font-weight:500; text-decoration:none; transition:background .2s; }
        .btn-dash-back:hover { background:rgba(255,255,255,.22); color:#fff; }

        /* ── Content area ── */
        .settings-area { padding:28px 32px; }
        @media (max-width:576px) { .settings-area { padding:16px; } }

        /* ── Alerts ── */
        .alert { padding:14px 18px; border-radius:10px; margin-bottom:18px; border-left:4px solid; display:flex; align-items:flex-start; gap:12px; font-size:.9rem; }
        .alert-success { background:#f0fdf4; border-color:#10B981; color:#065f46; }
        .alert-warning { background:#fffbeb; border-color:#F59E0B; color:#78350f; }
        .alert i { margin-top:2px; }

        /* ── Section label ── */
        .section-label { font-size:.7rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#94a3b8; margin-bottom:14px; padding-left:2px; }

        /* ── Settings Tile Grid ── */
        .settings-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:32px; }
        @media (max-width:900px) { .settings-grid { grid-template-columns:repeat(2,1fr); } }
        @media (max-width:480px) { .settings-grid { grid-template-columns:repeat(1,1fr); } }

        .settings-tile {
            background:#fff;
            border-radius:14px;
            padding:22px 20px 20px;
            border:1.5px solid #e8ecf0;
            text-decoration:none;
            display:block;
            cursor:pointer;
            transition:box-shadow .2s, border-color .2s, transform .18s;
            position:relative;
            overflow:hidden;
        }
        .settings-tile:hover { box-shadow:0 6px 22px rgba(0,0,0,.1); border-color:#c8d2de; transform:translateY(-2px); }
        .settings-tile.disabled { opacity:.55; cursor:not-allowed; pointer-events:none; }

        .tile-icon-wrap {
            width:52px; height:52px;
            border-radius:12px;
            display:flex; align-items:center; justify-content:center;
            font-size:1.5rem;
            margin-bottom:16px;
        }
        .tile-icon-wrap.amber  { background:rgba(245,158,11,.13); }
        .tile-icon-wrap.purple { background:rgba(139,92,246,.13); }
        .tile-icon-wrap.slate  { background:rgba(100,116,139,.13); }
        .tile-icon-wrap.blue   { background:rgba(59,130,246,.13); }
        .tile-icon-wrap.green  { background:rgba(16,185,129,.13); }
        .tile-icon-wrap.red    { background:rgba(230,57,70,.13); }

        .tile-title { font-size:1rem; font-weight:700; color:#1e293b; margin-bottom:6px; }
        .tile-desc  { font-size:.82rem; color:#64748b; line-height:1.5; }

        /* ── System Info bar ── */
        .sysinfo-bar { background:#fff; border-radius:14px; border:1.5px solid #e8ecf0; padding:18px 22px; display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:24px; }
        @media (max-width:768px) { .sysinfo-bar { grid-template-columns:repeat(2,1fr); } }
        @media (max-width:400px) { .sysinfo-bar { grid-template-columns:repeat(2,1fr); gap:8px; } }
        .sysinfo-item { display:flex; align-items:center; gap:10px; }
        .sysinfo-icon { width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:.95rem; color:#fff; flex-shrink:0; }
        .sysinfo-icon.blue   { background:linear-gradient(135deg,#3B82F6,#1D4ED8); }
        .sysinfo-icon.purple { background:linear-gradient(135deg,#8B5CF6,#7C3AED); }
        .sysinfo-icon.green  { background:linear-gradient(135deg,#10B981,#047857); }
        .sysinfo-icon.teal   { background:linear-gradient(135deg,#06b6d4,#0891b2); }
        .sysinfo-label { font-size:.72rem; color:#94a3b8; font-weight:500; }
        .sysinfo-val   { font-size:.88rem; font-weight:700; color:#1e293b; }

        /* ── Page footer ── */
        .page-footer { text-align:center; padding:20px 0 10px; color:#94a3b8; font-size:.82rem; border-top:1px solid #e8ecf0; display:flex; flex-direction:column; align-items:center; gap:8px; }
        .footer-logo { height:22px; opacity:.6; }

        /* ── Responsive sidebar ── */
        @media (max-width: 992px) {
            .sidebar { width:70px; overflow:hidden; }
            .sb-header { padding:12px 0; }
            .sb-logo { height:32px; }
            .nav-section-label { display:none; }
            .nav-link span { display:none; }
            .nav-link { justify-content:center; padding:11px 0; }
            .sidebar-footer { padding:6px 4px 10px; }
            .main-content { margin-left:70px; }
        }
    
        /* ── Responsive mobile (<576px) ── */
        @media (max-width: 576px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform .3s ease;
                z-index: 1050;
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.45);
                z-index: 1040;
            }
            .sidebar-overlay.show { display: block; }
            .main-content { margin-left: 0 !important; }
            .mobile-menu-btn {
                display: flex !important;
            }
        }
        .mobile-menu-btn {
            display: none;
            position: fixed;
            top: 14px;
            left: 14px;
            z-index: 1060;
            background: var(--telex-blue, #1D3557);
            color: white;
            border: none;
            border-radius: 8px;
            width: 40px;
            height: 40px;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.25);
        }</style>
</head>
<body>
    <div id="sidebarOverlay" class="sidebar-overlay" onclick="closeSidebar()"></div>
    <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fas fa-bars"></i></button>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sb-header">
            <img src="/images/Telex.png" alt="Telex" class="sb-logo">
        </div>
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i><span>Dashboard</span>
                </a>
            </div>
            <div class="nav-section-label">Contenu</div>
            <div class="nav-item"><a href="/admin/about" class="nav-link"><i class="fas fa-info-circle"></i><span>À Propos</span></a></div>
            <div class="nav-item"><a href="/admin/news" class="nav-link"><i class="fas fa-newspaper"></i><span>Actualités</span></a></div>
            <div class="nav-item"><a href="/admin/programs" class="nav-link"><i class="fas fa-tv"></i><span>Programmes</span></a></div>
            <div class="nav-section-label">Communauté</div>
            <div class="nav-item"><a href="/admin/baume-de-la-foi" class="nav-link"><i class="fas fa-cross"></i><span>Baume de la Foi</span></a></div>
            <div class="nav-item"><a href="/admin/contacts" class="nav-link"><i class="fas fa-envelope"></i><span>Messages</span></a></div>
            <div class="nav-section-label">Médias</div>
            <div class="nav-item"><a href="/admin/gallery" class="nav-link"><i class="fas fa-images"></i><span>Galerie</span></a></div>
            <div class="nav-item"><a href="/admin/album" class="nav-link"><i class="fas fa-book"></i><span>Album</span></a></div>
            <div class="nav-item"><a href="/admin/footer" class="nav-link"><i class="fas fa-globe"></i><span>Footer</span></a></div>
        </nav>
        <div class="sidebar-footer">
            <div class="nav-item"><a href="/admin/settings" class="nav-link active"><i class="fas fa-cog"></i><span>Paramètres</span></a></div>
            <div class="nav-item"><a href="/admin/logout" class="nav-link logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a></div>
        </div>
    </div>
    
    <!-- Main Content -->
    <div class="main-content" style="padding:0;">

        <!-- Dash Header -->
        <div class="dash-header">
            <div class="dash-header-left">
                <img src="/images/Telex.png" alt="Telex" class="dash-header-logo">
                <div>
                    <div class="dash-header-title"><i class="fas fa-cog me-2" style="color:#A8DADC;font-size:.95rem;"></i>Param&egrave;tres</div>
                    <div class="dash-header-sub">Configurez votre application Telex</div>
                </div>
            </div>
            <div class="dash-header-right">
                <a href="/admin/dashboard" class="btn-dash-back"><i class="fas fa-arrow-left"></i>Dashboard</a>
            </div>
        </div>

        <div class="settings-area">

            <!-- Flash messages -->
            <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success"><i class="fas fa-check-circle"></i><span><%= success_msg %></span></div>
            <% } %>
            <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-warning"><i class="fas fa-exclamation-triangle"></i><span><%= error_msg %></span></div>
            <% } %>

            <!-- Infos système -->
            <div class="sysinfo-bar">
                <div class="sysinfo-item">
                    <div class="sysinfo-icon blue"><i class="fas fa-code-branch"></i></div>
                    <div><div class="sysinfo-label">Version</div><div class="sysinfo-val">2.0.1</div></div>
                </div>
                <div class="sysinfo-item">
                    <div class="sysinfo-icon purple"><i class="fas fa-user-shield"></i></div>
                    <div><div class="sysinfo-label">Administrateur</div><div class="sysinfo-val"><%= user.username %></div></div>
                </div>
                <div class="sysinfo-item">
                    <div class="sysinfo-icon green"><i class="fas fa-calendar-alt"></i></div>
                    <div><div class="sysinfo-label">Date</div><div class="sysinfo-val"><%= new Date().toLocaleDateString('fr-FR') %></div></div>
                </div>
                <div class="sysinfo-item">
                    <div class="sysinfo-icon teal"><i class="fas fa-check-circle"></i></div>
                    <div><div class="sysinfo-label">Statut</div><div class="sysinfo-val">Op&eacute;rationnel</div></div>
                </div>
            </div>

            <!-- Section APPLICATION -->
            <div class="section-label">Application</div>
            <div class="settings-grid">

                <!-- Profil & Logo -->
                <a href="/admin/about" class="settings-tile">
                    <div class="tile-icon-wrap amber">
                        <i class="fas fa-tag" style="color:#F59E0B;"></i>
                    </div>
                    <div class="tile-title">Profil &amp; Logo</div>
                    <div class="tile-desc">Changer le nom et le logo affich&eacute;s dans la barre lat&eacute;rale</div>
                </a>

                <!-- Comptes & Accès -->
                <% if (user.role === 'superadmin') { %>
                <a href="/admin/users" class="settings-tile">
                <% } else { %>
                <div class="settings-tile disabled">
                <% } %>
                    <div class="tile-icon-wrap purple">
                        <i class="fas fa-users" style="color:#8B5CF6;"></i>
                    </div>
                    <div class="tile-title">Comptes &amp; Acc&egrave;s</div>
                    <div class="tile-desc">G&eacute;rer les utilisateurs, les r&ocirc;les et votre mot de passe</div>
                <% if (user.role === 'superadmin') { %>
                </a>
                <% } else { %>
                </div>
                <% } %>

                <!-- Footer -->
                <a href="/admin/footer" class="settings-tile">
                    <div class="tile-icon-wrap green">
                        <i class="fas fa-globe" style="color:#10B981;"></i>
                    </div>
                    <div class="tile-title">Footer du site</div>
                    <div class="tile-desc">Modifier les liens et informations du pied de page</div>
                </a>

            </div>

            <!-- Footer page -->
            <div class="page-footer">
                <img src="/images/Telex.png" alt="TELEX" class="footer-logo">
                <div>Telex Param&egrave;tres &bull; Version 2.0.1 &bull; <%= new Date().getFullYear() %></div>
                <div><i class="fas fa-clock me-1"></i><span id="current-time"></span></div>
            </div>

        </div><!-- /.settings-area -->
    </div>
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            function updateTime() {
                const el = document.getElementById('current-time');
                if (el) el.textContent = new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
            }
            updateTime();
            setInterval(updateTime, 60000);
        });
    </script>

    <script>
        function openSidebar() {
            document.querySelector('.sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('show');
        }
        function closeSidebar() {
            document.querySelector('.sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }
    </script></body>
</html>