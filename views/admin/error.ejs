<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Admin TELEX</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #1D3557 0%, #457B9D 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            color: white;
        }
        .error-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 3rem;
            max-width: 500px;
            margin: 0 auto;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .error-code {
            font-size: 4rem;
            font-weight: bold;
            color: #E63946;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="error-card">
            <div class="error-code"><%= code %></div>
            <h1 class="h3 mt-3"><%= title %></h1>
            <p class="mt-3"><%= message %></p>
            
            <% if (typeof details !== 'undefined' && details) { %>
            <div class="alert alert-warning mt-3">
                <strong>Détails:</strong><br>
                <%= details %>
            </div>
            <% } %>
            
            <% if (typeof stack !== 'undefined' && stack) { %>
            <details class="mt-3">
                <summary class="btn btn-outline-light btn-sm">Voir les détails techniques</summary>
                <pre class="text-start mt-2 p-2 bg-dark text-light rounded" style="font-size: 0.8rem; max-height: 200px; overflow-y: auto;"><%= stack %></pre>
            </details>
            <% } %>
            
            <div class="mt-4 pt-3 border-top border-light">
                <a href="/admin/dashboard" class="btn btn-light me-2">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a href="/" class="btn btn-outline-light">
                    <i class="fas fa-home"></i> Site
                </a>
            </div>
        </div>
    </div>
</body>
</html>