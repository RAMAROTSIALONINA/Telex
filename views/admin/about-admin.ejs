<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - À Propos | Telex</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --telex-light-blue: #457B9D;
            --sidebar-width: 280px;
            --transition-speed: 0.3s;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
            color: #334155;
        }
        
        /* Debug Info Styles */
        .debug-info {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px;
            margin: 20px 0;
            border-radius: 10px;
            font-family: 'Courier New', monospace;
            font-size: 13px;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        }
        
        .debug-info h4 {
            margin: 0 0 10px 0;
            font-size: 16px;
            font-weight: 600;
        }
        
        .debug-grid {
            display: grid;
            grid-template-columns: 200px 1fr;
            gap: 8px;
            align-items: center;
        }
        
        .debug-item strong {
            color: #ffd700;
            font-weight: 600;
        }
        
        .debug-value {
            padding: 4px 8px;
            border-radius: 4px;
            font-weight: 500;
        }
        
        .debug-success {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
            border: 1px solid #28a745;
        }
        
        .debug-warning {
            background: rgba(255, 193, 7, 0.2);
            color: #ffc107;
            border: 1px solid #ffc107;
        }
        
        .debug-error {
            background: rgba(220, 53, 69, 0.2);
            color: #dc3545;
            border: 1px solid #dc3545;
        }
        
        .debug-missing {
            margin-top: 10px;
            padding: 10px;
            background: rgba(220, 53, 69, 0.1);
            border: 1px solid #dc3545;
            border-radius: 4px;
            font-size: 12px;
        }
        
        /* Sidebar améliorée */
        html body .sidebar { 
            background: linear-gradient(180deg, #1e3a8a 0%, #1e40af 100%) !important; 
            color: white !important; 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
        }
        
        .sidebar:hover {
            box-shadow: 8px 0 25px rgba(0, 0, 0, 0.15);
        }
        
        .sidebar-brand {
            padding: 25px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(0, 0, 0, 0.1);
            position: relative;
            overflow: hidden;
        }
        
        .sidebar-logo {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        
        .sidebar-logo img {
            max-width: 120px;
            height: auto;
            margin-bottom: 15px;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
            transition: transform 0.3s ease;
        }
        
        .sidebar-logo img:hover {
            transform: scale(1.05);
        }
        
        /* Responsive pour mobile */
        @media (max-width: 768px) {
            .sidebar-logo img {
                max-width: 80px;
                margin-bottom: 10px;
            }
            
            .sidebar-logo .brand-text {
                font-size: 1.2rem;
            }
        }
        
        @media (max-width: 576px) {
            .sidebar-logo img {
                max-width: 60px;
                margin-bottom: 8px;
            }
            
            .sidebar-logo .brand-text {
                font-size: 1rem;
            }
        }
        
        .sidebar-logo .brand-text {
            color: white;
            font-weight: 700;
            font-size: 1.8rem;
            margin-bottom: 5px;
            letter-spacing: 0.5px;
        }
        
        .sidebar-logo .version {
            font-size: 0.85rem;
            opacity: 0.8;
            font-weight: 300;
            color: var(--telex-light);
        }
        
        .user-info {
            padding: 20px;
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.05);
            margin: 15px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all var(--transition-speed);
        }
        
        .user-info:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }
        
        .user-avatar {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.2rem;
            margin-right: 15px;
            box-shadow: 0 4px 10px rgba(230, 57, 70, 0.3);
        }
        
        .user-details h5 {
            font-weight: 600;
            margin-bottom: 3px;
            font-size: 1rem;
        }
        
        .user-details small {
            opacity: 0.8;
            font-size: 0.8rem;
            display: block;
        }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .sidebar-nav::-webkit-scrollbar {
            width: 5px;
        }
        
        .sidebar-nav::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 10px;
        }
        
        .nav-item {
            margin-bottom: 8px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 16px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-weight: 500;
            position: relative;
            overflow: hidden;
            border: 1px solid transparent;
            backdrop-filter: blur(10px);
        }
        
        .nav-link::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 4px;
            background: linear-gradient(180deg, var(--telex-red), #ff6b6b);
            transform: translateX(-100%);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 0 2px 2px 0;
        }
        
        .nav-link::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), transparent);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.15);
            color: white;
            transform: translateX(8px) scale(1.02);
            border-color: rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }
        
        .nav-link:hover::before {
            transform: translateX(0);
        }
        
        .nav-link:hover::after {
            opacity: 1;
        }
        
        .nav-link.active {
            background: linear-gradient(135deg, rgba(230, 57, 70, 0.2), rgba(230, 57, 70, 0.1));
            color: white;
            transform: translateX(5px);
            border-color: rgba(230, 57, 70, 0.3);
            box-shadow: 0 8px 30px rgba(230, 57, 70, 0.25);
            font-weight: 600;
        }
        
        .nav-link.active::before {
            transform: translateX(0);
            background: linear-gradient(180deg, var(--telex-red), #ff6b6b);
            box-shadow: 0 0 10px rgba(230, 57, 70, 0.5);
        }
        
        .nav-link.active::after {
            opacity: 1;
            background: linear-gradient(135deg, rgba(230, 57, 70, 0.1), transparent);
        }
        
        .nav-link i {
            width: 28px;
            font-size: 1.2rem;
            margin-right: 15px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            z-index: 2;
        }
        
        .nav-link:hover i {
            transform: scale(1.1);
            color: white;
        }
        
        .nav-link.active i {
            color: white;
            transform: scale(1.1);
        }
        
        .nav-link.logout {
            color: #ff9e9e;
            margin-top: 20px;
        }
        
        .nav-link.logout:hover {
            background: rgba(255, 107, 107, 0.1);
            color: #ff6b6b;
        }
        
        /* Main Content */
        html body .main-content { 
            margin-left: var(--sidebar-width) !important; 
            padding: 30px;
            min-height: 100vh;
            animation: fadeIn 0.5s ease-out;
            position: relative;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .admin-header {
            background: linear-gradient(135deg, #3498db 0%, #5dade2 100%);
            color: white;
            padding: 2rem 0;
            margin-bottom: 2rem;
        }
        
        .admin-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
            padding: 2rem;
            margin-bottom: 2rem;
            border-left: 4px solid #3498db;
        }
        
        .admin-card h3 {
            color: #3498db;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .admin-card h3 i {
            font-size: 1.2rem;
        }
        
        .form-label {
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 0.5rem;
        }
        
        .form-control, .form-select {
            border-radius: 8px;
            border: 2px solid #e1e8ed;
            padding: 0.75rem;
            transition: all 0.3s ease;
        }
        
        .form-control:focus, .form-select:focus {
            border-color: #3498db;
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.25);
        }
        
        .btn.btn-admin {
            background: #3498db !important;
            color: white !important;
            border: none !important;
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .btn.btn-admin:hover {
            background: #2980b9 !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(52, 152, 219, 0.3);
        }
        
        .team-member-card {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 1rem;
            border: 2px dashed #dee2e6;
        }
        
        .team-member-card h5 {
            color: #2c3e50;
            margin-bottom: 1rem;
        }
        
        .stat-input-group {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }
        
        .stat-input-group input {
            flex: 1;
        }
        
        .stat-input-group .input-group-text {
            background: #3498db;
            color: white;
            border: none;
            padding: 0.75rem;
            border-radius: 8px;
        }
        
        .preview-section {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 1.5rem;
            margin-top: 2rem;
            border: 2px solid #e1e8ed;
        }
        
        .preview-section h4 {
            color: #3498db;
            margin-bottom: 1rem;
        }
        
        .image-preview {
            max-width: 200px;
            max-height: 150px;
            object-fit: cover;
            border-radius: 8px;
            margin-top: 0.5rem;
        }
        
        .navbar-admin {
            background: #051d40 !important;
        }
        
        .navbar-admin .navbar-brand {
            color: #3AAFA9 !important;
        }
        
        .alert-custom {
            border-radius: 12px;
        }
    </style>
</head>
<body>
    <!-- Debug Info -->
    <% if (typeof debugInfo !== 'undefined') { %>
        <%= debugInfo %>
    <% } %>
    <!-- Bouton de retour au dashboard -->
    <div style="position: fixed; top: 20px; left: 20px; z-index: 1000;">
        <a href="/admin/dashboard" class="btn btn-admin btn-sm">
            <i class="fas fa-arrow-left me-2"></i>Retour Dashboard
        </a>
    </div>
    

    <!-- Main Content -->
    <div class="main-content" style="margin-left: 0 !important; padding: 20px;">
        <!-- Header Admin -->
        <div class="admin-header">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h1 class="display-4 fw-bold mb-3">
                            <i class="fas fa-info-circle me-3"></i>Administration - À Propos
                        </h1>
                        <p class="lead mb-0">Gérez le contenu de la page "À Propos" de Telex</p>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <a href="/about" target="_blank" class="btn btn-admin btn-lg">
                            <i class="fas fa-eye me-2"></i>Voir la page
                        </a>
                    </div>
                </div>
            </div>
        </div>

    <!-- Contenu Principal -->
    <div class="container">
        <div class="row">
            <div class="col-12">
                <!-- Alert de succès -->
                <div class="alert alert-success alert-custom d-none" id="successAlert">
                    <i class="fas fa-check-circle me-2"></i>
                    <strong>Succès !</strong> Les modifications ont été enregistrées.
                </div>

                <!-- Bouton de sauvegarde principal -->
                <div class="text-center mb-4">
                    <button type="button" class="btn btn-admin btn-lg" onclick="saveAllData()">
                        <i class="fas fa-save me-2"></i>Sauvegarder toutes les modifications
                    </button>
                </div>

                <!-- Section Hero -->
                <div class="admin-card">
                    <h3><i class="fas fa-image"></i> Section Hero</h3>
                    <form id="heroForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Titre Principal</label>
                                    <input type="text" class="form-control" name="hero_title" id="heroTitle" value="<%= about.hero_title || 'À propos de Telex' %>">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Sous-titre</label>
                                    <input type="text" class="form-control" name="hero_subtitle" id="heroSubtitle" value="<%= about.hero_subtitle || 'Découvrez notre histoire, notre équipe et notre vision' %>">
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Texte d'introduction</label>
                            <textarea class="form-control" name="hero_intro" id="heroIntro" rows="4"><%= about.hero_intro || 'Fondée par des étudiants passionnés, Telex est bien plus qu\'une télévision étudiante. C\'est un laboratoire d\'innovation, une école de talents et un média numérique pour la jeunesse engagée.' %></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Image Hero</label>
                            <input type="text" class="form-control" name="hero_image" id="heroImage" value="<%= about.hero_image || '/images/camera.png' %>">
                        </div>
                    </form>
                </div>

                <!-- Section Notre Histoire -->
                <div class="admin-card">
                    <h3><i class="fas fa-history"></i> Notre Histoire</h3>
                    <form id="historyForm">
                        <div class="mb-3">
                            <label class="form-label">Titre de la section</label>
                            <input type="text" class="form-control" id="historyTitle" value="<%= about.history_title || 'Notre Histoire' %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Paragraphe 1</label>
                            <textarea class="form-control" id="historyParagraph1" rows="4"><%= about.history_paragraph1 || 'Telex est né en 2024 de la passion commune d\'un groupe d\'étudiants déterminés à créer une télévision étudiante et un média numérique à leur image : innovants, indépendants et engagés. En partant d\'un simple projet d\'association, nous avons construit pas à pas une véritable chaîne de télévision étudiante reconnue aujourd\'hui comme la référence en matière d\'audiovisuel étudiant.' %></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Paragraphe 2</label>
                            <textarea class="form-control" id="historyParagraph2" rows="4"><%= about.history_paragraph2 || 'Notre aventure a commencé avec une petite équipe de 10 passionnés et un studio improvisé. Aujourd\'hui, nous comptons plus de 50 membres actifs, un studio professionnel et une audience grandissante. Chaque jour, nous repoussons les limites de la créativité étudiante pour offrir des contenus de qualité.' %></textarea>
                        </div>
                    </form>
                </div>

                <!-- Section Équipe -->
                <div class="admin-card">
                    <h3><i class="fas fa-users"></i> Notre Équipe</h3>
                    <form id="teamForm">
                        <div class="mb-3">
                            <label class="form-label">Titre de la section</label>
                            <input type="text" class="form-control" id="teamTitle" value="Notre Équipe">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Texte d'introduction</label>
                            <textarea class="form-control" id="teamIntro" rows="3">Notre force réside dans la diversité de nos profils. Journalistes, techniciens, monteurs, graphistes, communicants - tous étudiants et tous animés par la même passion pour l'audiovisuel. Chaque membre contribue avec ses compétences uniques pour créer des contenus exceptionnels.</textarea>
                        </div>
                        
                        <h5 class="mt-4 mb-3">Membres de l'équipe</h5>
                        
                        <!-- Rédaction -->
                        <div class="team-member-card">
                            <h5><i class="fas fa-newspaper me-2"></i>Rédaction</h5>
                            <input type="hidden" id="redactionTitle" value="Rédaction">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Nombre de membres</label>
                                        <input type="text" class="form-control" id="redactionCount" value="2 journalistes et reporters">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Image</label>
                                        <input type="text" class="form-control" id="redactionImage" value="/images/TELEX INTEGRATION.png">
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" id="redactionDescription" rows="3">Notre équipe éditoriale travaille sur l'écriture, les reportages et la vérification des informations.</textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Compétences (séparées par des virgules)</label>
                                <input type="text" class="form-control" id="redactionSkills" value="Journalisme, Reportage, Édition">
                            </div>
                        </div>

                        <!-- Technique -->
                        <div class="team-member-card">
                            <h5><i class="fas fa-video me-2"></i>Technique</h5>
                            <input type="hidden" id="techniqueTitle" value="Technique">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Nombre de membres</label>
                                        <input type="text" class="form-control" id="techniqueCount" value="2 techniciens audiovisuels">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Image</label>
                                        <input type="text" class="form-control" id="techniqueImage" value="/images/femme telex.png">
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" id="techniqueDescription" rows="3">Spécialistes de la prise de vue, du son et de l'éclairage pour une production de qualité professionnelle.</textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Compétences (séparées par des virgules)</label>
                                <input type="text" class="form-control" id="techniqueSkills" value="Caméra, Son, Éclairage">
                            </div>
                        </div>

                        <!-- Post-production -->
                        <div class="team-member-card">
                            <h5><i class="fas fa-edit me-2"></i>Post-production</h5>
                            <input type="hidden" id="postproductionTitle" value="Post-production">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Nombre de membres</label>
                                        <input type="text" class="form-control" id="postproductionCount" value="3 monteurs vidéo">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Image</label>
                                        <input type="text" class="form-control" id="postproductionImage" value="/images/ordi_telex.png">
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" id="postproductionDescription" rows="3">Experts en montage, étalonnage et effets spéciaux pour donner vie à nos contenus audiovisuels.</textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Compétences (séparées par des virgules)</label>
                                <input type="text" class="form-control" id="postproductionSkills" value="Montage, Étalonnage, Motion Design">
                            </div>
                        </div>

                        <!-- Communication -->
                        <div class="team-member-card">
                            <h5><i class="fas fa-bullhorn me-2"></i>Communication</h5>
                            <input type="hidden" id="communicationTitle" value="Communication">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Nombre de membres</label>
                                        <input type="text" class="form-control" id="communicationCount" value="1 chargés de communication">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Image</label>
                                        <input type="text" class="form-control" id="communicationImage" value="/images/Présentation du Telex.png">
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" id="communicationDescription" rows="3">Gestion des réseaux sociaux, relations presse et stratégie de diffusion pour maximiser notre audience.</textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Compétences (séparées par des virgules)</label>
                                <input type="text" class="form-control" id="communicationSkills" value="Réseaux sociaux, Stratégie, Community">
                            </div>
                        </div>

                    </form>
                </div>

                <!-- Section Chiffres -->
                <div class="admin-card">
                    <h3><i class="fas fa-chart-line"></i> Nos Chiffres</h3>
                    <form id="statsForm">
                        <div class="mb-3">
                            <label class="form-label">Titre de la section</label>
                            <input type="text" class="form-control" id="statsTitle" value="Nos Chiffres">
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="stat-input-group">
                                    <input type="text" class="form-control" id="stat1Number" value="50+">
                                    <span class="input-group-text">Membres actifs</span>
                                </div>
                                <div class="stat-input-group">
                                    <input type="text" class="form-control" id="stat2Number" value="200+">
                                    <span class="input-group-text">Heures de production</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="stat-input-group">
                                    <input type="text" class="form-control" id="stat3Number" value="15K+">
                                    <span class="input-group-text">Vues mensuelles</span>
                                </div>
                                <div class="stat-input-group">
                                    <input type="text" class="form-control" id="stat4Number" value="4">
                                    <span class="input-group-text">Émissions régulières</span>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>


                <!-- Section Preview -->
                <div class="preview-section">
                    <h4><i class="fas fa-eye me-2"></i>Aperçu des modifications</h4>
                    <div id="previewContent">
                        <p class="text-muted">Les modifications apparaîtront ici après avoir enregistré les sections.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    
    <script>
        // Fonction pour afficher l'alerte de succès
        function showSuccessAlert(message) {
            const alert = document.getElementById('successAlert');
            alert.innerHTML = `<i class="fas fa-check-circle me-2"></i><strong>Succès !</strong> ${message}`;
            alert.classList.remove('d-none');
            
            setTimeout(() => {
                alert.classList.add('d-none');
            }, 3000);
        }

        // Fonction pour sauvegarder toutes les données sur le serveur
        async function saveAllData() {
            try {
                console.log('🚀 Début de la sauvegarde...');
                
                // Vérifier que les éléments existent avant de les utiliser
                const getElementValue = (id, defaultValue = '') => {
                    const element = document.getElementById(id);
                    return element ? element.value : defaultValue;
                };
                
                // Collecter toutes les données des formulaires
                const formData = new FormData();
                
                // Données Hero
                formData.append('hero_title', getElementValue('heroTitle', 'À propos de Telex'));
                formData.append('hero_subtitle', getElementValue('heroSubtitle', 'Découvrez notre histoire, notre équipe et notre vision'));
                formData.append('hero_intro', getElementValue('heroIntro', 'Fondée par des étudiants passionnés...'));
                formData.append('hero_image', getElementValue('heroImage', '/images/camera.png'));
                
                // Données Histoire
                formData.append('history_title', getElementValue('historyTitle', 'Notre Histoire'));
                formData.append('history_paragraph1', getElementValue('historyParagraph1', 'Telex est né en 2024...'));
                formData.append('history_paragraph2', getElementValue('historyParagraph2', 'Notre aventure a commencé...'));
                
                // Données Équipe
                formData.append('team_title', getElementValue('teamTitle', 'Notre Équipe'));
                formData.append('team_intro', getElementValue('teamIntro', 'Notre force réside dans la diversité...'));
                formData.append('team_redaction_title', getElementValue('redactionTitle', 'Rédaction'));
                formData.append('team_redaction_count', getElementValue('redactionCount', '2 journalistes et reporters'));
                formData.append('team_redaction_image', getElementValue('redactionImage', '/images/TELEX INTEGRATION.png'));
                formData.append('team_redaction_description', getElementValue('redactionDescription', 'Notre équipe éditoriale travaille...'));
                formData.append('team_redaction_skills', getElementValue('redactionSkills', 'Journalisme, Reportage, Édition'));
                formData.append('team_technique_title', getElementValue('techniqueTitle', 'Technique'));
                formData.append('team_technique_count', getElementValue('techniqueCount', '2 techniciens audiovisuels'));
                formData.append('team_technique_image', getElementValue('techniqueImage', '/images/femme telex.png'));
                formData.append('team_technique_description', getElementValue('techniqueDescription', 'Spécialistes de la prise de vue...'));
                formData.append('team_technique_skills', getElementValue('techniqueSkills', 'Caméra, Son, Éclairage'));
                formData.append('team_postproduction_title', getElementValue('postproductionTitle', 'Post-production'));
                formData.append('team_postproduction_count', getElementValue('postproductionCount', '3 monteurs vidéo'));
                formData.append('team_postproduction_image', getElementValue('postproductionImage', '/images/ordi_telex.png'));
                formData.append('team_postproduction_description', getElementValue('postproductionDescription', 'Experts en montage...'));
                formData.append('team_postproduction_skills', getElementValue('postproductionSkills', 'Montage, Étalonnage, Motion Design'));
                formData.append('team_communication_title', getElementValue('communicationTitle', 'Communication'));
                formData.append('team_communication_count', getElementValue('communicationCount', '1 chargés de communication'));
                formData.append('team_communication_image', getElementValue('communicationImage', '/images/Présentation du Telex.png'));
                formData.append('team_communication_description', getElementValue('communicationDescription', 'Gestion des réseaux sociaux...'));
                formData.append('team_communication_skills', getElementValue('communicationSkills', 'Réseaux sociaux, Stratégie, Community'));
                
                // Données Chiffres
                formData.append('stats_title', getElementValue('statsTitle', 'Nos Chiffres'));
                formData.append('stats_members_count', getElementValue('stat1Number', '50+'));
                formData.append('stats_hours_count', getElementValue('stat2Number', '200+'));
                formData.append('stats_views_count', getElementValue('stat3Number', '15K+'));
                formData.append('stats_programs_count', getElementValue('stat4Number', '4'));

                console.log('📤 Envoi des données au serveur...');

                // Envoyer les données au serveur
                const response = await fetch('/admin/about', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                console.log('📥 Réponse du serveur:', result);

                if (result.success) {
                    showSuccessAlert('Toutes les modifications ont été enregistrées avec succès !');
                } else {
                    showErrorAlert('Erreur lors de la sauvegarde: ' + result.message);
                }
            } catch (error) {
                console.error('❌ Erreur lors de la sauvegarde:', error);
                showErrorAlert('Erreur lors de la sauvegarde des données: ' + error.message);
            }
        }

        // Fonction pour afficher une alerte de succès
        function showSuccessAlert(message) {
            const alert = document.getElementById('successAlert');
            if (alert) {
                alert.querySelector('strong').textContent = 'Succès !';
                alert.querySelector('i').nextSibling.textContent = ' ' + message;
                alert.classList.remove('d-none');
                
                setTimeout(() => {
                    alert.classList.add('d-none');
                }, 5000);
            }
        }

        // Fonction pour afficher une alerte d'erreur
        function showErrorAlert(message) {
            const alert = document.getElementById('successAlert');
            if (alert) {
                alert.className = 'alert alert-danger alert-custom';
                alert.querySelector('strong').textContent = 'Erreur !';
                alert.querySelector('i').nextSibling.textContent = ' ' + message;
                alert.classList.remove('d-none');
                
                setTimeout(() => {
                    alert.classList.add('d-none');
                    alert.className = 'alert alert-success alert-custom d-none';
                }, 5000);
            }
        }
    </script>
</body>
</html>
