<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - À Propos | Telex</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --telex-light-blue: #457B9D;
            --sidebar-width: 280px;
            --transition-speed: 0.3s;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
            color: #334155;
        }
        
        /* ── Dash Header ── */
        .dash-header { background:linear-gradient(135deg,#1D3557 0%,#2d4f7a 100%); padding:16px 28px; display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; }
        .dash-header-left { display:flex; align-items:center; gap:14px; }
        .dash-header-logo { height:44px; width:auto; object-fit:contain; }
        .dash-header-title { font-size:1.15rem; font-weight:700; color:#fff; line-height:1.3; }
        .dash-header-sub { font-size:.8rem; color:rgba(255,255,255,.65); margin-top:2px; }
        .dash-header-right { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
        .btn-dash-back { display:inline-flex; align-items:center; gap:7px; background:rgba(255,255,255,.12); color:#fff; border:1px solid rgba(255,255,255,.2); border-radius:8px; padding:7px 14px; font-size:.85rem; font-weight:500; text-decoration:none; transition:background .2s; }
        .btn-dash-back:hover { background:rgba(255,255,255,.22); color:#fff; }
        .btn-dash-view { display:inline-flex; align-items:center; gap:7px; background:#10B981; color:#fff; border:none; border-radius:8px; padding:7px 14px; font-size:.85rem; font-weight:600; text-decoration:none; transition:background .2s; }
        .btn-dash-view:hover { background:#059669; color:#fff; }

        /* ── Content Area ── */
        .content-area { padding:24px 28px; }
        @media (max-width:576px) { .content-area { padding:14px; } }

        /* ── Alert ── */
        .flash-alert { padding:13px 18px; border-radius:10px; margin-bottom:18px; display:flex; align-items:center; gap:10px; font-size:.9rem; border-left:4px solid; }
        .flash-success { background:#f0fdf4; border-color:#10B981; color:#065f46; }
        .flash-error   { background:#fef2f2; border-color:#EF4444; color:#7f1d1d; }

        /* ── Save bar ── */
        .save-bar { background:#fff; border:1.5px solid #e2e8f0; border-radius:12px; padding:14px 20px; margin-bottom:20px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; }
        .save-bar-info { font-size:.85rem; color:#64748b; }
        .btn-save { background:linear-gradient(135deg,#1D3557,#457B9D); color:#fff; border:none; border-radius:8px; padding:9px 22px; font-weight:600; font-size:.9rem; cursor:pointer; display:inline-flex; align-items:center; gap:8px; transition:all .2s; }
        .btn-save:hover { transform:translateY(-1px); box-shadow:0 4px 14px rgba(29,53,87,.3); }

        /* ── Form Cards ── */
        .form-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.07); border:1px solid #e2e8f0; margin-bottom:20px; overflow:hidden; }
        .form-card-header { display:flex; align-items:center; gap:14px; padding:16px 22px 14px; border-bottom:1px solid #f1f5f9; background:#fafbfc; }
        .form-card-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; }
        .form-card-title { font-size:.96rem; font-weight:700; color:#1e293b; }
        .form-card-sub { font-size:.77rem; color:#64748b; margin-top:2px; }
        .form-card-body { padding:20px 22px; }
        .form-card-body .mb-3 { margin-bottom:16px !important; }

        /* ── Team Member Cards ── */
        .team-card { background:#f8fafc; border-radius:10px; padding:18px; margin-bottom:14px; border:1.5px solid #e2e8f0; }
        .team-card-header { display:flex; align-items:center; gap:10px; margin-bottom:14px; padding-bottom:10px; border-bottom:1px solid #e2e8f0; }
        .team-card-header i { width:32px; height:32px; border-radius:8px; background:linear-gradient(135deg,#1D3557,#457B9D); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.85rem; flex-shrink:0; }
        .team-card-title { font-weight:700; color:#1e293b; font-size:.9rem; }

        /* ── Stat inputs ── */
        .stat-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
        @media (max-width:576px) { .stat-row { grid-template-columns:1fr; } }
        .stat-item { background:#f8fafc; border-radius:10px; padding:14px 16px; border:1.5px solid #e2e8f0; }
        .stat-item label { font-size:.75rem; font-weight:600; color:#64748b; text-transform:uppercase; letter-spacing:.05em; margin-bottom:6px; display:block; }
        .stat-item input { width:100%; border:none; background:transparent; font-size:1.3rem; font-weight:700; color:#1D3557; outline:none; }

        /* ── Form controls ── */
        .form-label { font-weight:600; color:#374151; font-size:.85rem; margin-bottom:5px; }
        .form-control, .form-select { border:1.5px solid #e2e8f0; border-radius:8px; padding:9px 12px; font-size:.9rem; background:#fff; transition:border-color .2s, box-shadow .2s; }
        .form-control:focus, .form-select:focus { border-color:#457B9D; box-shadow:0 0 0 3px rgba(69,123,157,.12); outline:none; }
        textarea.form-control { resize:vertical; min-height:100px; }
        
        /* Sidebar */
        .sidebar {
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%);
            color: white;
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }
        
        /* ── Sidebar header Option B ── */
        .sb-header { display:flex; align-items:center; justify-content:center; padding:18px 16px; border-bottom:1px solid rgba(255,255,255,.08); transition:background .2s; }
        .sb-header:hover { background: rgba(255,255,255,.04); }
        .sb-logo { height:52px; width:auto; display:block; flex-shrink:0; }
        .nav-section-label { font-size:.68rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:rgba(255,255,255,.28); padding:14px 10px 5px; }
        .sidebar-footer { padding:8px 10px 12px; border-top:1px solid rgba(255,255,255,.08); }
        .nav-link.logout { color:rgba(255,160,160,.7); }
        .nav-link.logout:hover { background:rgba(255,107,107,.1); color:#ff9e9e; }

        @media (max-width: 992px) {
            .sidebar { width: 70px; overflow: hidden; }
            .sb-header { padding:12px 0; }
            .sb-logo { height:32px; }
            .nav-section-label { display:none; }
            .nav-link span { display:none; }
            .nav-link { justify-content:center; padding:11px 0; }
            .sidebar-footer { padding:6px 4px 10px; }
            .main-content { margin-left: 70px; }
        }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .sidebar-nav::-webkit-scrollbar {
            width: 5px;
        }
        
        .sidebar-nav::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 10px;
        }
        
        .nav-item {
            margin-bottom: 8px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 14px 18px;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s;
            font-weight: 500;
            position: relative;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateX(5px);
        }

        .nav-link.active {
            background: rgba(230, 57, 70, 0.15);
            color: white;
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.2);
        }

        .nav-link i {
            width: 24px;
            font-size: 1.1rem;
            margin-right: 12px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            z-index: 2;
        }
        
        .nav-link:hover i {
            transform: scale(1.1);
            color: white;
        }
        
        .nav-link.active i {
            color: white;
            transform: scale(1.1);
        }
        
        .nav-link.logout {
            color: #ff9e9e;
            margin-top: 20px;
        }
        
        .nav-link.logout:hover {
            background: rgba(255, 107, 107, 0.1);
            color: #ff6b6b;
        }
        
        /* Main Content */
        .main-content { margin-left:var(--sidebar-width); min-height:100vh; padding:0; }
    
        /* ── Responsive mobile (<576px) ── */
        @media (max-width: 576px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform .3s ease;
                z-index: 1050;
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.45);
                z-index: 1040;
            }
            .sidebar-overlay.show { display: block; }
            .main-content { margin-left: 0 !important; }
            .mobile-menu-btn {
                display: flex !important;
            }
        }
        .mobile-menu-btn {
            display: none;
            position: fixed;
            top: 14px;
            left: 14px;
            z-index: 1060;
            background: var(--telex-blue, #1D3557);
            color: white;
            border: none;
            border-radius: 8px;
            width: 40px;
            height: 40px;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.25);
        }</style>
</head>
<body>
    <div id="sidebarOverlay" class="sidebar-overlay" onclick="closeSidebar()"></div>
    <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fas fa-bars"></i></button>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sb-header">
            <img src="/images/Telex.png" alt="Telex" class="sb-logo">
        </div>
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i><span>Dashboard</span>
                </a>
            </div>
            <div class="nav-section-label">Contenu</div>
            <div class="nav-item"><a href="/admin/news" class="nav-link"><i class="fas fa-newspaper"></i><span>Actualités</span></a></div>
            <div class="nav-item"><a href="/admin/programs" class="nav-link"><i class="fas fa-tv"></i><span>Programmes</span></a></div>
            <div class="nav-section-label">Communauté</div>
            <div class="nav-item"><a href="/admin/baume-de-la-foi" class="nav-link"><i class="fas fa-cross"></i><span>Baume de la Foi</span></a></div>
            <div class="nav-item"><a href="/admin/contacts" class="nav-link"><i class="fas fa-envelope"></i><span>Messages</span></a></div>
            <div class="nav-section-label">Médias</div>
            <div class="nav-item"><a href="/admin/gallery" class="nav-link"><i class="fas fa-images"></i><span>Galerie</span></a></div>
            <div class="nav-item"><a href="/admin/album" class="nav-link"><i class="fas fa-book"></i><span>Album</span></a></div>
        </nav>
        <div class="sidebar-footer">
            <div class="nav-item"><a href="/admin/settings" class="nav-link"><i class="fas fa-cog"></i><span>Paramètres</span></a></div>
            <div class="nav-item"><a href="/admin/logout" class="nav-link logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a></div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">

        <!-- Dash Header -->
        <div class="dash-header">
            <div class="dash-header-left">
                <img src="/images/Telex.png" alt="Telex" class="dash-header-logo">
                <div>
                    <div class="dash-header-title"><i class="fas fa-info-circle me-2" style="color:#A8DADC;font-size:.95rem;"></i>&Agrave; Propos</div>
                    <div class="dash-header-sub">G&eacute;rez le contenu de la page "&Agrave; Propos" de Telex</div>
                </div>
            </div>
            <div class="dash-header-right">
                <a href="/admin/settings" class="btn-dash-back"><i class="fas fa-arrow-left"></i>Param&egrave;tres</a>
                <a href="/about" target="_blank" class="btn-dash-view"><i class="fas fa-eye"></i>Voir la page</a>
            </div>
        </div>

        <div class="content-area">

            <!-- Alert succès/erreur -->
            <div class="flash-alert flash-success d-none" id="successAlert">
                <i class="fas fa-check-circle"></i><span>Les modifications ont &eacute;t&eacute; enregistr&eacute;es avec succ&egrave;s !</span>
            </div>
            <div class="flash-alert flash-error d-none" id="errorAlert">
                <i class="fas fa-exclamation-circle"></i><span id="errorMsg">Erreur lors de la sauvegarde.</span>
            </div>

            <!-- Save bar -->
            <div class="save-bar">
                <div class="save-bar-info"><i class="fas fa-info-circle me-1"></i>Les modifications sont enregistr&eacute;es sur le serveur.</div>
                <button type="button" class="btn-save" onclick="saveAllData()">
                    <i class="fas fa-save"></i>Sauvegarder toutes les modifications
                </button>
            </div>

            <!-- CARTE 1 : Section Hero -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon" style="background:linear-gradient(135deg,#3B82F6,#1D4ED8);">
                        <i class="fas fa-image" style="color:white;"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Section Hero</div>
                        <div class="form-card-sub">Titre, sous-titre et texte d'introduction de la page</div>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Titre principal</label>
                            <input type="text" class="form-control" id="heroTitle" value="<%= about.hero_title || 'À propos de Telex' %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Sous-titre</label>
                            <input type="text" class="form-control" id="heroSubtitle" value="<%= about.hero_subtitle || 'Découvrez notre histoire, notre équipe et notre vision' %>">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Texte d'introduction</label>
                            <textarea class="form-control" id="heroIntro" rows="4"><%= about.hero_intro || 'Fondée par des étudiants passionnés, Telex est bien plus qu\'une télévision étudiante.' %></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Image Hero (chemin)</label>
                            <input type="text" class="form-control" id="heroImage" value="<%= about.hero_image || '/images/camera.png' %>" placeholder="/images/camera.png">
                        </div>
                    </div>
                </div>
            </div>

            <!-- CARTE 2 : Notre Histoire -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon" style="background:linear-gradient(135deg,#10B981,#047857);">
                        <i class="fas fa-history" style="color:white;"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Notre Histoire</div>
                        <div class="form-card-sub">Les deux paragraphes de la section histoire</div>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Titre de la section</label>
                            <input type="text" class="form-control" id="historyTitle" value="<%= about.history_title || 'Notre Histoire' %>">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Paragraphe 1</label>
                            <textarea class="form-control" id="historyParagraph1" rows="4"><%= about.history_paragraph1 || 'Telex est né en 2024 de la passion commune d\'un groupe d\'étudiants déterminés à créer une télévision étudiante.' %></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Paragraphe 2</label>
                            <textarea class="form-control" id="historyParagraph2" rows="4"><%= about.history_paragraph2 || 'Notre aventure a commencé avec une petite équipe de 10 passionnés et un studio improvisé.' %></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CARTE 3 : Notre Équipe -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon" style="background:linear-gradient(135deg,#8B5CF6,#7C3AED);">
                        <i class="fas fa-users" style="color:white;"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Notre &Eacute;quipe</div>
                        <div class="form-card-sub">Introduction et d&eacute;tails des p&ocirc;les de l'&eacute;quipe</div>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Titre de la section</label>
                            <input type="text" class="form-control" id="teamTitle" value="Notre &Eacute;quipe">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Texte d'introduction</label>
                            <textarea class="form-control" id="teamIntro" rows="3">Notre force r&eacute;side dans la diversit&eacute; de nos profils. Journalistes, techniciens, monteurs, graphistes, communicants.</textarea>
                        </div>
                    </div>

                    <!-- Rédaction -->
                    <div class="team-card">
                        <div class="team-card-header">
                            <i class="fas fa-newspaper"></i>
                            <div class="team-card-title">R&eacute;daction</div>
                        </div>
                        <input type="hidden" id="redactionTitle" value="R&eacute;daction">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Nombre de membres</label>
                                <input type="text" class="form-control" id="redactionCount" value="2 journalistes et reporters">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Chemin image</label>
                                <input type="text" class="form-control" id="redactionImage" value="/images/TELEX INTEGRATION.png">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" id="redactionDescription" rows="2">Notre &eacute;quipe &eacute;ditoriale travaille sur l'&eacute;criture, les reportages et la v&eacute;rification des informations.</textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Comp&eacute;tences (s&eacute;par&eacute;es par des virgules)</label>
                                <input type="text" class="form-control" id="redactionSkills" value="Journalisme, Reportage, &Eacute;dition">
                            </div>
                        </div>
                    </div>

                    <!-- Technique -->
                    <div class="team-card">
                        <div class="team-card-header">
                            <i class="fas fa-video"></i>
                            <div class="team-card-title">Technique</div>
                        </div>
                        <input type="hidden" id="techniqueTitle" value="Technique">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Nombre de membres</label>
                                <input type="text" class="form-control" id="techniqueCount" value="2 techniciens audiovisuels">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Chemin image</label>
                                <input type="text" class="form-control" id="techniqueImage" value="/images/femme telex.png">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" id="techniqueDescription" rows="2">Sp&eacute;cialistes de la prise de vue, du son et de l'&eacute;clairage pour une production de qualit&eacute; professionnelle.</textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Comp&eacute;tences</label>
                                <input type="text" class="form-control" id="techniqueSkills" value="Cam&eacute;ra, Son, &Eacute;clairage">
                            </div>
                        </div>
                    </div>

                    <!-- Post-production -->
                    <div class="team-card">
                        <div class="team-card-header">
                            <i class="fas fa-edit"></i>
                            <div class="team-card-title">Post-production</div>
                        </div>
                        <input type="hidden" id="postproductionTitle" value="Post-production">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Nombre de membres</label>
                                <input type="text" class="form-control" id="postproductionCount" value="3 monteurs vid&eacute;o">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Chemin image</label>
                                <input type="text" class="form-control" id="postproductionImage" value="/images/ordi_telex.png">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" id="postproductionDescription" rows="2">Experts en montage, &eacute;talonnage et effets sp&eacute;ciaux pour donner vie &agrave; nos contenus audiovisuels.</textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Comp&eacute;tences</label>
                                <input type="text" class="form-control" id="postproductionSkills" value="Montage, &Eacute;talonnage, Motion Design">
                            </div>
                        </div>
                    </div>

                    <!-- Communication -->
                    <div class="team-card">
                        <div class="team-card-header">
                            <i class="fas fa-bullhorn"></i>
                            <div class="team-card-title">Communication</div>
                        </div>
                        <input type="hidden" id="communicationTitle" value="Communication">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Nombre de membres</label>
                                <input type="text" class="form-control" id="communicationCount" value="1 charg&eacute; de communication">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Chemin image</label>
                                <input type="text" class="form-control" id="communicationImage" value="/images/Pr&eacute;sentation du Telex.png">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" id="communicationDescription" rows="2">Gestion des r&eacute;seaux sociaux, relations presse et strat&eacute;gie de diffusion pour maximiser notre audience.</textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Comp&eacute;tences</label>
                                <input type="text" class="form-control" id="communicationSkills" value="R&eacute;seaux sociaux, Strat&eacute;gie, Community">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CARTE 4 : Nos Chiffres -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon" style="background:linear-gradient(135deg,#F59E0B,#D97706);">
                        <i class="fas fa-chart-line" style="color:white;"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Nos Chiffres</div>
                        <div class="form-card-sub">Les statistiques affich&eacute;es sur la page &agrave; propos</div>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="mb-3">
                        <label class="form-label">Titre de la section</label>
                        <input type="text" class="form-control" id="statsTitle" value="Nos Chiffres" style="max-width:320px;">
                    </div>
                    <div class="stat-row">
                        <div class="stat-item">
                            <label>Membres actifs</label>
                            <input type="text" id="stat1Number" value="50+">
                        </div>
                        <div class="stat-item">
                            <label>Heures de production</label>
                            <input type="text" id="stat2Number" value="200+">
                        </div>
                        <div class="stat-item">
                            <label>Vues mensuelles</label>
                            <input type="text" id="stat3Number" value="15K+">
                        </div>
                        <div class="stat-item">
                            <label>&Eacute;missions r&eacute;guli&egrave;res</label>
                            <input type="text" id="stat4Number" value="4">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bouton bas de page -->
            <div class="d-flex justify-content-end mb-4">
                <button type="button" class="btn-save" onclick="saveAllData()">
                    <i class="fas fa-save"></i>Sauvegarder toutes les modifications
                </button>
            </div>

        </div><!-- /.content-area -->

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    
    <script>
        // Fonction pour afficher l'alerte de succès
        function showSuccessAlert(message) {
            const el = document.getElementById('successAlert');
            el.querySelector('span').textContent = message;
            el.classList.remove('d-none');
            document.getElementById('errorAlert').classList.add('d-none');
            setTimeout(() => el.classList.add('d-none'), 5000);
        }

        // Fonction pour sauvegarder toutes les données sur le serveur
        async function saveAllData() {
            try {
                console.log('🚀 Début de la sauvegarde...');
                
                // Vérifier que les éléments existent avant de les utiliser
                const getElementValue = (id, defaultValue = '') => {
                    const element = document.getElementById(id);
                    return element ? element.value : defaultValue;
                };
                
                // Collecter toutes les données des formulaires
                const formData = new FormData();
                
                // Données Hero
                formData.append('hero_title', getElementValue('heroTitle', 'À propos de Telex'));
                formData.append('hero_subtitle', getElementValue('heroSubtitle', 'Découvrez notre histoire, notre équipe et notre vision'));
                formData.append('hero_intro', getElementValue('heroIntro', 'Fondée par des étudiants passionnés...'));
                formData.append('hero_image', getElementValue('heroImage', '/images/camera.png'));
                
                // Données Histoire
                formData.append('history_title', getElementValue('historyTitle', 'Notre Histoire'));
                formData.append('history_paragraph1', getElementValue('historyParagraph1', 'Telex est né en 2024...'));
                formData.append('history_paragraph2', getElementValue('historyParagraph2', 'Notre aventure a commencé...'));
                
                // Données Équipe
                formData.append('team_title', getElementValue('teamTitle', 'Notre Équipe'));
                formData.append('team_intro', getElementValue('teamIntro', 'Notre force réside dans la diversité...'));
                formData.append('team_redaction_title', getElementValue('redactionTitle', 'Rédaction'));
                formData.append('team_redaction_count', getElementValue('redactionCount', '2 journalistes et reporters'));
                formData.append('team_redaction_image', getElementValue('redactionImage', '/images/TELEX INTEGRATION.png'));
                formData.append('team_redaction_description', getElementValue('redactionDescription', 'Notre équipe éditoriale travaille...'));
                formData.append('team_redaction_skills', getElementValue('redactionSkills', 'Journalisme, Reportage, Édition'));
                formData.append('team_technique_title', getElementValue('techniqueTitle', 'Technique'));
                formData.append('team_technique_count', getElementValue('techniqueCount', '2 techniciens audiovisuels'));
                formData.append('team_technique_image', getElementValue('techniqueImage', '/images/femme telex.png'));
                formData.append('team_technique_description', getElementValue('techniqueDescription', 'Spécialistes de la prise de vue...'));
                formData.append('team_technique_skills', getElementValue('techniqueSkills', 'Caméra, Son, Éclairage'));
                formData.append('team_postproduction_title', getElementValue('postproductionTitle', 'Post-production'));
                formData.append('team_postproduction_count', getElementValue('postproductionCount', '3 monteurs vidéo'));
                formData.append('team_postproduction_image', getElementValue('postproductionImage', '/images/ordi_telex.png'));
                formData.append('team_postproduction_description', getElementValue('postproductionDescription', 'Experts en montage...'));
                formData.append('team_postproduction_skills', getElementValue('postproductionSkills', 'Montage, Étalonnage, Motion Design'));
                formData.append('team_communication_title', getElementValue('communicationTitle', 'Communication'));
                formData.append('team_communication_count', getElementValue('communicationCount', '1 chargés de communication'));
                formData.append('team_communication_image', getElementValue('communicationImage', '/images/Présentation du Telex.png'));
                formData.append('team_communication_description', getElementValue('communicationDescription', 'Gestion des réseaux sociaux...'));
                formData.append('team_communication_skills', getElementValue('communicationSkills', 'Réseaux sociaux, Stratégie, Community'));
                
                // Données Chiffres
                formData.append('stats_title', getElementValue('statsTitle', 'Nos Chiffres'));
                formData.append('stats_members_count', getElementValue('stat1Number', '50+'));
                formData.append('stats_hours_count', getElementValue('stat2Number', '200+'));
                formData.append('stats_views_count', getElementValue('stat3Number', '15K+'));
                formData.append('stats_programs_count', getElementValue('stat4Number', '4'));

                console.log('📤 Envoi des données au serveur...');

                // Envoyer les données au serveur
                const response = await fetch('/admin/about', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                console.log('📥 Réponse du serveur:', result);

                if (result.success) {
                    showSuccessAlert('Toutes les modifications ont été enregistrées avec succès !');
                } else {
                    showErrorAlert('Erreur lors de la sauvegarde: ' + result.message);
                }
            } catch (error) {
                console.error('❌ Erreur lors de la sauvegarde:', error);
                showErrorAlert('Erreur lors de la sauvegarde des données: ' + error.message);
            }
        }

        // Fonction pour afficher une alerte d'erreur
        function showErrorAlert(message) {
            const el = document.getElementById('errorAlert');
            document.getElementById('errorMsg').textContent = message;
            el.classList.remove('d-none');
            document.getElementById('successAlert').classList.add('d-none');
            setTimeout(() => el.classList.add('d-none'), 5000);
        }
    </script>

    <script>
        function openSidebar() {
            document.querySelector('.sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('show');
        }
        function closeSidebar() {
            document.querySelector('.sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }
    </script></body>
</html>
