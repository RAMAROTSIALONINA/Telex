<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@800;900&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { height: 100%; }
        body { min-height: 100%; }

        :root {
            --red:    #E63946;
            --red-dk: #c1121f;
            --navy:   #1D3557;
            --blue:   #457B9D;
            --border: #e2e8f0;
            --txt:    #0f172a;
            --muted:  #64748b;
        }

        /* ================================================================
           BODY = FOND BLEU INTÉGRAL
           Le côté blanc est créé par clip-path sur le panneau droit
        ================================================================ */
        body {
            min-height: 100vh;
            display: flex;
            font-family: 'Inter', sans-serif;
            background:
                radial-gradient(ellipse 80% 70% at 5% 10%, rgba(255,255,255,.13) 0%, transparent 55%),
                radial-gradient(ellipse 50% 60% at 90% 90%, rgba(29,53,87,.4) 0%, transparent 55%),
                linear-gradient(155deg, #5a9bbf 0%, #457B9D 48%, #2e6385 100%);
            position: relative;
            overflow-x: hidden; /* empêche scroll horizontal du clip-path diagonal */
        }

        /* ================================================================
           PANNEAU GAUCHE — transparent, hérite du bleu du body
        ================================================================ */
        .l-panel {
            flex: 0 0 38%;
            min-height: 100vh;
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
        }

        .l-body {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;   /* centrage horizontal du contenu */
            justify-content: center; /* centrage vertical */
            padding: 40px 36px;
            max-width: 320px;
            text-align: center;
        }

        .l-logo-wrap { margin-bottom: 32px; flex-shrink: 0; }
        .l-logo {
            height: 90px; width: auto; max-width: 260px; object-fit: contain;
            display: block;
            mix-blend-mode: multiply;
        }

        .l-tag {
            font-size: .62rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .2em;
            color: rgba(255,255,255,.65);
            display: flex; align-items: center; justify-content: center; gap: 9px;
            margin-bottom: 16px; flex-shrink: 0;
        }
        .l-tag::after {
            content: ''; width: 20px; height: 1px;
            background: rgba(255,255,255,.3); flex-shrink: 0;
        }

        .l-title {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.15rem; font-weight: 900;
            line-height: 1.18; letter-spacing: -.01em;
            white-space: nowrap;
            color: #fff; margin-bottom: 14px; flex-shrink: 0;
        }
        .l-title em { font-style: normal; color: var(--red); }

        .l-sub {
            font-size: .8rem; color: rgba(255,255,255,.58);
            line-height: 1.65; margin-bottom: 40px; flex-shrink: 0;
        }

        /* Feature cards */
        .l-cards { display: flex; flex-direction: column; gap: 8px; width: 100%; }

        .l-card {
            display: flex; align-items: center; gap: 13px;
            padding: 12px 15px; border-radius: 11px;
            background: rgba(255,255,255,.1);
            transition: background .2s;
        }
        .l-card:hover { background: rgba(255,255,255,.17); }

        .l-card-ico {
            width: 34px; height: 34px; border-radius: 8px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center; font-size: .82rem;
        }
        .ico-red { background: rgba(230,57,70,.28); color: #ffb3b8; }
        .ico-wh  { background: rgba(255,255,255,.2); color: #fff; }
        .ico-tl  { background: rgba(255,255,255,.14); color: #d0edf5; }

        .l-card-info strong { display:block; font-size:.78rem; font-weight:600; color:#fff; margin-bottom:1px; }
        .l-card-info span   { font-size:.7rem; color:rgba(255,255,255,.5); }

        .l-foot {
            position: relative; z-index: 1;
            padding: 16px 36px 26px;
            max-width: 320px; width: 100%;
            display: flex; align-items: center; justify-content: center; gap: 7px;
        }
        .l-foot span { font-size:.65rem; color:rgba(255,255,255,.35); }
        .l-foot .sep { width:3px; height:3px; border-radius:50%; background:rgba(255,255,255,.25); }

        /* ================================================================
           PANNEAU DROIT — BLANC avec clip-path DIAGONAL
           Le clip-path crée le bord diagonal : large en bas, rétréci en haut
           polygon(X% 0, 100% 0, 100% 100%, 0 100%)
           — la ligne diagonale va de (X% du panneau, haut) à (0%, bas)
        ================================================================ */
        .r-panel {
            flex: 1; /* ~62% du viewport */
            min-height: 100vh; /* s'étire sur toute la hauteur même si body > viewport */
            background: #fff;
            clip-path: polygon(20% 0, 100% 0, 100% 100%, 0 100%);
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
        }

        .r-center {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            /* padding-left pousse le formulaire dans la zone blanche visible */
            /* 20% de 62vw = 12.4vw → contenu commence à 50.4vw depuis la gauche */
            padding: 40px 60px 40px 22%;
        }

        .r-form-wrap { width: 100%; max-width: 390px; }

        /* En-tête */
        .r-head { margin-bottom: 32px; }

        .r-pill {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: .64rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .14em;
            color: var(--red);
            background: rgba(230,57,70,.07);
            border: 1px solid rgba(230,57,70,.18);
            padding: 4px 12px; border-radius: 20px;
            margin-bottom: 16px;
        }

        .r-h1 {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.95rem; font-weight: 900;
            color: var(--txt); letter-spacing: -.03em; margin-bottom: 7px;
        }

        .r-hint { font-size: .82rem; color: var(--muted); line-height: 1.55; }
        .r-bar  { width: 28px; height: 3px; background: var(--red); border-radius: 3px; margin-top: 14px; }

        /* Alertes */
        .r-alert {
            display: flex; align-items: flex-start; gap: 10px;
            padding: 11px 14px; border-radius: 9px;
            font-size: .81rem; line-height: 1.5; margin-bottom: 20px;
            animation: aUp .3s ease;
        }
        .r-alert.err { background:#fff5f5; border:1px solid #fecaca; color:#b91c1c; }
        .r-alert.ok  { background:#f0fdf4; border:1px solid #bbf7d0; color:#15803d; }
        .r-alert i   { flex-shrink:0; margin-top:1px; }

        @keyframes aUp {
            from { opacity:0; transform:translateY(-6px); }
            to   { opacity:1; transform:translateY(0); }
        }

        /* Champs */
        .f-row { margin-bottom: 16px; }
        .f-top {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 7px;
        }
        .f-lbl {
            font-size: .67rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .1em;
            color: var(--muted);
        }
        .f-link { font-size: .73rem; color: var(--blue); text-decoration:none; transition:color .2s; }
        .f-link:hover { color: var(--red); }

        .f-box { position: relative; }

        .f-ico {
            position: absolute; left:14px; top:50%; transform:translateY(-50%);
            font-size: .8rem; color: #c0cdd8; pointer-events:none; transition:color .2s;
        }
        .f-box:focus-within .f-ico { color: var(--red); }

        .f-inp {
            width: 100%; height: 50px;
            padding: 0 46px 0 40px;
            border: 1.5px solid #e8eef5; border-radius: 11px;
            background: #f8fafc;
            font-size: .91rem; color: var(--txt); font-family: inherit;
            outline: none;
            transition: border-color .2s, box-shadow .2s, background .2s;
        }
        .f-inp::placeholder { color: #c4d0dc; }
        .f-inp:hover  { border-color: #ccd8e8; background: #fff; }
        .f-inp:focus  { border-color: var(--red); box-shadow: 0 0 0 3px rgba(230,57,70,.1); background: #fff; }

        .f-eye {
            position: absolute; right:12px; top:50%; transform:translateY(-50%);
            background:none; border:none; color:#c0cdd8;
            font-size:.8rem; padding:5px; line-height:1;
            transition:color .2s;
        }
        .f-eye:hover { color: var(--navy); }

        /* Bouton */
        .btn-go {
            display: flex; align-items: center; justify-content: center; gap: 9px;
            width: 100%; height: 52px; margin-top: 24px;
            background: var(--red); color: #fff;
            border: none; border-radius: 11px;
            font-size: .93rem; font-weight: 700; font-family: inherit;
            cursor: pointer;
            box-shadow: 0 4px 14px rgba(230,57,70,.32);
            transition: transform .18s, box-shadow .18s, background .18s;
            position: relative; overflow: hidden;
        }
        .btn-go::before {
            content:''; position:absolute; top:0; left:-100%; width:60%; height:100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,.22), transparent);
            transition: left .55s ease;
        }
        .btn-go:hover::before { left:150%; }
        .btn-go:hover { background: var(--red-dk); transform:translateY(-2px); box-shadow: 0 8px 24px rgba(230,57,70,.36); }
        .btn-go:active { transform:translateY(0); }
        .btn-go:disabled { opacity:.7; cursor:not-allowed; transform:none; box-shadow:none; }
        .btn-go .sp {
            display:none; width:18px; height:18px;
            border:2.5px solid rgba(255,255,255,.35); border-top-color:#fff;
            border-radius:50%; animation:spin .7s linear infinite;
        }
        .btn-go.ld .tx { display:none; }
        .btn-go.ld .sp { display:block; }
        @keyframes spin { to { transform:rotate(360deg); } }

        /* Note sécurité */
        .r-sec {
            display: flex; align-items: flex-start; gap: 9px;
            margin-top: 20px; padding: 12px 14px;
            background: #f8fafc; border: 1px solid #edf2f7; border-radius: 10px;
        }
        .r-sec i { color: var(--blue); font-size:.88rem; flex-shrink:0; margin-top:1px; }
        .r-sec p { font-size:.71rem; color:#94a3b8; line-height:1.55; }

        /* Footer */
        .r-foot {
            padding: 14px 60px 14px 22%;
            border-top: 1px solid #f0f4f8;
            display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 6px;
        }
        .r-foot-left { display:flex; align-items:center; gap:5px; }
        .r-foot span { font-size:.68rem; color:#b8c4ce; }
        .r-foot .dot { color:#d8e0e8; font-size:.55rem; }
        .r-back {
            font-size:.71rem; color:#b8c4ce; text-decoration:none;
            display:flex; align-items:center; gap:5px; transition:color .2s;
        }
        .r-back:hover { color: var(--navy); }

        /* ================================================================
           RESPONSIVE
           Règle principale : padding-left du formulaire doit TOUJOURS
           être supérieur au clip (20%) pour rester dans la zone blanche.
           On utilise 25% comme valeur de référence (5% de buffer).
        ================================================================ */

        /* --- Grand écran : 1024–1280px --- */
        @media (max-width: 1280px) {
            .l-body  { padding: 40px 30px 0; max-width: 300px; }
            .l-foot  { padding: 14px 30px 24px; max-width: 300px; }
            .r-center { padding: 36px 48px 36px 25%; }
            .r-foot   { padding: 12px 48px 12px 25%; }
        }

        /* --- Moyen : 900–1024px, cards cachées --- */
        @media (max-width: 1024px) {
            .l-logo  { height: 75px; max-width: 220px; }
            .l-body  { padding: 32px 26px; max-width: 270px; }
            .l-foot  { padding: 12px 26px 22px; max-width: 270px; }
            .l-cards { display: none; }
            .l-sub   { margin-bottom: 0; font-size: .78rem; }
            .r-center { padding: 32px 40px 32px 25%; }
            .r-foot   { padding: 12px 40px 12px 25%; }
            .r-h1     { font-size: 1.75rem; }
        }

        /* --- Tablette paysage : 720–900px --- */
        @media (max-width: 900px) {
            .l-panel  { flex: 0 0 35%; }
            .l-body   { padding: 28px 22px; max-width: 240px; }
            .l-foot   { padding: 10px 22px 18px; max-width: 240px; }
            .l-logo   { height: 60px; max-width: 190px; }
            .l-tag    { display: none; }
            .l-sub    { display: none; }
            .l-title  { font-size: .95rem; }
            /* clip reste à 20%, padding à 25% → 5% buffer garanti */
            .r-center { padding: 28px 32px 28px 25%; }
            .r-foot   { padding: 10px 32px 10px 25%; }
            .r-h1     { font-size: 1.6rem; }
            .r-hint   { font-size: .78rem; }
        }

        /* --- Tablette portrait : 600–720px --- */
        @media (max-width: 720px) {
            .l-panel  { flex: 0 0 32%; }
            .l-body   { padding: 24px 18px; max-width: 200px; }
            .l-foot   { padding: 8px 18px 16px; max-width: 200px; }
            .l-logo   { height: 50px; max-width: 170px; }
            .l-title  { font-size: .95rem; }
            /* clip reste 20%, padding 25% → buffer OK */
            .r-center { padding: 24px 24px 24px 26%; }
            .r-foot   { padding: 10px 24px 10px 26%; }
            .r-h1     { font-size: 1.45rem; }
            .r-form-wrap { max-width: 340px; }
        }

        /* --- Mobile : ≤600px — bascule colonne --- */
        @media (max-width: 600px) {
            body { flex-direction: column; }

            /* Bandeau bleu compact en haut */
            .l-panel { flex: none; }
            .l-body {
                flex-direction: row; align-items: center;
                gap: 14px; padding: 14px 20px; max-width: 100%;
            }
            .l-logo-wrap { margin-bottom: 0; flex-shrink: 0; }
            .l-logo      { height: 40px; max-width: 150px; }

            /* Groupe tag + titre sur une seule ligne chacun */
            .l-txt-group {
                display: flex; flex-direction: column;
                gap: 2px; min-width: 0;
            }
            .l-tag {
                display: flex; align-items: center; gap: 5px;
                font-size: .58rem; margin-bottom: 0;
                white-space: nowrap;
            }
            .l-tag::after { display: none; }
            .l-title {
                display: block; white-space: nowrap;
                font-size: .88rem; margin-bottom: 0; line-height: 1.15;
            }
            .l-title br { display: none; }
            .l-sub, .l-cards, .l-foot { display: none; }

            /* Formulaire : zone blanche plein écran */
            .r-panel  { flex: 1; clip-path: none; }
            .r-center { padding: 28px 20px; justify-content: center; }
            .r-foot   { padding: 12px 20px; }
            .r-form-wrap { max-width: 100%; }
        }

        /* --- Très petit mobile : ≤400px --- */
        @media (max-width: 400px) {
            .l-logo  { height: 32px; }
            .l-title { font-size: .76rem; }
            .l-tag   { font-size: .52rem; }
            .f-inp   { height: 46px; }
            .btn-go  { height: 48px; font-size: .88rem; }
            .r-h1    { font-size: 1.4rem; }
            .r-center { padding: 20px 16px; }
        }
    </style>
</head>
<body>

    <!-- ============================================================
         PANNEAU GAUCHE (sur fond bleu du body)
    ============================================================ -->
    <div class="l-panel">
        <div class="l-body">
            <div class="l-logo-wrap">
                <img src="/images/Telex.png" alt="Telex" class="l-logo">
            </div>

            <div class="l-txt-group">
                <div class="l-tag">
                    <i class="fas fa-broadcast-tower" style="font-size:.58rem;"></i>
                    Télévision Étudiante
                </div>

                <h1 class="l-title">Interface d'<em>administration</em></h1>
            </div>

            <p class="l-sub">
                Gérez contenus, utilisateurs et programmes en un espace.
            </p>

            <div class="l-cards">
                <div class="l-card">
                    <div class="l-card-ico ico-red"><i class="fas fa-tv"></i></div>
                    <div class="l-card-info">
                        <strong>Programmes & émissions</strong>
                        <span>Plannings, contenus, diffusions</span>
                    </div>
                </div>
                <div class="l-card">
                    <div class="l-card-ico ico-wh"><i class="fas fa-newspaper"></i></div>
                    <div class="l-card-info">
                        <strong>Actualités & galerie</strong>
                        <span>Articles, photos, albums</span>
                    </div>
                </div>
                <div class="l-card">
                    <div class="l-card-ico ico-tl"><i class="fas fa-users-cog"></i></div>
                    <div class="l-card-info">
                        <strong>Utilisateurs & accès</strong>
                        <span>Rôles, droits, permissions</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="l-foot">
            <span>Telex Madagascar</span>
            <div class="sep"></div>
            <span>© <%= new Date().getFullYear() %></span>
        </div>
    </div>

    <!-- ============================================================
         PANNEAU DROIT — FOND BLANC avec bord diagonal clip-path
         Le bord diagonal va de (20% du panneau, haut) à (0%, bas)
         Soit de ~50% viewport (haut) à 38% viewport (bas) = diagonal visible
    ============================================================ -->
    <div class="r-panel">
        <div class="r-center">
            <div class="r-form-wrap">

                <div class="r-head">
                    <div class="r-pill">
                        <i class="fas fa-lock" style="font-size:.58rem;"></i>
                        Espace sécurisé
                    </div>
                    <h2 class="r-h1">Connexion</h2>
                    <p class="r-hint">Identifiez-vous pour accéder au tableau de bord.</p>
                    <div class="r-bar"></div>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                <div class="r-alert err">
                    <i class="fas fa-exclamation-circle"></i>
                    <div><strong>Identifiants incorrects</strong><br><%= error %></div>
                </div>
                <% } %>
                <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
                <div class="r-alert ok">
                    <i class="fas fa-check-circle"></i>
                    <div><%= success_msg %></div>
                </div>
                <% } %>

                <form method="POST" action="/admin/login" id="lf" novalidate>

                    <div class="f-row">
                        <div class="f-top">
                            <span class="f-lbl">Identifiant</span>
                        </div>
                        <div class="f-box">
                            <i class="fas fa-user f-ico"></i>
                            <input type="text" id="username" name="username"
                                   class="f-inp" placeholder="Votre identifiant"
                                   autocomplete="username" required>
                        </div>
                    </div>

                    <div class="f-row">
                        <div class="f-top">
                            <span class="f-lbl">Mot de passe</span>
                            <a href="#" class="f-link" id="forgotLink">
                                <i class="fas fa-question-circle" style="font-size:.68rem;"></i> Oublié ?
                            </a>
                        </div>
                        <div class="f-box">
                            <i class="fas fa-lock f-ico"></i>
                            <input type="password" id="password" name="password"
                                   class="f-inp" placeholder="••••••••••••"
                                   autocomplete="current-password" required>
                            <button type="button" class="f-eye" id="togPw">
                                <i class="fas fa-eye" id="togIco"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="btn-go" id="loginBtn">
                        <span class="sp"></span>
                        <span class="tx">
                            <i class="fas fa-sign-in-alt"></i>&nbsp; Se connecter
                        </span>
                    </button>
                </form>

                <div class="r-sec">
                    <i class="fas fa-shield-alt"></i>
                    <p>Accès réservé au personnel autorisé de Telex Madagascar. Toute tentative non autorisée est enregistrée.</p>
                </div>

            </div>
        </div>

        <div class="r-foot">
            <div class="r-foot-left">
                <span>Telex Admin</span>
                <span class="dot">•</span>
                <span>© <%= new Date().getFullYear() %></span>
            </div>
            <a href="/" class="r-back">
                <i class="fas fa-arrow-left" style="font-size:.6rem;"></i> Retour au site
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        document.getElementById('username').focus();

        const pw  = document.getElementById('password');
        const ico = document.getElementById('togIco');
        document.getElementById('togPw').addEventListener('click', function () {
            const show = pw.type === 'password';
            pw.type = show ? 'text' : 'password';
            ico.className = show ? 'fas fa-eye-slash' : 'fas fa-eye';
        });

        const form = document.getElementById('lf');
        const btn  = document.getElementById('loginBtn');

        form.addEventListener('submit', function (e) {
            if (!document.getElementById('username').value.trim() || !pw.value.trim()) {
                e.preventDefault();
                alertDyn('Veuillez saisir votre identifiant et votre mot de passe.', 'err');
                return;
            }
            btn.classList.add('ld');
            btn.disabled = true;
        });

        document.getElementById('forgotLink').addEventListener('click', function (e) {
            e.preventDefault();
            alertDyn('Contactez l\'administrateur système pour récupérer vos accès.', 'ok');
        });

        function alertDyn(msg, type) {
            document.querySelectorAll('.r-alert.dyn').forEach(el => el.remove());
            const d = document.createElement('div');
            d.className = `r-alert ${type} dyn`;
            d.innerHTML = `<i class="fas ${type==='err'?'fa-exclamation-circle':'fa-info-circle'}"></i><div>${msg}</div>`;
            form.before(d);
            setTimeout(() => { d.style.transition='opacity .4s'; d.style.opacity='0'; setTimeout(()=>d.remove(),400); }, 4500);
        }

        window.addEventListener('pageshow', function () {
            btn.classList.remove('ld'); btn.disabled = false;
        });
    });
    </script>
</body>
</html>
