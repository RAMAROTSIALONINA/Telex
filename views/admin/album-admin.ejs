<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administration Album - Telex</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --sidebar-width: 280px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            color: #334155;
        }

        /* ── Layout ── */
        .admin-wrapper { display: flex; min-height: 100vh; }

        .sidebar {
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%);
            color: white;
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            left: 0; top: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0,0,0,.1);
            display: flex;
            flex-direction: column;
        }

        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            min-width: 0;
        }

        /* ── Sidebar header ── */
        .sb-header { display:flex; align-items:center; justify-content:center; padding:18px 16px; border-bottom:1px solid rgba(255,255,255,.08); transition:background .2s; }
        .sb-header:hover { background:rgba(255,255,255,.04); }
        .sb-logo { height:52px; width:auto; display:block; flex-shrink:0; }

        /* ── Nav ── */
        .sidebar-nav { flex:1; padding:20px 15px; overflow-y:auto; }
        .nav-item { margin-bottom:8px; }
        .nav-link { display:flex; align-items:center; color:rgba(255,255,255,.8); padding:14px 18px; text-decoration:none; border-radius:10px; transition:all .3s; font-weight:500; }
        .nav-link:hover { background:rgba(255,255,255,.1); color:#fff; transform:translateX(5px); }
        .nav-link.active { background:rgba(230,57,70,.15); color:#fff; box-shadow:0 4px 12px rgba(230,57,70,.2); }
        .nav-link i { width:24px; font-size:1.1rem; margin-right:12px; text-align:center; }
        .nav-section-label { font-size:.68rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:rgba(255,255,255,.28); padding:14px 10px 5px; }

        /* ── Sidebar footer ── */
        .sidebar-footer { padding:8px 10px 12px; border-top:1px solid rgba(255,255,255,.08); }
        .nav-link.logout { color:rgba(255,160,160,.7); }
        .nav-link.logout:hover { background:rgba(255,107,107,.1); color:#ff9e9e; }

        /* ── Responsive ── */
        @media (max-width: 992px) {
            .sidebar { width:70px; overflow:hidden; }
            .sb-header { padding:12px 0; }
            .sb-logo { height:32px; }
            .nav-section-label { display:none; }
            .nav-link span { display:none; }
            .nav-link { justify-content:center; padding:11px 0; }
            .sidebar-footer { padding:6px 4px 10px; }
            .main-content { margin-left:70px; }
        }

        /* ── Dash Header ── */
        .dash-header { background:linear-gradient(135deg,#1D3557 0%,#2d4f7a 100%); padding:16px 28px; display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; }
        .dash-header-left { display:flex; align-items:center; gap:14px; }
        .dash-header-logo { height:44px; width:auto; object-fit:contain; }
        .dash-header-title { font-size:1.15rem; font-weight:700; color:#fff; line-height:1.3; }
        .dash-header-sub { font-size:.8rem; color:rgba(255,255,255,.65); margin-top:2px; }
        .dash-header-right { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
        .btn-dash-back { display:inline-flex; align-items:center; gap:7px; background:rgba(255,255,255,.12); color:#fff; border:1px solid rgba(255,255,255,.2); border-radius:8px; padding:7px 14px; font-size:.85rem; font-weight:500; text-decoration:none; transition:background .2s; }
        .btn-dash-back:hover { background:rgba(255,255,255,.22); color:#fff; }
        .btn-dash-add { display:inline-flex; align-items:center; gap:7px; background:#10B981; color:#fff; border:none; border-radius:8px; padding:7px 14px; font-size:.85rem; font-weight:600; text-decoration:none; transition:background .2s; cursor:pointer; }
        .btn-dash-add:hover { background:#059669; color:#fff; }

        /* ── KPI Cards ── */
        .kpi-row { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; padding:22px 28px 6px; }
        @media (max-width:900px) { .kpi-row { grid-template-columns:repeat(2,1fr); } }
        @media (max-width:480px) { .kpi-row { grid-template-columns:repeat(2,1fr); gap:10px; padding:14px 14px 4px; } }
        .kpi-card { background:#fff; border-radius:12px; padding:18px 20px; box-shadow:0 2px 8px rgba(0,0,0,.06); border-top:4px solid #e2e8f0; display:flex; align-items:center; gap:14px; }
        .kpi-card.blue { border-top-color:#3B82F6; }
        .kpi-card.green { border-top-color:#10B981; }
        .kpi-card.amber { border-top-color:#F59E0B; }
        .kpi-card.purple { border-top-color:#8B5CF6; }
        .kpi-icon { width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0; }
        .kpi-card.blue .kpi-icon { background:rgba(59,130,246,.12); color:#3B82F6; }
        .kpi-card.green .kpi-icon { background:rgba(16,185,129,.12); color:#10B981; }
        .kpi-card.amber .kpi-icon { background:rgba(245,158,11,.12); color:#F59E0B; }
        .kpi-card.purple .kpi-icon { background:rgba(139,92,246,.12); color:#8B5CF6; }
        .kpi-num { font-size:1.6rem; font-weight:700; color:#1e293b; line-height:1; }
        .kpi-label { font-size:.75rem; color:#64748b; margin-top:3px; font-weight:500; }

        /* ── Form Cards ── */
        .form-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.07); border:1px solid #e2e8f0; margin-bottom:20px; overflow:hidden; }
        .form-card-header { display:flex; align-items:center; gap:14px; padding:18px 22px 14px; border-bottom:1px solid #f1f5f9; background:#fafbfc; }
        .form-card-icon { width:42px; height:42px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0; }
        .form-card-title { font-size:.98rem; font-weight:700; color:#1e293b; }
        .form-card-sub { font-size:.78rem; color:#64748b; margin-top:2px; }
        .form-card-body { padding:22px; }

        /* ── Category Cards ── */
        .category-card { border:1.5px solid #e2e8f0; border-radius:12px; padding:18px; margin-bottom:14px; transition:all .25s; background:#fff; }
        .category-card:hover { border-color:#457B9D; box-shadow:0 4px 14px rgba(69,123,157,.15); transform:translateY(-1px); }
        .category-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px; gap:10px; flex-wrap:wrap; }
        .category-title { font-size:1.05rem; font-weight:700; color:#1D3557; margin:0; }
        .category-count { background:linear-gradient(135deg,#457B9D,#1D3557); color:white; padding:.2rem .7rem; border-radius:20px; font-size:.82rem; font-weight:600; white-space:nowrap; }

        /* ── Image Grid ── */
        .image-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr)); gap:10px; margin-top:10px; }
        @media (max-width:480px) { .image-grid { grid-template-columns:repeat(3,1fr); gap:7px; } }
        .image-item { position:relative; border-radius:8px; overflow:hidden; aspect-ratio:1; background:#f8f9fa; }
        .image-item img { width:100%; height:100%; object-fit:cover; transition:transform .3s; }
        .image-item:hover img { transform:scale(1.06); }
        .image-actions { position:absolute; top:.4rem; right:.4rem; display:flex; gap:.4rem; opacity:0; transition:opacity .25s; }
        .image-item:hover .image-actions { opacity:1; }
        .image-action-btn { background:rgba(255,255,255,.92); border:none; border-radius:50%; width:28px; height:28px; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:.75rem; transition:all .2s; }
        .image-action-btn:hover { background:#fff; transform:scale(1.12); }
        .image-action-btn.delete { background:rgba(220,53,69,.9); color:#fff; }
        .image-action-btn.delete:hover { background:#dc3545; }

        /* ── Upload Area ── */
        .upload-area { border:2.5px dashed #cbd5e1; border-radius:10px; padding:2.5rem 1.5rem; text-align:center; transition:all .25s; cursor:pointer; }
        .upload-area:hover, .upload-area.dragover { border-color:#457B9D; background:rgba(69,123,157,.04); }
        .upload-icon { font-size:2.5rem; color:#457B9D; margin-bottom:.8rem; }

        /* ── Buttons ── */
        .btn-admin-primary { background:linear-gradient(135deg,#457B9D 0%,#1D3557 100%); border:none; color:white; padding:.7rem 1.4rem; border-radius:8px; font-weight:600; transition:all .25s; }
        .btn-admin-primary:hover { transform:translateY(-1px); box-shadow:0 4px 14px rgba(69,123,157,.3); color:#fff; }

        /* ── Modal ── */
        .modal-header { background:linear-gradient(135deg,#457B9D 0%,#1D3557 100%); color:white; }

        /* ── Content padding ── */
        .content-area { padding:22px 28px; }
        @media (max-width:576px) { .content-area { padding:14px; } }
    
        /* ── Responsive mobile (<576px) ── */
        @media (max-width: 576px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform .3s ease;
                z-index: 1050;
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.45);
                z-index: 1040;
            }
            .sidebar-overlay.show { display: block; }
            .main-content { margin-left: 0 !important; }
            .mobile-menu-btn {
                display: flex !important;
            }
        }
        .mobile-menu-btn {
            display: none;
            position: fixed;
            top: 14px;
            left: 14px;
            z-index: 1060;
            background: var(--telex-blue, #1D3557);
            color: white;
            border: none;
            border-radius: 8px;
            width: 40px;
            height: 40px;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.25);
        }</style>
</head>
<body>
<div class="admin-wrapper">

    <div id="sidebarOverlay" class="sidebar-overlay" onclick="closeSidebar()"></div>
    <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fas fa-bars"></i></button>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sb-header">
            <img src="/images/Telex.png" alt="Telex" class="sb-logo">
        </div>
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i><span>Dashboard</span>
                </a>
            </div>
            <div class="nav-section-label">Contenu</div>
            <div class="nav-item"><a href="/admin/news" class="nav-link"><i class="fas fa-newspaper"></i><span>Actualités</span></a></div>
            <div class="nav-item"><a href="/admin/programs" class="nav-link"><i class="fas fa-tv"></i><span>Programmes</span></a></div>
            <div class="nav-section-label">Communauté</div>
            <div class="nav-item"><a href="/admin/baume-de-la-foi" class="nav-link"><i class="fas fa-cross"></i><span>Baume de la Foi</span></a></div>
            <div class="nav-item"><a href="/admin/contacts" class="nav-link"><i class="fas fa-envelope"></i><span>Messages</span></a></div>
            <div class="nav-section-label">Médias</div>
            <div class="nav-item"><a href="/admin/gallery" class="nav-link"><i class="fas fa-images"></i><span>Galerie</span></a></div>
            <div class="nav-item"><a href="/admin/album" class="nav-link active"><i class="fas fa-book"></i><span>Album</span></a></div>
        </nav>
        <div class="sidebar-footer">
            <div class="nav-item"><a href="/admin/settings" class="nav-link"><i class="fas fa-cog"></i><span>Paramètres</span></a></div>
            <div class="nav-item"><a href="/admin/logout" class="nav-link logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a></div>
        </div>
    </div>

    <!-- Contenu principal -->
    <div class="main-content">

        <!-- Dash Header -->
        <div class="dash-header">
            <div class="dash-header-left">
                <img src="/images/Telex.png" alt="Telex" class="dash-header-logo">
                <div>
                    <div class="dash-header-title"><i class="fas fa-book me-2" style="color:#A8DADC;font-size:.95rem;"></i>Administration Album</div>
                    <div class="dash-header-sub">G&eacute;rez les photos et cat&eacute;gories de l'album TELEX</div>
                </div>
            </div>
            <div class="dash-header-right">
                <a href="/album" target="_blank" class="btn-dash-back"><i class="fas fa-eye"></i>Voir l'Album</a>
            </div>
        </div>

        <!-- KPI Row -->
        <div class="kpi-row">
            <div class="kpi-card blue">
                <div class="kpi-icon"><i class="fas fa-images"></i></div>
                <div><div class="kpi-num" id="totalImages">0</div><div class="kpi-label">Total Images</div></div>
            </div>
            <div class="kpi-card green">
                <div class="kpi-icon"><i class="fas fa-folder"></i></div>
                <div><div class="kpi-num" id="totalCategories">0</div><div class="kpi-label">Cat&eacute;gories</div></div>
            </div>
            <div class="kpi-card amber">
                <div class="kpi-icon"><i class="fas fa-clock"></i></div>
                <div><div class="kpi-num" id="recentUploads">0</div><div class="kpi-label">Uploads R&eacute;cents</div></div>
            </div>
            <div class="kpi-card purple">
                <div class="kpi-icon"><i class="fas fa-database"></i></div>
                <div><div class="kpi-num" id="storageUsed">0 MB</div><div class="kpi-label">Espace Utilis&eacute;</div></div>
            </div>
        </div>

        <div class="content-area">

            <!-- Carte : Ajouter une catégorie -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon" style="background:linear-gradient(135deg,#10B981,#047857);">
                        <i class="fas fa-folder-plus" style="color:white;"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Ajouter une nouvelle cat&eacute;gorie</div>
                        <div class="form-card-sub">Cr&eacute;ez une nouvelle cat&eacute;gorie pour organiser vos photos</div>
                    </div>
                </div>
                <div class="form-card-body">
                    <form id="addCategoryForm">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Nom de la cat&eacute;gorie *</label>
                                <input type="text" class="form-control" id="categoryName" placeholder="Ex: &Eacute;v&eacute;nements culturels" required>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label fw-semibold">Description</label>
                                <input type="text" class="form-control" id="categoryDescription" placeholder="Description de la cat&eacute;gorie">
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-admin-primary w-100">
                                    <i class="fas fa-plus me-2"></i>Ajouter
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Carte : Upload d'images -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon" style="background:linear-gradient(135deg,#3B82F6,#1D4ED8);">
                        <i class="fas fa-upload" style="color:white;"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Ajouter des images</div>
                        <div class="form-card-sub">S&eacute;lectionnez une cat&eacute;gorie puis importez vos photos</div>
                    </div>
                </div>
                <div class="form-card-body">
                    <form id="uploadForm" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Cat&eacute;gorie cible *</label>
                            <select class="form-select" id="categorySelect" required>
                                <option value="">Choisir une cat&eacute;gorie...</option>
                            </select>
                        </div>
                        <div class="upload-area" id="uploadArea">
                            <i class="fas fa-cloud-upload-alt upload-icon"></i>
                            <h5 class="mb-1">Glissez-d&eacute;posez les images ici</h5>
                            <p class="text-muted mb-3">ou cliquez pour s&eacute;lectionner les fichiers</p>
                            <input type="file" id="fileInput" multiple accept="image/*" style="display:none;">
                            <button type="button" class="btn btn-admin-primary" id="chooseFilesBtn">
                                <i class="fas fa-folder-open me-2"></i>Choisir les fichiers
                            </button>
                        </div>
                        <div id="filePreview" class="row mt-3"></div>
                        <div class="mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <small class="text-muted"><i class="fas fa-info-circle me-1"></i><span id="fileCounter">0 fichier(s) s&eacute;lectionn&eacute;(s)</span></small>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary" style="display:none;" id="clearBtn" onclick="clearFiles()">
                                    <i class="fas fa-times me-1"></i>Effacer
                                </button>
                                <button type="submit" class="btn btn-admin-primary" style="display:none;" id="uploadBtn">
                                    <i class="fas fa-upload me-1"></i>Uploader les images
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Carte : Gestion des catégories -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon" style="background:linear-gradient(135deg,#F59E0B,#D97706);">
                        <i class="fas fa-folder" style="color:white;"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Gestion des cat&eacute;gories</div>
                        <div class="form-card-sub">Consultez, &eacute;ditez ou supprimez vos photos par cat&eacute;gorie</div>
                    </div>
                </div>
                <div class="form-card-body">
                    <div id="categoriesContainer"></div>
                </div>
            </div>

        </div><!-- /.content-area -->

    <!-- Modal confirmation suppression -->
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0" style="background:linear-gradient(135deg,#dc3545,#b02a37);">
                    <h5 class="modal-title text-white fs-6">
                        <i class="fas fa-exclamation-triangle me-2"></i>Confirmer la suppression
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="fas fa-trash-alt text-danger mb-3" style="font-size:2rem;"></i>
                    <p class="mb-1 fw-semibold">&Ecirc;tes-vous s&ucirc;r ?</p>
                    <p class="text-muted small mb-0">Cette action est irr&eacute;versible.</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-danger btn-sm" id="confirmDelete">
                        <i class="fas fa-trash me-1"></i>Supprimer
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Données des catégories (à remplacer par appel API)
        let categories = [
            {
                id: 'culture',
                name: 'Événements Culturels',
                description: 'Photos des événements culturels',
                images: [
                    { id: 1, src: '/images/logo ensemble.png', title: 'Festival Culturel TELEX' },
                    { id: 2, src: '/images/camera.png', title: 'Spectacle Traditionnel' },
                    { id: 3, src: '/images/ensemble telex2.png', title: 'Ensemble Culturel' }
                ]
            },
            {
                id: 'sport',
                name: 'Événements Sportifs',
                description: 'Photos des événements sportifs',
                images: [
                    { id: 4, src: '/images/TELEX BAREA.png', title: 'Compétition Sportive' },
                    { id: 5, src: '/images/Présentation telex.png', title: 'Équipe Sportive' }
                ]
            },
            {
                id: 'coutume',
                name: 'Événements Coutumes',
                description: 'Photos des coutumes et traditions',
                images: [
                    { id: 6, src: '/images/femme telex.png', title: 'Coutume Traditionnelle' }
                ]
            }
        ];

        let deleteTarget = null;

        // Initialisation
        document.addEventListener('DOMContentLoaded', function() {
            loadCategories();
            updateStats();
            setupUploadArea();
        });

        // Charger les catégories
        function loadCategories() {
            const container = document.getElementById('categoriesContainer');
            const select = document.getElementById('categorySelect');
            
            container.innerHTML = '';
            select.innerHTML = '<option value="">Choisir une catégorie...</option>';
            
            categories.forEach(category => {
                // Ajouter au select
                const option = document.createElement('option');
                option.value = category.id;
                option.textContent = category.name;
                select.appendChild(option);
                
                // Créer la carte de catégorie
                const categoryCard = createCategoryCard(category);
                container.appendChild(categoryCard);
            });
        }

        // Créer une carte de catégorie
        function createCategoryCard(category) {
            const card = document.createElement('div');
            card.className = 'category-card';
            card.innerHTML = `
                <div class="category-header">
                    <div>
                        <h4 class="category-title">${category.name}</h4>
                        <p class="text-muted mb-0">${category.description}</p>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="category-count">${category.images.length} photos</span>
                        <button class="btn btn-sm btn-outline-primary" onclick="editCategory('${category.id}')">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteCategory('${category.id}')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
                <div class="image-grid">
                    ${category.images.map(image => `
                        <div class="image-item" data-image-id="${image.id}">
                            <img src="${image.src}" alt="${image.title}" title="${image.title}">
                            <div class="image-actions">
                                <button class="image-action-btn" onclick="viewImage('${image.src}', '${image.title}')">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="image-action-btn delete" onclick="deleteImage('${category.id}', '${image.filename}')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    `).join('')}
                </div>
            `;
            return card;
        }

        // Mettre à jour les statistiques
        function updateStats() {
            const totalImages = categories.reduce((sum, cat) => sum + cat.images.length, 0);
            const totalCategories = categories.length;
            
            document.getElementById('totalImages').textContent = totalImages;
            document.getElementById('totalCategories').textContent = totalCategories;
            document.getElementById('recentUploads').textContent = Math.floor(Math.random() * 10) + 1;
            document.getElementById('storageUsed').textContent = Math.floor(totalImages * 0.5) + ' MB';
        }

        // Configuration de la zone d'upload
        function setupUploadArea() {
            const uploadArea = document.getElementById('uploadArea');
            const fileInput = document.getElementById('fileInput');
            const chooseFilesBtn = document.getElementById('chooseFilesBtn');
            
            // Événement pour la zone d'upload (cliquer sur la zone)
            uploadArea.addEventListener('click', (e) => {
                console.log('🔍 DEBUG: Upload area clicked, target:', e.target);
                // Uniquement ouvrir le sélecteur si on ne clique pas sur le bouton
                if (e.target !== chooseFilesBtn && !chooseFilesBtn.contains(e.target)) {
                    console.log('🔍 DEBUG: Opening file selector from upload area');
                    fileInput.click();
                } else {
                    console.log('🔍 DEBUG: Click was on chooseFilesBtn, ignoring');
                }
            });
            
            // Événement pour le bouton "Choisir les fichiers"
            chooseFilesBtn.addEventListener('click', (e) => {
                console.log('🔍 DEBUG: ChooseFilesBtn clicked');
                e.stopPropagation(); // Empêcher la propagation vers uploadArea
                fileInput.click();
            });
            
            uploadArea.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadArea.classList.add('dragover');
            });
            
            uploadArea.addEventListener('dragleave', () => {
                uploadArea.classList.remove('dragover');
            });
            
            uploadArea.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadArea.classList.remove('dragover');
                handleFiles(e.dataTransfer.files);
            });
            
            // Uniquement cet événement doit appeler handleFiles
            fileInput.addEventListener('change', (e) => {
                console.log('🔍 DEBUG: File input change event');
                console.log('🔍 DEBUG: Files selected:', e.target.files.length);
                handleFiles(e.target.files);
            });
        }

        // Variable globale pour stocker tous les fichiers sélectionnés
        let allSelectedFiles = [];

        // Gérer les fichiers
        function handleFiles(files) {
            console.log('🔍 DEBUG: === handleFiles called ===');
            console.log('🔍 DEBUG: Files count:', files.length);
            console.log('🔍 DEBUG: Current allSelectedFiles count:', allSelectedFiles.length);
            console.log('🔍 DEBUG: Stack trace:', new Error().stack);
            
            const preview = document.getElementById('filePreview');
            const uploadBtn = document.getElementById('uploadBtn');
            
            // NE PAS vider la prévisualisation - ajouter aux fichiers existants
            // preview.innerHTML = '';  // LIGNE SUPPRIMÉE
            
            let validFiles = [];
            
            Array.from(files).forEach(file => {
                if (file.type.startsWith('image/')) {
                    validFiles.push(file);
                    
                    // Ajouter aux fichiers globaux
                    if (!allSelectedFiles.some(f => f.name === file.name && f.size === file.size)) {
                        allSelectedFiles.push(file);
                        console.log('🔍 DEBUG: Added new file:', file.name);
                    } else {
                        console.log('🔍 DEBUG: Duplicate file skipped:', file.name);
                    }
                    
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        const previewItem = document.createElement('div');
                        previewItem.className = 'col-md-2 mb-2';
                        previewItem.innerHTML = `
                            <img src="${e.target.result}" class="img-fluid rounded" style="max-height: 100px;">
                            <p class="small mb-0">${file.name}</p>
                        `;
                        preview.appendChild(previewItem);
                    };
                    reader.readAsDataURL(file);
                }
            });
            
            console.log('🔍 DEBUG: Valid files:', validFiles.length);
            console.log('🔍 DEBUG: Total files selected:', allSelectedFiles.length);
            
            if (allSelectedFiles.length > 0) {
                uploadBtn.style.display = 'block';
                document.getElementById('clearBtn').style.display = 'block';
            } else {
                uploadBtn.style.display = 'none';
                document.getElementById('clearBtn').style.display = 'none';
            }
            
            // Mettre à jour le compteur
            document.getElementById('fileCounter').textContent = `${allSelectedFiles.length} fichier(s) sélectionné(s)`;
            
            console.log('🔍 DEBUG: === handleFiles completed ===');
        }

        // Effacer les fichiers sélectionnés
        function clearFiles() {
            const fileInput = document.getElementById('fileInput');
            const preview = document.getElementById('filePreview');
            const uploadBtn = document.getElementById('uploadBtn');
            const clearBtn = document.getElementById('clearBtn');
            
            fileInput.value = '';
            preview.innerHTML = '';
            uploadBtn.style.display = 'none';
            clearBtn.style.display = 'none';
            
            // Vider aussi les fichiers globaux
            allSelectedFiles = [];
            
            // Mettre à jour le compteur
            document.getElementById('fileCounter').textContent = '0 fichier(s) sélectionné(s)';
        }

        // Charger les catégories depuis l'API
        async function loadCategoriesFromAPI() {
            try {
                const response = await fetch('/admin/categories');
                const result = await response.json();
                
                if (result.success) {
                    categories = result.data;
                    loadCategories();
                } else {
                    console.error('Erreur lors du chargement des catégories:', result.message);
                }
            } catch (error) {
                console.error('Erreur lors du chargement des catégories:', error);
            }
        }

        // Charger les catégories au démarrage
        document.addEventListener('DOMContentLoaded', function() {
            loadCategoriesFromAPI();
        });

        // Ajouter une catégorie
        document.getElementById('addCategoryForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const name = document.getElementById('categoryName').value;
            const description = document.getElementById('categoryDescription').value;
            
            try {
                const response = await fetch('/admin/categories', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        name: name,
                        description: description
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Recharger les catégories depuis l'API
                    await loadCategoriesFromAPI();
                    updateStats();
                    
                    // Réinitialiser le formulaire
                    this.reset();
                    
                    // Afficher une notification de succès
                    showNotification('Catégorie ajoutée avec succès !', 'success');
                } else {
                    showNotification(result.message || 'Erreur lors de l\'ajout de la catégorie', 'error');
                }
            } catch (error) {
                console.error('Erreur lors de l\'ajout de la catégorie:', error);
                showNotification('Erreur lors de l\'ajout de la catégorie', 'error');
            }
        });

        // Upload d'images
        document.getElementById('uploadForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const categoryId = document.getElementById('categorySelect').value;
            
            // Utiliser les fichiers globaux au lieu de fileInput.files
            if (!categoryId || allSelectedFiles.length === 0) {
                showNotification('Veuillez sélectionner une catégorie et des images', 'warning');
                return;
            }
            
            try {
                const formData = new FormData();
                
                // Ajouter tous les fichiers sélectionnés (globaux)
                allSelectedFiles.forEach(file => {
                    formData.append('images', file);
                });
                
                console.log('🔍 DEBUG: Uploading', allSelectedFiles.length, 'files to category', categoryId);
                
                const response = await fetch(`/admin/upload/${categoryId}`, {
                    method: 'POST',
                    body: formData
                });
                
                // Vérifier si la réponse est OK
                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('Erreur HTTP:', response.status, response.statusText);
                    console.error('Réponse serveur:', errorText);
                    throw new Error(`Erreur HTTP ${response.status}: ${response.statusText}`);
                }
                
                const result = await response.json();
                
                if (result.success) {
                    // Recharger les catégories depuis l'API
                    await loadCategoriesFromAPI();
                    updateStats();
                    
                    // Réinitialiser proprement le formulaire
                    const fileInput = document.getElementById('fileInput');
                    fileInput.value = ''; // Vider le file input
                    document.getElementById('filePreview').innerHTML = ''; // Vider la prévisualisation
                    document.getElementById('uploadBtn').style.display = 'none'; // Cacher le bouton upload
                    document.getElementById('clearBtn').style.display = 'none'; // Cacher le bouton effacer
                    
                    // Vider les fichiers globaux
                    allSelectedFiles = [];
                    
                    // Réinitialiser le compteur
                    document.getElementById('fileCounter').textContent = '0 fichier(s) sélectionné(s)';
                    
                    // Afficher une notification de succès
                    showNotification(result.message || 'Images uploadées avec succès !', 'success');
                } else {
                    showNotification(result.message || 'Erreur lors de l\'upload des images', 'error');
                }
            } catch (error) {
                console.error('Erreur lors de l\'upload des images:', error);
                showNotification('Erreur lors de l\'upload des images', 'error');
                
                // Réinitialiser aussi en cas d'erreur
                const fileInput = document.getElementById('fileInput');
                fileInput.value = '';
                document.getElementById('filePreview').innerHTML = '';
                document.getElementById('uploadBtn').style.display = 'none';
                document.getElementById('clearBtn').style.display = 'none';
                allSelectedFiles = [];
                
                // Réinitialiser le compteur
                document.getElementById('fileCounter').textContent = '0 fichier(s) sélectionné(s)';
            }
        });

        // Supprimer une image
        function deleteImage(categoryId, filename) {
            deleteTarget = { categoryId, filename };
            const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }

        // Confirmer la suppression
        document.getElementById('confirmDelete').addEventListener('click', async function() {
            if (deleteTarget) {
                try {
                    const response = await fetch(`/admin/images/${deleteTarget.categoryId}/${deleteTarget.filename}`, {
                        method: 'DELETE'
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        // Recharger les catégories depuis l'API
                        await loadCategoriesFromAPI();
                        updateStats();
                        showNotification('Image supprimée avec succès', 'success');
                    } else {
                        showNotification(result.message || 'Erreur lors de la suppression de l\'image', 'error');
                    }
                } catch (error) {
                    console.error('Erreur lors de la suppression de l\'image:', error);
                    showNotification('Erreur lors de la suppression de l\'image', 'error');
                }
            }
            
            const modal = bootstrap.Modal.getInstance(document.getElementById('deleteModal'));
            modal.hide();
            deleteTarget = null;
        });

        // Voir une image
        function viewImage(src, title) {
            const modal = document.createElement('div');
            modal.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.9);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 10000;
                cursor: pointer;
            `;
            
            modal.innerHTML = `
                <div style="position: relative; max-width: 90%; max-height: 90vh;">
                    <button onclick="this.parentElement.parentElement.remove()" style="
                        position: absolute;
                        top: -40px;
                        right: -40px;
                        background: white;
                        border: none;
                        border-radius: 50%;
                        width: 40px;
                        height: 40px;
                        font-size: 20px;
                        cursor: pointer;
                    ">×</button>
                    <img src="${src}" alt="${title}" style="
                        max-width: 100%;
                        max-height: 90vh;
                        object-fit: contain;
                        border-radius: 10px;
                    ">
                </div>
            `;
            
            modal.addEventListener('click', function(e) {
                if (e.target === modal) {
                    document.body.removeChild(modal);
                }
            });
            
            document.body.appendChild(modal);
        }

        // Afficher une notification
        function showNotification(message, type = 'info') {
            const notification = document.createElement('div');
            notification.className = `alert alert-${type} position-fixed top-0 end-0 m-3`;
            notification.style.zIndex = '9999';
            notification.innerHTML = `
                <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'warning' ? 'exclamation-triangle' : 'info-circle'} me-2"></i>
                ${message}
            `;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }

        // Éditer une catégorie (placeholder)
        function editCategory(categoryId) {
            showNotification('Fonction d\'édition bientôt disponible', 'info');
        }

        // Supprimer une catégorie
        async function deleteCategory(categoryId) {
            if (confirm('Êtes-vous sûr de vouloir supprimer cette catégorie et toutes ses images ?')) {
                try {
                    const response = await fetch(`/admin/categories/${categoryId}`, {
                        method: 'DELETE'
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        // Recharger les catégories depuis l'API
                        await loadCategoriesFromAPI();
                        updateStats();
                        showNotification('Catégorie supprimée avec succès', 'success');
                    } else {
                        showNotification(result.message || 'Erreur lors de la suppression de la catégorie', 'error');
                    }
                } catch (error) {
                    console.error('Erreur lors de la suppression de la catégorie:', error);
                    showNotification('Erreur lors de la suppression de la catégorie', 'error');
                }
            }
        }
    </script>

    </div><!-- /.main-content -->
</div><!-- /.admin-wrapper -->

    <script>
        function openSidebar() {
            document.querySelector('.sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('show');
        }
        function closeSidebar() {
            document.querySelector('.sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }
    </script></body>
</html>
