<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --sidebar-width: 280px;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            color: #334155;
        }
        
        /* Sidebar */
        .sidebar { 
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%); 
            color: white; 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }
        
        .sidebar-brand {
            padding: 25px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(0, 0, 0, 0.1);
        }
        
        .sidebar-brand img {
            max-width: 120px;
            height: auto;
            max-height: 60px;
            margin-bottom: 15px;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
        }
        
        .sidebar-brand h3 {
            font-weight: 700;
            font-size: 1.5rem;
            margin-bottom: 5px;
        }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .nav-item {
            margin-bottom: 8px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 14px 18px;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s;
            font-weight: 500;
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateX(5px);
        }
        
        .nav-link.active {
            background: rgba(230, 57, 70, 0.15);
            color: white;
        }
        
        .nav-link i {
            width: 24px;
            font-size: 1.1rem;
            margin-right: 12px;
            text-align: center;
        }
        
        /* Main Content */
        .main-content { 
            margin-left: var(--sidebar-width); 
            padding: 30px;
            min-height: 100vh;
        }
        
        /* Top Bar */
        .top-bar {
            background: white;
            padding: 25px 30px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .page-title {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .page-logo {
            height: 40px;
            width: auto;
            opacity: 0.9;
        }
        
        .page-title h1 {
            font-weight: 700;
            color: var(--telex-blue);
            font-size: 1.8rem;
            margin-bottom: 5px;
        }
        
        .page-title p {
            color: #64748b;
            font-size: 1rem;
            margin: 0;
        }
        
        .top-actions {
            display: flex;
            gap: 15px;
            align-items: center;
        }
        
        .btn-telex {
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 10px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.3);
        }
        
        .btn-telex:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 18px rgba(230, 57, 70, 0.4);
            color: white;
        }
        
        /* Form Container */
        .form-container {
            background: white;
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
        }
        
        .form-header {
            border-bottom: 2px solid #f1f5f9;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        
        .form-header h2 {
            color: var(--telex-blue);
            font-weight: 700;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .form-header p {
            color: #64748b;
            margin: 0;
        }
        
        .form-group {
            margin-bottom: 25px;
        }
        
        .form-label {
            display: block;
            margin-bottom: 8px;
            color: var(--telex-blue);
            font-weight: 600;
            font-size: 0.95rem;
        }
        
        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            font-size: 1rem;
            transition: all 0.3s;
            background: #f8fafc;
        }
        
        .form-control:focus {
            outline: none;
            border-color: var(--telex-red);
            box-shadow: 0 0 0 3px rgba(230, 57, 70, 0.1);
            background: white;
        }
        
        textarea.form-control {
            resize: vertical;
            min-height: 120px;
        }
        
        .form-check {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        
        .form-check-input {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }
        
        .form-check-label {
            cursor: pointer;
            font-weight: 500;
            color: #334155;
        }
        
        .btn-success {
            background: linear-gradient(135deg, #10B981, #047857);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-success:hover {
            background: #047857;
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(16, 185, 129, 0.3);
        }
        
        .btn-outline-secondary {
            background: transparent;
            color: #64748b;
            border: 2px solid #e2e8f0;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-outline-secondary:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }
        
        /* Options de partage */
        .share-options {
            background: #f8fafc;
            border-radius: 12px;
            padding: 25px;
            margin-top: 20px;
            border: 1px solid #e2e8f0;
        }
        
        .share-options h5 {
            color: var(--telex-blue);
            margin-bottom: 20px;
            font-weight: 600;
            font-size: 1.1rem;
        }
        
        .share-checkboxes {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }
        
        .share-option {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }
        
        .share-option:hover {
            border-color: var(--telex-red);
            box-shadow: 0 4px 15px rgba(230, 57, 70, 0.15);
            transform: translateY(-2px);
        }
        
        .share-option input[type="checkbox"] {
            margin-right: 12px;
            transform: scale(1.3);
            accent-color: var(--telex-red);
        }
        
        .share-option label {
            margin: 0;
            cursor: pointer;
            font-weight: 600;
            color: #334155;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .share-option i {
            font-size: 1.2rem;
        }
        
        .share-facebook i { color: #1877f2; }
        .share-twitter i { color: #1da1f2; }
        .share-linkedin i { color: #0077b5; }
        .share-whatsapp i { color: #25d366; }
        .share-instagram i { color: #E4405F; }
        
        /* Alerts */
        .alert {
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 30px;
            border-left: 4px solid;
            display: flex;
            align-items: flex-start;
            gap: 15px;
        }
        
        .alert-success {
            background: linear-gradient(135deg, rgba(219, 234, 254, 0.8), rgba(224, 242, 254, 0.8));
            border-color: var(--telex-blue);
            color: var(--telex-blue);
        }
        
        .alert-danger {
            background: linear-gradient(135deg, rgba(254, 243, 199, 0.8), rgba(253, 230, 138, 0.8));
            border-color: #F59E0B;
            color: #7d6608;
        }
        
        .alert i {
            font-size: 1.5rem;
            margin-top: 2px;
        }
        
        .alert-content h4 {
            margin-bottom: 5px;
            font-weight: 700;
        }
        
        /* Responsive */
        @media (max-width: 992px) {
            .sidebar {
                width: 70px;
                overflow: hidden;
            }
            
            .sidebar-brand h3,
            .sidebar-brand img {
                display: none;
            }
            
            .sidebar-brand {
                padding: 15px 10px;
            }
            
            .sidebar-brand::after {
                content: "P";
                color: white;
                font-size: 1.5rem;
                font-weight: bold;
                display: block;
            }
            
            .nav-link span {
                display: none;
            }
            
            .nav-link {
                justify-content: center;
                padding: 15px;
            }
            
            .nav-link i {
                margin-right: 0;
                font-size: 1.2rem;
            }
            
            .main-content {
                margin-left: 70px;
                padding: 20px;
            }
            
            .top-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            
            .top-actions {
                width: 100%;
                justify-content: space-between;
            }
        }
    </style>
</head>
<body>
    <!-- Sidebar (identique à programs_new.ejs) -->
    <div class="sidebar">
        <div class="sidebar-brand">
            <img src="/images/Telex.png" alt="TELEX">
            <h3>Telex Admin</h3>
        </div>
        
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/news" class="nav-link">
                    <i class="fas fa-newspaper"></i>
                    <span>Actualités</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/programs" class="nav-link active">
                    <i class="fas fa-tv"></i>
                    <span>Programmes</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/contacts" class="nav-link">
                    <i class="fas fa-envelope"></i>
                    <span>Messages</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/gallery" class="nav-link">
                    <i class="fas fa-images"></i>
                    <span>Galerie</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/settings" class="nav-link">
                    <i class="fas fa-cog"></i>
                    <span>Paramètres</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/logout" class="nav-link">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Déconnexion</span>
                </a>
            </div>
        </nav>
    </div>
    
    <!-- Main Content -->
    <div class="main-content">
        <!-- Top bar -->
        <div class="top-bar">
            <div class="page-title">
                <img src="/images/Telex.png" alt="TELEX" class="page-logo">
                <div>
                    <h1>Éditer le Programme</h1>
                    <p>Modifiez les informations de votre émission TELEX</p>
                </div>
            </div>
            <div class="top-actions">
                <a href="/admin/programs" class="btn btn-telex">
                    <i class="fas fa-arrow-left me-2"></i>Retour aux programmes
                </a>
            </div>
        </div>
        
        <!-- Flash Messages -->
        <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            <div class="alert-content">
                <h4>Succès</h4>
                <p><%= success_msg %></p>
            </div>
        </div>
        <% } %>
        
        <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle"></i>
            <div class="alert-content">
                <h4>Erreur</h4>
                <p><%= error_msg %></p>
            </div>
        </div>
        <% } %>
        
        <!-- Form -->
        <div class="form-container">
            <div class="form-header">
                <h2><i class="fas fa-edit"></i>Édition du programme</h2>
                <p>Modifiez les informations de votre programme TELEX</p>
            </div>
            
            <form action="/admin/programs/update/<%= program.id %>" method="POST">
                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label for="title" class="form-label">Titre du programme *</label>
                            <input type="text" 
                                   class="form-control" 
                                   id="title" 
                                   name="title" 
                                   required 
                                   value="<%= program.title %>"
                                   placeholder="Ex: Le Journal de TELEX">
                        </div>
                        
                        <div class="form-group">
                            <label for="description" class="form-label">Description</label>
                            <textarea class="form-control" 
                                      id="description" 
                                      name="description" 
                                      placeholder="Décrivez votre programme en quelques lignes..."><%= program.description || '' %></textarea>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="presenter" class="form-label">Présentateur</label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="presenter" 
                                           name="presenter" 
                                           value="<%= program.presenter || '' %>"
                                           placeholder="Nom du présentateur">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="schedule_time" class="form-label">Horaire</label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="schedule_time" 
                                           name="schedule_time" 
                                           value="<%= program.schedule_time || '' %>"
                                           placeholder="Ex: 20h00">
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="category" class="form-label">Catégorie</label>
                            <select class="form-control" id="category" name="category">
                                <option value="">Sélectionner une catégorie</option>
                                <option value="actualités" <%= program.category === 'actualités' ? 'selected' : '' %>>Actualités</option>
                                <option value="divertissement" <%= program.category === 'divertissement' ? 'selected' : '' %>>Divertissement</option>
                                <option value="culture" <%= program.category === 'culture' ? 'selected' : '' %>>Culture</option>
                                <option value="sport" <%= program.category === 'sport' ? 'selected' : '' %>>Sport</option>
                                <option value="musique" <%= program.category === 'musique' ? 'selected' : '' %>>Musique</option>
                                <option value="documentaire" <%= program.category === 'documentaire' ? 'selected' : '' %>>Documentaire</option>
                                <option value="jeux" <%= program.category === 'jeux' ? 'selected' : '' %>>Jeux</option>
                                <option value="autre" <%= program.category === 'autre' ? 'selected' : '' %>>Autre</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="duration" class="form-label">Durée</label>
                            <input type="text" 
                                   class="form-control" 
                                   id="duration" 
                                   name="duration" 
                                   value="<%= program.duration || '' %>"
                                   placeholder="Ex: 30 min">
                        </div>
                        
                        <div class="form-check">
                            <input type="checkbox" 
                                   class="form-check-input" 
                                   id="is_active" 
                                   name="is_active" 
                                   <%= program.is_active ? 'checked' : '' %>>
                            <label class="form-check-label" for="is_active">
                                Programme actif
                            </label>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between mt-4">
                    <a href="/admin/programs" class="btn btn-outline-secondary">
                        <i class="fas fa-times me-2"></i>Annuler
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save me-2"></i>Mettre à jour
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Page Édition Programme TELEX chargée');
            
            // Auto-close alerts after 5 seconds
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.opacity = '0';
                    alert.style.transition = 'opacity 0.5s';
                    setTimeout(() => alert.remove(), 500);
                }, 5000);
            });
            
            // Form validation
            const form = document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function(e) {
                    const title = document.getElementById('title').value.trim();
                    
                    if (!title) {
                        e.preventDefault();
                        alert('Le titre du programme est obligatoire.');
                        return false;
                    }
                    
                    // Animation de soumission
                    const submitBtn = this.querySelector('button[type="submit"]');
                    const originalHTML = submitBtn.innerHTML;
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Mise à jour...';
                    submitBtn.disabled = true;
                });
            }
        });
    </script>
</body>
</html>