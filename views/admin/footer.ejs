<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --sidebar-width: 280px;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            color: #334155;
        }
        
        /* Sidebar */
        .sidebar { 
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%); 
            color: white; 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }
        
        /* ── Sidebar header Option B ── */
        .sb-header { display:flex; align-items:center; justify-content:center; padding:18px 16px; border-bottom:1px solid rgba(255,255,255,.08); transition:background .2s; }
        .sb-header:hover { background: rgba(255,255,255,.04); }
        .sb-logo { height:52px; width:auto; display:block; flex-shrink:0; }
        .nav-section-label { font-size:.68rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:rgba(255,255,255,.28); padding:14px 10px 5px; }
        .sidebar-footer { padding:8px 10px 12px; border-top:1px solid rgba(255,255,255,.08); }
        .nav-link.logout { color:rgba(255,160,160,.7); }
        .nav-link.logout:hover { background:rgba(255,107,107,.1); color:#ff9e9e; }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .nav-item {
            margin-bottom: 8px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 14px 18px;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s;
            font-weight: 500;
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateX(5px);
        }
        
        .nav-link.active {
            background: var(--telex-red);
            color: white;
        }
        
        .nav-link i {
            margin-right: 12px;
            font-size: 1.1rem;
        }
        
        /* ── Main Content ── */
        .main-content { margin-left:var(--sidebar-width); min-height:100vh; padding:0; }

        /* ── Dash Header ── */
        .dash-header { background:linear-gradient(135deg,#1D3557 0%,#2d4f7a 100%); padding:16px 28px; display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; }
        .dash-header-left { display:flex; align-items:center; gap:14px; }
        .dash-header-logo { height:44px; width:auto; object-fit:contain; }
        .dash-header-title { font-size:1.15rem; font-weight:700; color:#fff; }
        .dash-header-sub { font-size:.8rem; color:rgba(255,255,255,.65); margin-top:2px; }
        .dash-header-right { display:flex; align-items:center; gap:10px; }
        .btn-dash-back { display:inline-flex; align-items:center; gap:7px; background:rgba(255,255,255,.12); color:#fff; border:1px solid rgba(255,255,255,.2); border-radius:8px; padding:7px 14px; font-size:.85rem; font-weight:500; text-decoration:none; transition:background .2s; }
        .btn-dash-back:hover { background:rgba(255,255,255,.22); color:#fff; }

        /* ── Content Area ── */
        .content-area { padding:22px 28px; }
        @media (max-width:576px) { .content-area { padding:14px; } }

        /* ── Alerts ── */
        .flash-alert { padding:12px 16px; border-radius:10px; margin-bottom:16px; display:flex; align-items:center; gap:10px; font-size:.88rem; border-left:4px solid; }
        .flash-success { background:#f0fdf4; border-color:#10B981; color:#065f46; }
        .flash-error   { background:#fef2f2; border-color:#EF4444; color:#7f1d1d; }

        /* ── Form Cards ── */
        .form-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.07); border:1px solid #e2e8f0; margin-bottom:18px; overflow:hidden; }
        .form-card-header { display:flex; align-items:center; gap:14px; padding:16px 22px 14px; border-bottom:1px solid #f1f5f9; background:#fafbfc; }
        .form-card-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; }
        .form-card-title { font-size:.96rem; font-weight:700; color:#1e293b; }
        .form-card-sub { font-size:.77rem; color:#64748b; margin-top:2px; }
        .form-card-body { padding:20px 22px; }

        /* ── Form controls ── */
        .form-label { font-weight:600; color:#374151; font-size:.84rem; margin-bottom:5px; display:block; }
        .form-control { border:1.5px solid #e2e8f0; border-radius:8px; padding:9px 12px; font-size:.9rem; width:100%; transition:border-color .2s, box-shadow .2s; }
        .form-control:focus { border-color:#457B9D; box-shadow:0 0 0 3px rgba(69,123,157,.12); outline:none; }
        .form-text { font-size:.77rem; color:#94a3b8; margin-top:4px; display:block; }

        /* ── Social input rows ── */
        .social-row { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
        .social-icon-badge { width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:.95rem; color:#fff; flex-shrink:0; }
        .soc-youtube   { background:#ff0000; }
        .soc-instagram { background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888); }
        .soc-facebook  { background:#1877f2; }
        .soc-tiktok    { background:#010101; }
        .soc-twitter   { background:#1da1f2; }

        /* ── Social preview ── */
        .social-preview { display:flex; gap:8px; flex-wrap:wrap; margin-top:6px; }
        .social-preview a { display:inline-flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:50%; color:#fff; text-decoration:none; font-size:.95rem; transition:transform .2s; }
        .social-preview a:hover { transform:scale(1.12); }

        /* ── Buttons ── */
        .btn-primary-save { background:linear-gradient(135deg,#1D3557,#457B9D); color:#fff; border:none; padding:10px 22px; border-radius:8px; font-weight:600; font-size:.9rem; cursor:pointer; display:inline-flex; align-items:center; gap:8px; transition:all .2s; }
        .btn-primary-save:hover { transform:translateY(-1px); box-shadow:0 4px 14px rgba(29,53,87,.3); }
        .btn-secondary-cancel { background:#f1f5f9; color:#374151; border:1.5px solid #e2e8f0; padding:10px 20px; border-radius:8px; font-weight:600; font-size:.9rem; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:background .2s; }
        .btn-secondary-cancel:hover { background:#e2e8f0; color:#1e293b; }

        /* ── Responsive sidebar ── */
        @media (max-width: 992px) {
            .sidebar { width:70px; overflow:hidden; }
            .sb-header { padding:12px 0; }
            .sb-logo { height:32px; }
            .nav-section-label { display:none; }
            .nav-link span { display:none; }
            .nav-link { justify-content:center; padding:11px 0; }
            .sidebar-footer { padding:6px 4px 10px; }
            .main-content { margin-left:70px; }
        }
    
        /* ── Responsive mobile (<576px) ── */
        @media (max-width: 576px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform .3s ease;
                z-index: 1050;
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.45);
                z-index: 1040;
            }
            .sidebar-overlay.show { display: block; }
            .main-content { margin-left: 0 !important; }
            .mobile-menu-btn {
                display: flex !important;
            }
        }
        .mobile-menu-btn {
            display: none;
            position: fixed;
            top: 14px;
            left: 14px;
            z-index: 1060;
            background: var(--telex-blue, #1D3557);
            color: white;
            border: none;
            border-radius: 8px;
            width: 40px;
            height: 40px;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.25);
        }</style>
</head>
<body>
    <div id="sidebarOverlay" class="sidebar-overlay" onclick="closeSidebar()"></div>
    <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fas fa-bars"></i></button>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sb-header">
            <img src="/images/Telex.png" alt="Telex" class="sb-logo">
        </div>
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i><span>Dashboard</span>
                </a>
            </div>
            <div class="nav-section-label">Contenu</div>
            <div class="nav-item"><a href="/admin/news" class="nav-link"><i class="fas fa-newspaper"></i><span>Actualités</span></a></div>
            <div class="nav-item"><a href="/admin/programs" class="nav-link"><i class="fas fa-tv"></i><span>Programmes</span></a></div>
            <div class="nav-section-label">Communauté</div>
            <div class="nav-item"><a href="/admin/baume-de-la-foi" class="nav-link"><i class="fas fa-cross"></i><span>Baume de la Foi</span></a></div>
            <div class="nav-item"><a href="/admin/contacts" class="nav-link"><i class="fas fa-envelope"></i><span>Messages</span></a></div>
            <div class="nav-section-label">Médias</div>
            <div class="nav-item"><a href="/admin/gallery" class="nav-link"><i class="fas fa-images"></i><span>Galerie</span></a></div>
            <div class="nav-item"><a href="/admin/album" class="nav-link"><i class="fas fa-book"></i><span>Album</span></a></div>
        </nav>
        <div class="sidebar-footer">
            <div class="nav-item"><a href="/admin/settings" class="nav-link"><i class="fas fa-cog"></i><span>Paramètres</span></a></div>
            <div class="nav-item"><a href="/admin/logout" class="nav-link logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a></div>
        </div>
    </div>
    
    <!-- Main Content -->
    <div class="main-content">

        <!-- Dash Header -->
        <div class="dash-header">
            <div class="dash-header-left">
                <img src="/images/Telex.png" alt="Telex" class="dash-header-logo">
                <div>
                    <div class="dash-header-title"><i class="fas fa-globe me-2" style="color:#A8DADC;font-size:.95rem;"></i>Footer du site</div>
                    <div class="dash-header-sub">Modifier les liens et informations du pied de page</div>
                </div>
            </div>
            <div class="dash-header-right">
                <a href="/admin/settings" class="btn-dash-back"><i class="fas fa-arrow-left"></i>Param&egrave;tres</a>
            </div>
        </div>

        <div class="content-area">

            <!-- Alerts -->
            <% if (success_msg) { %>
            <div class="flash-alert flash-success"><i class="fas fa-check-circle"></i><span><%= success_msg %></span></div>
            <% } %>
            <% if (error_msg) { %>
            <div class="flash-alert flash-error"><i class="fas fa-exclamation-circle"></i><span><%= error_msg %></span></div>
            <% } %>

            <form action="/admin/footer/update" method="POST">

                <!-- CARTE 1 : Contact -->
                <div class="form-card">
                    <div class="form-card-header">
                        <div class="form-card-icon" style="background:linear-gradient(135deg,#3B82F6,#1D4ED8);">
                            <i class="fas fa-address-card" style="color:white;"></i>
                        </div>
                        <div>
                            <div class="form-card-title">Informations de contact</div>
                            <div class="form-card-sub">Email, t&eacute;l&eacute;phone et adresse affich&eacute;s dans le footer</div>
                        </div>
                    </div>
                    <div class="form-card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="contact_email" class="form-label">Email de contact</label>
                                <input type="email" class="form-control" id="contact_email" name="contact_email"
                                       value="<%= settings.contact_email || '' %>" placeholder="contact@telex.fr">
                            </div>
                            <div class="col-md-6">
                                <label for="contact_phone" class="form-label">T&eacute;l&eacute;phone principal</label>
                                <input type="tel" class="form-control" id="contact_phone" name="contact_phone"
                                       value="<%= settings.contact_phone || '' %>" placeholder="01 23 45 67 89">
                            </div>
                            <div class="col-md-6">
                                <label for="contact_phone_2" class="form-label">T&eacute;l&eacute;phone 2 (optionnel)</label>
                                <input type="tel" class="form-control" id="contact_phone_2" name="contact_phone_2"
                                       value="<%= settings.contact_phone_2 || '' %>" placeholder="06 12 34 56 78">
                            </div>
                            <div class="col-md-6">
                                <label for="contact_address" class="form-label">Adresse</label>
                                <input type="text" class="form-control" id="contact_address" name="contact_address"
                                       value="<%= settings.contact_address || '' %>" placeholder="Campus Universitaire, Paris">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CARTE 2 : Marque -->
                <div class="form-card">
                    <div class="form-card-header">
                        <div class="form-card-icon" style="background:linear-gradient(135deg,#10B981,#047857);">
                            <i class="fas fa-building" style="color:white;"></i>
                        </div>
                        <div>
                            <div class="form-card-title">Informations de la marque</div>
                            <div class="form-card-sub">Logo, description et texte de copyright</div>
                        </div>
                    </div>
                    <div class="form-card-body">
                        <div class="row g-3">
                            <div class="col-md-5">
                                <label for="footer_logo" class="form-label">URL du logo</label>
                                <input type="text" class="form-control" id="footer_logo" name="footer_logo"
                                       value="<%= settings.footer_logo || '/images/11.png' %>" placeholder="/images/Telex.png">
                            </div>
                            <div class="col-md-7">
                                <label for="footer_description" class="form-label">Description courte</label>
                                <input type="text" class="form-control" id="footer_description" name="footer_description"
                                       value="<%= settings.footer_description || '' %>" placeholder="T&eacute;l&eacute;vision &eacute;tudiante jeune et engag&eacute;e">
                            </div>
                            <div class="col-12">
                                <label for="copyright_text" class="form-label"><i class="fas fa-copyright me-1"></i>Texte du copyright</label>
                                <input type="text" class="form-control" id="copyright_text" name="copyright_text"
                                       value="<%= settings.copyright_text || '© 2026 Telex - Tous droits réservés' %>">
                                <span class="form-text">Affich&eacute; en bas du pied de page sur toutes les pages du site.</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CARTE 3 : Réseaux sociaux -->
                <div class="form-card">
                    <div class="form-card-header">
                        <div class="form-card-icon" style="background:linear-gradient(135deg,#F59E0B,#D97706);">
                            <i class="fas fa-share-alt" style="color:white;"></i>
                        </div>
                        <div>
                            <div class="form-card-title">R&eacute;seaux sociaux</div>
                            <div class="form-card-sub">URLs affich&eacute;es comme ic&ocirc;nes dans le footer</div>
                        </div>
                    </div>
                    <div class="form-card-body">
                        <div class="social-row">
                            <div class="social-icon-badge soc-youtube"><i class="fab fa-youtube"></i></div>
                            <input type="url" class="form-control" name="youtube_url" id="youtube_url"
                                   value="<%= settings.youtube_url || '' %>" placeholder="https://www.youtube.com/@Telexmadagascar">
                        </div>
                        <div class="social-row">
                            <div class="social-icon-badge soc-instagram"><i class="fab fa-instagram"></i></div>
                            <input type="url" class="form-control" name="instagram_url" id="instagram_url"
                                   value="<%= settings.instagram_url || '' %>" placeholder="https://www.instagram.com/telexmadagascar">
                        </div>
                        <div class="social-row">
                            <div class="social-icon-badge soc-facebook"><i class="fab fa-facebook"></i></div>
                            <input type="url" class="form-control" name="facebook_url" id="facebook_url"
                                   value="<%= settings.facebook_url || '' %>" placeholder="https://www.facebook.com/Telexmadagascar">
                        </div>
                        <div class="social-row">
                            <div class="social-icon-badge soc-tiktok"><i class="fab fa-tiktok"></i></div>
                            <input type="url" class="form-control" name="tiktok_url" id="tiktok_url"
                                   value="<%= settings.tiktok_url || '' %>" placeholder="https://www.tiktok.com/@telexmadagascar">
                        </div>
                        <div class="social-row" style="margin-bottom:0;">
                            <div class="social-icon-badge soc-twitter"><i class="fab fa-twitter"></i></div>
                            <input type="url" class="form-control" name="twitter_url" id="twitter_url"
                                   value="<%= settings.twitter_url || '' %>" placeholder="https://twitter.com/TelexMadagascar">
                        </div>

                        <!-- Aperçu -->
                        <% const hasSocial = settings.youtube_url || settings.instagram_url || settings.facebook_url || settings.tiktok_url || settings.twitter_url; %>
                        <% if (hasSocial) { %>
                        <div style="margin-top:16px; padding-top:14px; border-top:1px solid #f1f5f9;">
                            <div class="form-label" style="margin-bottom:8px;">Aper&ccedil;u</div>
                            <div class="social-preview">
                                <% if (settings.youtube_url) { %><a href="<%= settings.youtube_url %>" target="_blank" class="soc-youtube" title="YouTube"><i class="fab fa-youtube"></i></a><% } %>
                                <% if (settings.instagram_url) { %><a href="<%= settings.instagram_url %>" target="_blank" class="soc-instagram" title="Instagram"><i class="fab fa-instagram"></i></a><% } %>
                                <% if (settings.facebook_url) { %><a href="<%= settings.facebook_url %>" target="_blank" class="soc-facebook" title="Facebook"><i class="fab fa-facebook"></i></a><% } %>
                                <% if (settings.tiktok_url) { %><a href="<%= settings.tiktok_url %>" target="_blank" class="soc-tiktok" title="TikTok"><i class="fab fa-tiktok"></i></a><% } %>
                                <% if (settings.twitter_url) { %><a href="<%= settings.twitter_url %>" target="_blank" class="soc-twitter" title="Twitter"><i class="fab fa-twitter"></i></a><% } %>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>

                <!-- CARTE 4 : Actions -->
                <div class="form-card">
                    <div class="form-card-body" style="padding:16px 22px;">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <small class="text-muted"><i class="fas fa-info-circle me-1"></i>Les modifications seront appliqu&eacute;es imm&eacute;diatement sur le site.</small>
                            <div class="d-flex gap-2">
                                <a href="/admin/settings" class="btn-secondary-cancel"><i class="fas fa-times"></i>Annuler</a>
                                <button type="submit" class="btn-primary-save"><i class="fas fa-save"></i>Enregistrer les modifications</button>
                            </div>
                        </div>
                    </div>
                </div>

            </form>
        </div><!-- /.content-area -->
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function openSidebar() {
            document.querySelector('.sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('show');
        }
        function closeSidebar() {
            document.querySelector('.sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }
    </script></body>
</html>
