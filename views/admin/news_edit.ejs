<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Summernote -->
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --sidebar-width: 280px;
        }
        
        body {
            background-color: #f8f9fa;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .sidebar {
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%);
            color: white;
            height: 100vh;
            width: var(--sidebar-width);
            position: fixed;
            left: 0;
            top: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0,0,0,.1);
            display: flex;
            flex-direction: column;
        }
        
        /* ── Sidebar header Option B ── */
        .sb-header { display:flex; align-items:center; justify-content:center; padding:18px 16px; border-bottom:1px solid rgba(255,255,255,.08); transition:background .2s; }
        .sb-header:hover { background: rgba(255,255,255,.04); }
        .sb-logo { height:52px; width:auto; display:block; flex-shrink:0; }
        .nav-section-label { font-size:.68rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:rgba(255,255,255,.28); padding:14px 10px 5px; }
        .sidebar-footer { padding:8px 10px 12px; border-top:1px solid rgba(255,255,255,.08); }
        .nav-link.logout { color:rgba(255,160,160,.7); }
        .nav-link.logout:hover { background:rgba(255,107,107,.1); color:#ff9e9e; }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .nav-item {
            margin: 0.25rem 0.5rem;
        }
        
        .nav-link {
            color: rgba(255, 255, 255, 0.8);
            padding: 0.75rem 1rem;
            border-radius: 5px;
            text-decoration: none;
            display: flex;
            align-items: center;
            transition: all 0.3s;
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
        }
        
        .nav-link.active {
            background: var(--telex-red);
            color: white;
        }
        
        .nav-link i {
            width: 24px;
            margin-right: 0.75rem;
            font-size: 1.1rem;
        }
        
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 24px 28px;
            min-height: 100vh;
        }

        /* ── Page header ── */
        .edit-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 22px; gap: 12px; flex-wrap: wrap;
        }
        .edit-breadcrumb { display: flex; align-items: center; gap: 10px; }
        .edit-breadcrumb a { color: #64748b; text-decoration: none; font-size: .82rem; }
        .edit-breadcrumb a:hover { color: var(--telex-blue); }
        .edit-breadcrumb .sep { color: #cbd5e1; font-size: .75rem; }
        .edit-breadcrumb .current { font-size: .82rem; color: var(--telex-blue); font-weight: 600; }
        .edit-header-title { font-size: 1.15rem; font-weight: 700; color: var(--telex-blue); margin: 3px 0 0; display: flex; align-items: center; gap: 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 600px; }
        .edit-header-title i { color: var(--telex-red); }
        .edit-header-actions { display: flex; gap: 8px; align-items: center; }

        .btn-telex {
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            color: white !important; border: none;
            padding: 10px 22px; border-radius: 9px; font-weight: 600; font-size: .88rem;
            display: inline-flex; align-items: center; text-decoration: none;
            transition: all .2s; box-shadow: 0 3px 10px rgba(230,57,70,.3);
        }
        .btn-telex:hover { transform: translateY(-2px); box-shadow: 0 5px 16px rgba(230,57,70,.4); }

        /* ── Cards ── */
        .card {
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            box-shadow: 0 1px 6px rgba(0,0,0,.05);
            margin-bottom: 18px;
            overflow: hidden;
        }
        .card-header {
            background: #f8fafc;
            border-bottom: 1px solid #f1f5f9;
            padding: 14px 20px;
            display: flex; align-items: center; gap: 10px;
        }
        .card-header-dot {
            width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
        }
        .card-title { font-size: .92rem; font-weight: 700; color: var(--telex-blue); margin: 0; }
        .card-body { padding: 20px; }
        
        /* ── Upload zones ── */
        .upload-area {
            border: 2px dashed #d1d5db;
            border-radius: 12px;
            padding: 28px 20px;
            text-align: center;
            background: #f8fafc;
            cursor: pointer;
            transition: all .2s;
            margin-bottom: 1rem;
        }
        .upload-area:hover, .upload-area.dragover {
            border-color: var(--telex-red);
            background: #fff8f8;
        }
        .upload-area i { font-size: 2.2rem; color: #94a3b8; margin-bottom: 10px; display: block; }
        .upload-area h5 { color: var(--telex-blue); font-size: .9rem; font-weight: 600; margin-bottom: 4px; }
        .upload-area p { color: #94a3b8; font-size: .78rem; margin-bottom: 0; }

        .image-preview { max-height: 180px; max-width: 100%; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.1); }
        .preview-card { border: 1px solid #e2e8f0; border-radius: 10px; padding: 14px; background: white; }

        /* ── Form fields ── */
        .form-control, .form-select {
            border: 1.5px solid #e2e8f0;
            border-radius: 9px;
            padding: 10px 14px;
            font-size: .88rem;
            transition: border-color .15s, box-shadow .15s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--telex-blue);
            box-shadow: 0 0 0 3px rgba(29,53,87,.08);
        }
        .form-label { font-size: .83rem; font-weight: 600; color: #475569; margin-bottom: 6px; }

        /* ── Status toggle ── */
        .status-toggle { display: flex; gap: 8px; }
        .status-opt { flex: 1; }
        .status-opt input[type="radio"] { display: none; }
        .status-opt label {
            display: flex; align-items: center; justify-content: center; gap: 7px;
            padding: 9px 14px; border: 1.5px solid #e2e8f0; border-radius: 9px;
            cursor: pointer; font-size: .83rem; font-weight: 600; color: #64748b;
            transition: all .15s; width: 100%;
        }
        .status-opt input:checked + label.pub-label  { border-color: #10B981; background: #f0fdf4; color: #047857; }
        .status-opt input:checked + label.draft-label { border-color: #64748b; background: #f8fafc; color: #475569; }

        /* ── Sticky save bar ── */
        .save-bar {
            position: sticky; bottom: 0; z-index: 100;
            background: white; border-top: 1px solid #e2e8f0;
            padding: 12px 20px; display: flex; gap: 10px; align-items: center;
            box-shadow: 0 -4px 16px rgba(0,0,0,.06);
            border-radius: 0 0 14px 14px;
        }
        
        /* Styles pour les miniatures de vidéo */
        .video-thumbnail {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            background: #f8f9fa;
            aspect-ratio: 16/9;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #dee2e6;
        }
        
        .video-thumbnail-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .video-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        /* Responsive */
        @media (max-width: 992px) {
            .sidebar {
                width: 70px;
                overflow: hidden;
            }
            
            .sb-header { padding:12px 0; }
            .sb-logo { height:32px; }
            .nav-section-label { display:none; }
            .nav-link span { display:none; }
            .nav-link { justify-content:center; padding:11px 0; }
            .sidebar-footer { padding:6px 4px 10px; }
            
            .main-content {
                margin-left: 70px;
            }
        }
        
        @media (max-width: 768px) {
            .row {
                flex-direction: column;
            }
            
            .col-lg-8, .col-lg-4 {
                width: 100%;
            }
        }
    
        /* ── Responsive mobile (<576px) ── */
        @media (max-width: 576px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform .3s ease;
                z-index: 1050;
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.45);
                z-index: 1040;
            }
            .sidebar-overlay.show { display: block; }
            .main-content { margin-left: 0 !important; }
            .mobile-menu-btn {
                display: flex !important;
            }
        }
        .mobile-menu-btn {
            display: none;
            position: fixed;
            top: 14px;
            left: 14px;
            z-index: 1060;
            background: var(--telex-blue, #1D3557);
            color: white;
            border: none;
            border-radius: 8px;
            width: 40px;
            height: 40px;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.25);
        }</style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sb-header">
            <img src="/images/Telex.png" alt="Telex" class="sb-logo">
        </div>
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i><span>Dashboard</span>
                </a>
            </div>
            <div class="nav-section-label">Contenu</div>
            <div class="nav-item"><a href="/admin/news" class="nav-link active"><i class="fas fa-newspaper"></i><span>Actualités</span></a></div>
            <div class="nav-item"><a href="/admin/programs" class="nav-link"><i class="fas fa-tv"></i><span>Programmes</span></a></div>
            <div class="nav-section-label">Communauté</div>
            <div class="nav-item"><a href="/admin/baume-de-la-foi" class="nav-link"><i class="fas fa-cross"></i><span>Baume de la Foi</span></a></div>
            <div class="nav-item"><a href="/admin/contacts" class="nav-link"><i class="fas fa-envelope"></i><span>Messages</span></a></div>
            <div class="nav-section-label">Médias</div>
            <div class="nav-item"><a href="/admin/gallery" class="nav-link"><i class="fas fa-images"></i><span>Galerie</span></a></div>
            <div class="nav-item"><a href="/admin/album" class="nav-link"><i class="fas fa-book"></i><span>Album</span></a></div>
        </nav>
        <div class="sidebar-footer">
            <div class="nav-item"><a href="/admin/settings" class="nav-link"><i class="fas fa-cog"></i><span>Paramètres</span></a></div>
            <div class="nav-item"><a href="/admin/logout" class="nav-link logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a></div>
        </div>
    </div>
    
    <!-- Main content -->
    <div class="main-content">
        <!-- Header -->
        <div class="edit-header">
            <div>
                <div class="edit-breadcrumb">
                    <a href="/admin/dashboard"><i class="fas fa-home"></i> Dashboard</a>
                    <span class="sep"><i class="fas fa-chevron-right"></i></span>
                    <a href="/admin/news">Actualités</a>
                    <span class="sep"><i class="fas fa-chevron-right"></i></span>
                    <span class="current"><% if (news) { %>Éditer<% } else { %>Nouvelle<% } %></span>
                </div>
                <div class="edit-header-title">
                    <i class="fas fa-<% if (news) { %>edit<% } else { %>plus-circle<% } %>"></i>
                    <% if (news) { %><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">Éditer : <%= news.title %></span><% } else { %>Nouvelle actualité<% } %>
                </div>
            </div>
            <div class="edit-header-actions">
                <% if (news) { %>
                <a href="/news/<%= news.slug %>" target="_blank" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-external-link-alt me-1"></i>Voir
                </a>
                <% } %>
                <a href="/admin/news" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Retour
                </a>
            </div>
        </div>
        
        <!-- Messages Flash -->
        <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        
        <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        
        <!-- Formulaire -->
        <form id="newsForm" method="POST" action="/admin/news/save" enctype="multipart/form-data">
            <% if (news) { %>
            <input type="hidden" name="id" value="<%= news.id %>">
            <% } %>
            
            <div class="row">
                <!-- Colonne principale -->
                <div class="col-lg-8">
                    <div class="card mb-3">
                        <div class="card-header">
                            <span class="card-header-dot" style="background:#3B82F6"></span>
                            <h5 class="card-title"><i class="fas fa-align-left me-2" style="color:#3B82F6"></i>Contenu de l'actualité</h5>
                        </div>
                        <div class="card-body">
                            <!-- Titre -->
                            <div class="mb-4">
                                <label for="title" class="form-label">
                                    Titre de l'actualité *
                                    <span class="badge bg-secondary ms-2" id="titleCount">0/150</span>
                                </label>
                                <input type="text" 
                                       class="form-control form-control-lg" 
                                       id="title" 
                                       name="title" 
                                       value="<%= news ? news.title : '' %>"
                                       placeholder="Titre accrocheur..."
                                       maxlength="150"
                                       required>
                                <div class="form-text d-flex justify-content-between">
                                    <span>Un titre clair et informatif pour le SEO</span>
                                    <span id="titleStatus" class="text-muted"></span>
                                </div>
                            </div>
                            
                            <!-- Extrait -->
                            <div class="mb-4">
                                <label for="excerpt" class="form-label">
                                    Extrait / Description courte *
                                    <span class="badge bg-secondary ms-2" id="excerptCount">0/300</span>
                                </label>
                                <textarea class="form-control" 
                                          id="excerpt" 
                                          name="excerpt" 
                                          rows="3"
                                          maxlength="300"
                                          placeholder="Résumé en 1-2 phrases..."
                                          required><%= news ? news.excerpt : '' %></textarea>
                                <div class="form-text d-flex justify-content-between">
                                    <span>Apparaît dans les listes et les résultats de recherche</span>
                                    <span id="excerptStatus" class="text-muted"></span>
                                </div>
                            </div>
                            
                            <!-- Contenu -->
                            <div class="mb-4">
                                <label for="content" class="form-label">Contenu détaillé *</label>
                                <textarea class="form-control" 
                                          id="content" 
                                          name="content" 
                                          rows="15"
                                          required><%= news ? news.content : '' %></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Colonne latérale -->
                <div class="col-lg-4">
                    <!-- Publication -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <span class="card-header-dot" style="background:#10B981"></span>
                            <h5 class="card-title"><i class="fas fa-paper-plane me-2" style="color:#10B981"></i>Publication</h5>
                        </div>
                        <div class="card-body">
                            <!-- Statut -->
                            <div class="mb-3">
                                <label class="form-label">Statut</label>
                                <div class="status-toggle">
                                    <div class="status-opt">
                                        <input type="radio" name="is_published" id="published" value="1"
                                               <%= news && news.is_published ? 'checked' : 'checked' %>>
                                        <label class="pub-label" for="published">
                                            <i class="fas fa-check-circle"></i>Publié
                                        </label>
                                    </div>
                                    <div class="status-opt">
                                        <input type="radio" name="is_published" id="draft" value="0"
                                               <%= news && !news.is_published ? 'checked' : '' %>>
                                        <label class="draft-label" for="draft">
                                            <i class="fas fa-pen"></i>Brouillon
                                        </label>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Auteur -->
                            <div class="mb-3">
                                <label for="author" class="form-label">Auteur</label>
                                <input type="text" 
                                       class="form-control" 
                                       id="author" 
                                       name="author" 
                                       value="<%= news ? news.author : 'Équipe TELEX' %>"
                                       placeholder="Nom de l'auteur">
                            </div>
                            
                            <!-- Catégorie -->
                            <div class="mb-3">
                                <label for="category" class="form-label">Catégorie</label>
                                <select class="form-select" id="category" name="category">
                                    <option value="politique" <%= news && news.category === 'politique' ? 'selected' : '' %>>Politique</option>
                                    <option value="economie" <%= news && news.category === 'economie' ? 'selected' : '' %>>Économie</option>
                                    <option value="social" <%= news && news.category === 'social' ? 'selected' : '' %>>Social</option>
                                    <option value="sport" <%= news && news.category === 'sport' ? 'selected' : '' %>>Sport</option>
                                    <option value="culturel" <%= news && news.category === 'culturel' ? 'selected' : '' %>>Culturel</option>
                                    <option value="annonce" <%= news && news.category === 'annonce' ? 'selected' : '' %>>Annonce</option>
                                    <option value="autre" <%= news && news.category === 'autre' ? 'selected' : '' %>>Autre</option>
                                </select>
                            </div>
                            
                            <!-- Choix du média principal -->
                            <div class="mb-4">
                                <label class="form-label">
                                    <i class="fas fa-photo-video me-2"></i>Type de média principal
                                </label>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" 
                                           type="radio" 
                                           name="media_type" 
                                           id="media_image" 
                                           value="image"
                                           <%= (!news || !news.video_url || (news.image_url && !news.video_url)) ? 'checked' : '' %>
                                           onchange="toggleMediaType('image')">
                                    <label class="form-check-label" for="media_image">
                                        <i class="fas fa-image me-1"></i>
                                        Image
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" 
                                           type="radio" 
                                           name="media_type" 
                                           id="media_video" 
                                           value="video"
                                           <%= (news && news.video_url) ? 'checked' : '' %>
                                           onchange="toggleMediaType('video')">
                                    <label class="form-check-label" for="media_video">
                                        <i class="fas fa-video me-1"></i>
                                        Vidéo
                                    </label>
                                </div>
                                <div class="form-text">
                                    <i class="fas fa-info-circle me-1"></i>
                                    Choisissez un seul type de média pour votre actualité
                                </div>
                            </div>
                            
                            <!-- Image - SECTION CONDITIONNELLE -->
                            <div class="mb-4" id="imageSection" style="<%= (news && news.video_url) ? 'display: none;' : '' %>">
                                <label class="form-label">
                                    <i class="fas fa-image me-2"></i>Image de l'actualité
                                </label>
                                
                                <!-- Zone de drag & drop -->
                                <div class="upload-area" id="uploadArea">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                    <h5>Glissez-déposez votre image ici</h5>
                                    <p>ou cliquez pour sélectionner</p>
                                    <p class="small text-muted">JPG, PNG, GIF, WebP (max 20MB)</p>
                                </div>
                                
                                <input type="file" 
                                       class="form-control d-none" 
                                       id="image_file" 
                                       name="image_file"
                                       accept=".jpg,.jpeg,.png,.gif,.webp">
                                
                                <!-- Prévisualisation -->
                                <div id="imagePreview" class="mt-3" style="<%= (news && news.image_url) ? '' : 'display: none;' %>">
                                    <div class="preview-card">
                                        <p class="small mb-2"><strong>Image actuelle :</strong></p>
                                        <div id="previewContainer">
                                            <% if (news && news.image_url) { %>
                                                <img src="<%= news.image_url %>" 
                                                     alt="Image actuelle" 
                                                     class="image-preview">
                                                <div class="mt-2">
                                                    <button type="button" 
                                                            class="btn btn-sm btn-outline-danger" 
                                                            onclick="removeImage()">
                                                        <i class="fas fa-trash me-1"></i>Supprimer l'image
                                                    </button>
                                                </div>
                                            <% } else { %>
                                                <p class="text-muted">Aucune image sélectionnée</p>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Vidéo - SECTION CONDITIONNELLE -->
                            <div class="mb-4" id="videoSection" style="<%= (news && news.video_url) ? '' : 'display: none;' %>">
                                <label class="form-label">
                                    <i class="fas fa-video me-2"></i>Vidéo de l'actualité
                                </label>
                                
                                <!-- Upload de fichier vidéo -->
                                <div class="mb-3">
                                    <label class="form-label small">Téléchargez votre fichier vidéo</label>
                                    <div class="upload-area" id="videoUploadArea">
                                        <i class="fas fa-video"></i>
                                        <h5>Glissez-déposez votre vidéo ici</h5>
                                        <p>ou cliquez pour sélectionner</p>
                                        <p class="small text-muted">MP4, WebM, OGG (max 1000MB)</p>
                                    </div>
                                    
                                    <input type="file" 
                                           class="form-control d-none" 
                                           id="video_file" 
                                           name="video_file"
                                           accept=".mp4,.webm,.ogg,.mov,.avi">
                                </div>
                                
                                <!-- Prévisualisation vidéo -->
                                <div id="videoPreview" class="mt-3" style="<%= (news && news.video_url) ? '' : 'display: none;' %>">
                                    <div class="preview-card">
                                        <p class="small mb-2"><strong>Vidéo actuelle :</strong></p>
                                        <div id="videoPreviewContainer">
                                            <% if (news && news.video_url) { %>
                                                <% if (news.video_url.includes('youtube.com') || news.video_url.includes('youtu.be')) { %>
                                                    <div class="video-thumbnail">
                                                        <img src="https://img.youtube.com/vi/<%= news.video_url.split(/v=|youtu.be\//)[1].split('&')[0] %>/hqdefault.jpg" 
                                                             alt="Miniature YouTube" 
                                                             class="video-thumbnail-img">
                                                        <div class="video-overlay">
                                                            <i class="fab fa-youtube fa-3x text-white"></i>
                                                        </div>
                                                    </div>
                                                <% } else if (news.video_url.includes('vimeo.com')) { %>
                                                    <div class="video-thumbnail">
                                                        <i class="fab fa-vimeo fa-3x text-primary"></i>
                                                        <p class="mt-2 mb-0">Vidéo Vimeo</p>
                                                    </div>
                                                <% } else { %>
                                                    <div class="video-thumbnail">
                                                        <video 
                                                            class="video-thumbnail-img" 
                                                            muted 
                                                            preload="metadata"
                                                            onloadeddata="this.poster=''"
                                                            onerror="handleVideoError(this)">
                                                            <source src="<%= news.video_url %>" type="video/mp4">
                                                            <source src="<%= news.video_url %>" type="video/webm">
                                                            <source src="<%= news.video_url %>" type="video/ogg">
                                                            Votre navigateur ne supporte pas la lecture de vidéos.
                                                        </video>
                                                        <div class="video-overlay" onclick="this.previousElementSibling.play()">
                                                            <i class="fas fa-play-circle fa-3x text-white"></i>
                                                        </div>
                                                    </div>
                                                <% } %>
                                                <div class="mt-2">
                                                    <button type="button" 
                                                            class="btn btn-sm btn-outline-danger" 
                                                            onclick="removeVideo()">
                                                        <i class="fas fa-trash me-1"></i>Supprimer la vidéo
                                                    </button>
                                                </div>
                                            <% } else { %>
                                                <p class="text-muted">Aucune vidéo sélectionnée</p>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Save bar sticky -->
                            <div class="save-bar mt-3">
                                <button type="submit" class="btn-telex">
                                    <i class="fas fa-save me-2"></i>
                                    <% if (news) { %>Mettre à jour<% } else { %>Publier l'actualité<% } %>
                                </button>
                                <a href="/admin/news" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-times me-1"></i>Annuler
                                </a>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Informations -->
                    <div class="card">
                        <div class="card-header">
                            <span class="card-header-dot" style="background:#94a3b8"></span>
                            <h5 class="card-title"><i class="fas fa-info-circle me-2" style="color:#94a3b8"></i>Informations</h5>
                        </div>
                        <div class="card-body" style="padding:16px 20px">
                            <% if (news) { %>
                            <div style="display:flex;flex-direction:column;gap:10px">
                                <div style="display:flex;justify-content:space-between;font-size:.82rem">
                                    <span style="color:#94a3b8">Créée le</span>
                                    <strong style="color:#334155"><%= new Date(news.created_at).toLocaleDateString('fr-FR') %></strong>
                                </div>
                                <div style="display:flex;justify-content:space-between;font-size:.82rem">
                                    <span style="color:#94a3b8">Vues</span>
                                    <strong style="color:var(--telex-red)"><i class="fas fa-eye me-1"></i><%= news.views || 0 %></strong>
                                </div>
                                <div style="display:flex;justify-content:space-between;font-size:.82rem">
                                    <span style="color:#94a3b8">ID</span>
                                    <code style="font-size:.78rem;color:#64748b">#<%= news.id %></code>
                                </div>
                            </div>
                            <% } else { %>
                            <p style="color:#94a3b8;font-size:.8rem;margin:0;line-height:1.5">
                                <i class="fas fa-lightbulb me-1" style="color:#F59E0B"></i>
                                Remplissez tous les champs marqués * pour créer une nouvelle actualité.
                            </p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/lang/summernote-fr-FR.min.js"></script>
    
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialiser l'éditeur Summernote
        $('#content').summernote({
            height: 300,
            lang: 'fr-FR',
            toolbar: [
                ['style', ['style']],
                ['font', ['bold', 'italic', 'underline', 'clear']],
                ['fontname', ['fontname']],
                ['color', ['color']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['height', ['height']],
                ['table', ['table']],
                ['insert', ['link', 'picture', 'video']],
                ['view', ['fullscreen', 'codeview', 'help']]
            ],
            placeholder: 'Écrivez votre contenu ici...'
        });
        console.log('🔍 DEBUG: Summernote réactivé - éditeur riche disponible');
        
        // ========== COMPTEURS DE CARACTÈRES ==========
        const titleInput = document.getElementById('title');
        const excerptInput = document.getElementById('excerpt');
        const titleCount = document.getElementById('titleCount');
        const excerptCount = document.getElementById('excerptCount');
        const titleStatus = document.getElementById('titleStatus');
        const excerptStatus = document.getElementById('excerptStatus');
        
        function updateCharacterCount(input, countElement, max, statusElement) {
            const count = input.value.length;
            countElement.textContent = `${count}/${max}`;
            
            // Mettre à jour le statut
            if (count === 0) {
                statusElement.innerHTML = '<i class="fas fa-info-circle"></i> Obligatoire';
                statusElement.className = 'text-muted';
                countElement.className = 'badge bg-secondary ms-2';
            } else if (count < max * 0.7) {
                statusElement.innerHTML = '<i class="fas fa-check-circle text-success"></i> Bon';
                statusElement.className = 'text-success';
                countElement.className = 'badge bg-success ms-2';
            } else if (count < max) {
                statusElement.innerHTML = '<i class="fas fa-exclamation-triangle text-warning"></i> Presque plein';
                statusElement.className = 'text-warning';
                countElement.className = 'badge bg-warning ms-2';
            } else {
                statusElement.innerHTML = '<i class="fas fa-times-circle text-danger"></i> Limite atteinte';
                statusElement.className = 'text-danger';
                countElement.className = 'badge bg-danger ms-2';
            }
        }
        
        // Initialiser les compteurs
        if (titleInput) {
            titleInput.addEventListener('input', () => updateCharacterCount(titleInput, titleCount, 150, titleStatus));
            updateCharacterCount(titleInput, titleCount, 150, titleStatus);
        }
        
        if (excerptInput) {
            excerptInput.addEventListener('input', () => updateCharacterCount(excerptInput, excerptCount, 300, excerptStatus));
            updateCharacterCount(excerptInput, excerptCount, 300, excerptStatus);
        }
        
        // ========== GESTION DE L'UPLOAD D'IMAGE ==========
        const uploadArea = document.getElementById('uploadArea');
        const fileInput = document.getElementById('image_file');
        const imagePreview = document.getElementById('imagePreview');
        const previewContainer = document.getElementById('previewContainer');
        
        // Variables globales
        let uploadedFile = null;
        let imageRemoved = false;
        let isUploading = false; // Variable pour suivre l'état d'upload
        
        console.log('🔍 DEBUG: Initialisation du formulaire');
        
        // Cliquer sur la zone = cliquer sur le input file
        uploadArea.addEventListener('click', function() {
            fileInput.click();
        });
        
        // Gérer la sélection de fichier
        fileInput.addEventListener('change', function(e) {
            if (this.files && this.files[0]) {
                handleFileUpload(this.files[0]);
            }
        });
        
        // Drag & drop
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            uploadArea.addEventListener(eventName, preventDefaults, false);
        });
        
        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();
        }
        
        ['dragenter', 'dragover'].forEach(eventName => {
            uploadArea.addEventListener(eventName, () => {
                uploadArea.classList.add('dragover');
            });
        });
        
        ['dragleave', 'drop'].forEach(eventName => {
            uploadArea.addEventListener(eventName, () => {
                uploadArea.classList.remove('dragover');
            });
        });
        
        uploadArea.addEventListener('drop', function(e) {
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                handleFileUpload(files[0]);
            }
        });
        
        // Fonction pour gérer l'upload
        function handleFileUpload(file) {
            console.log('🔍 DEBUG: Début upload image - fichier:', file.name, 'taille:', file.size);
            isUploading = true; // Marquer l'état d'upload
            
            // Vérifier la taille (max 20MB)
            if (file.size > 20 * 1024 * 1024) {
                showNotification('❌ Fichier trop volumineux. Maximum 20MB autorisé.', 'danger');
                isUploading = false;
                return;
            }
            
            // Vérifier le type
            const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
            if (!validTypes.includes(file.type)) {
                showNotification('❌ Format non supporté. Utilisez JPG, PNG, GIF ou WebP.', 'danger');
                isUploading = false;
                return;
            }
            
            uploadedFile = file;
            imageRemoved = false;
            
            // Afficher la prévisualisation
            const reader = new FileReader();
            reader.onload = function(e) {
                previewContainer.innerHTML = `
                    <img src="${e.target.result}" alt="Prévisualisation" class="image-preview">
                    <div class="mt-2">
                        <p class="small text-success mb-1">
                            <i class="fas fa-check-circle me-1"></i>
                            ${file.name} (${Math.round(file.size / 1024)} KB)
                        </p>
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeUploadedImage()">
                            <i class="fas fa-times me-1"></i>Annuler l'upload
                        </button>
                    </div>
                `;
                
                imagePreview.style.display = 'block';
                isUploading = false; // Terminer l'état d'upload
                
                // Libérer l'URL pour éviter les fuites de mémoire
                URL.revokeObjectURL(e.target.result);
            };
            reader.readAsDataURL(file);
        }
        
        // Supprimer l'image uploadée
        window.removeUploadedImage = function() {
            uploadedFile = null;
            fileInput.value = '';
            previewContainer.innerHTML = '<p class="text-muted">Aucune image sélectionnée</p>';
            imagePreview.style.display = 'none';
        }
        
        // Supprimer l'image existante
        window.removeImage = function() {
            imageRemoved = true;
            fileInput.value = '';
            uploadedFile = null;
            imagePreview.style.display = 'none';
            
            // Ajouter un champ caché pour indiquer la suppression
            if (!document.getElementById('remove_image')) {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.id = 'remove_image';
                input.name = 'remove_image';
                input.value = '1';
                document.getElementById('newsForm').appendChild(input);
            }
        }
        
        // ========== FONCTION DE BASCULEMENT MÉDIA ==========
        window.toggleMediaType = function(type) {
            const imageSection = document.getElementById('imageSection');
            const videoSection = document.getElementById('videoSection');
            
            console.log('🔍 DEBUG: Toggle media type vers:', type);
            
            // Simplement afficher/masquer les sections sans supprimer les médias
            if (type === 'image') {
                // Afficher la section image, cacher la section vidéo
                imageSection.style.display = 'block';
                videoSection.style.display = 'none';
                console.log('🔍 DEBUG: Mode image activé - vidéo masquée');
                
            } else if (type === 'video') {
                // Afficher la section vidéo, cacher la section image
                videoSection.style.display = 'block';
                imageSection.style.display = 'none';
                console.log('🔍 DEBUG: Mode vidéo activé - image masquée');
            }
        }
        
        // ========== GESTION DE LA VIDÉO ==========
        const videoUploadArea = document.getElementById('videoUploadArea');
        const videoFileInput = document.getElementById('video_file');
        const videoPreview = document.getElementById('videoPreview');
        const videoPreviewContainer = document.getElementById('videoPreviewContainer');
        
        let uploadedVideoFile = null;
        let videoRemoved = false;
        let currentVideoUrl = null; // Pour libérer l'URL plus tard
        
        // Cliquer sur la zone de vidéo = cliquer sur le input file
        if (videoUploadArea) {
            videoUploadArea.addEventListener('click', function() {
                videoFileInput.click();
            });
            
            // Gérer la sélection de fichier vidéo
            videoFileInput.addEventListener('change', function(e) {
                if (this.files && this.files[0]) {
                    handleVideoUpload(this.files[0]);
                }
            });
            
            // Drag & drop
            videoUploadArea.addEventListener('dragover', function(e) {
                e.preventDefault();
                this.classList.add('dragover');
            });
            
            videoUploadArea.addEventListener('dragleave', function(e) {
                e.preventDefault();
                this.classList.remove('dragover');
            });
            
            videoUploadArea.addEventListener('drop', function(e) {
                e.preventDefault();
                this.classList.remove('dragover');
                
                const files = e.dataTransfer.files;
                if (files && files[0]) {
                    handleVideoUpload(files[0]);
                }
            });
        }
        
        function handleVideoUpload(file) {
            console.log('🔍 DEBUG: Début upload vidéo - fichier:', file.name, 'taille:', file.size);
            isUploading = true; // Marquer l'état d'upload
            
            // Validation du type de fichier
            const allowedTypes = ['video/mp4', 'video/webm', 'video/ogg', 'video/quicktime', 'video/x-msvideo'];
            if (!allowedTypes.includes(file.type)) {
                showNotification('❌ Type de fichier non supporté. Utilisez MP4, WebM ou OGG.', 'danger');
                isUploading = false;
                return;
            }
            
            // Validation de la taille (max 1000MB)
            const maxSize = 1000 * 1024 * 1024; // 1000MB
            if (file.size > maxSize) {
                showNotification('❌ Fichier trop volumineux. Maximum 1000MB autorisé.', 'danger');
                isUploading = false;
                return;
            }
            
            uploadedVideoFile = file;
            
            // Afficher la prévisualisation
            currentVideoUrl = URL.createObjectURL(file);
            const videoUrl = currentVideoUrl;
            videoPreviewContainer.innerHTML = `
                <video controls class="video-preview" style="max-width: 100%; max-height: 200px; border-radius: 8px;">
                    <source src="${videoUrl}" type="${file.type}">
                    Votre navigateur ne supporte pas la lecture de vidéos.
                </video>
                <div class="mt-2">
                    <p class="small text-success mb-1">
                        <i class="fas fa-file-video me-1"></i>
                        Fichier sélectionné : ${file.name}
                    </p>
                    <p class="small text-muted mb-2">
                        Taille : ${(file.size / 1024 / 1024).toFixed(2)} MB
                    </p>
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeVideo()">
                        <i class="fas fa-trash me-1"></i>Supprimer la vidéo
                    </button>
                </div>
            `;
            videoPreview.style.display = 'block';
            
            showNotification('✅ Vidéo chargée avec succès', 'success');
            isUploading = false; // Terminer l'état d'upload
        }
        
        window.removeVideo = function() {
            videoRemoved = true;
            videoFileInput.value = '';
            uploadedVideoFile = null;
            videoPreview.style.display = 'none';
            
            // Libérer l'URL pour éviter les fuites de mémoire
            if (currentVideoUrl) {
                URL.revokeObjectURL(currentVideoUrl);
                currentVideoUrl = null;
            }
            
            // Ajouter un champ caché pour indiquer la suppression
            if (!document.getElementById('remove_video')) {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.id = 'remove_video';
                input.name = 'remove_video';
                input.value = '1';
                document.getElementById('newsForm').appendChild(input);
            }
            
            showNotification('🗑️ Vidéo supprimée', 'info');
        }
        
        // ========== SYSTÈME DE NOTIFICATIONS ==========
        function showNotification(message, type = 'info') {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            // Insérer au début du main-content
            const mainContent = document.querySelector('.main-content');
            mainContent.insertBefore(alertDiv, mainContent.firstChild);
            
            // Auto-suppression après 5 secondes
            setTimeout(() => {
                if (alertDiv.parentNode) {
                    alertDiv.remove();
                }
            }, 5000);
        }
        
        // ========== GESTION DES ERREURS VIDÉO ==========
        window.handleVideoError = function(videoElement) {
            const thumbnailDiv = videoElement.parentElement;
            thumbnailDiv.innerHTML = `
                <div class="video-thumbnail">
                    <i class="fas fa-video fa-3x text-secondary"></i>
                    <p class="mt-2 mb-0">Vidéo externe</p>
                </div>
            `;
        }
        
        // ========== VALIDATION AMÉLIORÉE DU FORMULAIRE ==========
        document.getElementById('newsForm').addEventListener('submit', function(e) {
            console.log('🔍 DEBUG: Formulaire soumis - début validation');
            
            const title = document.getElementById('title').value.trim();
            const excerpt = document.getElementById('excerpt').value.trim();
            const content = document.getElementById('content').value.trim();
            
            console.log('🔍 DEBUG: Titre:', title, 'Extrait:', excerpt?.substring(0, 50), 'Contenu:', content?.substring(0, 50));
            
            // Validation des champs obligatoires
            if (!title || !excerpt || !content) {
                console.log('🔍 DEBUG: Validation échouée - champs manquants');
                e.preventDefault();
                showNotification('❌ Veuillez remplir tous les champs obligatoires.', 'danger');
                return false;
            }
            
            // Validation de la longueur
            if (title.length > 150) {
                e.preventDefault();
                console.log('🔍 DEBUG: Validation échouée - titre trop long');
                showNotification('❌ Le titre ne doit pas dépasser 150 caractères.', 'danger');
                return false;
            }
            
            if (excerpt.length > 300) {
                e.preventDefault();
                showNotification('❌ L\'extrait ne doit pas dépasser 300 caractères.', 'danger');
                return false;
            }
            
            // Validation simple - pas de suppression automatique des médias
            console.log('🔍 DEBUG: Validation simple - conservation des médias existants');
            
            // Désactiver le bouton pendant l'envoi
            const submitBtn = this.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Enregistrement en cours...';
            submitBtn.disabled = true;
            
            // Réactiver après 10 secondes maximum (au cas où)
            setTimeout(() => {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }, 10000);
        });
        
        // ========== AUTOSAVE (BROUILLON) ==========
        let autosaveTimeout;
        
        function autosave() {
            // Ne pas lancer l'auto-sauvegarde pendant un upload
            if (isUploading) return;
            
            clearTimeout(autosaveTimeout);
            autosaveTimeout = setTimeout(() => {
                try {
                    const formData = new FormData(document.getElementById('newsForm'));
                    formData.append('autosave', 'true');
                    
                    fetch('/admin/news/autosave', {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(`HTTP error! status: ${response.status}`);
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data.success) {
                            // Ne pas afficher de notification pour ne pas déranger l'utilisateur
                            console.log('✅ Auto-sauvegarde réussie:', data.message);
                        } else {
                            console.warn('⚠️ Auto-sauvegarde échouée:', data.error);
                        }
                    })
                    .catch(error => {
                        console.warn('⚠️ Auto-sauvegarde failed:', error);
                        // Ne pas afficher d'erreur à l'utilisateur pour ne pas le déranger
                    });
                } catch (error) {
                    console.error('❌ Erreur lors de l\'auto-sauvegarde:', error);
                }
            }, 30000); // 30 secondes après la dernière modification
        }
        
        // Activer l'autosave sur les changements - DÉSACTIVÉ TEMPORAIREMENT POUR TEST
        // ['title', 'excerpt', 'author', 'category'].forEach(id => {
        //     const element = document.getElementById(id);
        //     if (element) {
        //         element.addEventListener('input', autosave);
        //     }
        // });
        console.log('🔍 DEBUG: Autosave sur tous les champs désactivé pour test');
        
        // Autosave pour Summernote - DÉSACTIVÉ TEMPORAIREMENT POUR TEST
        // $('#content').on('summernote.change', function() {
        //     autosave();
        // });
        console.log('🔍 DEBUG: Autosave Summernote désactivé pour test');
    });
    </script>

    <script>
        function openSidebar() {
            document.querySelector('.sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('show');
        }
        function closeSidebar() {
            document.querySelector('.sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }
    </script></body>
</html>