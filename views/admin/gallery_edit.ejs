<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --telex-light-blue: #457B9D;
            --sidebar-width: 280px;
            --transition-speed: 0.3s;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            color: #334155;
        }
        
        /* Sidebar */
        .sidebar { 
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%); 
            color: white; 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }
        
        /* ── Sidebar header Option B ── */
        .sb-header { display:flex; align-items:center; justify-content:center; padding:18px 16px; border-bottom:1px solid rgba(255,255,255,.08); transition:background .2s; }
        .sb-header:hover { background: rgba(255,255,255,.04); }
        .sb-logo { height:52px; width:auto; display:block; flex-shrink:0; }
        .nav-section-label { font-size:.68rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:rgba(255,255,255,.28); padding:14px 10px 5px; }
        .sidebar-footer { padding:8px 10px 12px; border-top:1px solid rgba(255,255,255,.08); }
        .nav-link.logout { color:rgba(255,160,160,.7); }
        .nav-link.logout:hover { background:rgba(255,107,107,.1); color:#ff9e9e; }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .nav-item {
            margin-bottom: 8px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 14px 18px;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s;
            font-weight: 500;
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateX(5px);
        }
        
        .nav-link.active {
            background: var(--telex-red);
            color: white;
        }
        
        .nav-link i {
            margin-right: 12px;
            font-size: 1.1rem;
        }
        
        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 2rem;
            min-height: 100vh;
        }
        
        /* ── Dash Header ── */
        .dash-header { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:14px; padding:18px 28px; background:linear-gradient(135deg,var(--telex-blue) 0%,#0f1e3d 100%); border-radius:14px; box-shadow:0 4px 20px rgba(29,53,87,.25); margin-bottom:22px; }
        .dash-header-left { display:flex; align-items:center; gap:14px; }
        .dash-header-logo { height:44px; width:auto; flex-shrink:0; }
        .dash-header-title { font-size:1.35rem; font-weight:700; color:#fff; margin:0; line-height:1.2; }
        .dash-header-sub { font-size:.83rem; color:rgba(255,255,255,.60); margin:3px 0 0; }
        .dash-header-right { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
        .btn-dash-back { background:rgba(255,255,255,.12); color:white; border:1px solid rgba(255,255,255,.2); padding:9px 16px; border-radius:10px; font-weight:500; font-size:.85rem; display:inline-flex; align-items:center; gap:7px; text-decoration:none; transition:all .2s; }
        .btn-dash-back:hover { background:rgba(255,255,255,.22); color:white; }

        /* ── Form Card ── */
        .form-card { background:white; border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,.07); border:1px solid #e8ecf0; margin-bottom:20px; overflow:hidden; }
        .form-card-header { display:flex; align-items:center; gap:14px; padding:18px 22px 14px; border-bottom:1px solid #f0f4f8; background:#fafbfc; }
        .form-card-icon { width:42px; height:42px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0; }
        .form-card-title { font-size:.98rem; font-weight:700; color:#1D3557; }
        .form-card-sub { font-size:.78rem; color:#64748b; margin-top:2px; }
        .form-card-body { padding:22px; }
        
        /* Buttons */
        .btn-telex {
            background: var(--telex-blue);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s;
        }
        
        .btn-telex:hover {
            background: #15294e;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(29, 53, 87, 0.3);
        }
        
        .btn-new {
            background: var(--telex-red);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s;
        }
        
        .btn-new:hover {
            background: #d62828;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(230, 57, 70, 0.3);
        }
        
        /* Form Styles */
        .form-container {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.08);
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-label {
            font-weight: 600;
            color: var(--telex-blue);
            margin-bottom: 0.5rem;
        }
        
        .form-control {
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            padding: 12px 15px;
            transition: all 0.3s;
        }
        
        .form-control:focus {
            border-color: var(--telex-blue);
            box-shadow: 0 0 0 0.2rem rgba(29, 53, 87, 0.25);
        }
        
        .form-select {
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            padding: 12px 15px;
            transition: all 0.3s;
        }
        
        .form-select:focus {
            border-color: var(--telex-blue);
            box-shadow: 0 0 0 0.2rem rgba(29, 53, 87, 0.25);
        }
        
        /* Image Preview */
        .image-preview {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .image-preview img {
            max-width: 100%;
            max-height: 300px;
            border-radius: 10px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }
        
        /* Alerts */
        .alert {
            border-radius: 8px;
            border: none;
            padding: 1rem 1.5rem;
            margin-bottom: 1.5rem;
        }
        
        .alert-success {
            background: #d4edda;
            color: #155724;
        }
        
        .alert-error {
            background: #f8d7da;
            color: #721c24;
        }
        
        /* Responsive */
        @media (max-width: 992px) {
            .sidebar { width: 70px; overflow: hidden; }
            .sb-header { padding:12px 0; }
            .sb-logo { height:32px; }
            .nav-section-label { display:none; }
            .nav-link span { display:none; }
            .nav-link { justify-content:center; padding:11px 0; }
            .sidebar-footer { padding:6px 4px 10px; }
            .main-content { margin-left: 70px; }
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .main-content {
                margin-left: 0;
                padding: 1rem;
            }

            .top-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
        }
    
        /* ── Responsive mobile (<576px) ── */
        @media (max-width: 576px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform .3s ease;
                z-index: 1050;
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.45);
                z-index: 1040;
            }
            .sidebar-overlay.show { display: block; }
            .main-content { margin-left: 0 !important; }
            .mobile-menu-btn {
                display: flex !important;
            }
        }
        .mobile-menu-btn {
            display: none;
            position: fixed;
            top: 14px;
            left: 14px;
            z-index: 1060;
            background: var(--telex-blue, #1D3557);
            color: white;
            border: none;
            border-radius: 8px;
            width: 40px;
            height: 40px;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.25);
        }</style>
</head>
<body>
    <div id="sidebarOverlay" class="sidebar-overlay" onclick="closeSidebar()"></div>
    <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fas fa-bars"></i></button>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sb-header">
            <img src="/images/Telex.png" alt="Telex" class="sb-logo">
        </div>
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i><span>Dashboard</span>
                </a>
            </div>
            <div class="nav-section-label">Contenu</div>
            <div class="nav-item"><a href="/admin/news" class="nav-link"><i class="fas fa-newspaper"></i><span>Actualités</span></a></div>
            <div class="nav-item"><a href="/admin/programs" class="nav-link"><i class="fas fa-tv"></i><span>Programmes</span></a></div>
            <div class="nav-section-label">Communauté</div>
            <div class="nav-item"><a href="/admin/baume-de-la-foi" class="nav-link"><i class="fas fa-cross"></i><span>Baume de la Foi</span></a></div>
            <div class="nav-item"><a href="/admin/contacts" class="nav-link"><i class="fas fa-envelope"></i><span>Messages</span></a></div>
            <div class="nav-section-label">Médias</div>
            <div class="nav-item"><a href="/admin/gallery" class="nav-link active"><i class="fas fa-images"></i><span>Galerie</span></a></div>
            <div class="nav-item"><a href="/admin/album" class="nav-link"><i class="fas fa-book"></i><span>Album</span></a></div>
        </nav>
        <div class="sidebar-footer">
            <div class="nav-item"><a href="/admin/settings" class="nav-link"><i class="fas fa-cog"></i><span>Paramètres</span></a></div>
            <div class="nav-item"><a href="/admin/logout" class="nav-link logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a></div>
        </div>
    </div>
    
    <!-- Main Content -->
    <div class="main-content">
        <!-- Dash Header -->
        <div class="dash-header">
            <div class="dash-header-left">
                <img src="/images/Telex.png" alt="Telex" class="dash-header-logo">
                <div>
                    <div class="dash-header-title"><i class="fas fa-edit me-2" style="color:#A8DADC;font-size:.95rem;"></i>&Eacute;diter l'image</div>
                    <div class="dash-header-sub">Modifiez les informations de cette image</div>
                </div>
            </div>
            <div class="dash-header-right">
                <a href="/admin/gallery" class="btn-dash-back"><i class="fas fa-arrow-left"></i>Retour &agrave; la galerie</a>
            </div>
        </div>

        <!-- Alerts -->
        <% if (success_msg) { %>
            <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i><%= success_msg %></div>
        <% } %>
        <% if (error_msg) { %>
            <div class="alert alert-danger"><i class="fas fa-exclamation-circle me-2"></i><%= error_msg %></div>
        <% } %>

        <form action="/admin/gallery/update/<%= image.id %>" method="POST">

            <!-- CARTE 1 : Aperçu -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon" style="background:linear-gradient(135deg,#3B82F6,#1D4ED8);">
                        <i class="fas fa-image" style="color:white;"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Aper&ccedil;u de l'image</div>
                        <div class="form-card-sub">Image actuellement enregistr&eacute;e</div>
                    </div>
                </div>
                <div class="form-card-body text-center">
                    <img src="<%= image.image_url %>" alt="<%= image.title %>"
                         style="max-width:100%; max-height:320px; border-radius:10px; box-shadow:0 4px 16px rgba(0,0,0,.12); object-fit:contain;">
                </div>
            </div>

            <!-- CARTE 2 : Informations -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon" style="background:linear-gradient(135deg,#10B981,#047857);">
                        <i class="fas fa-info-circle" style="color:white;"></i>
                    </div>
                    <div>
                        <div class="form-card-title">Informations de l'image</div>
                        <div class="form-card-sub">Titre, description et cat&eacute;gorie</div>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label for="title" class="form-label">Titre de l'image *</label>
                            <input type="text" class="form-control" id="title" name="title" value="<%= image.title %>" required>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="category" class="form-label">Cat&eacute;gorie</label>
                            <select class="form-select" id="category" name="category">
                                <option value="evenement-culturel" <%= image.category === 'evenement-culturel' ? 'selected' : '' %>>Culturel</option>
                                <option value="evenement-sportif" <%= image.category === 'evenement-sportif' ? 'selected' : '' %>>Sportif</option>
                                <option value="evenement-coutume" <%= image.category === 'evenement-coutume' ? 'selected' : '' %>>Coutume</option>
                                <option value="evenement-exceptionnel" <%= image.category === 'evenement-exceptionnel' ? 'selected' : '' %>>Exceptionnel</option>
                                <option value="autres" <%= image.category === 'autres' ? 'selected' : '' %>>Autres</option>
                            </select>
                        </div>
                        <div class="col-12 mb-2">
                            <label for="description" class="form-label">Description</label>
                            <textarea class="form-control" id="description" name="description" rows="4" placeholder="D&eacute;crivez cette image..."><%= image.description || '' %></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CARTE 3 : Actions -->
            <div class="form-card">
                <div class="form-card-body" style="padding:18px 22px;">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <small class="text-muted"><i class="fas fa-info-circle me-1"></i>Les modifications remplaceront les informations actuelles.</small>
                        <div class="d-flex gap-2">
                            <a href="/admin/gallery" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-1"></i>Annuler
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save me-1"></i>Enregistrer les modifications
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function openSidebar() {
            document.querySelector('.sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('show');
        }
        function closeSidebar() {
            document.querySelector('.sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }
    </script></body>
</html>
