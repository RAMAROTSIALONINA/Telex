<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --telex-light-blue: #457B9D;
            --sidebar-width: 280px;
            --transition-speed: 0.3s;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            color: #334155;
        }
        
        /* Sidebar */
        .sidebar { 
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%); 
            color: white; 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }
        
        .sidebar-brand {
            padding: 25px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(0, 0, 0, 0.1);
        }
        
        .sidebar-brand img {
            max-width: 120px;
            height: auto;
            max-height: 60px;
            margin-bottom: 15px;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
            transition: transform 0.3s ease;
        }
        
        .sidebar-brand img:hover {
            transform: scale(1.05);
        }
        
        .sidebar-brand h3 {
            font-weight: 700;
            font-size: 1.5rem;
            margin-bottom: 5px;
            letter-spacing: 0.5px;
        }
        
        .sidebar-user {
            padding: 20px;
        }
        
        .user-info {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all var(--transition-speed);
        }
        
        .user-info:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }
        
        .user-avatar {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.2rem;
            margin-right: 15px;
            box-shadow: 0 4px 10px rgba(230, 57, 70, 0.3);
        }
        
        .user-details h5 {
            font-weight: 600;
            margin-bottom: 3px;
            font-size: 1rem;
        }
        
        .user-details small {
            opacity: 0.8;
            font-size: 0.8rem;
            display: block;
        }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .nav-item {
            margin-bottom: 8px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 14px 18px;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s;
            font-weight: 500;
            position: relative;
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateX(5px);
        }
        
        .nav-link.active {
            background: rgba(230, 57, 70, 0.15);
            color: white;
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.2);
        }
        
        .nav-link i {
            width: 24px;
            font-size: 1.1rem;
            margin-right: 12px;
            text-align: center;
        }
        
        /* Main Content */
        .main-content { 
            margin-left: var(--sidebar-width); 
            padding: 30px;
            min-height: 100vh;
            animation: fadeIn 0.5s ease-out;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* Top Bar */
        .top-bar {
            background: white;
            padding: 25px 30px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            overflow: hidden;
        }
        
        .top-bar::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--telex-red), var(--telex-blue));
        }
        
        .page-title {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .page-logo {
            height: 40px;
            width: auto;
            opacity: 0.9;
        }
        
        .page-title h1 {
            font-weight: 700;
            color: var(--telex-blue);
            font-size: 1.8rem;
            margin-bottom: 5px;
        }
        
        .page-title p {
            color: #64748b;
            font-size: 1rem;
            margin: 0;
        }
        
        .top-actions {
            display: flex;
            gap: 15px;
            align-items: center;
        }
        
        .btn-telex {
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 10px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.3);
        }
        
        .btn-telex:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 18px rgba(230, 57, 70, 0.4);
            color: white;
        }
        
        /* News Table Container */
        .table-container {
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            margin-bottom: 30px;
        }
        
        .table-header {
            padding: 25px 30px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .table-header h2 {
            color: var(--telex-blue);
            font-weight: 700;
            margin: 0;
            font-size: 1.4rem;
        }
        
        .table-responsive {
            padding: 0;
        }
        
        /* Table Styles */
        .table {
            margin-bottom: 0;
            border-collapse: separate;
            border-spacing: 0;
        }
        
        .table thead th {
            background: #f8fafc;
            color: var(--telex-blue);
            font-weight: 600;
            padding: 15px 20px;
            border-bottom: 2px solid #e2e8f0;
            border-top: none;
        }
        
        .table tbody td {
            padding: 15px 20px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }
        
        .table tbody tr:last-child td {
            border-bottom: none;
        }
        
        .table tbody tr:hover {
            background-color: #f8fafc;
        }
        
        /* News Item Styles */
        .news-title {
            font-weight: 600;
            color: var(--telex-blue);
            margin-bottom: 5px;
            display: block;
        }
        
        .news-excerpt {
            color: #64748b;
            font-size: 0.9rem;
            overflow: hidden;
            text-overflow: ellipsis;
            display: -webkit-box;
            
            -webkit-box-orient: vertical;
            max-width: 400px;
        }
        
        .category-badge {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            background: rgba(59, 130, 246, 0.1);
            color: #1D4ED8;
        }
        
        .date-info {
            display: flex;
            flex-direction: column;
        }
        
        .date-main {
            font-weight: 500;
            color: #475569;
        }
        
        .date-time {
            font-size: 0.85rem;
            color: #94a3b8;
        }
        
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }
        
        .status-published {
            background: rgba(16, 185, 129, 0.1);
            color: #047857;
        }
        
        .status-draft {
            background: rgba(107, 114, 128, 0.1);
            color: #4B5563;
        }
        
        .views-count {
            display: flex;
            align-items: center;
            gap: 5px;
            font-weight: 600;
            color: var(--telex-blue);
        }
        
        .views-count i {
            color: var(--telex-red);
        }
        
        /* Action Buttons */
        .action-buttons {
            display: flex;
            gap: 8px;
        }
        
        .btn-action {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #e2e8f0;
            background: white;
            color: #64748b;
            transition: all 0.3s;
            text-decoration: none;
        }
        
        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }
        
        .btn-view:hover {
            background: #3B82F6;
            color: white;
            border-color: #3B82F6;
        }
        
        .btn-edit:hover {
            background: #FBBF24;
            color: white;
            border-color: #FBBF24;
        }
        
        .btn-delete:hover {
            background: var(--telex-red);
            color: white;
            border-color: var(--telex-red);
        }
        
        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            text-align: center;
            transition: all 0.3s;
            border-top: 4px solid;
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
        }
        
        .stat-card.published {
            border-top-color: #10B981;
        }
        
        .stat-card.drafts {
            border-top-color: #6B7280;
        }
        
        .stat-card.categories {
            border-top-color: #3B82F6;
        }
        
        .stat-card.views {
            border-top-color: var(--telex-red);
        }
        
        .stat-icon {
            font-size: 2.5rem;
            margin-bottom: 15px;
            opacity: 0.8;
        }
        
        .stat-card.published .stat-icon { color: #10B981; }
        .stat-card.drafts .stat-icon { color: #6B7280; }
        .stat-card.categories .stat-icon { color: #3B82F6; }
        .stat-card.views .stat-icon { color: var(--telex-red); }
        
        .stat-number {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--telex-blue);
            margin-bottom: 5px;
            line-height: 1;
        }
        
        .stat-label {
            color: #64748b;
            font-size: 0.95rem;
            font-weight: 500;
        }
        
        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }
        
        .empty-state-icon {
            font-size: 4rem;
            color: #e2e8f0;
            margin-bottom: 20px;
        }
        
        .empty-state h3 {
            color: #64748b;
            font-weight: 600;
            margin-bottom: 10px;
        }
        
        .empty-state p {
            color: #94a3b8;
            margin-bottom: 30px;
            max-width: 400px;
            margin-left: auto;
            margin-right: auto;
        }
        
        /* Footer */
        .page-footer {
            text-align: center;
            padding: 20px;
            color: #94a3b8;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 30px;
            border-top: 1px solid #e2e8f0;
        }
        
        .footer-logo {
            height: 20px;
            width: auto;
            opacity: 0.6;
        }
        
        /* Responsive */
        @media (max-width: 992px) {
            .sidebar {
                width: 70px;
                overflow: hidden;
            }
            
            .sidebar-brand h3,
            .sidebar-brand img {
                display: none;
            }
            
            .sidebar-brand {
                padding: 15px 10px;
            }
            
            .sidebar-brand::after {
                content: "T";
                color: white;
                font-size: 1.5rem;
                font-weight: bold;
                display: block;
            }
            
            .sidebar-user {
                display: none;
            }
            
            .nav-link span {
                display: none;
            }
            
            .nav-link {
                justify-content: center;
                padding: 15px;
            }
            
            .nav-link i {
                margin-right: 0;
                font-size: 1.2rem;
            }
            
            .main-content {
                margin-left: 70px;
                padding: 20px;
            }
            
            .top-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            
            .top-actions {
                width: 100%;
                justify-content: space-between;
            }
        }
        
        @media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .table-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            
            .news-excerpt {
                max-width: 200px;
            }
            
            .action-buttons {
                flex-direction: column;
            }
        }
        
        @media (max-width: 576px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-brand">
            <img src="/images/11.png" alt="TELEX">
            <h3>Telex Admin</h3>
        </div>
        
        <div class="sidebar-user">
            <div class="user-info">
                <div class="user-avatar">
                    <%= user.username.charAt(0).toUpperCase() %>
                </div>
                <div class="user-details">
                    <h5><%= user.username %></h5>
                    <small>Administrateur</small>
                </div>
            </div>
        </div>
        
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/news" class="nav-link active">
                    <i class="fas fa-newspaper"></i>
                    <span>Actualités</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/programs" class="nav-link">
                    <i class="fas fa-tv"></i>
                    <span>Programmes</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/baume-de-la-foi" class="nav-link">
                    <i class="fas fa-cross"></i>
                    <span>Baume de la Foi</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/contacts" class="nav-link">
                    <i class="fas fa-envelope"></i>
                    <span>Messages</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/gallery" class="nav-link">
                    <i class="fas fa-images"></i>
                    <span>Galerie</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/footer" class="nav-link">
                    <i class="fas fa-globe"></i>
                    <span>Footer</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/settings" class="nav-link">
                    <i class="fas fa-cog"></i>
                    <span>Paramètres</span>
                </a>
            </div>
            <div class="nav-item">
                <a href="/admin/logout" class="nav-link">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Déconnexion</span>
                </a>
            </div>
        </nav>
    </div>
    
    <!-- Main Content -->
    <div class="main-content">
        <!-- Top bar -->
        <div class="top-bar">
            <div class="page-title">
                <img src="/images/Telex.png" alt="TELEX" class="page-logo">
                <div>
                    <h1>Gestion des Actualités</h1>
                    <p>Créez, modifiez et gérez les actualités de Telex</p>
                </div>
            </div>
            <div class="top-actions">
                <a href="/admin/news/new" class="btn btn-telex">
                    <i class="fas fa-plus me-2"></i>Nouvelle Actualité
                </a>
            </div>
        </div>
        
        <!-- Stats -->
        <% 
            const publishedCount = news.filter(n => n.is_published).length;
            const draftCount = news.filter(n => !n.is_published).length;
            const categoriesCount = [...new Set(news.map(n => n.category))].length;
            const totalViews = news.reduce((sum, n) => sum + (n.views || 0), 0);
        %>
        
        <div class="stats-grid">
            <div class="stat-card published">
                <div class="stat-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="stat-number"><%= publishedCount %></div>
                <div class="stat-label">Actualités Publiées</div>
            </div>
            
            <div class="stat-card drafts">
                <div class="stat-icon">
                    <i class="fas fa-edit"></i>
                </div>
                <div class="stat-number"><%= draftCount %></div>
                <div class="stat-label">Brouillons</div>
            </div>
            
            <div class="stat-card categories">
                <div class="stat-icon">
                    <i class="fas fa-tags"></i>
                </div>
                <div class="stat-number"><%= categoriesCount %></div>
                <div class="stat-label">Catégories</div>
            </div>
            
            <div class="stat-card views">
                <div class="stat-icon">
                    <i class="fas fa-eye"></i>
                </div>
                <div class="stat-number" id="totalViewsDisplay"><%= totalViews %></div>
                <div class="stat-label">Vues Totales</div>
            </div>
        </div>
        
        <!-- News Table -->
        <div class="table-container">
            <div class="table-header">
                <h2><i class="fas fa-list me-2"></i>Liste des Actualités</h2>
                <div class="text-muted">
                    <%= news.length %> actualité<%= news.length > 1 ? 's' : '' %> au total
                </div>
            </div>
            
            <% if (news.length > 0) { %>
            <div class="table-responsive">
                <table class="table" id="newsTable">
                    <thead>
                        <tr>
                            <th>Titre</th>
                            <th width="120">Auteur</th>
                            <th width="120">Catégorie</th>
                            <th width="120">Date</th>
                            <th width="100">Statut</th>
                            <th width="80">Vues</th>
                            <th width="80">Vidéo</th>
                            <th width="140" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% news.forEach(item => { %>
                        <tr>
                            <td>
                                <a href="/news/<%= item.slug %>" target="_blank" class="news-title">
                                    <%= item.title %>
                                </a>
                                <% if (item.excerpt) { %>
                                <div class="news-excerpt" title="<%= item.excerpt %>">
                                    <%= item.excerpt.substring(0, 100) + (item.excerpt.length > 100 ? '...' : '') %>
                                </div>
                                <% } %>
                            </td>
                            <td>
                                <div class="small">
                                    <i class="fas fa-user me-1"></i>
                                    <%= item.author %>
                                </div>
                            </td>
                            <td>
                                <span class="category-badge"><%= item.category %></span>
                            </td>
                            <td data-order="<%= new Date(item.created_at).getTime() %>">
                                <div class="date-info">
                                    <span class="date-main">
                                        <%= new Date(item.created_at).toLocaleDateString('fr-FR') %>
                                    </span>
                                    <span class="date-time">
                                        <i class="far fa-clock me-1"></i>
                                        <%= new Date(item.created_at).toLocaleTimeString('fr-FR', {hour: '2-digit', minute:'2-digit'}) %>
                                    </span>
                                </div>
                            </td>
                            <td>
                                <span class="status-badge <%= item.is_published ? 'status-published' : 'status-draft' %>">
                                    <% if (item.is_published) { %>
                                    <i class="fas fa-check-circle me-1"></i>Publié
                                    <% } else { %>
                                    <i class="fas fa-edit me-1"></i>Brouillon
                                    <% } %>
                                </span>
                            </td>
                            <td>
                                <div class="views-count">
                                    <i class="fas fa-eye"></i>
                                    <span class="views-number" id="views-<%= item.id %>"><%= item.views || 0 %></span>
                                </div>
                            </td>
                            <td class="text-center">
                                <% if (item.video_url) { %>
                                    <i class="fas fa-video text-success" title="Contient une vidéo"></i>
                                <% } else { %>
                                    <i class="fas fa-video-slash text-muted" title="Pas de vidéo"></i>
                                <% } %>
                            </td>
                            <td class="text-center">
                                <div class="action-buttons">
                                    <a href="/news/<%= item.slug %>" 
                                       target="_blank" 
                                       class="btn-action btn-view"
                                       title="Voir sur le site">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                    <a href="/admin/news/edit/<%= item.id %>" 
                                       class="btn-action btn-edit"
                                       title="Éditer">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/admin/news/delete/<%= item.id %>" 
                                       class="btn-action btn-delete"
                                       title="Supprimer"
                                       onclick="return confirm('Voulez-vous vraiment supprimer l\'actualité \'<%= item.title %>\' ? Cette action est irréversible.')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-newspaper"></i>
                </div>
                <h3>Aucune actualité trouvée</h3>
                <p>Commencez par créer votre première actualité pour enrichir votre site Telex.</p>
                <a href="/admin/news/new" class="btn btn-telex">
                    <i class="fas fa-plus me-2"></i>Créer ma première actualité
                </a>
            </div>
            <% } %>
        </div>
        
        <!-- Footer -->
        <div class="page-footer">
            <img src="/images/Telex.png" alt="TELEX" class="footer-logo">
            <div>
                Telex Actualités • <%= new Date().getFullYear() %> • <%= news.length %> publication<%= news.length > 1 ? 's' : '' %>
            </div>
        </div>
    </div>
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
    // Fonction pour formater les nombres avec K, M, B
    function formatNumber(num) {
        if (num >= 1000000000) {
            return (num / 1000000000).toFixed(1).replace(/\.0$/, '') + 'B';
        }
        if (num >= 1000000) {
            return (num / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
        }
        if (num >= 1000) {
            return (num / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
        }
        return num.toString();
    }

    document.addEventListener('DOMContentLoaded', function() {
        console.log('Gestion des Actualités TELEX chargée');
        
        // Formater les vues totales
        const totalViewsElement = document.getElementById('totalViewsDisplay');
        if (totalViewsElement) {
            const totalViews = parseInt(totalViewsElement.textContent);
            totalViewsElement.textContent = formatNumber(totalViews);
        }
        
        // Formater les vues de chaque actualité
        document.querySelectorAll('.views-number').forEach(element => {
            const views = parseInt(element.textContent);
            element.textContent = formatNumber(views);
        });
        
        // Initialiser DataTable
        const table = $('#newsTable').DataTable({
            language: {
                "processing": "Traitement en cours...",
                "search": "Rechercher:",
                "lengthMenu": "Afficher _MENU_ éléments",
                "info": "Affichage de _START_ à _END_ sur _TOTAL_ éléments",
                "paginate": {
                    "first": "Premier",
                    "last": "Dernier",
                    "next": "Suivant",
                    "previous": "Précédent"
                }
            },
            pageLength: 10,
            order: [[3, 'desc']], // Tri par colonne Date (index 3) du plus récent au plus ancien
            responsive: true,
            columnDefs: [
                { orderable: false, targets: [6, 7] }, // Colonnes Vidéo et Actions non triables
                { type: 'date', targets: 3 } // Assurer que la colonne Date est traitée comme date
            ],
            initComplete: function() {
                // Ajouter un champ de recherche personnalisé
                this.api().columns().every(function() {
                    const column = this;
                    // Exclure les colonnes d'actions
                    if (column.index() !== 6 && column.index() !== 7) {
                        const title = $(column.header()).text();
                        // Ajouter un champ de recherche pour chaque colonne
                    }
                });
            }
        });
        
        // Confirmation de suppression améliorée
        document.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const row = this.closest('tr');
                const title = row.querySelector('.news-title').textContent;
                
                if (!confirm(`Voulez-vous vraiment supprimer l'actualité "${title}" ?\n\nCette action est irréversible et supprimera définitivement l'actualité.`)) {
                    e.preventDefault();
                }
            });
        });
        
        // Animation des cartes de stats
        const statCards = document.querySelectorAll('.stat-card');
        statCards.forEach((card, index) => {
            card.style.animationDelay = `${index * 0.1}s`;
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            
            setTimeout(() => {
                card.style.transition = 'all 0.5s ease-out';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 100);
        });
        
        // Filtrage par statut
        const statusFilters = document.createElement('div');
        statusFilters.className = 'btn-group mb-3';
        statusFilters.innerHTML = `
            <button class="btn btn-outline-primary active" data-filter="all">Toutes</button>
            <button class="btn btn-outline-success" data-filter="published">Publiées</button>
            <button class="btn btn-outline-secondary" data-filter="draft">Brouillons</button>
        `;
        
        // Ajouter les filtres après le header de la table
        const tableHeader = document.querySelector('.table-header');
        if (tableHeader) {
            tableHeader.appendChild(statusFilters);
            
            // Gestion des filtres
            statusFilters.querySelectorAll('button').forEach(btn => {
                btn.addEventListener('click', function() {
                    statusFilters.querySelectorAll('button').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    
                    const filter = this.getAttribute('data-filter');
                    
                    if (filter === 'all') {
                        table.search('').draw();
                    } else {
                        table.column(5).search(filter === 'published' ? '^Publié$' : '^Brouillon$', true, false).draw();
                    }
                });
            });
        }
    });
    </script>
</body>
</html>