<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Telex | Administration</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            --telex-light-blue: #457B9D;
            --sidebar-width: 280px;
            --transition-speed: 0.3s;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: #f8fafc;
            font-family: 'Open Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            color: #334155;
        }
        
        /* Sidebar */
        .sidebar { 
            background: linear-gradient(180deg, var(--telex-blue) 0%, #0f1e3d 100%); 
            color: white; 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            left: 0;
            top: 0;
            padding: 0;
            z-index: 1000;
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }
        
        /* ── Sidebar header Option B ── */
        .sb-header { display:flex; align-items:center; justify-content:center; padding:18px 16px; border-bottom:1px solid rgba(255,255,255,.08); transition:background .2s; }
        .sb-header:hover { background: rgba(255,255,255,.04); }
        .sb-logo { height:52px; width:auto; display:block; flex-shrink:0; }
        .nav-section-label { font-size:.68rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:rgba(255,255,255,.28); padding:14px 10px 5px; }
        .sidebar-footer { padding:8px 10px 12px; border-top:1px solid rgba(255,255,255,.08); }
        .nav-link.logout { color:rgba(255,160,160,.7); }
        .nav-link.logout:hover { background:rgba(255,107,107,.1); color:#ff9e9e; }
        
        .sidebar-nav {
            flex: 1;
            padding: 20px 15px;
            overflow-y: auto;
        }
        
        .nav-item {
            margin-bottom: 8px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 14px 18px;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s;
            font-weight: 500;
            position: relative;
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            transform: translateX(5px);
        }
        
        .nav-link.active {
            background: rgba(230, 57, 70, 0.15);
            color: white;
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.2);
        }
        
        .nav-link i {
            width: 24px;
            font-size: 1.1rem;
            margin-right: 12px;
            text-align: center;
        }
        
        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 28px;
            min-height: 100vh;
        }

        /* ── Page header ── */
        .dash-header {
            background: linear-gradient(135deg, var(--telex-blue) 0%, #243b55 100%);
            border-radius: 16px;
            padding: 20px 26px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 22px;
            box-shadow: 0 4px 20px rgba(29,53,87,.18);
            position: relative;
            overflow: hidden;
        }
        .dash-header::after {
            content: '';
            position: absolute;
            right: -30px; top: -30px;
            width: 140px; height: 140px;
            background: rgba(255,255,255,.04);
            border-radius: 50%;
            pointer-events: none;
        }
        .dash-header-left { display: flex; align-items: center; gap: 14px; }
        .dash-header-logo { height: 44px; width: auto; opacity: .9; }
        .dash-header-title { color: white; font-size: 1.3rem; font-weight: 700; margin: 0 0 2px; line-height: 1.2; }
        .dash-header-sub   { color: rgba(255,255,255,.6); font-size: .8rem; margin: 0; }
        .dash-header-right { display: flex; gap: 10px; align-items: center; position: relative; z-index: 1; }

        .btn-telex {
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            color: white !important;
            border: none;
            padding: 10px 20px;
            border-radius: 9px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            font-weight: 600;
            font-size: .88rem;
            transition: all .2s;
            box-shadow: 0 3px 10px rgba(230,57,70,.35);
        }
        .btn-telex:hover { transform: translateY(-2px); box-shadow: 0 5px 16px rgba(230,57,70,.45); }
        .btn-site-link {
            display: inline-flex; align-items: center; gap: 6px;
            color: rgba(255,255,255,.75); font-size: .82rem; text-decoration: none;
            background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.15);
            padding: 8px 14px; border-radius: 8px; transition: background .15s;
        }
        .btn-site-link:hover { background: rgba(255,255,255,.18); color: white; }
        
        /* ── KPI tiles ── */
        .kpi-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-bottom: 22px; }
        .kpi-tile { background: white; border-radius: 12px; padding: 16px 18px; box-shadow: 0 1px 6px rgba(0,0,0,.05); border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 14px; transition: box-shadow .15s, transform .15s; }
        .kpi-tile:hover { box-shadow: 0 4px 16px rgba(0,0,0,.09); transform: translateY(-2px); }
        .kpi-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.05rem; color: white; flex-shrink: 0; }
        .kpi-icon.pub   { background: linear-gradient(135deg,#10B981,#047857); }
        .kpi-icon.draft { background: linear-gradient(135deg,#64748b,#475569); }
        .kpi-icon.cat   { background: linear-gradient(135deg,#3B82F6,#1D4ED8); }
        .kpi-icon.views { background: linear-gradient(135deg,#E63946,#c1121f); }
        .kpi-body { flex: 1; min-width: 0; }
        .kpi-num   { font-size: 1.65rem; font-weight: 800; color: var(--telex-blue); line-height: 1; margin-bottom: 2px; }
        .kpi-label { font-size: .73rem; color: #94a3b8; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }

        /* ── Table container ── */
        .table-container {
            background: white;
            border-radius: 14px;
            box-shadow: 0 1px 8px rgba(0,0,0,.07);
            border: 1px solid #e2e8f0;
            overflow: hidden;
            margin-bottom: 28px;
        }
        .table-header {
            padding: 18px 22px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .table-header h2 {
            color: var(--telex-blue);
            font-weight: 700;
            margin: 0;
            font-size: 1.05rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .table-header h2 i { color: var(--telex-red); font-size: .95rem; }

        /* Filter chips */
        .filter-chips { display: flex; gap: 6px; flex-wrap: wrap; }
        .chip { padding: 5px 14px; border-radius: 20px; font-size: .78rem; font-weight: 600; border: 1.5px solid #e2e8f0; background: #f8fafc; color: #64748b; cursor: pointer; transition: all .15s; }
        .chip:hover { border-color: var(--telex-blue); color: var(--telex-blue); }
        .chip.active-all  { background: var(--telex-blue); color: white; border-color: var(--telex-blue); }
        .chip.active-pub  { background: #10B981; color: white; border-color: #10B981; }
        .chip.active-draft{ background: #64748b; color: white; border-color: #64748b; }
        
        .table-responsive {
            padding: 0;
        }
        
        /* Table Styles */
        .table {
            margin-bottom: 0;
            border-collapse: separate;
            border-spacing: 0;
        }
        
        .table thead th {
            background: #f8fafc;
            color: var(--telex-blue);
            font-weight: 600;
            padding: 15px 20px;
            border-bottom: 2px solid #e2e8f0;
            border-top: none;
        }
        
        .table tbody td {
            padding: 12px 16px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }
        .table tbody td.col-titre {
            max-width: 0;
            width: 40%;
        }
        
        .table tbody tr:last-child td {
            border-bottom: none;
        }
        
        .table tbody tr:hover {
            background-color: #f8fafc;
        }
        
        /* News Item Styles */
        .news-title {
            font-weight: 600;
            color: var(--telex-blue);
            margin-bottom: 3px;
            display: block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100%;
        }

        .news-excerpt {
            color: #64748b;
            font-size: 0.82rem;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            max-width: 100%;
        }
        
        .category-badge {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            background: rgba(59, 130, 246, 0.1);
            color: #1D4ED8;
        }
        
        .date-info {
            display: flex;
            flex-direction: column;
        }
        
        .date-main {
            font-weight: 500;
            color: #475569;
        }
        
        .date-time {
            font-size: 0.85rem;
            color: #94a3b8;
        }
        
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }
        
        .status-published {
            background: rgba(16, 185, 129, 0.1);
            color: #047857;
        }
        
        .status-draft {
            background: rgba(107, 114, 128, 0.1);
            color: #4B5563;
        }
        
        .views-count {
            display: flex;
            align-items: center;
            gap: 5px;
            font-weight: 600;
            color: var(--telex-blue);
        }
        
        .views-count i {
            color: var(--telex-red);
        }
        
        /* Action Buttons */
        .action-buttons {
            display: flex;
            gap: 8px;
        }
        
        .btn-action {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #e2e8f0;
            background: white;
            color: #64748b;
            transition: all 0.3s;
            text-decoration: none;
        }
        
        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }
        
        .btn-view:hover {
            background: #3B82F6;
            color: white;
            border-color: #3B82F6;
        }
        
        .btn-edit:hover {
            background: #FBBF24;
            color: white;
            border-color: #FBBF24;
        }
        
        .btn-delete:hover {
            background: var(--telex-red);
            color: white;
            border-color: var(--telex-red);
        }
        
        /* thumbnail dans le tableau */
        .news-thumb { width: 52px; height: 40px; border-radius: 6px; object-fit: cover; background: #f1f5f9; display: block; }
        .news-thumb-empty { width: 52px; height: 40px; border-radius: 6px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; color: #cbd5e1; font-size: .75rem; }
        
        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }
        
        .empty-state-icon {
            font-size: 4rem;
            color: #e2e8f0;
            margin-bottom: 20px;
        }
        
        .empty-state h3 {
            color: #64748b;
            font-weight: 600;
            margin-bottom: 10px;
        }
        
        .empty-state p {
            color: #94a3b8;
            margin-bottom: 30px;
            max-width: 400px;
            margin-left: auto;
            margin-right: auto;
        }
        
        /* Footer */
        .page-footer {
            text-align: center;
            padding: 20px;
            color: #94a3b8;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 30px;
            border-top: 1px solid #e2e8f0;
        }
        
        .footer-logo {
            height: 20px;
            width: auto;
            opacity: 0.6;
        }
        
        /* Responsive */
        @media (max-width: 992px) {
            .sidebar {
                width: 70px;
                overflow: hidden;
            }
            
            .sb-header { padding:12px 0; }
            .sb-logo { height:32px; }
            .nav-section-label { display:none; }
            .nav-link span { display:none; }
            .nav-link { justify-content:center; padding:11px 0; }
            .sidebar-footer { padding:6px 4px 10px; }
            
            .main-content {
                margin-left: 70px;
                padding: 20px;
            }
            
            .top-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            
            .top-actions {
                width: 100%;
                justify-content: space-between;
            }
        }
        
        @media (max-width: 768px) {
            .kpi-row { grid-template-columns: repeat(2, 1fr); }
            .dash-header { flex-direction: column; align-items: flex-start; gap: 12px; }
            
            .table-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            
            .news-excerpt {
                max-width: 200px;
            }
            
            .action-buttons {
                flex-direction: column;
            }
        }
        
        @media (max-width: 576px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    
        /* ── Responsive mobile (<576px) ── */
        @media (max-width: 576px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform .3s ease;
                z-index: 1050;
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.45);
                z-index: 1040;
            }
            .sidebar-overlay.show { display: block; }
            .main-content { margin-left: 0 !important; }
            .mobile-menu-btn {
                display: flex !important;
            }
        }
        .mobile-menu-btn {
            display: none;
            position: fixed;
            top: 14px;
            left: 14px;
            z-index: 1060;
            background: var(--telex-blue, #1D3557);
            color: white;
            border: none;
            border-radius: 8px;
            width: 40px;
            height: 40px;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.25);
        }</style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sb-header">
            <img src="/images/Telex.png" alt="Telex" class="sb-logo">
        </div>
        <nav class="sidebar-nav">
            <div class="nav-item">
                <a href="/admin/dashboard" class="nav-link">
                    <i class="fas fa-tachometer-alt"></i><span>Dashboard</span>
                </a>
            </div>
            <div class="nav-section-label">Contenu</div>
            <div class="nav-item"><a href="/admin/news" class="nav-link active"><i class="fas fa-newspaper"></i><span>Actualités</span></a></div>
            <div class="nav-item"><a href="/admin/programs" class="nav-link"><i class="fas fa-tv"></i><span>Programmes</span></a></div>
            <div class="nav-section-label">Communauté</div>
            <div class="nav-item"><a href="/admin/baume-de-la-foi" class="nav-link"><i class="fas fa-cross"></i><span>Baume de la Foi</span></a></div>
            <div class="nav-item"><a href="/admin/contacts" class="nav-link"><i class="fas fa-envelope"></i><span>Messages</span></a></div>
            <div class="nav-section-label">Médias</div>
            <div class="nav-item"><a href="/admin/gallery" class="nav-link"><i class="fas fa-images"></i><span>Galerie</span></a></div>
            <div class="nav-item"><a href="/admin/album" class="nav-link"><i class="fas fa-book"></i><span>Album</span></a></div>
        </nav>
        <div class="sidebar-footer">
            <div class="nav-item"><a href="/admin/settings" class="nav-link"><i class="fas fa-cog"></i><span>Paramètres</span></a></div>
            <div class="nav-item"><a href="/admin/logout" class="nav-link logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a></div>
        </div>
    </div>
    
    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <%
            const publishedCount = news.filter(n => n.is_published).length;
            const draftCount = news.filter(n => !n.is_published).length;
            const categoriesCount = [...new Set(news.map(n => n.category))].length;
            const totalViews = news.reduce((sum, n) => sum + (n.views || 0), 0);
        %>
        <div class="dash-header">
            <div class="dash-header-left">
                <img src="/images/Telex.png" alt="Telex" class="dash-header-logo">
                <div>
                    <p class="dash-header-title"><i class="fas fa-newspaper me-2" style="color:var(--telex-red)"></i>Gestion des Actualités</p>
                    <p class="dash-header-sub"><%= news.length %> publication<%= news.length !== 1 ? 's' : '' %> · <%= publishedCount %> publiée<%= publishedCount !== 1 ? 's' : '' %></p>
                </div>
            </div>
            <div class="dash-header-right">
                <a href="/" target="_blank" class="btn-site-link"><i class="fas fa-globe"></i> Voir le site</a>
                <a href="/admin/news/new" class="btn-telex"><i class="fas fa-plus me-2"></i>Nouvelle actualité</a>
            </div>
        </div>

        <!-- KPI tiles -->
        <div class="kpi-row">
            <div class="kpi-tile">
                <div class="kpi-icon pub"><i class="fas fa-check-circle"></i></div>
                <div class="kpi-body">
                    <div class="kpi-num"><%= publishedCount %></div>
                    <div class="kpi-label">Publiées</div>
                </div>
            </div>
            <div class="kpi-tile">
                <div class="kpi-icon draft"><i class="fas fa-pen"></i></div>
                <div class="kpi-body">
                    <div class="kpi-num"><%= draftCount %></div>
                    <div class="kpi-label">Brouillons</div>
                </div>
            </div>
            <div class="kpi-tile">
                <div class="kpi-icon cat"><i class="fas fa-tags"></i></div>
                <div class="kpi-body">
                    <div class="kpi-num"><%= categoriesCount %></div>
                    <div class="kpi-label">Catégories</div>
                </div>
            </div>
            <div class="kpi-tile">
                <div class="kpi-icon views"><i class="fas fa-eye"></i></div>
                <div class="kpi-body">
                    <div class="kpi-num" id="totalViewsDisplay"><%= totalViews %></div>
                    <div class="kpi-label">Vues totales</div>
                </div>
            </div>
        </div>
        
        <!-- News Table -->
        <div class="table-container">
            <div class="table-header">
                <h2><i class="fas fa-newspaper"></i>Actualités</h2>
                <div class="filter-chips" id="filterChips">
                    <span class="chip active-all" data-filter="all">Toutes (<%= news.length %>)</span>
                    <span class="chip" data-filter="published">Publiées (<%= publishedCount %>)</span>
                    <span class="chip" data-filter="draft">Brouillons (<%= draftCount %>)</span>
                </div>
            </div>

            <% if (news.length > 0) { %>
            <div class="table-responsive">
                <table class="table" id="newsTable">
                    <thead>
                        <tr>
                            <th width="60"></th>
                            <th>Titre</th>
                            <th width="110">Catégorie</th>
                            <th width="120">Date</th>
                            <th width="95">Statut</th>
                            <th width="75">Vues</th>
                            <th width="120" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% news.forEach(item => { %>
                        <tr>
                            <td style="padding:10px 12px">
                                <% if (item.image_url) { %>
                                    <img src="<%= item.image_url %>" alt="" class="news-thumb">
                                <% } else if (item.video_url) { %>
                                    <div class="news-thumb-empty"><i class="fas fa-video"></i></div>
                                <% } else { %>
                                    <div class="news-thumb-empty"><i class="fas fa-newspaper"></i></div>
                                <% } %>
                            </td>
                            <td class="col-titre">
                                <a href="/news/<%= item.slug %>" target="_blank" class="news-title" title="<%= item.title %>">
                                    <%= item.title %>
                                </a>
                                <% if (item.excerpt) { %>
                                <div class="news-excerpt" title="<%= item.excerpt %>">
                                    <%= item.excerpt %>
                                </div>
                                <% } %>
                                <div style="font-size:.72rem;color:#94a3b8;margin-top:2px"><i class="fas fa-user me-1"></i><%= item.author %></div>
                            </td>
                            <td>
                                <span class="category-badge"><%= item.category %></span>
                            </td>
                            <td data-order="<%= new Date(item.created_at).getTime() %>">
                                <div class="date-info">
                                    <span class="date-main"><%= new Date(item.created_at).toLocaleDateString('fr-FR') %></span>
                                    <span class="date-time"><i class="far fa-clock me-1"></i><%= new Date(item.created_at).toLocaleTimeString('fr-FR', {hour: '2-digit', minute:'2-digit'}) %></span>
                                </div>
                            </td>
                            <td>
                                <span class="status-badge <%= item.is_published ? 'status-published' : 'status-draft' %>">
                                    <% if (item.is_published) { %>
                                    <i class="fas fa-circle" style="font-size:.45rem;vertical-align:middle"></i> Publié
                                    <% } else { %>
                                    <i class="fas fa-circle" style="font-size:.45rem;vertical-align:middle"></i> Brouillon
                                    <% } %>
                                </span>
                            </td>
                            <td>
                                <div class="views-count">
                                    <i class="fas fa-eye"></i>
                                    <span class="views-number" id="views-<%= item.id %>"><%= item.views || 0 %></span>
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="action-buttons" style="justify-content:center">
                                    <a href="/news/<%= item.slug %>" target="_blank" class="btn-action btn-view" title="Voir sur le site">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                    <a href="/admin/news/edit/<%= item.id %>" class="btn-action btn-edit" title="Éditer">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/admin/news/delete/<%= item.id %>" class="btn-action btn-delete" title="Supprimer"
                                       onclick="return confirm('Supprimer « <%= item.title %> » ? Cette action est irréversible.')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-newspaper"></i>
                </div>
                <h3>Aucune actualité trouvée</h3>
                <p>Commencez par créer votre première actualité pour enrichir votre site Telex.</p>
                <a href="/admin/news/new" class="btn btn-telex">
                    <i class="fas fa-plus me-2"></i>Créer ma première actualité
                </a>
            </div>
            <% } %>
        </div>
        
        <!-- Footer -->
        <div class="page-footer">
            <img src="/images/Telex.png" alt="TELEX" class="footer-logo">
            <div>
                Telex Actualités • <%= new Date().getFullYear() %> • <%= news.length %> publication<%= news.length > 1 ? 's' : '' %>
            </div>
        </div>
    </div>
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
    // Fonction pour formater les nombres avec K, M, B
    function formatNumber(num) {
        if (num >= 1000000000) {
            return (num / 1000000000).toFixed(1).replace(/\.0$/, '') + 'B';
        }
        if (num >= 1000000) {
            return (num / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
        }
        if (num >= 1000) {
            return (num / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
        }
        return num.toString();
    }

    document.addEventListener('DOMContentLoaded', function() {
        console.log('Gestion des Actualités TELEX chargée');
        
        // Formater les vues totales
        const totalViewsElement = document.getElementById('totalViewsDisplay');
        if (totalViewsElement) {
            const totalViews = parseInt(totalViewsElement.textContent);
            totalViewsElement.textContent = formatNumber(totalViews);
        }
        
        // Formater les vues de chaque actualité
        document.querySelectorAll('.views-number').forEach(element => {
            const views = parseInt(element.textContent);
            element.textContent = formatNumber(views);
        });
        
        // Initialiser DataTable
        const table = $('#newsTable').DataTable({
            language: {
                "processing": "Traitement en cours...",
                "search": "Rechercher:",
                "lengthMenu": "Afficher _MENU_ éléments",
                "info": "Affichage de _START_ à _END_ sur _TOTAL_ éléments",
                "paginate": {
                    "first": "Premier",
                    "last": "Dernier",
                    "next": "Suivant",
                    "previous": "Précédent"
                }
            },
            pageLength: 10,
            order: [[3, 'desc']], // Tri par colonne Date (index 3) du plus récent au plus ancien
            responsive: true,
            columnDefs: [
                { orderable: false, targets: [0, 6] }, // Thumbnail et Actions non triables
                { type: 'date', targets: 3 }
            ],
            initComplete: function() {
                // Ajouter un champ de recherche personnalisé
                this.api().columns().every(function() {
                    const column = this;
                    // Exclure les colonnes d'actions
                    if (column.index() !== 6 && column.index() !== 7) {
                        const title = $(column.header()).text();
                        // Ajouter un champ de recherche pour chaque colonne
                    }
                });
            }
        });
        
        // Confirmation de suppression améliorée
        document.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const row = this.closest('tr');
                const title = row.querySelector('.news-title').textContent;
                
                if (!confirm(`Voulez-vous vraiment supprimer l'actualité "${title}" ?\n\nCette action est irréversible et supprimera définitivement l'actualité.`)) {
                    e.preventDefault();
                }
            });
        });
        
        // Animation des cartes de stats
        const statCards = document.querySelectorAll('.stat-card');
        statCards.forEach((card, index) => {
            card.style.animationDelay = `${index * 0.1}s`;
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            
            setTimeout(() => {
                card.style.transition = 'all 0.5s ease-out';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 100);
        });
        
        // Filtrage par les chips dans le header
        document.querySelectorAll('#filterChips .chip').forEach(chip => {
            chip.addEventListener('click', function() {
                document.querySelectorAll('#filterChips .chip').forEach(c => {
                    c.className = 'chip';
                });
                const filter = this.getAttribute('data-filter');
                this.classList.add('active-' + filter);

                if (filter === 'all') {
                    table.column(4).search('').draw();
                } else if (filter === 'published') {
                    table.column(4).search('Publié', false, false).draw();
                } else {
                    table.column(4).search('Brouillon', false, false).draw();
                }
            });
        });
    });
    </script>

    <script>
        function openSidebar() {
            document.querySelector('.sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('show');
        }
        function closeSidebar() {
            document.querySelector('.sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }
    </script></body>
</html>