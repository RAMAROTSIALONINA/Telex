<!DOCTYPE html>
<html lang="<%= currentLang || 'fr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Telex' %> - Telex</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Style Telex -->
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        /* SYSTÈME DE PAGES */
        .page-content {
            display: none;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .page-content.active {
            display: block;
            opacity: 1;
            animation: fadeIn 0.4s ease;
        }
        
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* COMPENSATION MENU FIXE */
        body {
            padding-top: 76px !important;
        }
        
        /* HERO SECTIONS */
        .hero-section, .page-hero {
            margin-top: -76px;
            padding-top: 176px;
        }
    </style>
</head>
<body>
    <!-- NAVIGATION FIXE -->
    <nav class="navbar navbar-expand-lg navbar-telex fixed-top">
        <div class="container">
            <!-- Logo -->
            <a class="navbar-brand" href="#" onclick="showPage('home'); return false;">
                <img src="/images/Telex.png" alt="Logo Telex" class="logo-img">
                <span class="logo-text">TE<span class="text-danger">LEX</span></span>
            </a>
            
            <!-- Menu mobile -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                <span class="navbar-toggler-icon">
                    <i class="fas fa-bars"></i>
                </span>
            </button>
            
            <!-- Menu principal -->
            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0" id="mainNavMenu">
                    <!-- Sélecteur de langue global -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="languageDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-globe"></i>
                            <span class="ms-1"><%= currentLang === 'en' ? 'EN' : 'FR' %></span>
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item <%= currentLang === 'fr' ? 'active' : '' %>" 
                                   href="?lang=fr">
