    <!-- Script pour la gestion des cookies -->
    <script>
        // Gestion du consentement RGPD
        class CookieConsent {
            constructor() {
                this.consentGiven = localStorage.getItem('telex_cookie_consent');
                this.preferences = JSON.parse(localStorage.getItem('telex_cookie_preferences') || '{}');
                this.init();
            }
            
            init() {
                if (!this.consentGiven) {
                    this.showBanner();
                }
                this.setupEventListeners();
            }
            
            showBanner() {
                const banner = document.getElementById('cookieConsent');
                if (banner) {
                    console.log('Affichage de la bannière de cookies...');
                    banner.style.display = 'block';
                    banner.style.visibility = 'visible';
                    banner.style.opacity = '1';
                    banner.style.position = 'fixed';
                    banner.style.bottom = '0';
                    banner.style.left = '0';
                    banner.style.right = '0';
                    banner.style.zIndex = '9999';
                    
                    // Forcer le reflow pour l'animation
                    banner.offsetHeight;
                    
                    setTimeout(() => {
                        banner.style.animation = 'slideUp 0.5s ease';
                    }, 100);
                } else {
                    console.error('Bannière de cookies non trouvée');
                }
            }
            
            hideBanner() {
                const banner = document.getElementById('cookieConsent');
                if (banner) {
                    banner.style.animation = 'slideDown 0.5s ease';
                    setTimeout(() => {
                        banner.style.display = 'none';
                    }, 500);
                }
            }
            
            acceptAll() {
                this.preferences = {
                    essential: true,
                    performance: true,
                    personalization: true,
                    marketing: true
                };
                this.saveConsent();
                this.hideBanner();
                this.loadScripts();
            }
            
            acceptNecessary() {
                this.preferences = {
                    essential: true,
                    performance: false,
                    personalization: false,
                    marketing: false
                };
                this.saveConsent();
                this.hideBanner();
                this.loadEssentialScripts();
            }
            
            saveCustomPreferences() {
                this.preferences = {
                    essential: true,
                    performance: document.getElementById('performanceCookies').checked,
                    personalization: document.getElementById('personalizationCookies').checked,
                    marketing: document.getElementById('marketingCookies').checked
                };
                this.saveConsent();
                this.hideBanner();
                this.loadScripts();
            }
            
            saveConsent() {
                localStorage.setItem('telex_cookie_consent', 'given');
                localStorage.setItem('telex_cookie_preferences', JSON.stringify(this.preferences));
            }
            
            loadScripts() {
                // Charger les scripts selon les préférences
                if (this.preferences.performance) {
                    console.log('Chargement des scripts de performance...');
                    // Google Analytics, etc.
                }
                
                if (this.preferences.personalization) {
                    console.log('Chargement des scripts de personnalisation...');
                    // Scripts de personnalisation
                }
                
                if (this.preferences.marketing) {
                    console.log('Chargement des scripts de marketing...');
                    // Scripts de marketing/publicité
                }
                
                // Les scripts essentiels sont toujours chargés
                this.loadEssentialScripts();
            }
            
            loadEssentialScripts() {
                console.log('Chargement des scripts essentiels...');
                // Scripts nécessaires au fonctionnement du site
            }
            
            setupEventListeners() {
                // Bouton "Tout accepter"
                const acceptAllBtn = document.getElementById('acceptAllBtn');
                if (acceptAllBtn) {
                    acceptAllBtn.addEventListener('click', () => this.acceptAll());
                }
                
                // Bouton "Uniquement essentiel"
                const acceptNecessaryBtn = document.getElementById('acceptNecessaryBtn');
                if (acceptNecessaryBtn) {
                    acceptNecessaryBtn.addEventListener('click', () => this.acceptNecessary());
                }
                
                // Bouton "Personnaliser"
                const customizeBtn = document.getElementById('customizeBtn');
                if (customizeBtn) {
                    customizeBtn.addEventListener('click', () => {
                        const modal = new bootstrap.Modal(document.getElementById('cookieModal'));
                        modal.show();
                    });
                }
                
                // Bouton "Enregistrer les préférences"
                const savePreferencesBtn = document.getElementById('savePreferencesBtn');
                if (savePreferencesBtn) {
                    savePreferencesBtn.addEventListener('click', () => {
                        this.saveCustomPreferences();
                        const modal = bootstrap.Modal.getInstance(document.getElementById('cookieModal'));
                        modal.hide();
                    });
                }
                
                // Mettre à jour les switches dans la modal selon les préférences
                const modal = document.getElementById('cookieModal');
                if (modal) {
                    modal.addEventListener('show.bs.modal', () => {
                        document.getElementById('performanceCookies').checked = this.preferences.performance || false;
                        document.getElementById('personalizationCookies').checked = this.preferences.personalization || false;
                        document.getElementById('marketingCookies').checked = this.preferences.marketing || false;
                    });
                }
            }
        }
        
        // Animation CSS
        const style = document.createElement('style');
        style.textContent = `
            @keyframes slideUp {
                from {
                    transform: translateY(100%);
                    opacity: 0;
                }
                to {
                    transform: translateY(0);
                    opacity: 1;
                }
            }
            
            @keyframes slideDown {
                from {
                    transform: translateY(0);
                    opacity: 1;
                }
                to {
                    transform: translateY(100%);
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);
        
        // Initialiser la gestion des cookies
        document.addEventListener('DOMContentLoaded', function() {
            new CookieConsent();
            
            // Bouton de test pour afficher la bannière (à enlever en production)
            if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
                const testBtn = document.createElement('button');
                testBtn.innerHTML = '<i class="fas fa-cookie"></i> Test Bannière RGPD';
                testBtn.style.cssText = `
                    position: fixed;
                    top: 100px;
                    right: 20px;
                    background: #FF4757;
                    color: white;
                    border: none;
                    padding: 10px 15px;
                    border-radius: 8px;
                    z-index: 10000;
                    cursor: pointer;
                    font-size: 12px;
                    box-shadow: 0 4px 12px rgba(255,71,87,0.3);
                `;
                testBtn.onclick = function() {
                    // Supprimer le consentement existant
                    localStorage.removeItem('telex_cookie_consent');
                    localStorage.removeItem('telex_cookie_preferences');
                    
                    // Forcer l'affichage immédiat
                    const banner = document.getElementById('cookieConsent');
                    if (banner) {
                        banner.style.display = 'block';
                        banner.style.visibility = 'visible';
                        banner.style.opacity = '1';
                        banner.style.position = 'fixed';
                        banner.style.bottom = '0';
                        banner.style.left = '0';
                        banner.style.right = '0';
                        banner.style.zIndex = '9999';
                        console.log('Bannière forcée manuellement');
                    } else {
                        console.error('Bannière non trouvée même en forçage');
                        // Recharger si la bannière n'existe pas
                        window.location.reload();
                    }
                };
                document.body.appendChild(testBtn);
            }
        });
    </script>
    
    <% if (process.env.NODE_ENV === 'production') { %>
    <script>
        // PROTECTION CONTRE L'ACCÈS AU CODE SOURCE - PRODUCTION
        (function() {
            'use strict';
            
            // 1. Désactiver le clic droit
            document.addEventListener('contextmenu', function(e) {
                e.preventDefault();
                return false;
            });
            
            // 2. Bloquer les touches d'ouverture des outils de développement
            document.addEventListener('keydown', function(e) {
                // F12
                if (e.keyCode === 123) {
                    e.preventDefault();
                    return false;
                }
                // Ctrl+Shift+I
                if (e.ctrlKey && e.shiftKey && e.keyCode === 73) {
                    e.preventDefault();
                    return false;
                }
                // Ctrl+Shift+J (Chrome)
                if (e.ctrlKey && e.shiftKey && e.keyCode === 74) {
                    e.preventDefault();
                    return false;
                }
                // Ctrl+U (Voir source)
                if (e.ctrlKey && e.keyCode === 85) {
                    e.preventDefault();
                    return false;
                }
            });
            
            // 3. Détecter l'ouverture des outils de développement
            let devtools = {open: false, orientation: null};
            let threshold = 160;
            
            setInterval(function() {
                if (window.outerHeight - window.innerHeight > threshold || 
                    window.outerWidth - window.innerWidth > threshold) {
                    if (!devtools.open) {
                        devtools.open = true;
                        // Rediriger vers une page blanche
                        document.body.innerHTML = '<div style="display: flex; justify-content: center; align-items: center; height: 100vh; font-family: Arial, sans-serif; background: #f5f5f5;"><div style="text-align: center; padding: 40px; background: white; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);"><h2 style="color: #e74c3c; margin-bottom: 20px;"> Accès Refusé</h2><p style="color: #555; margin-bottom: 20px;">Les outils de développement ne sont pas autorisés sur cette page.</p><button onclick="location.reload()" style="padding: 10px 20px; background: #3498db; color: white; border: none; border-radius: 5px; cursor: pointer;">Recharger la page</button></div></div>';
                        console.clear();
                    }
                } else {
                    devtools.open = false;
                }
            }, 500);
            
            // 4. Masquer les console.log en production
            console.log = function() {};
            console.warn = function() {};
            console.error = function() {};
            console.info = function() {};
            console.debug = function() {};
            
            // 5. Protection contre la copie de texte
            document.addEventListener('selectstart', function(e) {
                e.preventDefault();
                return false;
            });
            
            // 6. Désactiver le drag and drop
            document.addEventListener('dragstart', function(e) {
                e.preventDefault();
                return false;
            });
        })();
    <% } %>
