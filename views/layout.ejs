                                   href="?lang=en">
                                    <i class="fas fa-flag-usa me-2"></i>English
                                </a>
                            </li>
                        </ul>
                    </li>
                    <!-- Tous les liens sont visibles -->
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'home' ? 'active' : '' %>" 
                           href="#" 
                           onclick="showPage('home'); return false;">
                            <i class="fas fa-home me-2"></i><%= __("navigation.home") %>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'about' ? 'active' : '' %>" 
                           href="#" 
                           onclick="showPage('about'); return false;">
                            <i class="fas fa-info-circle me-2"></i><%= __("navigation.about") %>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'programs' ? 'active' : '' %>" 
                           href="#" 
                           onclick="showPage('programs'); return false;">
                            <i class="fas fa-tv me-2"></i><%= __("navigation.programs") %>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'gallery' ? 'active' : '' %>" 
                           href="#" 
                           onclick="showPage('gallery'); return false;">
                            <i class="fas fa-images me-2"></i><%= __("navigation.gallery") %>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'album' ? 'active' : '' %>" 
                           href="/album">
                            <i class="fas fa-book me-2"></i>Album
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'baume-de-la-foi' ? 'active' : '' %>" 
                           href="/baume-de-la-foi">
                            <i class="fas fa-cross me-2"></i>Baume de la Foi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'news' ? 'active' : '' %>" 
                           href="#" 
                           onclick="showPage('news'); return false;">
                            <i class="fas fa-newspaper me-2"></i><%= __("navigation.news") %>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'contact' ? 'active' : '' %>" 
                           href="#" 
                           onclick="showPage('contact'); return false;">
