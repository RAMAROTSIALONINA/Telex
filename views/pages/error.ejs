<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Erreur' %> - Telex</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Montserrat:wght@400;600;700;900&display=swap" rel="stylesheet">

    <!-- CSS TELEX -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">

    <!-- Favicon -->
    <link rel="icon" href="/images/Telex.png" type="image/png">

    <style>
        /* ===== ERROR PAGE ===== */
        .error-hero {
            position: relative;
            background: linear-gradient(135deg, #457B9D 0%, #22385B 100%);
            padding: 64px 0 0;
            min-height: 320px;
            display: flex;
            align-items: center;
            overflow: hidden;
            text-align: center;
        }

        .error-hero-deco {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            opacity: 0.08;
            pointer-events: none;
            height: auto;
        }
        .error-hero-deco.left  { left: 24px;  max-width: 120px; }
        .error-hero-deco.right { right: 24px; max-width: 100px; }

        .error-code-display {
            font-size: clamp(5rem, 18vw, 9rem);
            font-weight: 900;
            font-family: 'Montserrat', sans-serif;
            color: rgba(255,255,255,0.12);
            line-height: 1;
            letter-spacing: -0.04em;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
            user-select: none;
            white-space: nowrap;
        }

        .error-hero-content {
            position: relative;
            z-index: 2;
            width: 100%;
        }

        .error-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(230, 57, 70, 0.18);
            border: 1px solid rgba(230, 57, 70, 0.45);
            color: #f87171;
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.16em;
            padding: 5px 14px;
            border-radius: 20px;
            margin-bottom: 18px;
        }

        .error-title {
            font-size: clamp(1.5rem, 4vw, 2.4rem);
            font-weight: 900;
            color: #fff;
            font-family: 'Montserrat', sans-serif;
            letter-spacing: -0.02em;
            margin-bottom: 12px;
            line-height: 1.1;
        }

        .error-message {
            font-size: 1rem;
            color: rgba(255,255,255,0.68);
            max-width: 460px;
            margin: 0 auto 32px;
            line-height: 1.65;
        }

        .error-actions {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 56px;
        }

        .btn-error-home {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #E63946;
            color: #fff !important;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.09em;
            padding: 12px 28px;
            border-radius: 8px;
            text-decoration: none !important;
            transition: background 0.2s, transform 0.15s;
            border: none;
        }
        .btn-error-home:hover {
            background: #c1121f;
            transform: translateY(-2px);
            color: #fff !important;
        }

        .btn-error-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.85) !important;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none !important;
            border: 1px solid rgba(255,255,255,0.2);
            transition: background 0.2s, transform 0.15s;
        }
        .btn-error-back:hover {
            background: rgba(255,255,255,0.18);
            transform: translateY(-2px);
            color: #fff !important;
        }

        .error-wave {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            display: block;
        }

        /* Suggestions section */
        .error-suggestions {
            background: #f8fafc;
            padding: 52px 0 64px;
        }

        .error-suggestions-title {
            font-size: 1rem;
            font-weight: 700;
            color: #1e293b;
            text-align: center;
            margin-bottom: 28px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-size: 0.75rem;
            color: #64748b;
        }

        .error-link-card {
            display: flex;
            align-items: center;
            gap: 14px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 18px 22px;
            text-decoration: none !important;
            transition: box-shadow 0.2s, transform 0.15s, border-color 0.2s;
            color: #1e293b !important;
        }
        .error-link-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            transform: translateY(-3px);
            border-color: #E63946;
            color: #1e293b !important;
        }

        .error-link-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: linear-gradient(135deg, #457B9D, #22385B);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .error-link-label {
            font-size: 0.9rem;
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 2px;
        }
        .error-link-desc {
            font-size: 0.75rem;
            color: #94a3b8;
        }

        @media (max-width: 768px) {
            .error-hero { padding: 52px 0 0; min-height: 280px; }
            .error-hero-deco { display: none; }
            .error-message { font-size: 0.9rem; }
            .error-actions { gap: 8px; }
        }
        @media (max-width: 576px) {
            .error-hero { padding: 44px 0 0; }
            .btn-error-home, .btn-error-back { width: 100%; justify-content: center; }
            .error-suggestions { padding: 36px 0 48px; }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include('../partials/navbar') %>

    <!-- Hero erreur -->
    <section class="error-hero">
        <img src="/images/logo.png"    alt="" class="error-hero-deco left"  aria-hidden="true">
        <img src="/images/drapeau.png" alt="" class="error-hero-deco right" aria-hidden="true">

        <!-- Code erreur en filigrane -->
        <div class="error-code-display" aria-hidden="true">
            <%= typeof code !== 'undefined' ? code : '404' %>
        </div>

        <div class="container error-hero-content">
            <div class="error-badge">
                <i class="fas fa-exclamation-triangle"></i>
                Erreur <%= typeof code !== 'undefined' ? code : '404' %>
            </div>

            <h1 class="error-title">
                <%= typeof title !== 'undefined' ? title : 'Page introuvable' %>
            </h1>

            <p class="error-message">
                <%= typeof message !== 'undefined' ? message : 'La page que vous recherchez n\'existe pas ou a été déplacée.' %>
            </p>

            <div class="error-actions">
                <a href="/" class="btn-error-home">
                    <i class="fas fa-home"></i> Accueil
                </a>
                <a href="javascript:history.back()" class="btn-error-back">
                    <i class="fas fa-arrow-left"></i> Page précédente
                </a>
            </div>
        </div>

        <!-- Wave separator -->
        <svg class="error-wave" viewBox="0 0 1440 52" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,32 C360,60 1080,0 1440,32 L1440,52 L0,52 Z" fill="#f8fafc"/>
            <path d="M0,32 C360,60 1080,0 1440,32" fill="none" stroke="#E63946" stroke-width="2.5"/>
        </svg>
    </section>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/location.js"></script>
</body>
</html>
