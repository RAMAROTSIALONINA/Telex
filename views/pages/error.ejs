<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- CSS TELEX -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    
    <!-- Favicon -->
    <link rel="icon" href="/images/Telex.png" type="image/png">
    
    <style>
        html, body { 
            background: linear-gradient(135deg, #1D3557 0%, #457B9D 100%);
            color: white;
            height: 100%;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
        }
        body {
            padding-top: 80px; /* Espace pour la navbar fixe */
            min-height: 100vh;
        }
        .error-container {
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
            padding: 2rem;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .error-code {
            font-size: 5rem;
            font-weight: bold;
            color: #E63946;
        }
        
        /* Réduire la taille du logo dans la navbar */
        .navbar .navbar-brand img,
        .navbar-telex .navbar-brand img,
        .navbar-baume .navbar-brand img {
            height: 50px !important;
            width: auto;
            max-width: 150px !important;
            margin-left: 0px !important;
            transform: scale(1) !important;
            transform-origin: center;
        }
        
        /* Augmenter la taille du texte dans la navbar */
        .navbar .navbar-nav .nav-link,
        .navbar-telex .navbar-nav .nav-link,
        .navbar-baume .navbar-nav .nav-link {
            font-size: 1rem !important;
            padding: 8px 14px !important;
            margin: 0 3px !important;
        }
        
        .navbar .navbar-nav .nav-link i,
        .navbar-telex .navbar-nav .nav-link i,
        .navbar-baume .navbar-nav .nav-link i {
            font-size: 0.95rem !important;
            margin-right: 8px !important;
        }
        
        /* Footer en bas */
        footer {
            margin-top: auto;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-baume fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/Telex.png" alt="Logo Telex" class="logo-img">
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu" style="border: none; color: var(--baume-primary);">
                <i class="fas fa-bars"></i>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            <i class="fas fa-home"></i>Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">
                            <i class="fas fa-info-circle"></i>À propos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/programs">
                            <i class="fas fa-tv"></i>Programmes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/gallery">
                            <i class="fas fa-images"></i>Galerie
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/album">
                            <i class="fas fa-book"></i>Album
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/baume-de-la-foi">
                            <i class="fas fa-cross"></i>Baume de la Foi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/news">
                            <i class="fas fa-newspaper"></i>Actualités
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact">
                            <i class="fas fa-envelope"></i>Contact
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Contenu de l'erreur -->
    <div class="error-container">
        <div class="error-code"><%= typeof code !== 'undefined' ? code : '404' %></div>
        <h1><%= title %></h1>
        <p class="lead"><%= message %></p>
        
        <div class="mt-4">
            <a href="/" class="btn btn-light btn-lg">
                <i class="fas fa-home me-2"></i>Retour à l'accueil
            </a>
        </div>
    </div>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/location.js"></script>
</body>
</html>