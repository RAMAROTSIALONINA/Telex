<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* ===== NAVBAR AMÉLIORÉ ===== */
        .navbar,
        .navbar-telex,
        .navbar-baume {
            background: #051d40 !important;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            transition: all 0.3s ease;
            z-index: 1030 !important;
            padding-top: 0.05rem !important;
            padding-bottom: 0.05rem !important;
            min-height: 20px !important;
        }

        .navbar .navbar-brand img,
        .navbar-telex .navbar-brand img,
        .navbar-baume .navbar-brand img {
            height: 40px;
            width: auto;
            max-width: 150px;
            margin-right: 10px;
            transform: scale(2);
            transform-origin: center;
        }

        .navbar .navbar-nav .nav-link,
        .navbar-telex .navbar-nav .nav-link,
        .navbar-baume .navbar-nav .nav-link {
            color: white !important;
            font-weight: 700 !important;
            font-size: 1.1rem !important;
            font-family: 'League Spartan', sans-serif !important;
            text-transform: uppercase !important;
            padding: 8px 16px !important;
            margin: 0 4px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .navbar .navbar-nav .nav-link i,
        .navbar-telex .navbar-nav .nav-link i,
        .navbar-baume .navbar-nav .nav-link i {
            color: white !important;
            margin-right: 8px;
            font-size: 1.1rem !important;
        }

        .navbar .navbar-nav .nav-link:hover,
        .navbar-telex .navbar-nav .nav-link:hover,
        .navbar-baume .navbar-nav .nav-link:hover {
            color: white !important;
            background: #dc3545 !important;
            transform: translateY(-2px);
        }

        .navbar .navbar-nav .nav-link.active,
        .navbar-telex .navbar-nav .nav-link.active,
        .navbar-baume .navbar-nav .nav-link.active {
            color: white !important;
            background: #dc3545 !important;
        }

        body {
            padding-top: 0.1cm;
        }

        @media (max-width: 576px) {
            .navbar .navbar-brand img,
            .navbar-telex .navbar-brand img,
            .navbar-baume .navbar-brand img {
                height: 35px;
                width: auto;
                max-width: 120px;
                transform: scale(2);
                transform-origin: center;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-telex fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="/images/Telex.png" alt="Logo Telex" class="logo-img">
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/social">Réseaux</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <section class="page-hero">
        <div class="container">
            <h1>Réseaux sociaux Telex</h1>
            <p>Rejoignez notre communauté en ligne</p>
        </div>
    </section>

    <section class="section">
        <div class="container">
            <!-- Plateformes principales -->
            <div class="row mb-5">
                <div class="col-md-6 mb-4">
                    <div class="social-card youtube-card">
                        <div class="social-card-header">
                            <i class="fab fa-youtube fa-3x"></i>
                            <h3>YouTube</h3>
                        </div>
                        <div class="social-card-body">
                            <p>Retrouvez toutes nos émissions, reportages et interviews en intégralité.</p>
                            <div class="social-stats">
                                <div class="stat">
                                    <strong>2.5K</strong>
                                    <span>Abonnés</span>
                                </div>
                                <div class="stat">
                                    <strong>50+</strong>
                                    <span>Vidéos</span>
                                </div>
                                <div class="stat">
                                    <strong>10K</strong>
                                    <span>Vues/mois</span>
                                </div>
                            </div>
                            <a href="https://youtube.com" target="_blank" class="btn btn-youtube">
                                <i class="fab fa-youtube me-2"></i>S'abonner
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="social-card instagram-card">
                        <div class="social-card-header">
                            <i class="fab fa-instagram fa-3x"></i>
                            <h3>Instagram</h3>
                        </div>
                        <div class="social-card-body">
                            <p>Les coulisses, stories et moments en direct de notre équipe.</p>
                            <div class="social-stats">
                                <div class="stat">
                                    <strong>1.8K</strong>
                                    <span>Abonnés</span>
                                </div>
                                <div class="stat">
                                    <strong>200+</strong>
                                    <span>Publications</span>
                                </div>
                                <div class="stat">
                                    <strong>500+</strong>
                                    <span>Stories/semaine</span>
                                </div>
                            </div>
                            <a href="https://instagram.com" target="_blank" class="btn btn-instagram">
                                <i class="fab fa-instagram me-2"></i>Nous suivre
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Autres réseaux -->
            <h3 class="text-center mb-4">Autres plateformes</h3>
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="social-platform-card">
                        <div class="platform-icon facebook">
                            <i class="fab fa-facebook-f fa-2x"></i>
                        </div>
                        <h4>Facebook</h4>
                        <p>Actualités, événements, albums photo</p>
                        <div class="platform-stats">
                            <span class="badge bg-primary">950 abonnés</span>
                        </div>
                        <a href="https://www.facebook.com/Telexmadagascar" target="_blank" class="btn btn-outline-primary btn-sm">
                            Voir la page
                        </a>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="social-platform-card">
                        <div class="platform-icon twitter">
                            <i class="fab fa-twitter fa-2x"></i>
                        </div>
                        <h4>Twitter</h4>
                        <p>Actualités en direct, live-tweets, débats</p>
                        <div class="platform-stats">
                            <span class="badge bg-info">1.2K abonnés</span>
                        </div>
                        <a href="https://twitter.com" target="_blank" class="btn btn-outline-info btn-sm">
                            Nous suivre
                        </a>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="social-platform-card">
                        <div class="platform-icon tiktok">
                            <i class="fab fa-tiktok fa-2x"></i>
                        </div>
                        <h4>TikTok</h4>
                        <p>Contenus courts, défis, humour</p>
                        <div class="platform-stats">
                            <span class="badge bg-dark">3.1K abonnés</span>
                        </div>
                        <a href="https://tiktok.com" target="_blank" class="btn btn-outline-dark btn-sm">
                            Suivre
                        </a>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="social-platform-card">
                        <div class="platform-icon linkedin">
                            <i class="fab fa-linkedin fa-2x"></i>
                        </div>
                        <h4>LinkedIn</h4>
                        <p>Réseau professionnel, offres de stage</p>
                        <div class="platform-stats">
                            <span class="badge bg-linkedin">450 abonnés</span>
                        </div>
                        <a href="https://linkedin.com" target="_blank" class="btn btn-outline-linkedin btn-sm">
                            Suivre
                        </a>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="social-platform-card">
                        <div class="platform-icon discord">
                            <i class="fab fa-discord fa-2x"></i>
                        </div>
                        <h4>Discord</h4>
                        <p>Communauté, échanges, entraide</p>
                        <div class="platform-stats">
                            <span class="badge bg-discord">300 membres</span>
                        </div>
                        <a href="https://discord.com" target="_blank" class="btn btn-outline-discord btn-sm">
                            Rejoindre
                        </a>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="social-platform-card">
                        <div class="platform-icon twitch">
                            <i class="fab fa-twitch fa-2x"></i>
                        </div>
                        <h4>Twitch</h4>
                        <p>Direct, gaming, discussions</p>
                        <div class="platform-stats">
                            <span class="badge bg-twitch">800 followers</span>
                        </div>
                        <a href="https://twitch.com" target="_blank" class="btn btn-outline-twitch btn-sm">
                            Suivre
                        </a>
                    </div>
                </div>
            </div>

            <!-- Hashtags -->
            <div class="hashtags-section text-center mt-5">
                <h4 class="mb-3">Nos hashtags</h4>
                <div class="hashtags">
                    <span class="hashtag">#TelexTV</span>
                    <span class="hashtag">#EtudiantsActifs</span>
                    <span class="hashtag">#CampusLife</span>
                    <span class="hashtag">#JeunesseEngagée</span>
                    <span class="hashtag">#MediasEtudiants</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>