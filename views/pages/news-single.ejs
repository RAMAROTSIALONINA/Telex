<!DOCTYPE html>
<html lang="fr">
<head>
        <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= news ? news.title + ' - Actualités' : 'Actualités' %> - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    
    <!-- Open Graph Meta Tags pour Facebook -->
    <% if (news) { %>
        <meta property="og:title" content="<%= news.title %> - Telex">
        <meta property="og:description" content="<%= (news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex, la télévision étudiante.') %>">
        <meta property="og:url" content="https://telex.mg/news/<%= news.id %>">
        <meta property="og:type" content="article">
        <meta property="og:site_name" content="Telex - Télévision Étudiante">
        <% if (news.image_url) { %>
            <meta property="og:image" content="https://telex.mg<%= news.image_url %>">
            <meta property="og:image:alt" content="<%= news.title %>">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
        <% } else if (news.video_url) { %>
            <meta property="og:image" content="https://telex.mg/images/Telex.png">
            <meta property="og:image:alt" content="<%= news.title %> - Vidéo">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
        <% } else { %>
            <meta property="og:image" content="https://telex.mg/images/Telex.png">
            <meta property="og:image:alt" content="Telex - Télévision Étudiante">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
        <% } %>
        <meta property="og:locale" content="fr_FR">
        <meta property="article:author" content="Telex">
        <meta property="article:section" content="<%= news.category || 'Actualités' %>">
        <meta property="article:published_time" content="<%= news.created_at ? new Date(news.created_at).toISOString() : new Date().toISOString() %>">
        
        <!-- Facebook App ID pour le SDK -->
        <!-- <meta property="fb:app_id" content="966242223397117"> -->
        
        <!-- Twitter Card Meta Tags -->
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="<%= news.title %> - Telex">
        <meta name="twitter:description" content="<%= (news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex.') %>">
        <% if (news.image_url) { %>
            <meta name="twitter:image" content="https://telex.mg<%= news.image_url %>">
        <% } else { %>
            <meta name="twitter:image" content="https://telex.mg/images/Telex.png">
        <% } %>
        <!-- Métadonnées pour le partage (article) -->
        <meta name="article:title" content="<%= news.title || '' %>">
        <meta name="article:description" content="<%= (news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex, la télévision étudiante.') %>">
        <meta name="article:url" content="https://telex.mg/news/<%= news.id %>">
    <% } %>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    
    <style>
        /* ===== NEWS-SINGLE PAGE STYLES ===== */
        body.article-page { padding-top: 0; background: #f8f9fa; }

        /* Hero wrapper */
        .article-hero-wrapper { position: relative !important; margin-bottom: 18px; }


        /* Media container */
        .article-hero-container { position: relative; border-radius: 12px; overflow: hidden; background: transparent; }

        .article-hero-image { width: 100%; height: 280px; overflow: hidden; background: #f8f9fa; display: flex; align-items: center; justify-content: center; }
        /* Spécificité (0,3,1) pour battre .article-page img:not() de style.css */
        .article-page .article-hero-container .article-hero-image img {
            width: auto !important;
            height: 100% !important;
            max-width: 100% !important;
            max-height: 280px !important;
            object-fit: contain !important;
            display: block !important;
            margin: 0 auto !important;
        }

        /* Video — max-height 360px pour rester compact */
        .video-container { width: 100%; position: relative; max-height: 360px; }
        .video-wrapper { position: relative; width: 100%; padding-top: min(56.25%, 360px); background: #1a1a1a; border-radius: 12px; overflow: hidden; }
        .video-wrapper iframe,
        .video-wrapper video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }

        /* Category badge on media */
        .image-category {
            position: absolute;
            top: 12px; left: 12px;
            background: rgba(220,53,69,0.9);
            color: white;
            font-size: 0.75rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.5px;
            padding: 4px 12px; border-radius: 20px;
            z-index: 5;
        }

        /* No-media hero */
        .article-hero-no-media { background: linear-gradient(135deg, #1d3557 0%, #457b9d 100%); border-radius: 12px; overflow: hidden; }
        .hero-no-media-background { padding: 36px 24px; text-align: center; position: relative; }
        .hero-pattern-overlay { position: absolute; inset: 0; opacity: 0.3; background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(255,255,255,0.03) 20px, rgba(255,255,255,0.03) 40px); }
        .hero-content-center { position: relative; z-index: 1; color: white; }
        .hero-icon-wrapper { width: 70px; height: 70px; background: rgba(255,255,255,0.15); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 2rem; margin-bottom: 16px; }
        .hero-title { font-size: 1.6rem; font-weight: 700; color: white; margin-bottom: 8px; }
        .hero-subtitle { color: rgba(255,255,255,0.8); margin-bottom: 16px; }
        .hero-meta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
        .hero-date, .hero-category { background: rgba(255,255,255,0.15); color: white; padding: 6px 14px; border-radius: 20px; font-size: 0.85rem; display: flex; align-items: center; gap: 6px; }

        /* Title section */
        .article-title-section { margin: 16px 0 14px; }
        .article-title-section h1 { font-size: 1.55rem; font-weight: 800; color: #1a1a2e; line-height: 1.25; margin-bottom: 10px; }

        /* Meta */
        .article-meta { display: flex; gap: 12px 16px; flex-wrap: wrap; margin-bottom: 0; padding-bottom: 12px; border-bottom: 2px solid #f0f0f0; }
        .meta-item { display: flex; align-items: center; gap: 6px; color: #6c757d; font-size: 0.82rem; }
        .meta-item i { color: #dc3545; font-size: 0.75rem; }

        /* Content */
        .article-content { font-size: 1.05rem; line-height: 1.85; color: #333; margin-bottom: 30px; }
        .article-content p { margin-bottom: 1rem; }

        /* Share buttons */
        .share-buttons { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin: 24px 0; padding: 16px; background: #f8f9fa; border-radius: 10px; }
        .share-title { font-weight: 700; color: #1d3557; margin-right: 4px; }
        .share-btn {
            display: inline-flex; align-items: center; justify-content: center;
            width: 40px; height: 40px; border-radius: 50%;
            color: white; font-size: 1rem;
            text-decoration: none; transition: transform 0.2s ease, opacity 0.2s ease;
        }
        .share-btn:hover { transform: scale(1.1); opacity: 0.9; color: white; }
        .share-facebook  { background: #1877f2; }
        .share-twitter   { background: #1da1f2; }
        .share-instagram { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
        .share-tiktok    { background: #010101; }
        .share-linkedin  { background: #0077b5; }
        .share-whatsapp  { background: #25d366; }

        /* Back button */
        .back-section { margin: 20px 0 30px; }
        .back-button { display: inline-flex; align-items: center; gap: 8px; background: #1d3557; color: white; padding: 10px 20px; border-radius: 25px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: background 0.2s; }
        .back-button:hover { background: #dc3545; color: white; }

        /* Not found */
        .article-not-found { text-align: center; padding: 80px 20px; }
        .article-not-found h1 { color: #1d3557; margin-bottom: 12px; }

        /* Sidebar */
        .sidebar-section { background: white; border: none; border-radius: 12px; padding: 20px; margin-bottom: 20px; }
        .sidebar-title { font-size: 1rem; font-weight: 700; color: #1d3557; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; border-bottom: 2px solid #f0f0f0; padding-bottom: 10px; }
        .sidebar-title i { color: #dc3545; }

        /* Sidebar items */
        .similar-videos, .similar-images { display: flex; flex-direction: column; gap: 12px; max-height: 500px; overflow-y: auto; }
        .similar-video-item, .similar-image-item { display: flex; gap: 10px; align-items: flex-start; text-decoration: none; color: inherit; padding: 8px; border-radius: 8px; transition: background 0.2s; }
        .similar-video-item:hover, .similar-image-item:hover { background: #f8f9fa; }
        .similar-video-thumbnail, .similar-image-thumbnail { width: 90px; height: 60px; border-radius: 6px; overflow: hidden; flex-shrink: 0; background: #e9ecef; position: relative; }
        .similar-video-thumbnail img, .similar-video-thumbnail iframe, .similar-video-thumbnail video,
        .similar-image-thumbnail img { width: 100%; height: 100%; object-fit: cover; border: none; }
        .similar-video-info, .similar-image-info { flex: 1; min-width: 0; }
        .similar-video-title, .similar-image-title { font-size: 0.85rem; font-weight: 600; color: #1a1a2e; line-height: 1.3; margin-bottom: 4px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
        .similar-video-meta, .similar-image-meta { font-size: 0.75rem; color: #6c757d; display: flex; align-items: center; gap: 4px; }

        /* Loading / fallback states */
        .loading-videos, .loading-images { text-align: center; padding: 24px; color: #6c757d; font-size: 0.9rem; }
        .loading-videos i, .loading-images i { display: block; font-size: 1.8rem; margin-bottom: 8px; color: #dee2e6; }
        .video-fallback { text-align: center; padding: 30px; color: #6c757d; }
        .video-fallback i { font-size: 2.5rem; color: #dc3545; margin-bottom: 10px; display: block; }

        /* Thumbnails sidebar — spécificité (0,3,1) pour battre style.css */
        .article-page .similar-video-thumbnail img,
        .article-page .similar-image-thumbnail img {
            width: 100% !important;
            height: 100% !important;
            max-width: none !important;
            max-height: none !important;
            object-fit: cover !important;
            display: block !important;
            margin: 0 !important;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 992px) {
            .article-layout { grid-template-columns: 1fr !important; }
            .article-sidebar { display: none; }
            .article-hero-image { height: 240px; }
            .article-page .article-hero-container .article-hero-image img { max-height: 240px !important; }
        }
        @media (max-width: 768px) {
            .article-title-section { margin: 12px 0 10px; }
            .article-title-section h1 { font-size: 1.3rem; }
            .article-hero-image { height: 210px; }
            .article-page .article-hero-container .article-hero-image img { max-height: 210px !important; }
            .video-wrapper { padding-top: min(56.25%, 280px); }
            .article-content { font-size: 0.97rem; line-height: 1.75; }
            .share-buttons { gap: 8px; padding: 12px; }
            .share-btn { width: 36px; height: 36px; font-size: 0.9rem; }
        }
        @media (max-width: 576px) {
            .article-title-section h1 { font-size: 1.15rem; }
            .article-hero-image { height: 180px; }
            .article-page .article-hero-container .article-hero-image img { max-height: 180px !important; }
            .hero-no-media-background { padding: 28px 14px; }
            .hero-title { font-size: 1.1rem; }
            .meta-item { font-size: 0.78rem; }
            .article-content { font-size: 0.93rem; }
            .share-buttons { flex-wrap: wrap; }
        }
    </style>
</head>
<body class="article-page">
    <%- include('../partials/navbar') %>

    <div class="article-page">
        <div class="container" style="max-width:960px">
            <div class="article-layout">
                <!-- Colonne principale -->
                <div class="article-main">
                    <% if (news) { %>
                        <!-- Titre et métadonnées AU-DESSUS de l'image -->
                        <div class="article-title-section">
                            <h1><%= news.title %></h1>
                            <div class="article-meta">
                                <div class="meta-item">
                                    <i class="far fa-calendar"></i>
                                    <%= new Date(news.created_at).toLocaleDateString('fr-FR', {
                                        day: 'numeric',
                                        month: 'long',
                                        year: 'numeric'
                                    }) %>
                                </div>
                                <% if (news.author) { %>
                                <div class="meta-item">
                                    <i class="fas fa-user"></i>
                                    <%= news.author %>
                                </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- WRAPPER IMAGE -->
                        <div class="article-hero-wrapper">
                            
                            <!-- Contenu média principal -->
                            <div class="hero-content">
                                <% 
                                // Fonctions d'extraction d'ID vidéo
                                function extractYouTubeId(url) {
                                    try {
                                        const urlStr = String(url || '');
                                        const match = urlStr.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/);
                                        if (match && match[1]) return match[1];
                                        const vParam = urlStr.match(/[?&]v=([A-Za-z0-9_-]{11})/);
                                        if (vParam && vParam[1]) return vParam[1];
                                        return '';
                                    } catch (e) {
                                        return '';
                                    }
                                }

                                function extractVimeoId(url) {
                                    try {
                                        const urlStr = String(url || '');
                                        const clean = urlStr.split('?')[0].split('#')[0];
                                        const match = clean.match(/vimeo\.com\/(?:video\/)?(\d+)/);
                                        if (match && match[1]) return match[1];
                                        const last = clean.split('/').filter(Boolean).pop() || '';
                                        return /^\d+$/.test(last) ? last : '';
                                    } catch (e) {
                                        return '';
                                    }
                                }
                                %>

                                <% if (news.video_url && !news.image_url) { %>
                                    <!-- CAS 1: Seulement vidéo -->
                                    <div class="article-hero-container">
                                        <div class="video-container">
                                            <div class="video-wrapper">
                                                <% 
                                                let videoId = '';
                                                let videoType = 'unknown';
                                                let videoSrc = news.video_url;

                                                if (news.video_url.includes('youtube.com') || news.video_url.includes('youtu.be')) {
                                                    videoId = extractYouTubeId(news.video_url);
                                                    videoType = 'youtube';
                                                    videoSrc = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&controls=1&enablejsapi=1`;
                                                } else if (news.video_url.includes('vimeo.com')) {
                                                    videoId = extractVimeoId(news.video_url);
                                                    videoType = 'vimeo';
                                                    videoSrc = `https://player.vimeo.com/video/${videoId}?autoplay=1&muted=1&controls=1`;
                                                } else {
                                                    videoType = 'uploaded';
                                                }
                                                %>

                                                <% if (videoType === 'youtube' || videoType === 'vimeo') { %>
                                                    <iframe 
                                                        src="<%= videoSrc %>"
                                                        frameborder="0"
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                        allowfullscreen>
                                                    </iframe>
                                                <% } else { %>
                                                    <video 
                                                        src="<%= news.video_url %>"
                                                        controls
                                                        autoplay
                                                        muted
                                                        preload="metadata"
                                                        playsinline>
                                                        Votre navigateur ne supporte pas la vidéo.
                                                    </video>
                                                <% } %>
                                            </div>
                                            <span class="image-category"><%= news.category || 'Actualité' %></span>
                                        </div>
                                    </div>

                                <% } else if (news.image_url && !news.video_url) { %>
                                    <!-- CAS 2: Seulement image -->
                                    <div class="article-hero-container">
                                        <div class="article-hero-image">
                                            <img src="<%= news.image_url %>" alt="<%= news.title %>" loading="lazy">
                                        </div>
                                        <span class="image-category"><%= news.category || 'Actualité' %></span>
                                    </div>

                                <% } else if (news.image_url && news.video_url) { %>
                                    <!-- CAS 3: Vidéo ET image -->
                                    <div class="article-hero-container">
                                        <div class="video-container">
                                            <div class="video-wrapper">
                                                <% 
                                                let videoId = '';
                                                let videoType = 'unknown';
                                                let videoSrc = news.video_url;

                                                if (news.video_url.includes('youtube.com') || news.video_url.includes('youtu.be')) {
                                                    videoId = extractYouTubeId(news.video_url);
                                                    videoType = 'youtube';
                                                    videoSrc = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&controls=1&enablejsapi=1`;
                                                } else if (news.video_url.includes('vimeo.com')) {
                                                    videoId = extractVimeoId(news.video_url);
                                                    videoType = 'vimeo';
                                                    videoSrc = `https://player.vimeo.com/video/${videoId}?autoplay=1&muted=1&controls=1`;
                                                } else {
                                                    videoType = 'uploaded';
                                                }
                                                %>
                                                
                                                <% if (videoType === 'youtube' || videoType === 'vimeo') { %>
                                                    <iframe 
                                                        src="<%= videoSrc %>"
                                                        frameborder="0"
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                        allowfullscreen>
                                                    </iframe>
                                                <% } else { %>
                                                    <video 
                                                        src="<%= news.video_url %>"
                                                        controls
                                                        autoplay
                                                        muted
                                                        preload="metadata"
                                                        playsinline>
                                                        Votre navigateur ne supporte pas la vidéo.
                                                    </video>
                                                <% } %>
                                            </div>
                                            <span class="image-category"><%= news.category || 'Actualité' %></span>
                                        </div>
                                    </div>
                                    
                                    <!-- Image additionnelle -->
                                    <div class="article-hero-container" style="margin-top: 20px;">
                                        <div class="article-hero-image">
                                            <img src="<%= news.image_url %>" alt="<%= news.title %>" loading="lazy">
                                        </div>
                                    </div>

                                <% } else { %>
                                    <!-- CAS 4: Aucun média -->
                                    <div class="article-hero-container">
                                        <div class="article-hero-no-media">
                                            <div class="hero-no-media-background">
                                                <div class="hero-pattern-overlay"></div>
                                                <div class="hero-content-center">
                                                    <div class="hero-icon-wrapper">
                                                        <i class="fas fa-newspaper"></i>
                                                    </div>
                                                    <h2 class="hero-title"><%= news.title %></h2>
                                                    <p class="hero-subtitle">Actualité</p>
                                                    <div class="hero-meta">
                                                        <span class="hero-date">
                                                            <i class="far fa-calendar"></i>
                                                            <%
                                                            const newsDate = new Date(news.created_at);
                                                            const formattedDate = newsDate.toLocaleDateString('fr-FR', {
                                                                day: 'numeric',
                                                                month: 'long',
                                                                year: 'numeric'
                                                            });
                                                            %>
                                                            <%= formattedDate %>
                                                        </span>
                                                        <span class="hero-category">
                                                            <i class="fas fa-tag"></i>
                                                            <%= news.category || 'Actualité' %>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        
                        <!-- Contenu -->
                        <div class="article-content">
                            <%- news.content %>
                        </div>
                        
                        <!-- Partager -->
                        <% 
                        const baseShareUrl = `https://telex.mg/news/${news.id}`;
                        const timestamp = Date.now();
                        const shareUrl = encodeURIComponent(`${baseShareUrl}?t=${timestamp}`);
                        const shareTitle = encodeURIComponent(news.title || '');
                        const shareDescription = encodeURIComponent((news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex, la télévision étudiante.'));
                        const shareText = encodeURIComponent(`${news.title || ''} ${baseShareUrl}`.trim());

                        const allowFacebook = news.share_facebook === undefined ? true : !!news.share_facebook;
                        const allowTwitter = news.share_twitter === undefined ? true : !!news.share_twitter;
                        const allowLinkedin = news.share_linkedin === undefined ? true : !!news.share_linkedin;
                        const allowWhatsapp = news.share_whatsapp === undefined ? true : !!news.share_whatsapp;
                        const allowInstagram = news.share_instagram === undefined ? true : !!news.share_instagram;
                        const allowTiktok = news.share_tiktok === undefined ? true : !!news.share_tiktok;

                        const anyShare = allowFacebook || allowTwitter || allowLinkedin || allowWhatsapp || allowInstagram || allowTiktok;
                        %>
                        
                        <% if (anyShare) { %>
                            <div class="share-buttons">
                                <span class="share-title">Partager :</span>
                                <% if (allowFacebook) { %>
                                    <a href="#" 
                                       onclick="shareArticleOnFacebook(); return false;"
                                       class="share-btn share-facebook"
                                       title="Partager sur Facebook (compte personnel)">
                                        <i class="fab fa-facebook-f"></i>
                                    </a>
                                    <a href="#" 
                                       onclick="copyLinkForPage(); return false;"
                                       class="share-btn share-facebook"
                                       title="Copier le lien pour publication sur page Facebook">
                                        <i class="fas fa-link"></i>
                                    </a>
                                <% } %>
                                <% if (allowTwitter) { %>
                                    <a href="https://twitter.com/intent/tweet?url=<%= shareUrl %>&text=<%= shareTitle %>"
                                       target="_blank"
                                       rel="noopener"
                                       class="share-btn share-twitter"
                                       title="Partager sur Twitter">
                                        <i class="fab fa-twitter"></i>
                                    </a>
                                <% } %>
                                <% if (allowInstagram) { %>
                                    <a href="https://www.instagram.com/" 
                                       target="_blank"
                                       rel="noopener"
                                       onclick="copyToClipboard('<%= baseShareUrl %>'); showNotification('Lien copié ! Collez-le dans votre story Instagram.', 'success'); return false;"
                                       class="share-btn share-instagram"
                                       title="Partager sur Instagram">
                                        <i class="fab fa-instagram"></i>
                                    </a>
                                <% } %>
                                <% if (allowTiktok) { %>
                                    <a href="https://www.tiktok.com/" 
                                       target="_blank"
                                       rel="noopener"
                                       onclick="copyToClipboard('<%= baseShareUrl %>'); showNotification('Lien copié ! Collez-le dans votre vidéo TikTok.', 'success'); return false;"
                                       class="share-btn share-tiktok"
                                       title="Partager sur TikTok">
                                        <i class="fab fa-tiktok"></i>
                                    </a>
                                <% } %>
                                <% if (allowLinkedin) { %>
                                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= shareUrl %>"
                                       target="_blank"
                                       rel="noopener"
                                       class="share-btn share-linkedin"
                                       title="Partager sur LinkedIn">
                                        <i class="fab fa-linkedin-in"></i>
                                    </a>
                                <% } %>
                                <% if (allowWhatsapp) { %>
                                    <a href="https://wa.me/?text=<%= shareText %>"
                                       target="_blank"
                                       rel="noopener"
                                       class="share-btn share-whatsapp"
                                       title="Partager sur WhatsApp">
                                        <i class="fab fa-whatsapp"></i>
                                    </a>
                                <% } %>
                            </div>
                        <% } %>
                        
                        <!-- Retour -->
                        <div class="back-section">
                            <a href="/news" class="back-button">
                                <i class="fas fa-arrow-left"></i> Retour aux actualités
                            </a>
                        </div>
                    <% } else { %>
                        <div class="article-not-found">
                            <h1>Article non trouvé</h1>
                            <p>Cet article n'existe pas ou a été supprimé.</p>
                            <a href="/news" class="back-button">
                                <i class="fas fa-arrow-left"></i> Retour aux actualités
                            </a>
                        </div>
                    <% } %>
                </div>

                <!-- Sidebar -->
                <div class="article-sidebar">
                    <!-- Section À suivre -->
                    <div class="sidebar-section">
                        <h3 class="sidebar-title">
                            <i class="fas fa-video"></i> À suivre
                        </h3>
                        <div class="similar-videos">
                            <% 
                            const mediaForSidebar = (typeof allMedia !== 'undefined' && Array.isArray(allMedia)) ? allMedia : [];
                            const baseMedia = mediaForSidebar.filter(v => v && (v.video_url || v.image_url));

                            const currentHasVideo = !!(news && news.video_url && String(news.video_url).trim() !== '');
                            const currentHasImage = !!(news && news.image_url && String(news.image_url).trim() !== '');

                            let filteredMedia = baseMedia;
                            if (currentHasVideo && !currentHasImage) {
                                filteredMedia = baseMedia.filter(v => v && v.video_url && String(v.video_url).trim() !== '');
                            } else if (currentHasImage && !currentHasVideo) {
                                filteredMedia = baseMedia.filter(v => !v.video_url || String(v.video_url).trim() === '');
                            }
                            %>

                            <% if (filteredMedia.length === 0) { %>
                                <div class="loading-videos">
                                    <i class="fas fa-photo-video"></i>
                                    Aucun contenu disponible
                                </div>
                            <% } else { %>
                                <% filteredMedia.slice(0, 30).forEach(item => { %>
                                    <% 
                                    const videoUrl = String(item.video_url || '').trim();
                                    const isVideoItem = !!(videoUrl && videoUrl !== '');

                                    let thumbnailSrc = '/images/Telex.png';
                                    let isVideo = false;

                                    if (isVideoItem) {
                                        isVideo = true;
                                        if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
                                            const vid = extractYouTubeId(videoUrl);
                                            thumbnailSrc = vid ? `https://img.youtube.com/vi/${vid}/mqdefault.jpg` : '/images/Telex.png';
                                        } else if (item.image_url && String(item.image_url).trim() !== '') {
                                            thumbnailSrc = String(item.image_url).trim();
                                        }
                                    } else if (item.image_url && String(item.image_url).trim() !== '') {
                                        thumbnailSrc = String(item.image_url).trim();
                                    }

                                    const itemTitle = item.title && item.title.length > 60 ? item.title.substring(0, 60) + '...' : (item.title || 'Contenu');
                                    %>

                                    <a href="/news/<%= item.id %>" class="similar-video-item">
                                        <div class="similar-video-thumbnail">
                                            <img src="<%= thumbnailSrc %>" alt="<%= itemTitle %>" loading="lazy" onerror="this.onerror=null;this.src='/images/Telex.png';">
                                            <% if (isVideo) { %>
                                                <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:22px;height:22px;background:rgba(220,38,38,0.85);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                                    <i class="fas fa-play" style="font-size:8px;color:#fff;margin-left:2px;"></i>
                                                </div>
                                            <% } %>
                                        </div>
                                        <div class="similar-video-info">
                                            <div class="similar-video-title"><%= itemTitle %></div>
                                            <div class="similar-video-meta">
                                                <i class="far fa-calendar"></i>
                                                <%= item.created_at ? new Date(item.created_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }) : '' %>
                                            </div>
                                        </div>
                                    </a>
                                <% }); %>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Section images similaires -->
                    <% if (news && news.image_url && String(news.image_url).trim() !== '') { %>
                    <div class="sidebar-section" id="similarImagesSection">
                        <h3 class="sidebar-title">
                            <i class="fas fa-image"></i> Images similaires
                        </h3>
                        <div class="similar-images" id="similarImages">
                            <div class="loading-images">
                                <i class="fas fa-spinner fa-spin"></i>
                                Chargement...
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Données depuis le serveur
        const newsData = <%- typeof news !== 'undefined' ? JSON.stringify(news) : '{}' %>;
        const relatedNewsData = <%- typeof relatedNews !== 'undefined' ? JSON.stringify(relatedNews) : '[]' %>;

        // Les vidéos utilisent le padding-top:56.25% trick (CSS) — aucun resize JS nécessaire.
        // Cette fonction ne touche qu'aux images statiques hors .video-wrapper.
        function resizeAllMedia() {
            document.querySelectorAll('.article-hero-image img').forEach(img => {
                if (!img.closest('.flag-decoration')) {
                    img.style.maxHeight = Math.min(window.innerHeight * 0.40, 280) + 'px';
                }
            });
        }

        // Créer un fallback pour les vidéos
        function createVideoFallback(wrapper, reason) {
            if (wrapper.querySelector('.video-fallback')) return;
            
            const fallback = document.createElement('div');
            fallback.className = 'video-fallback';
            fallback.innerHTML = `
                <i class="fas fa-exclamation-triangle"></i>
                <p>Vidéo non disponible</p>
                <p style="font-size:0.9rem">${reason}</p>
            `;
            
            const video = wrapper.querySelector('video');
            if (video) video.style.display = 'none';
            wrapper.appendChild(fallback);
        }

        // Obtenir la miniature d'une vidéo
        async function getVideoThumbnail(videoUrl) {
            if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
                let videoId = '';
                if (videoUrl.includes('youtube.com')) {
                    videoId = videoUrl.split('v=')[1]?.split('&')[0] || '';
                } else {
                    videoId = videoUrl.split('/').pop() || '';
                }
                return `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`;
            } else if (videoUrl.includes('vimeo.com')) {
                const videoId = videoUrl.split('/').pop();
                try {
                    const response = await fetch(`https://vimeo.com/api/v2/video/${videoId}.json`);
                    const data = await response.json();
                    return data[0]?.thumbnail_large || '/images/Telex.png';
                } catch {
                    return '/images/Telex.png';
                }
            }
            return '/images/Telex.png';
        }

        // Charger les images similaires
        function loadSimilarImages() {
            const container = document.getElementById('similarImages');
            const section = document.getElementById('similarImagesSection');
            
            if (!container) return;
            
            try {
                const similarImages = relatedNewsData.filter(article => article.image_url);
                
                if (similarImages.length === 0) {
                    if (section) section.style.display = 'none';
                    return;
                }
                
                const imagesHTML = similarImages.slice(0, 5).map(article => {
                    const title = article.title && article.title.length > 50 
                        ? article.title.substring(0, 50) + '...' 
                        : article.title || 'Image';
                    
                    const date = article.created_at 
                        ? new Date(article.created_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })
                        : '';
                    
                    return `
                        <a href="/news/${article.id}" class="similar-image-item">
                            <div class="similar-image-thumbnail">
                                <img src="${article.image_url}" alt="${article.title || 'Image'}" loading="lazy"
                                     onerror="this.onerror=null; this.src='/images/Telex.png';">
                            </div>
                            <div class="similar-image-info">
                                <div class="similar-image-title">${title}</div>
                                <div class="similar-image-meta">
                                    <i class="far fa-calendar"></i> ${date}
                                </div>
                            </div>
                        </a>
                    `;
                }).join('');
                
                container.innerHTML = imagesHTML;
                
            } catch (error) {
                console.error('❌ Erreur chargement images similaires:', error);
                container.innerHTML = `
                    <div style="text-align:center; padding:20px; color:#6c757d;">
                        <i class="fas fa-exclamation-triangle" style="font-size:2rem; margin-bottom:10px;"></i>
                        <p>Chargement indisponible</p>
                    </div>
                `;
            }
        }

        // Initialisation vidéos
        function initVideos() {
            document.querySelectorAll('.video-wrapper video').forEach(video => {
                video.addEventListener('error', () => {
                    createVideoFallback(video.parentElement, 'Erreur de chargement');
                });
                setTimeout(() => {
                    if (video.readyState === 0) {
                        createVideoFallback(video.parentElement, 'Timeout');
                    }
                }, 8000);
            });
        }

        // Fonction pour copier dans le presse-papiers
        function copyToClipboard(text) {
            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(text).catch(() => {
                    fallbackCopyTextToClipboard(text);
                });
            } else {
                fallbackCopyTextToClipboard(text);
            }
        }

        function fallbackCopyTextToClipboard(text) {
            const textArea = document.createElement('textarea');
            textArea.value = text;
            textArea.style.cssText = 'position:fixed;left:-999999px;top:-999999px';
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            try { document.execCommand('copy'); } catch (_) {}
            document.body.removeChild(textArea);
        }

        // ===== INITIALISATION =====
        document.addEventListener('DOMContentLoaded', function() {
            resizeAllMedia();
            initVideos();
            if (newsData.image_url) loadSimilarImages();
            window.addEventListener('resize', resizeAllMedia);
        });

        // Fonction pour copier le lien pour publication sur page
        function copyLinkForPage() {
            const url = document.querySelector('meta[name="article:url"]')?.content || window.location.href;
            const title = document.querySelector('meta[name="article:title"]')?.content || '';
            
            // Copier le lien dans le presse-papiers
            copyToClipboard(url);
            
            // Afficher des instructions détaillées
            showNotification(`
                <strong>Lien copié !</strong><br><br>
                <strong>Pour publier sur votre page Facebook :</strong><br>
                1. Allez sur votre page Facebook<br>
                2. Créez une nouvelle publication<br>
                3. Collez le lien (Ctrl+V)<br>
                4. Ajoutez un commentaire si besoin<br>
                5. Publiez<br><br>
                <em>Publication immédiate garantie !</em>
            `, 'info');
        }

        // Fonction pour partager l'article sur Facebook (méthode simple et fiable)
        function shareArticleOnFacebook() {
            // Récupérer les données depuis les métadonnées
            const title = document.querySelector('meta[name="article:title"]')?.content || '';
            const description = document.querySelector('meta[name="article:description"]')?.content || '';
            const url = document.querySelector('meta[name="article:url"]')?.content || window.location.href;
            
            // Utiliser la méthode classique de Facebook qui fonctionne partout
            const shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(title + '\n\n' + description)}`;
            
            // Ouvrir dans une nouvelle fenêtre avec des dimensions optimales
            window.open(shareUrl, '_blank', 'width=600,height=400,scrollbars=yes,resizable=yes');
            
            // Afficher une notification de confirmation
            showNotification('Fenêtre de partage Facebook ouverte', 'info');
        }

        // Fonction pour afficher des notifications
        function showNotification(message, type = 'info') {
            const notification = document.createElement('div');
            notification.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            notification.style.cssText = `
                top: 20px;
                right: 20px;
                z-index: 9999;
                min-width: 300px;
                border-radius: 8px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            `;
            
            notification.innerHTML = `
                <div class="d-flex align-items-center">
                    <i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'} me-2"></i>
                    <div class="flex-grow-1">${message}</div>
                    <button type="button" class="btn-close ms-2" data-bs-dismiss="alert"></button>
                </div>
            `;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 5000);
        }
    </script>
</body>
</html>