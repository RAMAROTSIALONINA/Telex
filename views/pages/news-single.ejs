<!DOCTYPE html>
<html lang="fr">
<head>
        <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= news ? news.title + ' - Actualités' : 'Actualités' %> - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    
    <!-- Open Graph Meta Tags pour Facebook -->
    <% if (news) { %>
        <meta property="og:title" content="<%= news.title %> - Telex">
        <meta property="og:description" content="<%= (news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex, la télévision étudiante.') %>">
        <meta property="og:url" content="https://telex.mg/news/<%= news.id %>">
        <meta property="og:type" content="article">
        <meta property="og:site_name" content="Telex - Télévision Étudiante">
        <% if (news.image_url) { %>
            <meta property="og:image" content="https://telex.mg<%= news.image_url %>">
            <meta property="og:image:alt" content="<%= news.title %>">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
        <% } else if (news.video_url) { %>
            <meta property="og:image" content="https://telex.mg/images/Telex.png">
            <meta property="og:image:alt" content="<%= news.title %> - Vidéo">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
        <% } else { %>
            <meta property="og:image" content="https://telex.mg/images/Telex.png">
            <meta property="og:image:alt" content="Telex - Télévision Étudiante">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
        <% } %>
        <meta property="og:locale" content="fr_FR">
        <meta property="article:author" content="Telex">
        <meta property="article:section" content="<%= news.category || 'Actualités' %>">
        <meta property="article:published_time" content="<%= news.created_at ? new Date(news.created_at).toISOString() : new Date().toISOString() %>">
        
        <!-- Facebook App ID pour le SDK -->
        <!-- <meta property="fb:app_id" content="966242223397117"> -->
        
        <!-- Twitter Card Meta Tags -->
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="<%= news.title %> - Telex">
        <meta name="twitter:description" content="<%= (news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex.') %>">
        <% if (news.image_url) { %>
            <meta name="twitter:image" content="https://telex.mg<%= news.image_url %>">
        <% } else { %>
            <meta name="twitter:image" content="https://telex.mg/images/Telex.png">
        <% } %>
    <% } %>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    
    <!-- STYLES BLEUS POUR NEWS-SINGLE -->
</head>
<body class="article-page">
    <%- include('../partials/navbar') %>

    <div class="article-page">
        <div class="container">
            <div class="article-layout">
                <!-- Colonne principale -->
                <div class="article-main">
                    <% if (news) { %>
                        <!-- WRAPPER PRINCIPAL AVEC DRAPEAU -->
                        <div class="article-hero-wrapper">
                            <!-- Drapeau décoratif -->
                            <div class="flag-decoration">
                                <img src="/images/drapeau.png" alt="Drapeau Madagascar" loading="lazy" onerror="this.onerror=null; this.src='/images/Telex.png';">
                            </div>
                            
                            <!-- Contenu média principal -->
                            <div class="hero-content">
                                <% 
                                // Fonctions d'extraction d'ID vidéo
                                function extractYouTubeId(url) {
                                    try {
                                        const urlStr = String(url || '');
                                        const match = urlStr.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/);
                                        if (match && match[1]) return match[1];
                                        const vParam = urlStr.match(/[?&]v=([A-Za-z0-9_-]{11})/);
                                        if (vParam && vParam[1]) return vParam[1];
                                        return '';
                                    } catch (e) {
                                        return '';
                                    }
                                }

                                function extractVimeoId(url) {
                                    try {
                                        const urlStr = String(url || '');
                                        const clean = urlStr.split('?')[0].split('#')[0];
                                        const match = clean.match(/vimeo\.com\/(?:video\/)?(\d+)/);
                                        if (match && match[1]) return match[1];
                                        const last = clean.split('/').filter(Boolean).pop() || '';
                                        return /^\d+$/.test(last) ? last : '';
                                    } catch (e) {
                                        return '';
                                    }
                                }
                                %>

                                <% if (news.video_url && !news.image_url) { %>
                                    <!-- CAS 1: Seulement vidéo -->
                                    <div class="article-hero-container">
                                        <div class="video-container">
                                            <div class="video-wrapper">
                                                <% 
                                                let videoId = '';
                                                let videoType = 'unknown';
                                                let videoSrc = news.video_url;

                                                if (news.video_url.includes('youtube.com') || news.video_url.includes('youtu.be')) {
                                                    videoId = extractYouTubeId(news.video_url);
                                                    videoType = 'youtube';
                                                    videoSrc = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&controls=1&enablejsapi=1`;
                                                } else if (news.video_url.includes('vimeo.com')) {
                                                    videoId = extractVimeoId(news.video_url);
                                                    videoType = 'vimeo';
                                                    videoSrc = `https://player.vimeo.com/video/${videoId}?autoplay=1&muted=1&controls=1`;
                                                } else {
                                                    videoType = 'uploaded';
                                                }
                                                %>

                                                <% if (videoType === 'youtube' || videoType === 'vimeo') { %>
                                                    <iframe 
                                                        src="<%= videoSrc %>"
                                                        frameborder="0"
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                        allowfullscreen>
                                                    </iframe>
                                                <% } else { %>
                                                    <video 
                                                        src="<%= news.video_url %>"
                                                        controls
                                                        autoplay
                                                        muted
                                                        preload="metadata"
                                                        playsinline>
                                                        Votre navigateur ne supporte pas la vidéo.
                                                    </video>
                                                <% } %>
                                            </div>
                                            <span class="image-category"><%= news.category || 'Actualité' %></span>
                                        </div>
                                    </div>

                                <% } else if (news.image_url && !news.video_url) { %>
                                    <!-- CAS 2: Seulement image -->
                                    <div class="article-hero-container">
                                        <div class="article-hero-image">
                                            <img src="<%= news.image_url %>" alt="<%= news.title %>" loading="lazy">
                                        </div>
                                        <span class="image-category"><%= news.category || 'Actualité' %></span>
                                    </div>

                                <% } else if (news.image_url && news.video_url) { %>
                                    <!-- CAS 3: Vidéo ET image -->
                                    <div class="article-hero-container">
                                        <div class="video-container">
                                            <div class="video-wrapper">
                                                <% 
                                                let videoId = '';
                                                let videoType = 'unknown';
                                                let videoSrc = news.video_url;

                                                if (news.video_url.includes('youtube.com') || news.video_url.includes('youtu.be')) {
                                                    videoId = extractYouTubeId(news.video_url);
                                                    videoType = 'youtube';
                                                    videoSrc = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&controls=1&enablejsapi=1`;
                                                } else if (news.video_url.includes('vimeo.com')) {
                                                    videoId = extractVimeoId(news.video_url);
                                                    videoType = 'vimeo';
                                                    videoSrc = `https://player.vimeo.com/video/${videoId}?autoplay=1&muted=1&controls=1`;
                                                } else {
                                                    videoType = 'uploaded';
                                                }
                                                %>
                                                
                                                <% if (videoType === 'youtube' || videoType === 'vimeo') { %>
                                                    <iframe 
                                                        src="<%= videoSrc %>"
                                                        frameborder="0"
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                        allowfullscreen>
                                                    </iframe>
                                                <% } else { %>
                                                    <video 
                                                        src="<%= news.video_url %>"
                                                        controls
                                                        autoplay
                                                        muted
                                                        preload="metadata"
                                                        playsinline>
                                                        Votre navigateur ne supporte pas la vidéo.
                                                    </video>
                                                <% } %>
                                            </div>
                                            <span class="image-category"><%= news.category || 'Actualité' %></span>
                                        </div>
                                    </div>
                                    
                                    <!-- Image additionnelle -->
                                    <div class="article-hero-container" style="margin-top: 20px;">
                                        <div class="article-hero-image">
                                            <img src="<%= news.image_url %>" alt="<%= news.title %>" loading="lazy">
                                        </div>
                                    </div>

                                <% } else { %>
                                    <!-- CAS 4: Aucun média - Hero amélioré -->
                                    <!-- TEST DE DIAGNOSTIC -->
                                    <div style="background: red !important; color: white !important; padding: 20px; margin: 20px; font-size: 24px; font-weight: bold; text-align: center; border: 5px solid yellow;">
                                        🚨 CONDITION ELSE EXECUTEE - HERO SANS MÉDIA 🚨
                                        <br>
                                        Variables: 
                                        - news.image_url: "<%= typeof news.image_url !== 'undefined' ? news.image_url : 'UNDEFINED' %>"
                                        - news.video_url: "<%= typeof news.video_url !== 'undefined' ? news.video_url : 'UNDEFINED' %>"
                                        <br>
                                        Date: <%= new Date().toISOString() %>
                                    </div>
                                    
                                    <div class="article-hero-container">
                                        <div class="article-hero-no-media" style="background: yellow !important; border: 5px solid red !important;">
                                            <!-- Hero avec dégradé et pattern -->
                                            <div class="hero-no-media-background" style="background: lime !important;">
                                                <div class="hero-pattern-overlay"></div>
                                                <div class="hero-content-center" style="background: magenta !important; color: white !important; padding: 20px !important; border: 3px solid white !important;">
                                                    <div class="hero-icon-wrapper" style="background: cyan !important; color: black !important;">
                                                        <i class="fas fa-newspaper"></i>
                                                    </div>
                                                    <h2 class="hero-title" style="color: yellow !important; background: black !important; padding: 10px !important;"><%= news.title %></h2>
                                                    <p class="hero-subtitle" style="color: lime !important; font-weight: bold !important;">Actualité</p>
                                                    <div class="hero-meta" style="background: orange !important; padding: 15px !important;">
                                                        <span class="hero-date" style="background: white !important; color: black !important;">
                                                            <i class="far fa-calendar"></i>
                                                            <% 
                                                            const newsDate = new Date(news.created_at);
                                                            const formattedDate = newsDate.toLocaleDateString('fr-FR', {
                                                                day: 'numeric',
                                                                month: 'long',
                                                                year: 'numeric'
                                                            });
                                                            %>
                                                            <%= formattedDate %>
                                                        </span>
                                                        <span class="hero-category" style="background: white !important; color: black !important;">
                                                            <i class="fas fa-tag"></i>
                                                            <%= news.category || 'Actualité' %>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <span class="image-category"><%= news.category || 'Actualité' %></span>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        
                        <!-- Titre et métadonnées -->
                        <div class="article-title-section">
                            <h1><%= news.title %></h1>
                            
                            <div class="article-meta">
                                <div class="meta-item">
                                    <i class="far fa-calendar"></i>
                                    <%= new Date(news.created_at).toLocaleDateString('fr-FR', {
                                        day: 'numeric',
                                        month: 'long',
                                        year: 'numeric'
                                    }) %>
                                </div>
                                
                                <% if (news.author) { %>
                                <div class="meta-item">
                                    <i class="fas fa-user"></i>
                                    <%= news.author %>
                                </div>
                                <% } %>
                            </div>
                        </div>
                        
                        <!-- Contenu -->
                        <div class="article-content">
                            <%- news.content %>
                        </div>
                        
                        <!-- Partager -->
                        <% 
                        const baseShareUrl = `https://telex.mg/news/${news.id}`;
                        const timestamp = Date.now();
                        const shareUrl = encodeURIComponent(`${baseShareUrl}?t=${timestamp}`);
                        const shareTitle = encodeURIComponent(news.title || '');
                        const shareDescription = encodeURIComponent((news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex, la télévision étudiante.'));
                        const shareText = encodeURIComponent(`${news.title || ''} ${baseShareUrl}`.trim());

                        const allowFacebook = news.share_facebook === undefined ? true : !!news.share_facebook;
                        const allowTwitter = news.share_twitter === undefined ? true : !!news.share_twitter;
                        const allowLinkedin = news.share_linkedin === undefined ? true : !!news.share_linkedin;
                        const allowWhatsapp = news.share_whatsapp === undefined ? true : !!news.share_whatsapp;
                        const allowInstagram = news.share_instagram === undefined ? true : !!news.share_instagram;
                        const allowTiktok = news.share_tiktok === undefined ? true : !!news.share_tiktok;

                        const anyShare = allowFacebook || allowTwitter || allowLinkedin || allowWhatsapp || allowInstagram || allowTiktok;
                        %>
                        
                        <!-- Métadonnées pour le partage -->
                        <meta name="article:title" content="<%= news.title || '' %>">
                        <meta name="article:description" content="<%= (news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex, la télévision étudiante.') %>">
                        <meta name="article:url" content="https://telex.mg/news/<%= news.id %>">
                        
                        <% if (anyShare) { %>
                            <div class="share-buttons">
                                <span class="share-title">Partager :</span>
                                <% if (allowFacebook) { %>
                                    <a href="#" 
                                       onclick="shareArticleOnFacebook(); return false;"
                                       class="share-btn share-facebook"
                                       title="Partager sur Facebook (compte personnel)">
                                        <i class="fab fa-facebook-f"></i>
                                    </a>
                                    <a href="#" 
                                       onclick="copyLinkForPage(); return false;"
                                       class="share-btn share-facebook"
                                       title="Copier le lien pour publication sur page Facebook">
                                        <i class="fas fa-link"></i>
                                    </a>
                                <% } %>
                                <% if (allowTwitter) { %>
                                    <a href="https://twitter.com/intent/tweet?url=<%= shareUrl %>&text=<%= shareTitle %>"
                                       target="_blank"
                                       rel="noopener"
                                       class="share-btn share-twitter"
                                       title="Partager sur Twitter">
                                        <i class="fab fa-twitter"></i>
                                    </a>
                                <% } %>
                                <% if (allowInstagram) { %>
                                    <a href="https://www.instagram.com/" 
                                       target="_blank"
                                       rel="noopener"
                                       onclick="copyToClipboard('<%= baseShareUrl %>'); alert('Lien copié! Collez-le dans votre story Instagram.'); return false;"
                                       class="share-btn share-instagram"
                                       title="Partager sur Instagram">
                                        <i class="fab fa-instagram"></i>
                                    </a>
                                <% } %>
                                <% if (allowTiktok) { %>
                                    <a href="https://www.tiktok.com/" 
                                       target="_blank"
                                       rel="noopener"
                                       onclick="copyToClipboard('<%= baseShareUrl %>'); alert('Lien copié! Collez-le dans votre vidéo TikTok.'); return false;"
                                       class="share-btn share-tiktok"
                                       title="Partager sur TikTok">
                                        <i class="fab fa-tiktok"></i>
                                    </a>
                                <% } %>
                                <% if (allowLinkedin) { %>
                                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= shareUrl %>"
                                       target="_blank"
                                       rel="noopener"
                                       class="share-btn share-linkedin"
                                       title="Partager sur LinkedIn">
                                        <i class="fab fa-linkedin-in"></i>
                                    </a>
                                <% } %>
                                <% if (allowWhatsapp) { %>
                                    <a href="https://wa.me/?text=<%= shareText %>"
                                       target="_blank"
                                       rel="noopener"
                                       class="share-btn share-whatsapp"
                                       title="Partager sur WhatsApp">
                                        <i class="fab fa-whatsapp"></i>
                                    </a>
                                <% } %>
                            </div>
                        <% } %>
                        
                        <!-- Retour -->
                        <div class="back-section">
                            <a href="/news" class="back-button">
                                <i class="fas fa-arrow-left"></i> Retour aux actualités
                            </a>
                        </div>
                    <% } else { %>
                        <div class="article-not-found">
                            <h1>Article non trouvé</h1>
                            <p>Cet article n'existe pas ou a été supprimé.</p>
                            <a href="/news" class="back-button">
                                <i class="fas fa-arrow-left"></i> Retour aux actualités
                            </a>
                        </div>
                    <% } %>
                </div>

                <!-- Sidebar -->
                <div class="article-sidebar">
                    <!-- Section À suivre -->
                    <div class="sidebar-section">
                        <h3 class="sidebar-title">
                            <i class="fas fa-video"></i> À suivre
                        </h3>
                        <div class="similar-videos">
                            <% 
                            const mediaForSidebar = (typeof allMedia !== 'undefined' && Array.isArray(allMedia)) ? allMedia : [];
                            const baseMedia = mediaForSidebar.filter(v => v && (v.video_url || v.image_url));

                            const currentHasVideo = !!(news && news.video_url && String(news.video_url).trim() !== '');
                            const currentHasImage = !!(news && news.image_url && String(news.image_url).trim() !== '');

                            let filteredMedia = baseMedia;
                            if (currentHasVideo && !currentHasImage) {
                                filteredMedia = baseMedia.filter(v => v && v.video_url && String(v.video_url).trim() !== '');
                            } else if (currentHasImage && !currentHasVideo) {
                                filteredMedia = baseMedia.filter(v => !v.video_url || String(v.video_url).trim() === '');
                            }
                            %>

                            <% if (filteredMedia.length === 0) { %>
                                <div class="loading-videos">
                                    <i class="fas fa-photo-video"></i>
                                    Aucun contenu disponible
                                </div>
                            <% } else { %>
                                <% filteredMedia.slice(0, 30).forEach(item => { %>
                                    <% 
                                    const videoUrl = String(item.video_url || '').trim();
                                    const isVideoItem = !!(videoUrl && videoUrl !== '');

                                    let poster = (item.image_url && String(item.image_url).trim() !== '') ? String(item.image_url).trim() : '/images/Telex.png';
                                    let embedSrc = '';
                                    let embedType = 'unknown';
                                    
                                    if (isVideoItem) {
                                        if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
                                            const vid = extractYouTubeId(videoUrl);
                                            if (vid) {
                                                embedType = 'youtube';
                                                embedSrc = `https://www.youtube.com/embed/${vid}?controls=1&rel=0`;
                                            }
                                        } else if (videoUrl.includes('vimeo.com')) {
                                            const vid = extractVimeoId(videoUrl);
                                            if (vid) {
                                                embedType = 'vimeo';
                                                embedSrc = `https://player.vimeo.com/video/${vid}`;
                                            }
                                        } else if (videoUrl.match(/\.(mp4|webm|ogg|mov|avi)$/i) || videoUrl.includes('/uploads/videos/')) {
                                            embedType = 'uploaded';
                                            embedSrc = videoUrl;
                                        }
                                    }

                                    const itemTitle = item.title && item.title.length > 60 ? item.title.substring(0, 60) + '...' : (item.title || 'Contenu');
                                    %>

                                    <a href="/news/<%= item.id %>" class="similar-video-item">
                                        <div class="similar-video-thumbnail">
                                            <% if (embedType === 'youtube' || embedType === 'vimeo') { %>
                                                <iframe 
                                                    src="<%= embedSrc %>"
                                                    title="<%= itemTitle %>"
                                                    loading="lazy"
                                                    allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                                                </iframe>
                                            <% } else if (embedType === 'uploaded') { %>
                                                <video src="<%= embedSrc %>" preload="metadata" muted></video>
                                            <% } else { %>
                                                <img src="<%= poster %>" alt="<%= itemTitle %>" loading="lazy" onerror="this.onerror=null;this.src='/images/Telex.png';">
                                            <% } %>
                                        </div>
                                        <div class="similar-video-info">
                                            <div class="similar-video-title"><%= itemTitle %></div>
                                            <div class="similar-video-meta">
                                                <i class="far fa-calendar"></i>
                                                <%= item.created_at ? new Date(item.created_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }) : '' %>
                                            </div>
                                        </div>
                                    </a>
                                <% }); %>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Section images similaires -->
                    <% if (news && news.image_url && String(news.image_url).trim() !== '') { %>
                    <div class="sidebar-section" id="similarImagesSection">
                        <h3 class="sidebar-title">
                            <i class="fas fa-image"></i> Images similaires
                        </h3>
                        <div class="similar-images" id="similarImages">
                            <div class="loading-images">
                                <i class="fas fa-spinner fa-spin"></i>
                                Chargement...
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Données depuis le serveur
        const newsData = <%- typeof news !== 'undefined' ? JSON.stringify(news) : '{}' %>;
        const relatedNewsData = <%- typeof relatedNews !== 'undefined' ? JSON.stringify(relatedNews) : '[]' %>;

        // ===== FONCTIONS DE REDIMENSIONNEMENT INTELLIGENT =====
        
        // Redimensionner tous les médias (sauf le drapeau)
        function resizeAllMedia() {
            const windowHeight = window.innerHeight;
            const maxHeight = Math.min(windowHeight * 0.7, 500); // Max 70% de l'écran ou 500px
            
            // Images principales (exclure le drapeau)
            document.querySelectorAll('.article-hero-image img, .article-hero-image video').forEach(media => {
                if (!media.closest('.flag-decoration')) {
                    media.style.maxHeight = maxHeight + 'px';
                    media.style.width = 'auto';
                    media.style.height = 'auto';
                }
            });
            
            // Vidéos dans les conteneurs
            document.querySelectorAll('.video-wrapper video').forEach(video => {
                video.style.maxHeight = maxHeight + 'px';
                video.style.width = '100%';
                video.style.height = 'auto';
            });
            
            // Iframes
            document.querySelectorAll('.video-wrapper iframe').forEach(iframe => {
                iframe.style.maxHeight = maxHeight + 'px';
                iframe.style.width = '100%';
                iframe.style.height = Math.min(iframe.offsetWidth * 0.5625, maxHeight) + 'px';
            });
            
            console.log('📐 Médias redimensionnés - Hauteur max:', maxHeight + 'px');
        }

        // Créer un fallback pour les vidéos
        function createVideoFallback(wrapper, reason) {
            if (wrapper.querySelector('.video-fallback')) return;
            
            const fallback = document.createElement('div');
            fallback.className = 'video-fallback';
            fallback.innerHTML = `
                <i class="fas fa-exclamation-triangle"></i>
                <p>Vidéo non disponible</p>
                <p style="font-size:0.9rem">${reason}</p>
            `;
            
            const video = wrapper.querySelector('video');
            if (video) video.style.display = 'none';
            wrapper.appendChild(fallback);
        }

        // Obtenir la miniature d'une vidéo
        async function getVideoThumbnail(videoUrl) {
            if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
                let videoId = '';
                if (videoUrl.includes('youtube.com')) {
                    videoId = videoUrl.split('v=')[1]?.split('&')[0] || '';
                } else {
                    videoId = videoUrl.split('/').pop() || '';
                }
                return `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`;
            } else if (videoUrl.includes('vimeo.com')) {
                const videoId = videoUrl.split('/').pop();
                try {
                    const response = await fetch(`https://vimeo.com/api/v2/video/${videoId}.json`);
                    const data = await response.json();
                    return data[0]?.thumbnail_large || '/images/Telex.png';
                } catch {
                    return '/images/Telex.png';
                }
            }
            return '/images/Telex.png';
        }

        // Charger les images similaires
        function loadSimilarImages() {
            const container = document.getElementById('similarImages');
            const section = document.getElementById('similarImagesSection');
            
            if (!container) return;
            
            try {
                const similarImages = relatedNewsData.filter(article => article.image_url);
                
                if (similarImages.length === 0) {
                    if (section) section.style.display = 'none';
                    return;
                }
                
                const imagesHTML = similarImages.slice(0, 5).map(article => {
                    const title = article.title && article.title.length > 50 
                        ? article.title.substring(0, 50) + '...' 
                        : article.title || 'Image';
                    
                    const date = article.created_at 
                        ? new Date(article.created_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })
                        : '';
                    
                    return `
                        <a href="/news/${article.id}" class="similar-image-item">
                            <div class="similar-image-thumbnail">
                                <img src="${article.image_url}" alt="${article.title || 'Image'}" loading="lazy"
                                     onerror="this.onerror=null; this.src='/images/Telex.png';">
                            </div>
                            <div class="similar-image-info">
                                <div class="similar-image-title">${title}</div>
                                <div class="similar-image-meta">
                                    <i class="far fa-calendar"></i> ${date}
                                </div>
                            </div>
                        </a>
                    `;
                }).join('');
                
                container.innerHTML = imagesHTML;
                
            } catch (error) {
                console.error('❌ Erreur chargement images similaires:', error);
                container.innerHTML = `
                    <div style="text-align:center; padding:20px; color:#6c757d;">
                        <i class="fas fa-exclamation-triangle" style="font-size:2rem; margin-bottom:10px;"></i>
                        <p>Chargement indisponible</p>
                    </div>
                `;
            }
        }

        // Initialisation vidéos
        function initVideos() {
            document.querySelectorAll('.video-wrapper video').forEach((video, index) => {
                console.log(`🎥 Vidéo ${index + 1} chargée`);
                
                video.addEventListener('loadedmetadata', () => {
                    resizeAllMedia();
                });
                
                video.addEventListener('error', (e) => {
                    console.error('❌ Erreur vidéo:', e);
                    createVideoFallback(video.parentElement, 'Erreur de chargement');
                });
                
                // Timeout de sécurité
                setTimeout(() => {
                    if (video.readyState === 0) {
                        createVideoFallback(video.parentElement, 'Timeout');
                    }
                }, 8000);
            });

            document.querySelectorAll('.video-wrapper iframe').forEach(iframe => {
                iframe.addEventListener('load', () => {
                    console.log('✅ Iframe chargé:', iframe.src);
                });
            });
        }

        // Fonction pour copier dans le presse-papiers
        function copyToClipboard(text) {
            if (navigator.clipboard && window.isSecureContext) {
                // Utiliser l'API Clipboard moderne
                navigator.clipboard.writeText(text).then(() => {
                    console.log('✅ Lien copié dans le presse-papiers');
                }).catch(err => {
                    console.error('❌ Erreur de copie:', err);
                    fallbackCopyTextToClipboard(text);
                });
            } else {
                // Fallback pour les navigateurs anciens
                fallbackCopyTextToClipboard(text);
            }
        }

        function fallbackCopyTextToClipboard(text) {
            const textArea = document.createElement("textarea");
            textArea.value = text;
            textArea.style.position = "fixed";
            textArea.style.left = "-999999px";
            textArea.style.top = "-999999px";
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            
            try {
                const successful = document.execCommand('copy');
                if (successful) {
                    console.log('✅ Lien copié avec fallback');
                } else {
                    console.error('❌ La copie a échoué');
                }
            } catch (err) {
                console.error('❌ Erreur de copie fallback:', err);
            }
            
            document.body.removeChild(textArea);
        }

        // ===== INITIALISATION =====
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🚀 Initialisation...');
            
            // Appliquer le redimensionnement
            resizeAllMedia();
            
            // Initialiser les vidéos
            initVideos();
            
            // Charger les images similaires
            if (newsData.image_url) {
                loadSimilarImages();
            }
            
            // Observer les changements de taille
            window.addEventListener('resize', resizeAllMedia);
            
            // Observer les mutations du DOM
            const observer = new MutationObserver(resizeAllMedia);
            observer.observe(document.body, {
                childList: true,
                subtree: true,
                attributes: false
            });
            
            console.log('✅ Initialisation terminée');
        });

        // Fonction pour copier le lien pour publication sur page
        function copyLinkForPage() {
            const url = document.querySelector('meta[name="article:url"]')?.content || window.location.href;
            const title = document.querySelector('meta[name="article:title"]')?.content || '';
            
            // Copier le lien dans le presse-papiers
            copyToClipboard(url);
            
            // Afficher des instructions détaillées
            showNotification(`
                <strong>Lien copié !</strong><br><br>
                <strong>Pour publier sur votre page Facebook :</strong><br>
                1. Allez sur votre page Facebook<br>
                2. Créez une nouvelle publication<br>
                3. Collez le lien (Ctrl+V)<br>
                4. Ajoutez un commentaire si besoin<br>
                5. Publiez<br><br>
                <em>Publication immédiate garantie !</em>
            `, 'info');
        }

        // Fonction pour partager l'article sur Facebook (méthode simple et fiable)
        function shareArticleOnFacebook() {
            // Récupérer les données depuis les métadonnées
            const title = document.querySelector('meta[name="article:title"]')?.content || '';
            const description = document.querySelector('meta[name="article:description"]')?.content || '';
            const url = document.querySelector('meta[name="article:url"]')?.content || window.location.href;
            
            // Utiliser la méthode classique de Facebook qui fonctionne partout
            const shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(title + '\n\n' + description)}`;
            
            // Ouvrir dans une nouvelle fenêtre avec des dimensions optimales
            window.open(shareUrl, '_blank', 'width=600,height=400,scrollbars=yes,resizable=yes');
            
            // Afficher une notification de confirmation
            showNotification('Fenêtre de partage Facebook ouverte', 'info');
        }

        // Fonction pour afficher des notifications
        function showNotification(message, type = 'info') {
            const notification = document.createElement('div');
            notification.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            notification.style.cssText = `
                top: 20px;
                right: 20px;
                z-index: 9999;
                min-width: 300px;
                border-radius: 8px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            `;
            
            notification.innerHTML = `
                <div class="d-flex align-items-center">
                    <i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'} me-2"></i>
                    <div class="flex-grow-1">${message}</div>
                    <button type="button" class="btn-close ms-2" data-bs-dismiss="alert"></button>
                </div>
            `;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 5000);
        }
    </script>
</body>
</html>