<!DOCTYPE html>
<html lang="fr">
<head>
        <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= news ? news.title + ' - Actualités' : 'Actualités' %> - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    
    <!-- Open Graph Meta Tags pour Facebook -->
    <% if (news) { %>
        <meta property="og:title" content="<%= news.title %> - Telex">
        <meta property="og:description" content="<%= (news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex, la télévision étudiante.') %>">
        <meta property="og:url" content="https://telex.mg/news/<%= news.id %>">
        <meta property="og:type" content="article">
        <meta property="og:site_name" content="Telex - Télévision Étudiante">
        <% if (news.image_url) { %>
            <meta property="og:image" content="https://telex.mg<%= news.image_url %>">
            <meta property="og:image:alt" content="<%= news.title %>">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
        <% } else if (news.video_url) { %>
            <meta property="og:image" content="https://telex.mg/images/Telex.png">
            <meta property="og:image:alt" content="<%= news.title %> - Vidéo">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
        <% } else { %>
            <meta property="og:image" content="https://telex.mg/images/Telex.png">
            <meta property="og:image:alt" content="Telex - Télévision Étudiante">
            <meta property="og:image:width" content="1200">
            <meta property="og:image:height" content="630">
        <% } %>
        <meta property="og:locale" content="fr_FR">
        <meta property="article:author" content="Telex">
        <meta property="article:section" content="<%= news.category || 'Actualités' %>">
        <meta property="article:published_time" content="<%= news.created_at ? new Date(news.created_at).toISOString() : new Date().toISOString() %>">
        
        <!-- Facebook App ID pour le SDK -->
        <!-- <meta property="fb:app_id" content="966242223397117"> -->
        
        <!-- Twitter Card Meta Tags -->
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="<%= news.title %> - Telex">
        <meta name="twitter:description" content="<%= (news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex.') %>">
        <% if (news.image_url) { %>
            <meta name="twitter:image" content="https://telex.mg<%= news.image_url %>">
        <% } else { %>
            <meta name="twitter:image" content="https://telex.mg/images/Telex.png">
        <% } %>
    <% } %>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    
    <!-- STYLES BLEUS POUR NEWS-SINGLE -->
    <style>
        /* Style de base pour toutes les navbars - Inspiré de baume-de-la-foi.ejs */
        .navbar-telex,
        .navbar-baume {
            background: #051d40 !important;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            transition: all 0.3s ease;
            z-index: 1030 !important;
            padding-top: 0.05rem !important;
            padding-bottom: 0.05rem !important;
            min-height: 20px !important;
        }

        .navbar .navbar-brand,
        .navbar-telex .navbar-brand,
        .navbar-baume .navbar-brand {
            color: #3AAFA9 !important;
            font-weight: 700;
            font-size: 1.8rem;
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
        }
        
        .navbar .navbar-brand:hover,
        .navbar-telex .navbar-brand:hover,
        .navbar-baume .navbar-brand:hover {
            color: #c1121f !important;
            transform: translateY(-1px);
        }
        
        .navbar .navbar-brand img,
        .navbar-telex .navbar-brand img,
        .navbar-baume .navbar-brand img {
            height: 60px;
            width: auto;
            max-width: 200px;
            margin-left: 0px !important;
            transform: scale(1);
            transform-origin: center;
        }

        /* ===== TOUS LES LIENS DU MENU ===== */
        .navbar .navbar-nav .nav-link,
        .navbar-telex .navbar-nav .nav-link,
        .navbar-baume .navbar-nav .nav-link {
            color: white !important;
            font-weight: 700 !important;
            font-size: 1rem !important;
            font-family: 'League Spartan', sans-serif !important;
            text-transform: uppercase !important;
            padding: 8px 12px !important;
            margin: 0 2px;
            border-radius: 8px;
            transition: all 0.3s ease;
            position: relative;
            white-space: nowrap;
        }

        .navbar .navbar-nav .nav-link i,
        .navbar-telex .navbar-nav .nav-link i,
        .navbar-baume .navbar-nav .nav-link i {
            color: white !important;
            margin-right: 8px;
            font-size: 1rem !important;
            transition: all 0.3s ease;
        }

        .navbar .navbar-nav .nav-link:hover,
        .navbar-telex .navbar-nav .nav-link:hover,
        .navbar-baume .navbar-nav .nav-link:hover {
            color: white !important;
            background: #dc3545 !important;
            transform: translateY(-2px);
        }

        .navbar .navbar-nav .nav-link.active,
        .navbar-telex .navbar-nav .nav-link.active,
        .navbar-baume .navbar-nav .nav-link.active {
            color: white !important;
            background: #dc3545 !important;
        }

        body {
            padding-top: 0.1cm;
        }

        @media (max-width: 576px) {
            /* Les styles mobiles utilisent maintenant baume-navbar.css */
        }

        /* ===== LE LOGO UTILISE MAINTENANT baume-navbar.css ===== */
        
        /* ===== REDIMENSIONNEMENT INTELLIGENT POUR TOUS LES MÉDIAS ===== */
        .article-page img:not(.logo-img):not([src*="Telex.png"]):not([src*="drapeau.png"]),
        .article-page video,
        .article-page iframe {
            max-width: 100% !important;
            max-height: 70vh !important; /* 70% de la hauteur de l'écran */
            width: auto !important;
            height: auto !important;
            object-fit: contain !important;
            display: block !important;
            margin-left: auto !important;
            margin-right: auto !important;
            border-radius: 8px;
        }
        
        /* ===== LE LOGO UTILISE LES STANDARDS DE baume-navbar.css ===== */

        /* Limites spécifiques selon le contexte */
        .article-hero-image img,
        .article-hero-image video,
        .article-hero-container img,
        .article-hero-container video {
            max-height: 500px !important;
            width: auto !important;
        }

        .article-content img,
        .article-content video {
            max-height: 400px !important;
        }

        .similar-image-thumbnail img,
        .similar-video-thumbnail img,
        .similar-video-thumbnail video,
        .similar-video-thumbnail iframe {
            max-height: 80px !important;
            width: 100% !important;
            object-fit: cover !important;
        }

        /* ===== CORRECTIONS DES PROBLÈMES D'AFFICHAGE ===== */
        .article-page {
            position: relative;
            z-index: 1;
            padding: 100px 0 60px;
            background: #f8f9fa;
        }

        /* Layout principal */
        .article-layout {
            display: grid !important;
            grid-template-columns: minmax(0, 1fr) 350px !important;
            gap: 40px !important;
            margin-top: 30px;
        }

        .article-main {
            min-width: 0;
            overflow: visible;
        }

        .article-sidebar {
            display: flex;
            flex-direction: column;
            gap: 30px;
            position: sticky;
            top: 100px;
            max-height: calc(100vh - 120px);
            overflow: auto;
        }

        /* Wrapper avec drapeau */
        .article-hero-wrapper {
            position: relative;
            display: flex;
            align-items: flex-start;
            gap: 20px;
            margin-bottom: 30px;
            animation: fadeInUp 0.6s ease;
        }

        .flag-decoration {
            position: relative;
            flex: 0 0 300px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px;
            background: transparent;
            border-radius: 12px;
        }

        .flag-decoration img {
            width: 100%;
            height: auto;
            max-height: 100vh;
            object-fit: contain !important;
            border-radius: 8px;
        }

        
        .hero-content {
            flex: 1;
            min-width: 0;
            background: transparent;
            border-radius: 0;
            box-shadow: none;
            padding: 0;
        }

        /* Conteneurs média */
        .article-hero-container {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
            background: white;
            width: 100%;
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100px;
        }

        .article-hero-image {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8f9fa;
            border-radius: 8px;
            overflow: hidden;
        }

        /* Conteneur vidéo optimisé */
        .video-container {
            position: relative;
            width: 100%;
            max-height: 500px;
            background: transparent;
            border-radius: 8px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .video-wrapper {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
        }

        /* Styles unifiés pour tous les types de vidéos */
        .video-wrapper video {
            width: 100% !important;
            height: auto !important;
            max-height: 500px !important;
            object-fit: contain !important;
            background: #000 !important;
            display: block !important;
            border-radius: 8px;
        }

        .video-wrapper iframe {
            width: 100% !important;
            height: 100% !important;
            min-height: 315px !important;
            max-height: 500px !important;
            border: none !important;
            object-fit: contain !important;
            border-radius: 8px;
        }

        /* Badge catégorie */
        .image-category {
            position: absolute;
            top: 35px;
            left: 35px;
            background: rgba(230, 57, 70, 0.95);
            color: white;
            padding: 10px 25px;
            border-radius: 25px;
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 15px rgba(230, 57, 70, 0.3);
            z-index: 10;
        }

        /* Titre et métadonnées */
        .article-title-section {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.1);
            text-align: center;
            margin-bottom: 30px;
            animation: fadeInUp 0.8s ease;
        }

        .article-title-section h1 {
            font-size: 2.2rem;
            font-weight: 800;
            color: #1D3557;
            margin-bottom: 25px;
            line-height: 1.3;
            position: relative;
        }

        .article-title-section h1::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: linear-gradient(90deg, #E63946, #457B9D);
            border-radius: 2px;
        }

        .article-meta {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 30px;
            color: #6c757d;
            font-size: 0.95rem;
            flex-wrap: wrap;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .meta-item i {
            color: #E63946;
        }

        /* Contenu principal */
        .article-content {
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            margin-top: 30px;
            font-size: 1.1rem;
            line-height: 1.7;
            color: #444;
            animation: fadeInUp 1s ease;
            overflow: hidden;
        }

        .article-content img,
        .article-content video {
            max-width: 100% !important;
            max-height: 400px !important;
            width: auto !important;
            height: auto !important;
            object-fit: contain !important;
            margin: 20px auto;
            display: block;
            background: #f8f9fa;
            padding: 10px;
            border-radius: 8px;
        }

        .article-content iframe {
            max-width: 100% !important;
            height: 315px !important;
            border-radius: 8px;
            margin: 20px auto;
            display: block;
        }

        /* Sidebar sections */
        .sidebar-section {
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            border: 1px solid #f0f0f0;
            animation: fadeInUp 1.2s ease;
        }

        .sidebar-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: #1D3557;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-title i {
            color: #E63946;
            font-size: 1.1rem;
        }

        /* Contenus similaires */
        .similar-videos,
        .similar-images {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .similar-video-item,
        .similar-image-item {
            display: flex;
            gap: 15px;
            padding: 12px;
            border-radius: 8px;
            background: #f8f9fa;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            color: inherit;
        }

        .similar-video-item:hover,
        .similar-image-item:hover {
            background: #e9ecef;
            transform: translateX(5px);
        }

        .similar-video-thumbnail,
        .similar-image-thumbnail {
            width: 120px;
            height: 80px;
            border-radius: 6px;
            overflow: hidden;
            position: relative;
            flex-shrink: 0;
        }

        .similar-video-thumbnail img,
        .similar-image-thumbnail img,
        .similar-video-thumbnail video,
        .similar-video-thumbnail iframe {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border: none;
        }

        .similar-video-info,
        .similar-image-info {
            flex: 1;
            min-width: 0;
        }

        .similar-video-title,
        .similar-image-title {
            font-size: 0.9rem;
            font-weight: 600;
            color: #1D3557;
            margin-bottom: 5px;
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .similar-video-meta,
        .similar-image-meta {
            font-size: 0.8rem;
            color: #6c757d;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .video-indicator {
            position: absolute;
            bottom: 5px;
            right: 5px;
            background: rgba(230, 57, 70, 0.9);
            color: white;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
        }

        /* Boutons de partage */
        .share-buttons {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            margin: 30px 0;
            flex-wrap: wrap;
        }

        .share-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #1D3557;
            margin-right: 10px;
        }

        .share-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            border: none;
            cursor: pointer;
            font-size: 1.2rem;
        }

        .share-facebook { background: #1877f2; color: white; }
        .share-facebook:hover { background: #166fe5; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(24, 119, 242, 0.3); }
        .share-twitter { background: #1DA1F2; color: white; }
        .share-twitter:hover { background: #0d8bd9; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(29, 161, 242, 0.3); }
        .share-instagram { background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); color: white; }
        .share-instagram:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(225, 48, 108, 0.3); }
        .share-tiktok { background: #000000; color: white; }
        .share-tiktok:hover { background: #1a1a1a; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3); }
        .share-linkedin { background: #0077b5; color: white; }
        .share-linkedin:hover { background: #006396; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0, 119, 181, 0.3); }
        .share-whatsapp { background: #25D366; color: white; }
        .share-whatsapp:hover { background: #1da851; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(37, 211, 102, 0.3); }

        /* Bouton retour */
        .back-section {
            text-align: center;
            margin-top: 40px;
        }

        .back-button {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: #1D3557;
            color: white;
            padding: 12px 25px;
            border-radius: 5px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
        }

        .back-button:hover {
            background: #E63946;
            transform: translateX(-5px);
            color: white;
        }

        /* Fallback vidéo */
        .video-fallback {
            background: linear-gradient(135deg, #E63946, #1D3557);
            color: white;
            border-radius: 8px;
            text-align: center;
            padding: 20px;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 200;
        }

        .video-fallback i {
            font-size: 3rem;
            margin-bottom: 15px;
        }

        /* Loading states */
        .loading-videos,
        .loading-images {
            text-align: center;
            padding: 30px;
            color: #6c757d;
        }

        .loading-videos i,
        .loading-images i {
            font-size: 2rem;
            margin-bottom: 10px;
            display: block;
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes flagPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.02); }
        }

        @keyframes flagWave {
            0%, 100% { transform: translateX(-50%) rotate(0deg); }
            25% { transform: translateX(-50%) rotate(-5deg); }
            75% { transform: translateX(-50%) rotate(5deg); }
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .article-layout {
                grid-template-columns: minmax(0, 1fr) 300px !important;
                gap: 30px !important;
            }
        }

        @media (max-width: 992px) {
            .article-hero-wrapper {
                gap: 15px;
            }
            .flag-decoration {
                flex: 0 0 250px;
            }
            .flag-decoration img {
                max-height: 80vh;
            }
        }

        @media (max-width: 768px) {
            .article-layout {
                grid-template-columns: 1fr !important;
                gap: 20px !important;
            }
            
            .article-sidebar {
                position: static;
                top: auto;
                max-height: none;
                overflow: visible;
            }

            .article-hero-wrapper {
                flex-direction: column;
                gap: 20px;
            }
            
            .flag-decoration {
                flex: 0 0 auto;
                width: 100%;
                max-width: 250px;
                margin: 0 auto;
                padding: 30px;
            }

            .flag-decoration img {
                max-height: 70vh;
            }

            .article-title-section h1 {
                font-size: 1.8rem;
            }

            .article-content {
                padding: 25px;
            }

            .similar-video-thumbnail,
            .similar-image-thumbnail {
                width: 100px;
                height: 70px;
            }
        }

        @media (max-width: 576px) {
            .article-meta {
                flex-direction: column;
                align-items: center;
                gap: 10px;
            }

            .share-buttons {
                flex-direction: row;
                align-items: center;
                justify-content: center;
                flex-wrap: wrap;
                gap: 10px;
            }

            .share-title {
                width: 100%;
                text-align: center;
                margin-right: 0;
                margin-bottom: 10px;
            }

            .share-btn {
                width: 40px;
                height: 40px;
                font-size: 1rem;
            }

            .similar-video-thumbnail,
            .similar-image-thumbnail {
                width: 80px;
                height: 60px;
            }
        }

            @keyframes flagWave {
                0%, 100% { transform: translateX(-50%) rotate(0deg); }
                25% { transform: translateX(-50%) rotate(-5deg); }
                75% { transform: translateX(-50%) rotate(5deg); }
        }

        .hero-no-media-background {
            position: relative;
            min-height: 500px;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #7e22ce 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 16px;
            overflow: hidden;
        }
        
        .hero-pattern-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(255, 255, 255, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 40% 60%, rgba(255, 255, 255, 0.05) 0%, transparent 50%);
            opacity: 0.6;
        }
        
        .hero-content-center {
            position: relative;
            z-index: 2;
            text-align: center;
            color: white;
            max-width: 600px;
            padding: 40px 20px;
        }
        
        .hero-icon-wrapper {
            margin-bottom: 20px;
            animation: float 3s ease-in-out infinite;
        }
        
        .hero-icon-wrapper i {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.9);
            text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }
        
        .hero-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 15px;
            line-height: 1.2;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
            animation: fadeInUp 0.8s ease;
        }
        
        .hero-subtitle {
            font-size: 1.2rem;
            font-weight: 500;
            margin-bottom: 25px;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 2px;
            animation: fadeInUp 1s ease 0.2s;
        }
        
        .hero-meta {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
            animation: fadeInUp 1.2s ease 0.4s;
        }
        
        .hero-date,
        .hero-category {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.15);
            padding: 8px 16px;
            border-radius: 25px;
            font-size: 0.9rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        .hero-date i,
        .hero-category i {
            font-size: 0.85rem;
        }
        
        /* Animation pour l'icône */
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        
        /* Animation pour l'apparition */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ===== STYLES POUR LE HERO SANS MÉDIA ===== */
        .article-hero-no-media {
            position: relative;
            min-height: 500px;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #7e22ce 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 30px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
        }
        
        .hero-no-media-background {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #7e22ce 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .hero-pattern-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(255, 255, 255, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 40% 60%, rgba(255, 255, 255, 0.05) 0%, transparent 50%);
            opacity: 0.6;
        }
        
        .hero-content-center {
            position: relative;
            z-index: 2;
            text-align: center;
            color: white;
            max-width: 600px;
            padding: 40px 20px;
        }
        
        .hero-icon-wrapper {
            margin-bottom: 20px;
            animation: float 3s ease-in-out infinite;
        }
        
        .hero-icon-wrapper i {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.9);
            text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }
        
        .hero-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 15px;
            line-height: 1.2;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
            animation: fadeInUp 0.8s ease;
        }
        
        .hero-subtitle {
            font-size: 1.2rem;
            font-weight: 500;
            margin-bottom: 25px;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 2px;
            animation: fadeInUp 1s ease 0.2s;
        }
        
        .hero-meta {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
            animation: fadeInUp 1.2s ease 0.4s;
        }
        
        .hero-date,
        .hero-category {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.15);
            padding: 8px 16px;
            border-radius: 25px;
            font-size: 0.9rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        .hero-date i,
        .hero-category i {
            font-size: 0.85rem;
        }
        
        /* Animation pour l'icône */
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
    </style>
</head>
<body class="article-page">
    <nav class="navbar navbar-expand-lg navbar-baume fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/Telex.png" alt="Logo Telex" class="logo-img">
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu" style="border: none; color: var(--baume-primary);">
                <i class="fas fa-bars"></i>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            <i class="fas fa-home"></i>Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">
                            <i class="fas fa-info-circle"></i>À propos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/programs">
                            <i class="fas fa-tv"></i>Programmes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/gallery">
                            <i class="fas fa-images"></i>Galerie
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/album">
                            <i class="fas fa-book"></i>Album
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/baume-de-la-foi">
                            <i class="fas fa-cross"></i>Baume de la Foi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/news">
                            <i class="fas fa-newspaper"></i>Actualités
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact">
                            <i class="fas fa-envelope"></i>Contact
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="article-page">
        <div class="container">
            <div class="article-layout">
                <!-- Colonne principale -->
                <div class="article-main">
                    <% if (news) { %>
                        <!-- WRAPPER PRINCIPAL AVEC DRAPEAU -->
                        <div class="article-hero-wrapper">
                            <!-- Drapeau décoratif -->
                            <div class="flag-decoration">
                                <img src="/images/drapeau.png" alt="Drapeau Madagascar" loading="lazy" onerror="this.onerror=null; this.src='/images/Telex.png';">
                            </div>
                            
                            <!-- Contenu média principal -->
                            <div class="hero-content">
                                <% 
                                // Fonctions d'extraction d'ID vidéo
                                function extractYouTubeId(url) {
                                    try {
                                        const urlStr = String(url || '');
                                        const match = urlStr.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/);
                                        if (match && match[1]) return match[1];
                                        const vParam = urlStr.match(/[?&]v=([A-Za-z0-9_-]{11})/);
                                        if (vParam && vParam[1]) return vParam[1];
                                        return '';
                                    } catch (e) {
                                        return '';
                                    }
                                }

                                function extractVimeoId(url) {
                                    try {
                                        const urlStr = String(url || '');
                                        const clean = urlStr.split('?')[0].split('#')[0];
                                        const match = clean.match(/vimeo\.com\/(?:video\/)?(\d+)/);
                                        if (match && match[1]) return match[1];
                                        const last = clean.split('/').filter(Boolean).pop() || '';
                                        return /^\d+$/.test(last) ? last : '';
                                    } catch (e) {
                                        return '';
                                    }
                                }
                                %>

                                <% if (news.video_url && !news.image_url) { %>
                                    <!-- CAS 1: Seulement vidéo -->
                                    <div class="article-hero-container">
                                        <div class="video-container">
                                            <div class="video-wrapper">
                                                <% 
                                                let videoId = '';
                                                let videoType = 'unknown';
                                                let videoSrc = news.video_url;

                                                if (news.video_url.includes('youtube.com') || news.video_url.includes('youtu.be')) {
                                                    videoId = extractYouTubeId(news.video_url);
                                                    videoType = 'youtube';
                                                    videoSrc = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&controls=1&enablejsapi=1`;
                                                } else if (news.video_url.includes('vimeo.com')) {
                                                    videoId = extractVimeoId(news.video_url);
                                                    videoType = 'vimeo';
                                                    videoSrc = `https://player.vimeo.com/video/${videoId}?autoplay=1&muted=1&controls=1`;
                                                } else {
                                                    videoType = 'uploaded';
                                                }
                                                %>

                                                <% if (videoType === 'youtube' || videoType === 'vimeo') { %>
                                                    <iframe 
                                                        src="<%= videoSrc %>"
                                                        frameborder="0"
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                        allowfullscreen>
                                                    </iframe>
                                                <% } else { %>
                                                    <video 
                                                        src="<%= news.video_url %>"
                                                        controls
                                                        autoplay
                                                        muted
                                                        preload="metadata"
                                                        playsinline>
                                                        Votre navigateur ne supporte pas la vidéo.
                                                    </video>
                                                <% } %>
                                            </div>
                                            <span class="image-category"><%= news.category || 'Actualité' %></span>
                                        </div>
                                    </div>

                                <% } else if (news.image_url && !news.video_url) { %>
                                    <!-- CAS 2: Seulement image -->
                                    <div class="article-hero-container">
                                        <div class="article-hero-image">
                                            <img src="<%= news.image_url %>" alt="<%= news.title %>" loading="lazy">
                                        </div>
                                        <span class="image-category"><%= news.category || 'Actualité' %></span>
                                    </div>

                                <% } else if (news.image_url && news.video_url) { %>
                                    <!-- CAS 3: Vidéo ET image -->
                                    <div class="article-hero-container">
                                        <div class="video-container">
                                            <div class="video-wrapper">
                                                <% 
                                                let videoId = '';
                                                let videoType = 'unknown';
                                                let videoSrc = news.video_url;

                                                if (news.video_url.includes('youtube.com') || news.video_url.includes('youtu.be')) {
                                                    videoId = extractYouTubeId(news.video_url);
                                                    videoType = 'youtube';
                                                    videoSrc = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&controls=1&enablejsapi=1`;
                                                } else if (news.video_url.includes('vimeo.com')) {
                                                    videoId = extractVimeoId(news.video_url);
                                                    videoType = 'vimeo';
                                                    videoSrc = `https://player.vimeo.com/video/${videoId}?autoplay=1&muted=1&controls=1`;
                                                } else {
                                                    videoType = 'uploaded';
                                                }
                                                %>
                                                
                                                <% if (videoType === 'youtube' || videoType === 'vimeo') { %>
                                                    <iframe 
                                                        src="<%= videoSrc %>"
                                                        frameborder="0"
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                        allowfullscreen>
                                                    </iframe>
                                                <% } else { %>
                                                    <video 
                                                        src="<%= news.video_url %>"
                                                        controls
                                                        autoplay
                                                        muted
                                                        preload="metadata"
                                                        playsinline>
                                                        Votre navigateur ne supporte pas la vidéo.
                                                    </video>
                                                <% } %>
                                            </div>
                                            <span class="image-category"><%= news.category || 'Actualité' %></span>
                                        </div>
                                    </div>
                                    
                                    <!-- Image additionnelle -->
                                    <div class="article-hero-container" style="margin-top: 20px;">
                                        <div class="article-hero-image">
                                            <img src="<%= news.image_url %>" alt="<%= news.title %>" loading="lazy">
                                        </div>
                                    </div>

                                <% } else { %>
                                    <!-- CAS 4: Aucun média - Hero amélioré -->
                                    <!-- TEST DE DIAGNOSTIC -->
                                    <div style="background: red !important; color: white !important; padding: 20px; margin: 20px; font-size: 24px; font-weight: bold; text-align: center; border: 5px solid yellow;">
                                        🚨 CONDITION ELSE EXECUTEE - HERO SANS MÉDIA 🚨
                                        <br>
                                        Variables: 
                                        - news.image_url: "<%= typeof news.image_url !== 'undefined' ? news.image_url : 'UNDEFINED' %>"
                                        - news.video_url: "<%= typeof news.video_url !== 'undefined' ? news.video_url : 'UNDEFINED' %>"
                                        <br>
                                        Date: <%= new Date().toISOString() %>
                                    </div>
                                    
                                    <div class="article-hero-container">
                                        <div class="article-hero-no-media" style="background: yellow !important; border: 5px solid red !important;">
                                            <!-- Hero avec dégradé et pattern -->
                                            <div class="hero-no-media-background" style="background: lime !important;">
                                                <div class="hero-pattern-overlay"></div>
                                                <div class="hero-content-center" style="background: magenta !important; color: white !important; padding: 20px !important; border: 3px solid white !important;">
                                                    <div class="hero-icon-wrapper" style="background: cyan !important; color: black !important;">
                                                        <i class="fas fa-newspaper"></i>
                                                    </div>
                                                    <h2 class="hero-title" style="color: yellow !important; background: black !important; padding: 10px !important;"><%= news.title %></h2>
                                                    <p class="hero-subtitle" style="color: lime !important; font-weight: bold !important;">Actualité</p>
                                                    <div class="hero-meta" style="background: orange !important; padding: 15px !important;">
                                                        <span class="hero-date" style="background: white !important; color: black !important;">
                                                            <i class="far fa-calendar"></i>
                                                            <% 
                                                            const newsDate = new Date(news.created_at);
                                                            const formattedDate = newsDate.toLocaleDateString('fr-FR', {
                                                                day: 'numeric',
                                                                month: 'long',
                                                                year: 'numeric'
                                                            });
                                                            %>
                                                            <%= formattedDate %>
                                                        </span>
                                                        <span class="hero-category" style="background: white !important; color: black !important;">
                                                            <i class="fas fa-tag"></i>
                                                            <%= news.category || 'Actualité' %>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <span class="image-category"><%= news.category || 'Actualité' %></span>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        
                        <!-- Titre et métadonnées -->
                        <div class="article-title-section">
                            <h1><%= news.title %></h1>
                            
                            <div class="article-meta">
                                <div class="meta-item">
                                    <i class="far fa-calendar"></i>
                                    <%= new Date(news.created_at).toLocaleDateString('fr-FR', {
                                        day: 'numeric',
                                        month: 'long',
                                        year: 'numeric'
                                    }) %>
                                </div>
                                
                                <% if (news.author) { %>
                                <div class="meta-item">
                                    <i class="fas fa-user"></i>
                                    <%= news.author %>
                                </div>
                                <% } %>
                            </div>
                        </div>
                        
                        <!-- Contenu -->
                        <div class="article-content">
                            <%- news.content %>
                        </div>
                        
                        <!-- Partager -->
                        <% 
                        const baseShareUrl = `https://telex.mg/news/${news.id}`;
                        const timestamp = Date.now();
                        const shareUrl = encodeURIComponent(`${baseShareUrl}?t=${timestamp}`);
                        const shareTitle = encodeURIComponent(news.title || '');
                        const shareDescription = encodeURIComponent((news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex, la télévision étudiante.'));
                        const shareText = encodeURIComponent(`${news.title || ''} ${baseShareUrl}`.trim());

                        const allowFacebook = news.share_facebook === undefined ? true : !!news.share_facebook;
                        const allowTwitter = news.share_twitter === undefined ? true : !!news.share_twitter;
                        const allowLinkedin = news.share_linkedin === undefined ? true : !!news.share_linkedin;
                        const allowWhatsapp = news.share_whatsapp === undefined ? true : !!news.share_whatsapp;
                        const allowInstagram = news.share_instagram === undefined ? true : !!news.share_instagram;
                        const allowTiktok = news.share_tiktok === undefined ? true : !!news.share_tiktok;

                        const anyShare = allowFacebook || allowTwitter || allowLinkedin || allowWhatsapp || allowInstagram || allowTiktok;
                        %>
                        
                        <!-- Métadonnées pour le partage -->
                        <meta name="article:title" content="<%= news.title || '' %>">
                        <meta name="article:description" content="<%= (news.excerpt && news.excerpt.trim()) ? news.excerpt : (news.content ? news.content.substring(0, 200) + '...' : 'Découvrez cette actualité sur Telex, la télévision étudiante.') %>">
                        <meta name="article:url" content="https://telex.mg/news/<%= news.id %>">
                        
                        <% if (anyShare) { %>
                            <div class="share-buttons">
                                <span class="share-title">Partager :</span>
                                <% if (allowFacebook) { %>
                                    <a href="#" 
                                       onclick="shareArticleOnFacebook(); return false;"
                                       class="share-btn share-facebook"
                                       title="Partager sur Facebook (compte personnel)">
                                        <i class="fab fa-facebook-f"></i>
                                    </a>
                                    <a href="#" 
                                       onclick="copyLinkForPage(); return false;"
                                       class="share-btn share-facebook"
                                       title="Copier le lien pour publication sur page Facebook">
                                        <i class="fas fa-link"></i>
                                    </a>
                                <% } %>
                                <% if (allowTwitter) { %>
                                    <a href="https://twitter.com/intent/tweet?url=<%= shareUrl %>&text=<%= shareTitle %>"
                                       target="_blank"
                                       rel="noopener"
                                       class="share-btn share-twitter"
                                       title="Partager sur Twitter">
                                        <i class="fab fa-twitter"></i>
                                    </a>
                                <% } %>
                                <% if (allowInstagram) { %>
                                    <a href="https://www.instagram.com/" 
                                       target="_blank"
                                       rel="noopener"
                                       onclick="copyToClipboard('<%= baseShareUrl %>'); alert('Lien copié! Collez-le dans votre story Instagram.'); return false;"
                                       class="share-btn share-instagram"
                                       title="Partager sur Instagram">
                                        <i class="fab fa-instagram"></i>
                                    </a>
                                <% } %>
                                <% if (allowTiktok) { %>
                                    <a href="https://www.tiktok.com/" 
                                       target="_blank"
                                       rel="noopener"
                                       onclick="copyToClipboard('<%= baseShareUrl %>'); alert('Lien copié! Collez-le dans votre vidéo TikTok.'); return false;"
                                       class="share-btn share-tiktok"
                                       title="Partager sur TikTok">
                                        <i class="fab fa-tiktok"></i>
                                    </a>
                                <% } %>
                                <% if (allowLinkedin) { %>
                                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= shareUrl %>"
                                       target="_blank"
                                       rel="noopener"
                                       class="share-btn share-linkedin"
                                       title="Partager sur LinkedIn">
                                        <i class="fab fa-linkedin-in"></i>
                                    </a>
                                <% } %>
                                <% if (allowWhatsapp) { %>
                                    <a href="https://wa.me/?text=<%= shareText %>"
                                       target="_blank"
                                       rel="noopener"
                                       class="share-btn share-whatsapp"
                                       title="Partager sur WhatsApp">
                                        <i class="fab fa-whatsapp"></i>
                                    </a>
                                <% } %>
                            </div>
                        <% } %>
                        
                        <!-- Retour -->
                        <div class="back-section">
                            <a href="/news" class="back-button">
                                <i class="fas fa-arrow-left"></i> Retour aux actualités
                            </a>
                        </div>
                    <% } else { %>
                        <div class="article-not-found">
                            <h1>Article non trouvé</h1>
                            <p>Cet article n'existe pas ou a été supprimé.</p>
                            <a href="/news" class="back-button">
                                <i class="fas fa-arrow-left"></i> Retour aux actualités
                            </a>
                        </div>
                    <% } %>
                </div>

                <!-- Sidebar -->
                <div class="article-sidebar">
                    <!-- Section À suivre -->
                    <div class="sidebar-section">
                        <h3 class="sidebar-title">
                            <i class="fas fa-video"></i> À suivre
                        </h3>
                        <div class="similar-videos">
                            <% 
                            const mediaForSidebar = (typeof allMedia !== 'undefined' && Array.isArray(allMedia)) ? allMedia : [];
                            const baseMedia = mediaForSidebar.filter(v => v && (v.video_url || v.image_url));

                            const currentHasVideo = !!(news && news.video_url && String(news.video_url).trim() !== '');
                            const currentHasImage = !!(news && news.image_url && String(news.image_url).trim() !== '');

                            let filteredMedia = baseMedia;
                            if (currentHasVideo && !currentHasImage) {
                                filteredMedia = baseMedia.filter(v => v && v.video_url && String(v.video_url).trim() !== '');
                            } else if (currentHasImage && !currentHasVideo) {
                                filteredMedia = baseMedia.filter(v => !v.video_url || String(v.video_url).trim() === '');
                            }
                            %>

                            <% if (filteredMedia.length === 0) { %>
                                <div class="loading-videos">
                                    <i class="fas fa-photo-video"></i>
                                    Aucun contenu disponible
                                </div>
                            <% } else { %>
                                <% filteredMedia.slice(0, 30).forEach(item => { %>
                                    <% 
                                    const videoUrl = String(item.video_url || '').trim();
                                    const isVideoItem = !!(videoUrl && videoUrl !== '');

                                    let poster = (item.image_url && String(item.image_url).trim() !== '') ? String(item.image_url).trim() : '/images/Telex.png';
                                    let embedSrc = '';
                                    let embedType = 'unknown';
                                    
                                    if (isVideoItem) {
                                        if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
                                            const vid = extractYouTubeId(videoUrl);
                                            if (vid) {
                                                embedType = 'youtube';
                                                embedSrc = `https://www.youtube.com/embed/${vid}?controls=1&rel=0`;
                                            }
                                        } else if (videoUrl.includes('vimeo.com')) {
                                            const vid = extractVimeoId(videoUrl);
                                            if (vid) {
                                                embedType = 'vimeo';
                                                embedSrc = `https://player.vimeo.com/video/${vid}`;
                                            }
                                        } else if (videoUrl.match(/\.(mp4|webm|ogg|mov|avi)$/i) || videoUrl.includes('/uploads/videos/')) {
                                            embedType = 'uploaded';
                                            embedSrc = videoUrl;
                                        }
                                    }

                                    const itemTitle = item.title && item.title.length > 60 ? item.title.substring(0, 60) + '...' : (item.title || 'Contenu');
                                    %>

                                    <a href="/news/<%= item.id %>" class="similar-video-item">
                                        <div class="similar-video-thumbnail">
                                            <% if (embedType === 'youtube' || embedType === 'vimeo') { %>
                                                <iframe 
                                                    src="<%= embedSrc %>"
                                                    title="<%= itemTitle %>"
                                                    loading="lazy"
                                                    allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                                                </iframe>
                                            <% } else if (embedType === 'uploaded') { %>
                                                <video src="<%= embedSrc %>" preload="metadata" muted></video>
                                            <% } else { %>
                                                <img src="<%= poster %>" alt="<%= itemTitle %>" loading="lazy" onerror="this.onerror=null;this.src='/images/Telex.png';">
                                            <% } %>
                                        </div>
                                        <div class="similar-video-info">
                                            <div class="similar-video-title"><%= itemTitle %></div>
                                            <div class="similar-video-meta">
                                                <i class="far fa-calendar"></i>
                                                <%= item.created_at ? new Date(item.created_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }) : '' %>
                                            </div>
                                        </div>
                                    </a>
                                <% }); %>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Section images similaires -->
                    <% if (news && news.image_url && String(news.image_url).trim() !== '') { %>
                    <div class="sidebar-section" id="similarImagesSection">
                        <h3 class="sidebar-title">
                            <i class="fas fa-image"></i> Images similaires
                        </h3>
                        <div class="similar-images" id="similarImages">
                            <div class="loading-images">
                                <i class="fas fa-spinner fa-spin"></i>
                                Chargement...
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Données depuis le serveur
        const newsData = <%- typeof news !== 'undefined' ? JSON.stringify(news) : '{}' %>;
        const relatedNewsData = <%- typeof relatedNews !== 'undefined' ? JSON.stringify(relatedNews) : '[]' %>;

        // ===== FONCTIONS DE REDIMENSIONNEMENT INTELLIGENT =====
        
        // Redimensionner tous les médias (sauf le drapeau)
        function resizeAllMedia() {
            const windowHeight = window.innerHeight;
            const maxHeight = Math.min(windowHeight * 0.7, 500); // Max 70% de l'écran ou 500px
            
            // Images principales (exclure le drapeau)
            document.querySelectorAll('.article-hero-image img, .article-hero-image video').forEach(media => {
                if (!media.closest('.flag-decoration')) {
                    media.style.maxHeight = maxHeight + 'px';
                    media.style.width = 'auto';
                    media.style.height = 'auto';
                }
            });
            
            // Vidéos dans les conteneurs
            document.querySelectorAll('.video-wrapper video').forEach(video => {
                video.style.maxHeight = maxHeight + 'px';
                video.style.width = '100%';
                video.style.height = 'auto';
            });
            
            // Iframes
            document.querySelectorAll('.video-wrapper iframe').forEach(iframe => {
                iframe.style.maxHeight = maxHeight + 'px';
                iframe.style.width = '100%';
                iframe.style.height = Math.min(iframe.offsetWidth * 0.5625, maxHeight) + 'px';
            });
            
            console.log('📐 Médias redimensionnés - Hauteur max:', maxHeight + 'px');
        }

        // Créer un fallback pour les vidéos
        function createVideoFallback(wrapper, reason) {
            if (wrapper.querySelector('.video-fallback')) return;
            
            const fallback = document.createElement('div');
            fallback.className = 'video-fallback';
            fallback.innerHTML = `
                <i class="fas fa-exclamation-triangle"></i>
                <p>Vidéo non disponible</p>
                <p style="font-size:0.9rem">${reason}</p>
            `;
            
            const video = wrapper.querySelector('video');
            if (video) video.style.display = 'none';
            wrapper.appendChild(fallback);
        }

        // Obtenir la miniature d'une vidéo
        async function getVideoThumbnail(videoUrl) {
            if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
                let videoId = '';
                if (videoUrl.includes('youtube.com')) {
                    videoId = videoUrl.split('v=')[1]?.split('&')[0] || '';
                } else {
                    videoId = videoUrl.split('/').pop() || '';
                }
                return `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`;
            } else if (videoUrl.includes('vimeo.com')) {
                const videoId = videoUrl.split('/').pop();
                try {
                    const response = await fetch(`https://vimeo.com/api/v2/video/${videoId}.json`);
                    const data = await response.json();
                    return data[0]?.thumbnail_large || '/images/Telex.png';
                } catch {
                    return '/images/Telex.png';
                }
            }
            return '/images/Telex.png';
        }

        // Charger les images similaires
        function loadSimilarImages() {
            const container = document.getElementById('similarImages');
            const section = document.getElementById('similarImagesSection');
            
            if (!container) return;
            
            try {
                const similarImages = relatedNewsData.filter(article => article.image_url);
                
                if (similarImages.length === 0) {
                    if (section) section.style.display = 'none';
                    return;
                }
                
                const imagesHTML = similarImages.slice(0, 5).map(article => {
                    const title = article.title && article.title.length > 50 
                        ? article.title.substring(0, 50) + '...' 
                        : article.title || 'Image';
                    
                    const date = article.created_at 
                        ? new Date(article.created_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })
                        : '';
                    
                    return `
                        <a href="/news/${article.id}" class="similar-image-item">
                            <div class="similar-image-thumbnail">
                                <img src="${article.image_url}" alt="${article.title || 'Image'}" loading="lazy"
                                     onerror="this.onerror=null; this.src='/images/Telex.png';">
                            </div>
                            <div class="similar-image-info">
                                <div class="similar-image-title">${title}</div>
                                <div class="similar-image-meta">
                                    <i class="far fa-calendar"></i> ${date}
                                </div>
                            </div>
                        </a>
                    `;
                }).join('');
                
                container.innerHTML = imagesHTML;
                
            } catch (error) {
                console.error('❌ Erreur chargement images similaires:', error);
                container.innerHTML = `
                    <div style="text-align:center; padding:20px; color:#6c757d;">
                        <i class="fas fa-exclamation-triangle" style="font-size:2rem; margin-bottom:10px;"></i>
                        <p>Chargement indisponible</p>
                    </div>
                `;
            }
        }

        // Initialisation vidéos
        function initVideos() {
            document.querySelectorAll('.video-wrapper video').forEach((video, index) => {
                console.log(`🎥 Vidéo ${index + 1} chargée`);
                
                video.addEventListener('loadedmetadata', () => {
                    resizeAllMedia();
                });
                
                video.addEventListener('error', (e) => {
                    console.error('❌ Erreur vidéo:', e);
                    createVideoFallback(video.parentElement, 'Erreur de chargement');
                });
                
                // Timeout de sécurité
                setTimeout(() => {
                    if (video.readyState === 0) {
                        createVideoFallback(video.parentElement, 'Timeout');
                    }
                }, 8000);
            });

            document.querySelectorAll('.video-wrapper iframe').forEach(iframe => {
                iframe.addEventListener('load', () => {
                    console.log('✅ Iframe chargé:', iframe.src);
                });
            });
        }

        // Fonction pour copier dans le presse-papiers
        function copyToClipboard(text) {
            if (navigator.clipboard && window.isSecureContext) {
                // Utiliser l'API Clipboard moderne
                navigator.clipboard.writeText(text).then(() => {
                    console.log('✅ Lien copié dans le presse-papiers');
                }).catch(err => {
                    console.error('❌ Erreur de copie:', err);
                    fallbackCopyTextToClipboard(text);
                });
            } else {
                // Fallback pour les navigateurs anciens
                fallbackCopyTextToClipboard(text);
            }
        }

        function fallbackCopyTextToClipboard(text) {
            const textArea = document.createElement("textarea");
            textArea.value = text;
            textArea.style.position = "fixed";
            textArea.style.left = "-999999px";
            textArea.style.top = "-999999px";
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            
            try {
                const successful = document.execCommand('copy');
                if (successful) {
                    console.log('✅ Lien copié avec fallback');
                } else {
                    console.error('❌ La copie a échoué');
                }
            } catch (err) {
                console.error('❌ Erreur de copie fallback:', err);
            }
            
            document.body.removeChild(textArea);
        }

        // ===== INITIALISATION =====
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🚀 Initialisation...');
            
            // Appliquer le redimensionnement
            resizeAllMedia();
            
            // Initialiser les vidéos
            initVideos();
            
            // Charger les images similaires
            if (newsData.image_url) {
                loadSimilarImages();
            }
            
            // Observer les changements de taille
            window.addEventListener('resize', resizeAllMedia);
            
            // Observer les mutations du DOM
            const observer = new MutationObserver(resizeAllMedia);
            observer.observe(document.body, {
                childList: true,
                subtree: true,
                attributes: false
            });
            
            console.log('✅ Initialisation terminée');
        });

        // Fonction pour copier le lien pour publication sur page
        function copyLinkForPage() {
            const url = document.querySelector('meta[name="article:url"]')?.content || window.location.href;
            const title = document.querySelector('meta[name="article:title"]')?.content || '';
            
            // Copier le lien dans le presse-papiers
            copyToClipboard(url);
            
            // Afficher des instructions détaillées
            showNotification(`
                <strong>Lien copié !</strong><br><br>
                <strong>Pour publier sur votre page Facebook :</strong><br>
                1. Allez sur votre page Facebook<br>
                2. Créez une nouvelle publication<br>
                3. Collez le lien (Ctrl+V)<br>
                4. Ajoutez un commentaire si besoin<br>
                5. Publiez<br><br>
                <em>Publication immédiate garantie !</em>
            `, 'info');
        }

        // Fonction pour partager l'article sur Facebook (méthode simple et fiable)
        function shareArticleOnFacebook() {
            // Récupérer les données depuis les métadonnées
            const title = document.querySelector('meta[name="article:title"]')?.content || '';
            const description = document.querySelector('meta[name="article:description"]')?.content || '';
            const url = document.querySelector('meta[name="article:url"]')?.content || window.location.href;
            
            // Utiliser la méthode classique de Facebook qui fonctionne partout
            const shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(title + '\n\n' + description)}`;
            
            // Ouvrir dans une nouvelle fenêtre avec des dimensions optimales
            window.open(shareUrl, '_blank', 'width=600,height=400,scrollbars=yes,resizable=yes');
            
            // Afficher une notification de confirmation
            showNotification('Fenêtre de partage Facebook ouverte', 'info');
        }

        // Fonction pour afficher des notifications
        function showNotification(message, type = 'info') {
            const notification = document.createElement('div');
            notification.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            notification.style.cssText = `
                top: 20px;
                right: 20px;
                z-index: 9999;
                min-width: 300px;
                border-radius: 8px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            `;
            
            notification.innerHTML = `
                <div class="d-flex align-items-center">
                    <i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'} me-2"></i>
                    <div class="flex-grow-1">${message}</div>
                    <button type="button" class="btn-close ms-2" data-bs-dismiss="alert"></button>
                </div>
            `;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 5000);
        }
    </script>
</body>
</html>