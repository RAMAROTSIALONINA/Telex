<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    <style>
        /* ===== CONTACT FORM STYLES ===== */
        .contact-form-card {
            background: #fff !important;
            border-radius: 16px !important;
            padding: 40px 48px !important;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08) !important;
            border: none !important;
            max-width: 780px;
            margin: 0 auto;
        }
        .contact-form-card h2 {
            font-size: 1.6rem !important;
            font-weight: 700 !important;
            color: #1a1a2e !important;
            margin-bottom: 28px !important;
        }

        /* Labels uppercase */
        .contact-form-card .form-label {
            font-size: 0.7rem !important;
            font-weight: 700 !important;
            text-transform: uppercase !important;
            letter-spacing: 0.08em !important;
            color: #64748b !important;
            margin-bottom: 6px !important;
        }

        /* Inputs / Select / Textarea */
        .contact-form-card .form-control,
        .contact-form-card .form-select {
            border: 1px solid #e2e8f0 !important;
            border-radius: 8px !important;
            padding: 10px 14px !important;
            font-size: 0.92rem !important;
            color: #1a1a2e !important;
            background: #fff !important;
            box-shadow: none !important;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .contact-form-card .form-control::placeholder { color: #a0aec0; }
        .contact-form-card .form-control:focus,
        .contact-form-card .form-select:focus {
            border-color: #dc2626 !important;
            box-shadow: 0 0 0 3px rgba(220,38,38,0.1) !important;
            outline: none !important;
        }
        .contact-form-card .form-control.is-invalid,
        .contact-form-card .form-select.is-invalid {
            border-color: #dc2626 !important;
        }
        .contact-form-card textarea.form-control {
            resize: vertical !important;
            min-height: 130px !important;
        }

        /* Character count */
        .contact-form-card .form-text {
            font-size: 0.78rem !important;
            color: #94a3b8 !important;
            margin-top: 5px !important;
        }
        .contact-form-card .form-text span {
            color: #1e40af !important;
            font-weight: 500 !important;
        }

        /* Checkbox */
        .contact-form-card .form-check-label {
            font-size: 0.85rem !important;
            color: #475569 !important;
        }

        /* Submit button */
        .btn-send {
            display: inline-flex !important;
            align-items: center !important;
            gap: 8px !important;
            background: #dc2626 !important;
            color: #fff !important;
            border: none !important;
            border-radius: 8px !important;
            padding: 12px 28px !important;
            font-size: 0.8rem !important;
            font-weight: 700 !important;
            text-transform: uppercase !important;
            letter-spacing: 0.08em !important;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
        }
        .btn-send:hover { background: #b91c1c !important; transform: translateY(-1px); }
        .btn-send:active { transform: translateY(0); }
        .btn-send:disabled { background: #fca5a5 !important; cursor: not-allowed; transform: none; }

        /* Section wrapper */
        .section { padding: 48px 0 64px !important; background: #f8fafc !important; }

        /* ===== HERO OPTION A — CENTRÉ ===== */
        body[data-page="contact"] .page-hero {
            padding: 52px 0 0 !important;
            min-height: 0 !important;
            position: relative !important;
            overflow: hidden !important;
            text-align: center !important;
            flex-direction: column !important;
            justify-content: center !important;
        }
        .contact-hero-eyebrow {
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
            margin-bottom: 12px;
            text-align: center !important;
        }
        body[data-page="contact"] .page-hero h1 {
            font-size: clamp(1.8rem, 5vw, 2.8rem) !important;
            font-weight: 900 !important;
            color: #fff !important;
            letter-spacing: -0.03em !important;
            line-height: 1.05 !important;
            margin-bottom: 14px !important;
            text-align: center !important;
        }
        body[data-page="contact"] .page-hero p {
            font-size: 1rem !important;
            color: rgba(255,255,255,0.7) !important;
            max-width: 480px !important;
            margin: 0 auto 24px !important;
            line-height: 1.65 !important;
            text-align: center !important;
        }
        body[data-page="contact"] .page-hero .container {
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            text-align: center !important;
        }
        .contact-hero-cta {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #dc2626;
            color: #fff !important;
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.09em;
            padding: 12px 28px;
            border-radius: 8px;
            text-decoration: none !important;
            transition: background 0.2s, transform 0.15s;
            margin-bottom: 60px;
        }
        .contact-hero-cta:hover { background: #b91c1c; transform: translateY(-2px); color: #fff !important; }
        .contact-hero-wave {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 48px;
            display: block;
        }
        .hero-deco-left, .hero-deco-right {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            opacity: 0.18;
            pointer-events: none;
            z-index: 1;
            height: auto;
            display: block;
        }
        .hero-deco-left  { left: 28px;  max-width: 130px; }
        .hero-deco-right { right: 28px; max-width: 110px; }
        @media (max-width: 768px) {
            .hero-deco-left, .hero-deco-right { display: none; }
        }

        /* Responsive */
        @media (max-width: 768px) {
            body[data-page="contact"] .page-hero { padding: 36px 0 0 !important; }
            body[data-page="contact"] .page-hero p { font-size: 0.9rem !important; }
            .contact-hero-cta { font-size: 0.73rem; padding: 10px 22px; }
            .contact-hero-wave { height: 36px; }
            .contact-form-card { padding: 28px 20px !important; }
            .contact-form-card h2 { font-size: 1.3rem !important; margin-bottom: 20px !important; }
        }
        @media (max-width: 576px) {
            body[data-page="contact"] .page-hero { padding: 28px 0 0 !important; }
            .contact-form-card { padding: 20px 14px !important; border-radius: 10px !important; }
        }
    </style>
</head>
<body data-page="contact">
    <!-- Navigation -->
<%- include('../partials/navbar') %>
    <!-- Hero Section — Option A : Centré -->
    <section class="page-hero">
        <img src="/images/logo.png" alt="" class="hero-deco-left" aria-hidden="true">
        <img src="/images/drapeau.png" alt="" class="hero-deco-right" aria-hidden="true">
        <div class="container" style="display:flex;flex-direction:column;align-items:center;text-align:center;position:relative;z-index:2;">
            <div class="contact-hero-eyebrow" style="text-align:center;">Télévision Étudiante &middot; Madagascar</div>
            <h1 style="text-align:center;width:100%;">Contactez-nous</h1>
            <p style="text-align:center;max-width:480px;margin-left:auto;margin-right:auto;">Une question, une suggestion, un projet de collaboration&nbsp;? On est à votre écoute pour donner vie à vos idées audiovisuelles.</p>
            <a href="#contact-form" class="contact-hero-cta">
                <i class="fas fa-envelope"></i>Envoyer un message
            </a>
        </div>
        <svg class="contact-hero-wave" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,24 C240,48 480,0 720,24 C960,48 1200,0 1440,24 L1440,48 L0,48 Z" fill="#f8fafc"/>
        </svg>
    </section>

    <!-- Section principale -->
    <section class="section">
        <div class="container">
            <div class="row">
                <!-- Formulaire de contact -->
                <div class="col-lg-12">
                    <div class="contact-form-card" id="contact-form">
                        <h2>Envoyez-nous un message</h2>
                        
                        <!-- Message de succès/erreur -->
                        <div id="messageAlert" class="alert" style="display: none;"></div>
                        
                        <form id="contactForm">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="name" class="form-label">Nom complet </label>
                                    <input type="text" class="form-control" id="name" name="name" required 
                                           placeholder="Votre nom et prénom">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="email" class="form-label">Email </label>
                                    <input type="email" class="form-control" id="email" name="email" required 
                                           placeholder="votre@email.com">
                                    <small class="text-muted" id="emailHelp"></small>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="subject" class="form-label">Sujet </label>
                                <select class="form-select" id="subject" name="subject" required>
                                    <option value="" selected disabled>Choisir un sujet</option>
                                    <option value="participation">Participer à Telex</option>
                                    <option value="partenariat">Proposition de partenariat</option>
                                    <option value="information">Demande d'information</option>
                                    <option value="suggestion">Suggestion ou idée</option>
                                    <option value="probleme">Signaler un problème</option>
                                    <option value="autre">Autre</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="message" class="form-label">Message </label>
                                <textarea class="form-control" id="message" name="message" rows="6" required 
                                          placeholder="Décrivez votre demande en détail..."></textarea>
                                <div class="form-text">
                                    <span id="charCount">0</span> caractères (<span>minimum 10 caractères</span>)
                                </div>
                            </div>

                            <div class="mb-4 form-check">
                                <input type="checkbox" class="form-check-input" id="newsletter" name="newsletter">
                                <label class="form-check-label" for="newsletter">
                                    Je souhaite m'abonner à la newsletter Telex pour recevoir nos actualités
                                </label>
                            </div>

                            <!-- Alertes de doublon -->
                            <div id="duplicateWarning" class="alert alert-warning" style="display: none;">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <span id="duplicateMessage"></span>
                            </div>

                            <button type="submit" class="btn-send" id="submitBtn">
                                <i class="fas fa-paper-plane me-2"></i>Envoyer le message
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/location.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const contactForm = document.getElementById('contactForm');
            const submitBtn = document.getElementById('submitBtn');
            const messageTextarea = document.getElementById('message');
            const charCount = document.getElementById('charCount');
            const emailInput = document.getElementById('email');
            const emailHelp = document.getElementById('emailHelp');
            const duplicateWarning = document.getElementById('duplicateWarning');
            const duplicateMessage = document.getElementById('duplicateMessage');
            
            // Stockage local pour suivre les soumissions
            const storageKey = 'telex_contact_submissions';
            
            // Compteur de caractères
            messageTextarea.addEventListener('input', function() {
                const length = this.value.length;
                charCount.textContent = length;
                
                if (length < 10) {
                    charCount.style.color = '#dc3545';
                } else if (length > 500) {
                    charCount.style.color = '#3AAFA9';
                } else {
                    charCount.style.color = '#28a745';
                }
            });
            
            // Validation email en temps réel
            emailInput.addEventListener('blur', function() {
                const email = this.value.trim();
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                
                if (email && !emailRegex.test(email)) {
                    emailHelp.textContent = 'Veuillez entrer une adresse email valide.';
                    emailHelp.style.color = '#dc3545';
                    this.classList.add('is-invalid');
                } else {
                    emailHelp.textContent = '';
                    this.classList.remove('is-invalid');
                }
            });
            
            // Vérifier les doublons en temps réel
            function checkDuplicate(email, subject) {
                const submissions = JSON.parse(localStorage.getItem(storageKey) || '[]');
                const now = Date.now();
                const oneDayAgo = now - (24 * 60 * 60 * 1000);
                
                // Chercher des soumissions similaires dans les dernières 24h
                const duplicate = submissions.find(sub => {
                    return sub.email === email.toLowerCase() && 
                           sub.subject === subject && 
                           sub.timestamp > oneDayAgo;
                });
                
                if (duplicate) {
                    const hoursAgo = Math.floor((now - duplicate.timestamp) / (1000 * 60 * 60));
                    
                    if (hoursAgo < 1) {
                        showDuplicateWarning('Vous avez déjà envoyé un message avec le même sujet il y a moins d\'une heure. Veuillez patienter.');
                        return true;
                    } else {
                        showDuplicateWarning(`Vous avez envoyé un message similaire il y a ${hoursAgo} heure${hoursAgo > 1 ? 's' : ''}. Modifiez le sujet ou attendez 24h.`);
                        return true;
                    }
                }
                
                hideDuplicateWarning();
                return false;
            }
            
            function showDuplicateWarning(message) {
                duplicateMessage.textContent = message;
                duplicateWarning.style.display = 'block';
                submitBtn.disabled = true;
            }
            
            function hideDuplicateWarning() {
                duplicateWarning.style.display = 'none';
                submitBtn.disabled = false;
            }
            
            // Vérifier les doublons quand l'email ou le sujet change
            emailInput.addEventListener('input', function() {
                const subject = document.getElementById('subject').value;
                if (this.value.trim() && subject) {
                    checkDuplicate(this.value.trim(), subject);
                }
            });
            
            document.getElementById('subject').addEventListener('change', function() {
                const email = emailInput.value.trim();
                if (email && this.value) {
                    checkDuplicate(email, this.value);
                }
            });
            
            // Soumission du formulaire
            contactForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const formData = new FormData(this);
                const data = Object.fromEntries(formData);
                
                // Validation côté client
                if (!data.name || !data.email || !data.subject || !data.message) {
                    showAlert('Veuillez remplir tous les champs obligatoires.', 'danger');
                    highlightInvalidFields();
                    return;
                }
                
                if (data.message.length < 10) {
                    showAlert('Le message doit contenir au moins 10 caractères.', 'danger');
                    messageTextarea.classList.add('is-invalid');
                    return;
                }
                
                // Vérification finale des doublons
                if (checkDuplicate(data.email, data.subject)) {
                    return;
                }
                
                // Désactiver le bouton
                const btnOriginalText = submitBtn.innerHTML;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Envoi en cours...';
                submitBtn.disabled = true;
                
                try {
                    const response = await fetch('/contact', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(data)
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        // Enregistrer la soumission dans localStorage
                        const submissions = JSON.parse(localStorage.getItem(storageKey) || '[]');
                        submissions.push({
                            email: data.email.toLowerCase(),
                            subject: data.subject,
                            timestamp: Date.now()
                        });
                        localStorage.setItem(storageKey, JSON.stringify(submissions));
                        
                        showAlert(result.message, 'success');
                        this.reset();
                        charCount.textContent = '0';
                        hideDuplicateWarning();
                        
                        // Nettoyer les anciennes soumissions (plus de 7 jours)
                        const oneWeekAgo = Date.now() - (7 * 24 * 60 * 60 * 1000);
                        const recentSubmissions = submissions.filter(sub => sub.timestamp > oneWeekAgo);
                        localStorage.setItem(storageKey, JSON.stringify(recentSubmissions));
                        
                    } else {
                        // Gérer les différents types d'erreurs
                        if (response.status === 429) {
                            showDuplicateWarning(result.message);
                        } else {
                            showAlert(result.message || 'Erreur lors de l\'envoi du message.', 'danger');
                        }
                    }
                    
                } catch (error) {
                    showAlert('Erreur de connexion. Veuillez réessayer.', 'danger');
                    
                } finally {
                    // Réactiver le bouton
                    submitBtn.innerHTML = btnOriginalText;
                    submitBtn.disabled = false;
                }
            });
            
            function showAlert(message, type) {
                const alertEl = document.getElementById('messageAlert');
                alertEl.className = `alert alert-${type} alert-dismissible fade show`;
                alertEl.style.display = 'block';

                // Injection sécurisée — textContent pour le message (pas innerHTML)
                alertEl.textContent = '';
                const msgNode = document.createTextNode(message);
                alertEl.appendChild(msgNode);

                const closeBtn = document.createElement('button');
                closeBtn.type = 'button';
                closeBtn.className = 'btn-close';
                closeBtn.setAttribute('data-bs-dismiss', 'alert');
                closeBtn.setAttribute('aria-label', 'Close');
                alertEl.appendChild(closeBtn);

                if (type === 'success') {
                    setTimeout(() => {
                        if (alertEl.style.display !== 'none') {
                            alertEl.style.display = 'none';
                        }
                    }, 8000);
                }
            }
            
            function highlightInvalidFields() {
                const fields = [
                    { id: 'name', value: document.getElementById('name').value.trim() },
                    { id: 'email', value: document.getElementById('email').value.trim() },
                    { id: 'subject', value: document.getElementById('subject').value },
                    { id: 'message', value: document.getElementById('message').value.trim() }
                ];
                
                fields.forEach(field => {
                    const element = document.getElementById(field.id);
                    if (!field.value) {
                        element.classList.add('is-invalid');
                    } else {
                        element.classList.remove('is-invalid');
                    }
                });
            }
        });
    </script>
</body>
</html>