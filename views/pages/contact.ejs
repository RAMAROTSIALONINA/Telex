<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    <style>
        /* Styles améliorés pour la page contact - THÈME BLEU */
        
        /* ===== STYLES POUR LE LOGO - INSPIRÉ DE BAUME-DE-LA-FOI ===== */
        .navbar .navbar-brand,
        .navbar-telex .navbar-brand,
        .navbar-baume .navbar-brand {
            color: #3AAFA9 !important;
            font-weight: 700;
            font-size: 1.8rem;
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
        }
        
        .navbar .navbar-brand:hover,
        .navbar-telex .navbar-brand:hover,
        .navbar-baume .navbar-brand:hover {
            color: #c1121f !important;
            transform: translateY(-1px);
        }
        
        .navbar .navbar-brand img,
        .navbar-telex .navbar-brand img,
        .navbar-baume .navbar-brand img {
            height: 60px;
            width: auto;
            max-width: 200px;
            margin-left: 0px !important;
            transform: scale(1);
            transform-origin: center;
        }

        /* ===== TOUS LES LIENS DU MENU ===== */
        .navbar .navbar-nav .nav-link,
        .navbar-telex .navbar-nav .nav-link,
        .navbar-baume .navbar-nav .nav-link {
            color: white !important;
            font-weight: 700 !important;
            font-size: 1rem !important;
            font-family: 'League Spartan', sans-serif !important;
            text-transform: uppercase !important;
            padding: 8px 12px !important;
            margin: 0 2px;
            border-radius: 8px;
            transition: all 0.3s ease;
            position: relative;
            white-space: nowrap;
        }

        .navbar .navbar-nav .nav-link i,
        .navbar-telex .navbar-nav .nav-link i,
        .navbar-baume .navbar-nav .nav-link i {
            color: white !important;
            margin-right: 8px;
            font-size: 1rem !important;
            transition: all 0.3s ease;
        }

        .navbar .navbar-nav .nav-link:hover,
        .navbar-telex .navbar-nav .nav-link:hover,
        .navbar-baume .navbar-nav .nav-link:hover {
            color: white !important;
            background: #dc3545 !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
        }

        .navbar .navbar-nav .nav-link.active,
        .navbar-telex .navbar-nav .nav-link.active,
        .navbar-baume .navbar-nav .nav-link.active {
            color: white !important;
            background: #dc3545 !important;
            font-weight: 600;
            border-radius: 8px;
        }

        /* Responsive pour mobile */
        @media (max-width: 768px) {
            .navbar .navbar-brand img,
            .navbar-telex .navbar-brand img,
            .navbar-baume .navbar-brand img {
                height: 50px;
                width: auto;
                max-width: 160px;
                margin-left: 0px !important;
                transform: scale(1);
            }
            
            .navbar .navbar-nav .nav-link,
            .navbar-telex .navbar-nav .nav-link,
            .navbar-baume .navbar-nav .nav-link {
                font-size: 0.9rem !important;
                padding: 10px 8px !important;
            }
        }

        @media (max-width: 576px) {
            .navbar .navbar-brand img,
            .navbar-telex .navbar-brand img,
            .navbar-baume .navbar-brand img {
                height: 40px;
                width: auto;
                max-width: 130px;
                margin-left: 0px !important;
                transform: scale(1);
            }
            
            .navbar .navbar-nav .nav-link,
            .navbar-telex .navbar-nav .nav-link,
            .navbar-baume .navbar-nav .nav-link {
                font-size: 0.8rem !important;
                padding: 8px 6px !important;
            }
        }
        
        /* Hero section améliorée */
        .page-hero {
            background: linear-gradient(135deg, #3498db 0%, #5dade2 50%, #2980b9 100%);
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        .page-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="rgba(255,255,255,0.1)"/><circle cx="75" cy="75" r="1" fill="rgba(255,255,255,0.1)"/><circle cx="50" cy="10" r="0.5" fill="rgba(255,255,255,0.05)"/><circle cx="10" cy="50" r="0.5" fill="rgba(255,255,255,0.05)"/><circle cx="90" cy="30" r="0.5" fill="rgba(255,255,255,0.05)"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
            opacity: 0.3;
        }
        
        .hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: white;
        }
        
        .hero-content h1 {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 3px;
            animation: fadeInUp 0.8s ease;
        }
        
        .hero-content p {
            font-size: 1.3rem;
            margin-bottom: 30px;
            opacity: 0.9;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            animation: fadeInUp 0.8s ease 0.2s both;
        }
        
        .hero-image-wrapper {
            margin-top: 40px;
            text-align: center;
        }
        
        .hero-image-wrapper img {
            max-width: 300px;
            height: auto;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            animation: float 6s ease-in-out infinite;
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }
        
        /* Section principale */
        .section {
            padding: 80px 0;
            background: #f8f9fa;
        }
        
        /* Formulaire de contact amélioré */
        .contact-form-card {
            background: white;
            border-radius: 20px;
            padding: 50px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(0, 0, 0, 0.05);
            position: relative;
            overflow: hidden;
            animation: slideUp 0.8s ease;
        }
        
        .contact-form-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, #E63946, #457B9D, #1D3557);
        }
        
        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* Formulaire styles */
        .form-control, .form-select {
            padding: 15px 20px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-size: 1rem;
            transition: all 0.3s ease;
            margin-bottom: 25px;
            background: #f8f9fa;
        }
        
        .form-control:focus, .form-select:focus {
            border-color: #E63946;
            box-shadow: 0 0 0 0.25rem rgba(230, 57, 70, 0.15);
            background: white;
            transform: translateY(-2px);
        }
        
        .form-label {
            font-weight: 600;
            color: #1D3557;
            margin-bottom: 10px;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        /* Alerte message */
        #messageAlert {
            border-radius: 12px;
            padding: 20px 25px;
            margin-bottom: 30px;
            border: none;
            display: none;
            font-weight: 500;
            animation: shake 0.5s ease;
        }
        
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }
        
        /* Bouton d'envoi */
        .btn-send {
            background: linear-gradient(135deg, #E63946, #c1121f);
            color: white;
            padding: 18px 40px;
            border-radius: 12px;
            border: none;
            font-weight: 600;
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }
        
        .btn-send:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(230, 57, 70, 0.3);
        }
        
        .btn-send:active {
            transform: translateY(-1px);
        }
        
        .btn-send::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s ease;
        }
        
        .btn-send:hover::before {
            left: 100%;
        }
        
        .btn-send:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(230, 57, 70, 0.3);
        }
        
        .btn-send:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }
        
        /* Checkbox */
        .form-check-input:checked {
            background-color: #E63946;
            border-color: #E63946;
        }
        
        .form-check-label {
            color: #555;
            font-weight: 500;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .page-hero {
                padding: 100px 0 60px;
            }
            
            .hero-content h1 {
                font-size: 2.5rem;
            }
            
            .hero-content p {
                font-size: 1.1rem;
            }
            
            .contact-form-card {
                padding: 30px 25px;
                margin: 0 15px;
            }
            
            .contact-form-card h2 {
                font-size: 2rem;
            }
            
            .section {
                padding: 60px 0;
            }
        }
        
        @media (max-width: 576px) {
            .hero-content h1 {
                font-size: 2rem;
            }
            
            .contact-form-card {
                padding: 25px 20px;
            }
            
            .btn-send {
                padding: 15px 25px;
                font-size: 1rem;
            }
        }
    </style>
</head>
<body data-page="contact">
    <!-- Navigation -->
<nav class="navbar navbar-expand-lg navbar-baume fixed-top">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="/">
