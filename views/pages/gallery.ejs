<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galerie - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
</head>
<body>
    <!-- Navigation -->
<%- include('../partials/navbar') %>

    <!-- Hero Section Galerie - TAILLE CORRIGÉE -->
    <section class="gallery-page-hero">
        <!-- Image décorative gauche -->
        <div class="hero-side-image hero-left-image">
            <img id="heroLeftImage" src="/images/11.png" alt="Logo Telex">
        </div>
        
        <!-- Image décorative droite -->
        <div class="hero-side-image hero-right-image">
            <img id="heroRightImage" src="/images/Telex.png" alt="Telex">
        </div>
        
        <div class="container">
            <div class="row justify-content-center align-items-center">
                <div class="col-lg-10 col-xl-8 text-center">
                    <div class="gallery-hero-content">
                        <h1>Galerie Telex</h1>
                        
                        <p class="lead">
                            Plongez au cœur de l'aventure audiovisuelle étudiante. 
                            Découvrez nos coulisses, nos tournages et l'énergie qui anime notre télévision.
                        </p>
                        
                        <div class="telex-stats">
                            <div class="stat-item">
                                <span class="stat-number">12+</span>
                                <span class="stat-label">Émissions</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">50+</span>
                                <span class="stat-label">Étudiants</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">100+</span>
                                <span class="stat-label">Productions</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Section Galerie -->
    <section class="section" style="padding: 40px 0;">
        <div class="container">
            <!-- Filtres améliorés -->
            <div class="text-center mb-4">
                <div class="gallery-filters">
                    <button type="button" class="gallery-filter-btn active" data-filter="all">
                        <i class="fas fa-th"></i> Tout voir
                    </button>
                    <button type="button" class="gallery-filter-btn" data-filter="evenement-culturel">
                        <i class="fas fa-theater-masks"></i> Culture
                    </button>
                    <button type="button" class="gallery-filter-btn" data-filter="evenement-sportif">
                        <i class="fas fa-futbol"></i> Sport
                    </button>
                    <button type="button" class="gallery-filter-btn" data-filter="evenement-coutume">
                        <i class="fas fa-landmark"></i> Coutume
                    </button>
                    <button type="button" class="gallery-filter-btn" data-filter="evenement-exceptionnel">
                        <i class="fas fa-star"></i> Exceptionnel
                    </button>
                    <button type="button" class="gallery-filter-btn" data-filter="autres">
                        <i class="fas fa-ellipsis-h"></i> Autres
                    </button>
                </div>
            </div>

            <!-- Introduction -->
            <div class="gallery-introduction">
                <h3 class="gallery-intro-title">Découvrez Notre Univers Audiovisuel</h3>
                <p class="gallery-intro-text">
                    Plongez au cœur de la télévision étudiante à travers nos coulisses, nos équipements professionnels, 
                    notre équipe passionnée et les moments inoubliables qui façonnent l'expérience Telex.
                </p>
            </div>

            <!-- Grille de galerie dynamique avec catégories améliorées -->
            <div class="gallery-grid" id="galleryGrid">
                <% if (gallery && gallery.length > 0) { %>
                    <% gallery.forEach(item => { %>
                    <div class="gallery-item" data-category="<%= item.category || 'coulisses' %>">
                        <div class="image-wrapper">
                            <img src="<%= item.image_url %>" 
                                 alt="<%= item.title || 'Image Telex' %>" 
                                 class="img-fluid">
                        </div>
                        <div class="gallery-overlay">
                            <h5><%= item.title || 'Image Telex' %></h5>
                            <p><%= item.description || 'Découvrez nos productions' %></p>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <!-- Images par défaut organisées par catégories d'événements -->
                    
                    <!-- Événement Culturel -->
                    <div class="gallery-item" data-category="evenement-culturel">
                        <div class="image-wrapper">
                            <img src="/images/logo ensemble.png" 
                                 alt="Festival culturel étudiant" 
                                 class="img-fluid">
                        </div>
                        <div class="gallery-overlay">
                            <h5>Festival Culturel TELEX</h5>
                            <p>Célébration de la culture malgache étudiante</p>
                        </div>
                    </div>

                    <!-- Événement Sportif -->
                    <div class="gallery-item" data-category="evenement-sportif">
                        <div class="image-wrapper">
                            <img src="/images/TELEX BAREA12.png" 
                                 alt="Compétition sportive universitaire" 
                                 class="img-fluid">
                        </div>
                        <div class="gallery-overlay">
                            <h5>Challenge Sportif</h5>
                            <p>Compétition entre universités partenaires</p>
                        </div>
                    </div>

                    <!-- Événement Coutume -->
                    <div class="gallery-item" data-category="evenement-coutume">
                        <div class="image-wrapper">
                            <img src="/images/TELEX INTEGRATION.png" 
                                 alt="Cérémonie traditionnelle étudiante" 
                                 class="img-fluid">
                        </div>
                        <div class="gallery-overlay">
                            <h5>Héritage Culturel</h5>
                            <p>Préservation des coutumes malgaches</p>
                        </div>
                    </div>

                    <!-- Événement Exceptionnel -->
                    <div class="gallery-item" data-category="evenement-exceptionnel">
                        <div class="image-wrapper">
                            <img src="/images/Présentation du Telex.png" 
                                 alt="Lancement officiel TELEX" 
                                 class="img-fluid">
                        </div>
                        <div class="gallery-overlay">
                            <h5>Lancement Exceptionnel</h5>
                            <p>Inauguration de la télévision étudiante</p>
                        </div>
                    </div>

                    <!-- Événement Culturel 2 -->
                    <div class="gallery-item" data-category="evenement-culturel">
                        <div class="image-wrapper">
                            <img src="/images/camera.png" 
                                 alt="Spectacle culturel" 
                                 class="img-fluid">
                        </div>
                        <div class="gallery-overlay">
                            <h5>Spectacle Traditionnel</h5>
                            <p>Arts et performances culturelles</p>
                        </div>
                    </div>

                    <!-- Événement Sportif 2 -->
                    <div class="gallery-item" data-category="evenement-sportif">
                        <div class="image-wrapper">
                            <img src="/images/11.png" 
                                 alt="Tournoi sportif étudiant" 
                                 class="img-fluid">
                        </div>
                        <div class="gallery-overlay">
                            <h5>Tournoi Inter-Écoles</h5>
                            <p>Compétition et esprit sportif</p>
                        </div>
                    </div>

                    <!-- Événement Coutume 2 -->
                    <div class="gallery-item" data-category="evenement-coutume">
                        <div class="image-wrapper">
                            <img src="/images/mirco2.png" 
                                 alt="Cérémonie traditionnelle" 
                                 class="img-fluid">
                        </div>
                        <div class="gallery-overlay">
                            <h5>Coutumes Malgaches</h5>
                            <p>Transmission du patrimoine culturel</p>
                        </div>
                    </div>

                    <!-- Autres -->
                    <div class="gallery-item" data-category="autres">
                        <div class="image-wrapper">
                            <img src="/images/Présentation telex.png" 
                                 alt="Équipement professionnel" 
                                 class="img-fluid">
                        </div>
                        <div class="gallery-overlay">
                            <h5>Matériel Professionnel</h5>
                            <p>Équipements de pointe pour la production</p>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

     <!-- Footer -->
    <%- include('../partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
    // GALLERY SCRIPT SIMPLIFIÉ
    document.addEventListener('DOMContentLoaded', function() {
        // ===== SYSTÈME DE ROTATION AUTOMATIQUE DES IMAGES LATÉRALES =====
        const leftImages = [
            '/images/11.png',
            '/images/2.png',
            '/images/3.png',
            '/images/4.png',
            '/images/5.png',
            '/images/Telex.png'
        ];
        
        const rightImages = [
            '/images/Telex.png',
            '/images/Telex11.png',
            '/images/11.png',
            '/images/logo ensemble.png',
            '/images/ensemble telex.png',
            '/images/TELEX BAREA.png'
        ];
        
        let leftImageIndex = 0;
        let rightImageIndex = 0;
        const heroLeftImage = document.getElementById('heroLeftImage');
        const heroRightImage = document.getElementById('heroRightImage');
        
        // Fonction pour changer l'image de gauche
        function changeLeftImage() {
            leftImageIndex = (leftImageIndex + 1) % leftImages.length;
            heroLeftImage.style.opacity = '0.3';
            
            setTimeout(() => {
                heroLeftImage.src = leftImages[leftImageIndex];
                heroLeftImage.style.opacity = '0.8';
            }, 500);
        }
        
        // Fonction pour changer l'image de droite
        function changeRightImage() {
            rightImageIndex = (rightImageIndex + 1) % rightImages.length;
            heroRightImage.style.opacity = '0.3';
            
            setTimeout(() => {
                heroRightImage.src = rightImages[rightImageIndex];
                heroRightImage.style.opacity = '0.8';
            }, 500);
        }
        
        // Changer les images toutes les 20 secondes (décalées pour éviter le changement simultané)
        setInterval(changeLeftImage, 20000);
        setInterval(changeRightImage, 25000); // 5 secondes de décalage
        
        // Éléments
        const filterButtons = document.querySelectorAll('.gallery-filter-btn');
        const galleryItems = document.querySelectorAll('.gallery-item');
        let currentLightboxIndex = 0;
        
        // Filtrage
        filterButtons.forEach(button => {
            button.addEventListener('click', function() {
                const filter = this.getAttribute('data-filter');
                
                // Active le bouton
                filterButtons.forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');
                
                // Filtre les images
                galleryItems.forEach(item => {
                    const category = item.getAttribute('data-category');
                    
                    if (filter === 'all' || category === filter) {
                        item.style.display = 'block';
                        setTimeout(() => {
                            item.style.opacity = '1';
                        }, 10);
                    } else {
                        item.style.opacity = '0';
                        setTimeout(() => {
                            item.style.display = 'none';
                        }, 300);
                    }
                });
            });
        });
        
        // Lightbox
        const images = document.querySelectorAll('.gallery-item img');
        let lightbox = null;
        
        images.forEach((img, index) => {
            img.addEventListener('click', function() {
                currentLightboxIndex = index;
                openLightbox();
            });
        });
        
        function openLightbox() {
            // Crée la lightbox
            lightbox = document.createElement('div');
            lightbox.className = 'lightbox';
            
            const currentImg = images[currentLightboxIndex];
            
            lightbox.innerHTML = `
                <div class="lightbox-content">
                    <button class="lightbox-nav prev">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <img src="${currentImg.src}" alt="${currentImg.alt}">
                    <button class="lightbox-nav next">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                    <button class="close">&times;</button>
                    <div class="lightbox-counter">${currentLightboxIndex + 1} / ${images.length}</div>
                </div>
            `;
            
            document.body.appendChild(lightbox);
            
            // Active la lightbox après un délai
            setTimeout(() => {
                lightbox.classList.add('active');
                document.body.style.overflow = 'hidden';
            }, 10);
            
            // Événements
            const closeBtn = lightbox.querySelector('.close');
            const prevBtn = lightbox.querySelector('.prev');
            const nextBtn = lightbox.querySelector('.next');
            
            closeBtn.addEventListener('click', closeLightbox);
            lightbox.addEventListener('click', function(e) {
                if (e.target === lightbox) closeLightbox();
            });
            
            prevBtn.addEventListener('click', () => navigateLightbox(-1));
            nextBtn.addEventListener('click', () => navigateLightbox(1));
            
            // Navigation clavier
            document.addEventListener('keydown', handleKeydown);
        }
        
        function navigateLightbox(direction) {
            currentLightboxIndex += direction;
            
            // Boucle
            if (currentLightboxIndex < 0) currentLightboxIndex = images.length - 1;
            if (currentLightboxIndex >= images.length) currentLightboxIndex = 0;
            
            // Met à jour l'image
            const lightboxImg = document.querySelector('.lightbox-content img');
            const counter = document.querySelector('.lightbox-counter');
            
            lightboxImg.style.opacity = '0';
            
            setTimeout(() => {
                const newImg = images[currentLightboxIndex];
                lightboxImg.src = newImg.src;
                lightboxImg.alt = newImg.alt;
                counter.textContent = `${currentLightboxIndex + 1} / ${images.length}`;
                lightboxImg.style.opacity = '1';
            }, 200);
        }
        
        function closeLightbox() {
            if (!lightbox) return;
            
            lightbox.classList.remove('active');
            setTimeout(() => {
                document.body.removeChild(lightbox);
                lightbox = null;
                document.body.style.overflow = '';
                document.removeEventListener('keydown', handleKeydown);
            }, 300);
        }
        
        function handleKeydown(e) {
            if (!lightbox) return;
            
            switch(e.key) {
                case 'Escape':
                    closeLightbox();
                    break;
                case 'ArrowLeft':
                    navigateLightbox(-1);
                    break;
                case 'ArrowRight':
                    navigateLightbox(1);
                    break;
            }
        }
    });
    </script>
</body>
</html>