    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
    // GALLERY SCRIPT SIMPLIFIÉ
    document.addEventListener('DOMContentLoaded', function() {
        // ===== SYSTÈME DE ROTATION AUTOMATIQUE DES IMAGES LATÉRALES =====
        const leftImages = [
            '/images/11.png',
            '/images/2.png',
            '/images/3.png',
            '/images/4.png',
            '/images/5.png',
            '/images/Telex.png'
        ];
        
        const rightImages = [
            '/images/Telex.png',
            '/images/Telex11.png',
            '/images/11.png',
            '/images/logo ensemble.png',
            '/images/ensemble telex.png',
            '/images/TELEX BAREA.png'
        ];
        
        let leftImageIndex = 0;
        let rightImageIndex = 0;
        const heroLeftImage = document.getElementById('heroLeftImage');
        const heroRightImage = document.getElementById('heroRightImage');
        
        // Fonction pour changer l'image de gauche
        function changeLeftImage() {
            leftImageIndex = (leftImageIndex + 1) % leftImages.length;
            heroLeftImage.style.opacity = '0.3';
            
            setTimeout(() => {
                heroLeftImage.src = leftImages[leftImageIndex];
                heroLeftImage.style.opacity = '0.8';
            }, 500);
        }
        
        // Fonction pour changer l'image de droite
        function changeRightImage() {
            rightImageIndex = (rightImageIndex + 1) % rightImages.length;
            heroRightImage.style.opacity = '0.3';
            
            setTimeout(() => {
                heroRightImage.src = rightImages[rightImageIndex];
                heroRightImage.style.opacity = '0.8';
            }, 500);
        }
        
        // Changer les images toutes les 20 secondes (décalées pour éviter le changement simultané)
        setInterval(changeLeftImage, 20000);
        setInterval(changeRightImage, 25000); // 5 secondes de décalage
        
        // Éléments
        const filterButtons = document.querySelectorAll('.gallery-filter-btn');
        const galleryItems = document.querySelectorAll('.gallery-item');
        let currentLightboxIndex = 0;
        
        // Filtrage
        filterButtons.forEach(button => {
            button.addEventListener('click', function() {
                const filter = this.getAttribute('data-filter');
                
                // Active le bouton
                filterButtons.forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');
                
                // Filtre les images
                galleryItems.forEach(item => {
                    const category = item.getAttribute('data-category');
                    
                    if (filter === 'all' || category === filter) {
                        item.style.display = 'block';
                        setTimeout(() => {
                            item.style.opacity = '1';
                        }, 10);
                    } else {
                        item.style.opacity = '0';
                        setTimeout(() => {
                            item.style.display = 'none';
                        }, 300);
                    }
                });
            });
        });
        
        // Lightbox
        const images = document.querySelectorAll('.gallery-item img');
        let lightbox = null;
        
        images.forEach((img, index) => {
            img.addEventListener('click', function() {
                currentLightboxIndex = index;
                openLightbox();
            });
        });
        
        function openLightbox() {
            // Crée la lightbox
            lightbox = document.createElement('div');
            lightbox.className = 'lightbox';
            
            const currentImg = images[currentLightboxIndex];
            
            lightbox.innerHTML = `
                <div class="lightbox-content">
                    <button class="lightbox-nav prev">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <img src="${currentImg.src}" alt="${currentImg.alt}">
                    <button class="lightbox-nav next">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                    <button class="close">&times;</button>
                    <div class="lightbox-counter">${currentLightboxIndex + 1} / ${images.length}</div>
                </div>
            `;
            
            document.body.appendChild(lightbox);
            
            // Active la lightbox après un délai
            setTimeout(() => {
                lightbox.classList.add('active');
                document.body.style.overflow = 'hidden';
            }, 10);
            
            // Événements
            const closeBtn = lightbox.querySelector('.close');
            const prevBtn = lightbox.querySelector('.prev');
            const nextBtn = lightbox.querySelector('.next');
            
            closeBtn.addEventListener('click', closeLightbox);
            lightbox.addEventListener('click', function(e) {
                if (e.target === lightbox) closeLightbox();
            });
            
            prevBtn.addEventListener('click', () => navigateLightbox(-1));
            nextBtn.addEventListener('click', () => navigateLightbox(1));
            
            // Navigation clavier
            document.addEventListener('keydown', handleKeydown);
        }
        
        function navigateLightbox(direction) {
            currentLightboxIndex += direction;
            
            // Boucle
            if (currentLightboxIndex < 0) currentLightboxIndex = images.length - 1;
            if (currentLightboxIndex >= images.length) currentLightboxIndex = 0;
            
            // Met à jour l'image
            const lightboxImg = document.querySelector('.lightbox-content img');
            const counter = document.querySelector('.lightbox-counter');
            
            lightboxImg.style.opacity = '0';
            
            setTimeout(() => {
                const newImg = images[currentLightboxIndex];
                lightboxImg.src = newImg.src;
                lightboxImg.alt = newImg.alt;
                counter.textContent = `${currentLightboxIndex + 1} / ${images.length}`;
                lightboxImg.style.opacity = '1';
            }, 200);
        }
        
        function closeLightbox() {
            if (!lightbox) return;
            
            lightbox.classList.remove('active');
            setTimeout(() => {
                document.body.removeChild(lightbox);
                lightbox = null;
                document.body.style.overflow = '';
                document.removeEventListener('keydown', handleKeydown);
            }, 300);
        }
        
        function handleKeydown(e) {
            if (!lightbox) return;
            
            switch(e.key) {
                case 'Escape':
                    closeLightbox();
                    break;
                case 'ArrowLeft':
                    navigateLightbox(-1);
                    break;
                case 'ArrowRight':
                    navigateLightbox(1);
                    break;
            }
        }
    });
    </script>
</body>
