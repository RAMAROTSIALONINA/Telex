<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Album Photo - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    <style>
        /* ===== HERO ===== */
        .album-hero {
            background: linear-gradient(135deg, #1d3557 0%, #457b9d 50%, #1d3557 100%);
            background-size: 200% 200%;
            animation: heroShift 15s ease-in-out infinite;
            color: white;
            padding: 100px 0 60px;
            position: relative;
            overflow: hidden;
        }
        @keyframes heroShift {
            0%, 100% { background-position: 0% 50%; }
            50%       { background-position: 100% 50%; }
        }
        .album-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url('/images/Telex.png') no-repeat center / contain;
            opacity: 0.08;
        }
        .album-hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
        }
        .album-hero-content h1 {
            font-size: 3rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }
        .album-hero-content .lead {
            font-size: 1.2rem;
            opacity: 0.9;
        }

        /* ===== CATEGORIES ===== */
        .album-categories { padding: 60px 0; }
        .category-header { text-align: center; margin-bottom: 3rem; }
        .category-header h2 {
            font-size: 2.2rem; font-weight: 700;
            color: #1d3557; position: relative; display: inline-block;
        }
        .category-header h2::after {
            content: ''; position: absolute; bottom: -10px; left: 50%;
            transform: translateX(-50%); width: 80px; height: 4px;
            background: linear-gradient(90deg, #e63946, #ffd60a); border-radius: 2px;
        }
        .category-header p { color: #6c757d; font-size: 1rem; }

        /* ===== ALBUM GRID ===== */
        .album-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 60px;
        }
        .album-card {
            background: white; border-radius: 15px; overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease; cursor: pointer;
        }
        .album-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.15); }
        .album-cover { position: relative; height: 220px; overflow: hidden; background: #e9ecef; }
        .album-cover img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
        .album-card:hover .album-cover img { transform: scale(1.08); }
        .album-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(135deg, rgba(29,53,87,0.85), rgba(230,57,70,0.85));
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            opacity: 0; transition: opacity 0.3s ease; color: white;
        }
        .album-card:hover .album-overlay { opacity: 1; }
        .album-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
        .album-overlay h3 { font-size: 1.2rem; font-weight: 700; text-align: center; padding: 0 1rem; }
        .album-info { padding: 20px; }
        .album-title { font-size: 1.3rem; font-weight: 700; color: #1d3557; margin-bottom: 8px; }
        .album-description { color: #666; font-size: 0.9rem; margin-bottom: 12px; line-height: 1.5; }
        .album-meta { display: flex; justify-content: space-between; padding-top: 12px; border-top: 1px solid #eee; }
        .album-count { background: #457b9d; color: white; padding: 4px 10px; border-radius: 20px; font-size: 0.82rem; font-weight: 600; }
        .album-date { color: #999; font-size: 0.82rem; }

        /* ===== EMPTY STATE ===== */
        .empty-album { padding: 60px 20px; text-align: center; background: #f8f9fa; border-radius: 15px; border: 2px dashed #dee2e6; }
        .empty-icon { font-size: 3.5rem; color: #adb5bd; display: block; margin-bottom: 1rem; }

        /* ===== STATS ===== */
        .album-stats { padding: 40px 0; background: #f8fafc; }
        .stats-container { display: flex; justify-content: center; gap: 60px; flex-wrap: wrap; }
        .stat-item { text-align: center; }
        .stat-number { font-size: 2.5rem; font-weight: 700; color: #1d3557; display: block; }
        .stat-label { color: #666; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; }

        /* ===== LIGHTBOX ===== */
        .album-lightbox {
            position: fixed; inset: 0; background: rgba(0,0,0,0.95);
            display: none; align-items: center; justify-content: center;
            z-index: 10000; padding: 20px;
        }
        .album-lightbox.active { display: flex; }
        .lightbox-album-content {
            background: white; border-radius: 20px;
            max-width: 1200px; max-height: 90vh; width: 100%;
            overflow: hidden; animation: slideUp 0.3s ease;
        }
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(40px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .lightbox-album-header {
            background: linear-gradient(135deg, #1d3557, #457b9d);
            color: white; padding: 20px 25px;
            display: flex; justify-content: space-between; align-items: center;
        }
        .lightbox-album-title { font-size: 1.6rem; font-weight: 700; margin: 0; }
        .lightbox-close {
            background: rgba(255,255,255,0.2); border: none; color: white;
            font-size: 1.3rem; width: 38px; height: 38px; border-radius: 50%;
            cursor: pointer; transition: all 0.2s ease;
        }
        .lightbox-close:hover { background: rgba(255,255,255,0.35); transform: rotate(90deg); }
        .lightbox-gallery {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 16px; max-height: 70vh; overflow-y: auto; padding: 20px;
        }
        .lightbox-item {
            border-radius: 10px; overflow: hidden; cursor: pointer;
            aspect-ratio: 16/9; border: 1px solid #e5e7eb;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            transition: all 0.25s ease; position: relative;
        }
        .lightbox-item:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.12); }
        .lightbox-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
        .lightbox-item:hover img { transform: scale(1.05); }
        .lightbox-item::after {
            content: attr(data-title); position: absolute; bottom: 0; left: 0; right: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.75), transparent);
            color: white; padding: 10px; font-size: 13px; font-weight: 500;
            opacity: 0; transition: opacity 0.3s ease;
        }
        .lightbox-item:hover::after { opacity: 1; }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .album-hero { padding: 90px 0 40px; }
            .album-hero-content h1 { font-size: 2.2rem; }
            .album-grid { grid-template-columns: 1fr; gap: 20px; }
            .stats-container { gap: 30px; }
            .lightbox-gallery { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 10px; padding: 12px; max-height: 60vh; }
        }
        @media (max-width: 480px) {
            .album-hero-content h1 { font-size: 1.8rem; }
            .lightbox-gallery { grid-template-columns: repeat(2, 1fr); gap: 8px; padding: 10px; }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include('../partials/navbar') %>

    <!-- Hero Section -->
    <section class="album-hero">
        <div class="container">
            <div class="album-hero-content">
                <h1>Album Photo Telex</h1>
                <p class="lead">
                    Explorez nos souvenirs immortalisés à travers nos différents événements et activités
                </p>
            </div>
        </div>
    </section>

    <!-- Album Categories -->
    <section class="album-categories">
        <div class="container">
            <div class="category-header">
                <h2>Nos Albums Thématiques</h2>
                <p>Découvrez nos moments précieux organisés par catégories pour une expérience immersive</p>
            </div>
            
            <!-- Élément caché pour stocker les données des catégories -->
            <div id="categoriesData" style="display: none;" data-categories='<%= JSON.stringify(categories || []) %>'></div>

            <div class="album-grid">
                <% if (categories && categories.length > 0) { %>
                    <% categories.forEach(category => { %>
                        <!-- Album <%= category.name %> -->
                        <div class="album-card" data-category="<%= category.id %>">
                            <div class="album-cover">
                                <% if (category.images && category.images.length > 0) { %>
                                    <img src="<%= category.images[0].src %>" alt="Album <%= category.name %>">
                                <% } else { %>
                                    <img src="/images/Telex.png" alt="Album <%= category.name %>">
                                <% } %>
                                <div class="album-overlay <%= category.color %>">
                                    <i class="<%= category.icon %> album-icon"></i>
                                    <h3><%= category.name %></h3>
                                </div>
                            </div>
                            <div class="album-info">
                                <h3 class="album-title"><%= category.name %></h3>
                                <p class="album-description">
                                    <%= category.description %>
                                </p>
                                <div class="album-meta">
                                    <span class="album-count"><%= category.count %> photos</span>
                                    <span class="album-date">2024-2025</span>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <!-- Aucune catégorie disponible -->
                    <div class="col-12 text-center">
                        <div class="empty-album">
                            <i class="fas fa-images empty-icon"></i>
                            <h3>Aucun album disponible</h3>
                            <p>Les albums seront bientôt disponibles. Revenez nous visiter !</p>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
                        <!-- Stats Section -->
    <section class="album-stats">
        <div class="container">
            <div class="stats-container">
                <div class="stat-item">
                    <span class="stat-number"><%= categories ? categories.length : 0 %></span>
                    <span class="stat-label">Albums</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number"><%= categories ? categories.reduce((sum, cat) => sum + cat.count, 0) : 0 %></span>
                    <span class="stat-label">Photos</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number"><%= categories ? categories.length : 0 %></span>
                    <span class="stat-label">Événements</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">2024-25</span>
                    <span class="stat-label">Année</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Lightbox -->
    <div class="album-lightbox" id="albumLightbox">
        <div class="lightbox-album-content">
            <div class="lightbox-album-header">
                <h2 class="lightbox-album-title" id="lightboxTitle">Album Photos</h2>
                <button class="lightbox-close" onclick="closeLightbox()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="lightbox-album-body">
                <div class="lightbox-gallery" id="lightboxGallery">
                    <!-- Images will be loaded dynamically -->
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Global function for closing lightbox
        function closeLightbox() {
            const lightbox = document.getElementById('albumLightbox');
            if (lightbox) {
                lightbox.classList.remove('active');
                document.body.style.overflow = '';
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
        // Récupérer les données depuis l'attribut data
        const categoriesDataElement = document.getElementById('categoriesData');
        const categoriesData = categoriesDataElement ? JSON.parse(categoriesDataElement.getAttribute('data-categories')) : [];
        
        // Convertir en format albumData
        const albumData = {};
        if (categoriesData && categoriesData.length > 0) {
            categoriesData.forEach(cat => {
                albumData[cat.id] = {
                    title: cat.name,
                    images: cat.images || []
                };
            });
        }
        
        // Elements
        const lightbox = document.getElementById('albumLightbox');
        const lightboxTitle = document.getElementById('lightboxTitle');
        const lightboxGallery = document.getElementById('lightboxGallery');

        // Get all album cards
        const albumCards = document.querySelectorAll('.album-card');

        // Add click event to album cards
        albumCards.forEach(card => {
            card.addEventListener('click', function() {
                const category = this.getAttribute('data-category');
                openAlbum(category);
            });
        });

        // Open album function
        function openAlbum(category) {
            const album = albumData[category];
            if (!album) return;

            lightboxTitle.textContent = album.title;
            lightboxGallery.innerHTML = '';

            album.images.forEach((image, index) => {
                const item = document.createElement('div');
                item.className = 'lightbox-item';
                item.setAttribute('data-title', image.title || 'Image ' + (index + 1));
                item.innerHTML = `
                    <img src="${image.src}" alt="${image.title}" title="${image.title}">
                `;
                item.addEventListener('click', () => openImageModal(image));
                lightboxGallery.appendChild(item);
            });

            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function openImageModal(image) {
            
            // Create a simple image modal
            const modal = document.createElement('div');
            modal.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.95);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 10001;
                cursor: pointer;
                padding: 20px;
                box-sizing: border-box;
            `;
            
            modal.innerHTML = `
                <div style="position: relative; max-width: 95%; max-height: 95vh; display: flex; align-items: center; justify-content: center;">
                    <button onclick="this.parentElement.parentElement.remove()" style="
                        position: absolute;
                        top: -50px;
                        right: -50px;
                        background: rgba(255, 255, 255, 0.9);
                        border: none;
                        border-radius: 50%;
                        width: 40px;
                        height: 40px;
                        font-size: 20px;
                        cursor: pointer;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        z-index: 10002;
                        transition: all 0.3s ease;
                    " >
                        ×
                    </button>
                    <img src="${image.src}" alt="${image.title}" style="
                        max-width: 100%;
                        max-height: 90vh;
                        width: auto;
                        height: auto;
                        object-fit: contain;
                        border-radius: 10px;
                        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
                        transition: transform 0.3s ease;
                    " onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
                    <div style="
                        position: absolute;
                        bottom: -40px;
                        left: 50%;
                        transform: translateX(-50%);
                        color: white;
                        text-align: center;
                        font-size: 16px;
                        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
                        background: rgba(0, 0, 0, 0.7);
                        padding: 8px 16px;
                        border-radius: 20px;
                        backdrop-filter: blur(10px);
                    ">
                        ${image.title}
                    </div>
                </div>
            `;
            
            // Add to body and close on click outside image
            document.body.appendChild(modal);
            
            modal.addEventListener('click', function(e) {
                if (e.target === modal) {
                    modal.remove();
                    document.body.style.overflow = '';
                }
            });
            
            // Close on escape key
            const handleEscape = (e) => {
                if (e.key === 'Escape') {
                    modal.remove();
                    document.body.style.overflow = '';
                    document.removeEventListener('keydown', handleEscape);
                }
            };
            document.addEventListener('keydown', handleEscape);
        }

        // Close lightbox on escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && lightbox.classList.contains('active')) {
                closeLightbox();
            }
        });

        // Close lightbox on background click
        lightbox.addEventListener('click', function(e) {
            if (e.target === lightbox) {
                closeLightbox();
            }
        });
    });
    </script>
</body>
</html>
