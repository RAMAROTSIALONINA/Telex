                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="essentialCookies" checked disabled>
                                    <label class="form-check-label" for="essentialCookies">Toujours actifs</label>
                                </div>
                            </div>
                        </div>

                        <!-- Cookies de performance -->
                        <div class="cookie-category">
                            <div class="category-header">
                                <div class="category-info">
                                    <h6><i class="fas fa-chart-line text-info me-2"></i>Cookies de performance</h6>
                                    <p class="text-muted small">Aident à améliorer le fonctionnement du site</p>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="performanceCookies">
                                    <label class="form-check-label" for="performanceCookies">Activés</label>
                                </div>
                            </div>
                        </div>

                        <!-- Cookies de personnalisation -->
                        <div class="cookie-category">
                            <div class="category-header">
                                <div class="category-info">
                                    <h6><i class="fas fa-palette text-warning me-2"></i>Cookies de personnalisation</h6>
                                    <p class="text-muted small">Permettent de personnaliser votre expérience</p>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="personalizationCookies">
                                    <label class="form-check-label" for="personalizationCookies">Activés</label>
                                </div>
                            </div>
                        </div>

                        <!-- Cookies de marketing -->
                        <div class="cookie-category">
                            <div class="category-header">
                                <div class="category-info">
                                    <h6><i class="fas fa-bullhorn text-danger me-2"></i>Cookies de marketing</h6>
                                    <p class="text-muted small">Utilisés pour les publicités ciblées</p>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="marketingCookies">
                                    <label class="form-check-label" for="marketingCookies">Activés</label>
                                </div>
