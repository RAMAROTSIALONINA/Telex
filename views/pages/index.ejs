                            </div>
                            <a href="/baume-de-la-foi#prieres" class="program-link" data-translate="common.read_more">Lire la suite →</a>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-12 text-center">
                        <p>Aucune prière disponible pour le moment.</p>
                    </div>
                <% } %>
