<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Accueil - Telex | Télévision Étudiante</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- CSS TELEX -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">

    <!-- Favicon -->
    <link rel="icon" href="/images/Telex.png" type="image/png">

    <!-- Styles section actualites accueil -->
    <style>
        /* === CARTES ACTUALITES ACCUEIL === */
        .news-home-card {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            border: 1px solid #e8e8e8;
            display: flex;
            flex-direction: column;
            height: 100%;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }
        .news-home-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 28px rgba(0,0,0,0.13);
        }
        .news-home-img {
            position: relative;
            width: 100%;
            overflow: hidden;
            background: #ffffff;
            flex-shrink: 0;
        }
        .news-home-img img,
        .news-home-img video {
            width: 100%;
            height: auto;
            display: block;
            transition: transform 0.4s ease;
        }
        .news-home-card:hover .news-home-img img { transform: scale(1.03); }
        .news-home-placeholder {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #457B9D, #1D3557);
            color: white; font-size: 2rem;
        }
        .news-home-badge {
            position: absolute; top: 10px; left: 10px;
            background: #dc3545; color: white;
            padding: 4px 12px; border-radius: 20px;
            font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .news-home-body {
            padding: 16px;
            display: flex; flex-direction: column; flex: 1;
        }
        .news-home-title {
            font-size: 1.05rem;
            font-weight: 700;
            color: #1D3557;
            line-height: 1.45;
            margin-bottom: 12px;
            flex: 1;
        }
        .news-home-date {
            font-size: 0.78rem;
            color: #999;
            margin-bottom: 12px;
        }
        .news-home-link {
            font-size: 0.85rem;
            font-weight: 600;
            color: #dc3545;
            text-decoration: none;
        }
        .news-home-link:hover { text-decoration: underline; }

        .news-thumbnail {
            margin-bottom: 12px;
            position: relative;
            overflow: hidden;
            border-radius: 8px;
            max-height: 120px;
        }
        .news-thumbnail img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            transition: transform 0.3s ease;
        }
        .news-thumbnail video {
            width: 100%;
            height: 120px;
            object-fit: cover;
        }
        .news-thumbnail:hover img { transform: scale(1.05); }
        .video-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.3);
            display: flex; align-items: center; justify-content: center;
            opacity: 0; transition: opacity 0.3s ease;
        }
        .news-thumbnail:hover .video-overlay { opacity: 1; }

        /* Banniere cookies */
        .cookie-consent-banner {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 340px;
            height: auto;
            background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
            color: white;
            padding: 20px;
            z-index: 9999;
            box-shadow: 0 8px 30px rgba(0,0,0,0.4);
            border: 2px solid #ffffff;
            border-radius: 15px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            animation: slideInRight 0.5s ease;
        }
        @keyframes slideInRight {
            from { transform: translateX(100%); opacity: 0; }
            to   { transform: translateX(0);    opacity: 1; }
        }
        @keyframes slideOutRight {
            from { transform: translateX(0);    opacity: 1; }
            to   { transform: translateX(100%); opacity: 0; }
        }
        .cookie-consent-content { display: flex; flex-direction: column; gap: 12px; }
        .cookie-consent-header { text-align: center; padding-bottom: 8px; border-bottom: 1px solid rgba(255,255,255,0.2); }
        .cookie-consent-icon { font-size: 2rem; color: #fff; margin-bottom: 8px; }
        .cookie-consent-text { text-align: center; }
        .cookie-consent-text h4 { margin: 0 0 8px 0; font-size: 0.95rem; font-weight: 600; }
        .cookie-consent-text p  { margin: 0; font-size: 0.82rem; line-height: 1.4; opacity: 0.9; }
        .cookie-link { color: #fff; text-decoration: none; font-weight: 500; }
        .cookie-link:hover { text-decoration: underline; }
        .cookie-consent-buttons { display: flex; flex-direction: column; gap: 6px; }
        .btn-accept-all {
            background: #28a745; color: white; border: none;
            padding: 9px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 500; transition: all 0.3s ease;
        }
        .btn-accept-all:hover { background: #218838; transform: translateY(-1px); }
        .btn-accept-necessary {
            background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3);
            padding: 9px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 500; transition: all 0.3s ease;
        }
        .btn-accept-necessary:hover { background: rgba(255,255,255,0.3); }
        .btn-customize {
            background: transparent; color: white; border: 1px solid rgba(255,255,255,0.5);
            padding: 9px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 500; transition: all 0.3s ease;
        }
        .btn-customize:hover { background: rgba(255,255,255,0.1); border-color: white; }
        .cookie-category { border: 1px solid #e9ecef; border-radius: 8px; padding: 12px; margin-bottom: 12px; }
        .category-header { display: flex; justify-content: space-between; align-items: center; }
        .category-info h6 { margin: 0; font-weight: 600; }
        .category-info p  { margin: 4px 0 0; font-size: 0.82rem; }
        .cookie-test-btn.hidden { display: none !important; }

        @media (max-width: 480px) {
            .cookie-consent-banner { width: calc(100vw - 20px); right: 10px; bottom: 10px; padding: 15px; }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include('../partials/navbar') %>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="hero-title">
                        <span class="text-primary" data-translate="home.title">Telex</span><br>
                        <span data-translate="home.subtitle">La Voix Étudiante</span>
                    </h1>
                    <p class="hero-subtitle" data-translate="home.description">
                        Première télévision étudiante et média numérique 100 % indépendants.
                        Nous donnons la parole à la jeunesse, formons les talents de demain
                        et produisons des contenus audiovisuels qui inspirent et font réfléchir.
                    </p>
                    <div class="hero-buttons">
                        <a href="/programs" class="btn btn-primary btn-lg">
                            <i class="fas fa-play me-2"></i><span data-translate="home.see_programs">Voir nos programmes</span>
                        </a>
                        <a href="/about" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-info-circle me-2"></i><span data-translate="home.discover">Découvrir</span>
                        </a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div id="telexCarousel" class="carousel slide rounded shadow-lg overflow-hidden" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            <!-- Slide 1 : ENSEMBLE TELEX -->
                            <div class="carousel-item active" data-bs-interval="4500">
                                <img src="/images/logo&expression.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Ensemble Telex - La Voix Étudiante">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">L'aventure audiovisuelle étudiante en commun</p>
                                </div>
                            </div>
                            
                            <!-- Slide 2 : TELEX BAREA -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/micro.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="TELEX BAREA12 - L'Équipe">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">L'équipe dynamique derrière la caméra</p>
                                </div>
                            </div>
                            
                            <!-- Slide 3 : FEMME TELEX -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/femme%20telex.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Femme Telex - Talent Féminin">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">Le talent féminin au cœur de nos productions</p>
                                </div>
                            </div>
                            
                            <!-- Slide 4 : BAUME DE LA FOI -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/Hero.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Baume de la Foi - Spiritualité">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">La spiritualité dans nos émissions</p>
                                </div>
                            </div>
                            
                            <!-- Slide 5 : DÉBAT CAMPUS -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/Débat.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Débat Campus - Échange d'idées">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">Face-à-face d'idées sur les grands sujets de société</p>
                                </div>
                            </div>
                        </div>
                        <!-- Contrôles -->
                        <button class="carousel-control-prev" type="button" data-bs-target="#telexCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Précédent</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#telexCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Suivant</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Section Dernières Actualités -->
    <section class="section section-programs" id="section-news">
        <div class="container">
            <h2 class="section-title" data-translate="home.latest_news">Dernières Actualités</h2>
            <p class="section-subtitle" data-translate="home.news_subtitle">Découvrez nos derniers articles et productions vidéo</p>
            
            <div class="row g-3">
                <% if (news && news.length > 0) { %>
                    <% news.slice(0, 4).forEach((article, index) => { %>
                    <div class="col-lg-3 col-md-6 col-sm-6">
                        <div class="news-home-card">
                            <!-- Image en haut -->
                            <div class="news-home-img">
                                <% if (article.image_url) { %>
                                    <img src="<%= article.image_url %>" alt="<%= article.title %>">
                                <% } else if (article.video_url) { %>
                                    <video preload="metadata">
                                        <source src="<%= article.video_url %>" type="video/mp4">
                                    </video>
                                <% } else { %>
                                    <div class="news-home-placeholder">
                                        <i class="fas fa-newspaper"></i>
                                    </div>
                                <% } %>
                                <% if (article.category) { %>
                                    <span class="news-home-badge"><%= article.category %></span>
                                <% } %>
                            </div>
                            <!-- Titre et infos en dessous -->
                            <div class="news-home-body">
                                <h3 class="news-home-title"><%= article.title.length > 80 ? article.title.substring(0, 80) + '...' : article.title %></h3>
                                <div class="news-home-date">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(article.created_at).toLocaleDateString('fr-FR') %>
                                </div>
                                <a href="/news/<%= article.id %>" class="news-home-link">Lire la suite →</a>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <!-- Articles par défaut - 5 dernières actualités -->
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Lancement de la nouvelle saison TELEX</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date().toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Information
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Nouveau tournage en cours</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 86400000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Production
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Interview exclusive</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 172800000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Interview
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Formation audiovisuelle</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 259200000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Éducation
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Prix du meilleur média étudiant</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 345600000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Récompense
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                <% } %>
            </div>
            
            <div class="row mt-4">
                <div class="col-12 text-center">
                    <a href="/news" class="btn btn-primary btn-lg">
                        <i class="fas fa-newspaper me-2"></i>Voir toutes les actualités
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Section Réflexions et Prières -->
    <!-- Section Programmes -->
    <section class="section section-programs" id="section-programs-main">
        <div class="container">
            <h2 class="section-title" data-translate="home.featured_programs">Nos Programmes Phares</h2>
            <p class="section-subtitle" data-translate="home.programs_subtitle">Explorez nos émissions, conçues par les étudiants et destinées aux étudiants</p>
            
            <div class="row g-3">
                <% if (programs && programs.length > 0) { %>
                    <% programs.slice(0, 5).forEach((program, index) => { %>
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-icon">
                                <% if (program.program_type) { %>
                                    <% if (program.program_type.includes('Information') || program.program_type.includes('Actus')) { %>
                                        <i class="fas fa-newspaper"></i>
                                    <% } else if (program.program_type.includes('Débat')) { %>
                                        <i class="fas fa-comments"></i>
                                    <% } else if (program.program_type.includes('Culture')) { %>
                                        <i class="fas fa-film"></i>
                                    <% } else if (program.program_type.includes('Sport')) { %>
                                        <i class="fas fa-futbol"></i>
                                    <% } else if (program.program_type.includes('Jeunesse')) { %>
                                        <i class="fas fa-graduation-cap"></i>
                                    <% } else if (program.program_type.includes('Environnement')) { %>
                                        <i class="fas fa-leaf"></i>
                                    <% } else if (program.program_type.includes('Éducation')) { %>
                                        <i class="fas fa-chalkboard-teacher"></i>
                                    <% } else if (program.program_type.includes('Technologie')) { %>
                                        <i class="fas fa-microchip"></i>
                                    <% } else if (program.program_type.includes('Économie')) { %>
                                        <i class="fas fa-chart-line"></i>
                                    <% } else { %>
                                        <i class="fas fa-tv"></i>
                                    <% } %>
                                <% } else { %>
                                    <i class="fas fa-tv"></i>
                                <% } %>
                            </div>
                            <h3><%= program.title || 'Programme TELEX' %></h3>
                            <p><%= program.description ? (program.description.length > 80 ? program.description.substring(0, 80) + '...' : program.description) : 'Découvrez ce programme passionnant.' %></p>
                            <a href="/programs#program-<%= program.id %>" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <!-- Programmes par défaut si aucun programme en base de données -->
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-image">
                                <img src="/images/Débat.png" alt="Le Journal Campus" class="program-img">
                            </div>
                            <h3 data-translate="programs.default.journal_campus.title">Le Journal Campus</h3>
                            <p data-translate="programs.default.journal_campus.description">L'actualité étudiante décryptée chaque semaine.</p>
                            <a href="/programs#journal" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-image">
                                <img src="/images/micro.png" alt="Débat Campus" class="program-img">
                            </div>
                            <h3 data-translate="programs.default.debate_campus.title">Débat Campus</h3>
                            <p data-translate="programs.default.debate_campus.description">Face-à-face d'idées sur les grands sujets de société.</p>
                            <a href="/programs#debat" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-image">
                                <img src="/images/camera.png" alt="Culture Express" class="program-img">
                            </div>
                            <h3 data-translate="programs.default.culture_express.title">Culture Express</h3>
                            <p data-translate="programs.default.culture_express.description">Découverte de la scène culturelle étudiante.</p>
                            <a href="/programs#culture" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-image">
                                <img src="/images/femme%20telex.png" alt="Telex Sports" class="program-img">
                            </div>
                            <h3 data-translate="programs.default.telex_sports.title">Telex Sports</h3>
                            <p data-translate="programs.default.telex_sports.description">Toute l'actualité sportive universitaire.</p>
                            <a href="/programs#sports" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-image">
                                <img src="/images/TELEX INTEGRATION.png" alt="Coulisses" class="program-img">
                            </div>
                            <h3 data-translate="programs.default.behind_scenes.title">Coulisses</h3>
                            <p data-translate="programs.default.behind_scenes.description">Les coulisses de la création audiovisuelle étudiante.</p>
                            <a href="/programs#coulisses" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Section À propos -->
    <section class="section section-about bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h2 class="section-title" data-translate="home.who_are_we">Qui sommes-nous ?</h2>
                    <p data-translate="home.about_text">
                        Telex est une télévision jeune, dynamique et engagée, 
                        portée par des étudiants et destinée à la jeunesse. 
                        Fondée en 2024, notre équipe compte plus de 50 étudiants 
                        bénévoles passionnés par l'audiovisuel.
                    </p>
                    <ul class="about-list">
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.student_led">100% étudiant</span></li>
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.professional_training">Formation professionnelle</span></li>
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.engaged_content">Contenus engagés</span></li>
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.active_community">Communauté active</span></li>
                    </ul>
                    <a href="/about" class="btn btn-outline-primary" data-translate="home.learn_more">En savoir plus sur nous</a>
                </div>
                <div class="col-lg-6">
                    <img src="https://images.unsplash.com/photo-1523580494863-6f3031224c94?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
                         alt="Studio TELEX" class="img-fluid rounded shadow">
                </div>
            </div>
        </div>
    </section>

    <section class="section section-programs" id="section-baume">
        <div class="container">
            <h2 class="section-title" data-translate="home.baume_title">Baume de la Foi</h2>
            <p class="section-subtitle" data-translate="home.baume_subtitle">Découvrez les derniers contenus spirituels pour nourrir votre foi</p>
            
            <div class="row g-3">
                <%
                const baumeItems = [
                    ...(reflexions || []).map(r => ({ ...r, type: 'Réflexion', icon: 'fas fa-lightbulb', href: '/baume-de-la-foi#reflexions', defaultImg: '/images/Hero.png' })),
                    ...(prieres || []).map(p => ({ ...p, type: 'Prière', icon: 'fas fa-pray', href: '/baume-de-la-foi#prieres', defaultImg: '/images/Prière.png' }))
                ].slice(0, 4);
                %>
                <% if (baumeItems.length > 0) { %>
                    <% baumeItems.forEach(item => { %>
                    <div class="col-lg-3 col-md-6 col-sm-6">
                        <div class="news-home-card">
                            <div class="news-home-img">
                                <% if (item.image_url && item.image_url.trim() !== '') { %>
                                    <img src="<%= item.image_url %>" alt="<%= item.title %>">
                                <% } else if (item.video_url && item.video_url.trim() !== '' && /\.(mp4|webm|ogg|mov|avi)$/i.test(item.video_url)) { %>
                                    <video preload="metadata">
                                        <source src="<%= item.video_url %>" type="video/mp4">
                                    </video>
                                <% } else { %>
                                    <img src="<%= item.defaultImg %>" alt="<%= item.title %>">
                                <% } %>
                                <span class="news-home-badge"><i class="<%= item.icon %> me-1"></i><%= item.type %></span>
                            </div>
                            <div class="news-home-body">
                                <h3 class="news-home-title"><%= item.title.length > 80 ? item.title.substring(0, 80) + '...' : item.title %></h3>
                                <div class="news-home-date">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(item.publication_date || item.created_at).toLocaleDateString('fr-FR') %>
                                </div>
                                <a href="<%= item.href %>" class="news-home-link">Lire la suite →</a>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-12 text-center py-4">
                        <i class="fas fa-cross fa-2x text-muted mb-3 d-block"></i>
                        <p class="text-muted">Aucun contenu disponible pour le moment.</p>
                    </div>
                <% } %>
            </div>
            
            <div class="row mt-4">
                <div class="col-12 text-center">
                    <a href="/baume-de-la-foi" class="btn btn-primary btn-lg">
                        <i class="fas fa-cross me-2"></i><span data-translate="home.see_all_reflections">Voir toutes les réflexions et prières</span>
                    </a>
                </div>
            </div>
        </div>
    </section>
    <!-- Section Contact -->
    <section class="section section-contact">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8 text-center">
                    <h2 class="section-title" data-translate="home.join_adventure">Rejoignez l'aventure Telex</h2>
                    <p class="section-subtitle">
                        Vous êtes étudiant et passionné par l'audiovisuel et journaliste ? 
                        Contactez-nous pour participer à nos projets et donner vie à vos idées !
                    </p>
                    <a href="/contact" class="btn btn-primary btn-lg">
                        <i class="fas fa-user-plus me-2"></i>Nous rejoindre
                    </a>
                </div>
            </div>
        </div>
    </section>

    
    <!-- Footer -->
    <%- include('../partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/location.js"></script>
    <script src="/js/simple-language.js"></script>
    
    
    <script>
    // Script pour la page d'accueil
    document.addEventListener('DOMContentLoaded', function() {
        console.log('TELEX - Page d\'accueil chargée');
        
        // Animation des cartes programmes
        const programCards = document.querySelectorAll('.program-card');
        programCards.forEach((card, index) => {
            card.style.animationDelay = `${index * 0.1}s`;
        });
    });
    </script>

    <!-- Bannière de consentement Telex -->
    <div id="cookieConsent" class="cookie-consent-banner" style="display: none;">
        <div class="cookie-consent-content">
            <div class="cookie-consent-icon">
                <i class="fas fa-shield-alt"></i>
            </div>
            <div class="cookie-consent-text">
                <h4>🛡️ Consentement - Telex</h4>
                <p>
                    Telex utilise des cookies pour améliorer votre expérience, 
                    analyser le trafic et personnaliser les contenus. 
                    En continuant, vous acceptez notre 
                    <a href="/privacy" class="cookie-link">politique de confidentialité</a> 
                    et nos <a href="/cookies" class="cookie-link">pratiques cookies</a>.
                </p>
            </div>
            <div class="cookie-consent-buttons">
                <button id="acceptAllBtn" class="btn btn-accept-all">
                    <i class="fas fa-check me-1"></i>Tout accepter
                </button>
                <button id="acceptNecessaryBtn" class="btn btn-accept-necessary">
                    <i class="fas fa-shield-alt me-1"></i>Uniquement essentiel
                </button>
                <button id="customizeBtn" class="btn btn-customize">
                    <i class="fas fa-cog me-1"></i>Personnaliser
                </button>
            </div>
        </div>
    </div>

    <!-- Modal de personnalisation des cookies -->
    <div class="modal fade" id="cookieModal" tabindex="-1" aria-labelledby="cookieModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="cookieModalLabel">
                        <i class="fas fa-cog me-2"></i>Personnaliser les cookies Telex
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="cookie-categories">
                        <!-- Cookies essentiels -->
                        <div class="cookie-category">
                            <div class="category-header">
                                <div class="category-info">
                                    <h6><i class="fas fa-shield-alt text-success me-2"></i>Cookies essentiels</h6>
                                    <p class="text-muted small">Nécessaires au fonctionnement du site</p>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="essentialCookies" checked disabled>
                                    <label class="form-check-label" for="essentialCookies">Toujours actifs</label>
                                </div>
                            </div>
                        </div>

                        <!-- Cookies de performance -->
                        <div class="cookie-category">
                            <div class="category-header">
                                <div class="category-info">
                                    <h6><i class="fas fa-chart-line text-info me-2"></i>Cookies de performance</h6>
                                    <p class="text-muted small">Aident à améliorer le fonctionnement du site</p>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="performanceCookies">
                                    <label class="form-check-label" for="performanceCookies">Activés</label>
                                </div>
                            </div>
                        </div>

                        <!-- Cookies de personnalisation -->
                        <div class="cookie-category">
                            <div class="category-header">
                                <div class="category-info">
                                    <h6><i class="fas fa-palette text-warning me-2"></i>Cookies de personnalisation</h6>
                                    <p class="text-muted small">Permettent de personnaliser votre expérience</p>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="personalizationCookies">
                                    <label class="form-check-label" for="personalizationCookies">Activés</label>
                                </div>
                            </div>
                        </div>

                        <!-- Cookies de marketing -->
                        <div class="cookie-category">
                            <div class="category-header">
                                <div class="category-info">
                                    <h6><i class="fas fa-bullhorn text-danger me-2"></i>Cookies de marketing</h6>
                                    <p class="text-muted small">Utilisés pour les publicités ciblées</p>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="marketingCookies">
                                    <label class="form-check-label" for="marketingCookies">Activés</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-primary" id="savePreferencesBtn">
                        <i class="fas fa-save me-1"></i>Enregistrer mes préférences
                    </button>
                </div>
            </div>
        </div>
    </div>


    <!-- Script pour la gestion des cookies -->
    <script>
        // Gestion du consentement
        class CookieConsent {
            constructor() {
                // Vérifier si le consentement a été donné AUJOURD'HUI
                const consentData = localStorage.getItem('telex_cookie_consent');
                const today = new Date().toDateString();
                
                if (!consentData) {
                    this.consentGiven = false; // Premier visite
                } else {
                    try {
                        const parsed = JSON.parse(consentData);
                        const consentDate = new Date(parsed.timestamp).toDateString();
                        this.consentGiven = consentDate === today; // True seulement si même jour
                    } catch (e) {
                        this.consentGiven = false; // Erreur, afficher la bannière
                    }
                }
                
                this.preferences = JSON.parse(localStorage.getItem('telex_cookie_preferences') || '{}');
                this.init();
            }
            
            init() {
                if (!this.consentGiven) {
                    this.showBanner();
                }
                this.setupEventListeners();
            }
            
            showBanner() {
                const banner = document.getElementById('cookieConsent');
                if (banner) {
                    console.log('Affichage de la bannière de cookies...');
                    banner.style.display = 'block';
                    banner.style.visibility = 'visible';
                    banner.style.opacity = '1';
                    banner.style.position = 'fixed';
                    banner.style.bottom = '0';
                    banner.style.left = '0';
                    banner.style.right = '0';
                    banner.style.zIndex = '9999';
                    
                    // Forcer le reflow pour l'animation
                    banner.offsetHeight;
                    
                    setTimeout(() => {
                        banner.style.animation = 'slideUp 0.5s ease';
                    }, 100);
                } else {
                    console.error('Bannière de cookies non trouvée');
                }
            }
            
            hideBanner() {
                const banner = document.getElementById('cookieConsent');
                if (banner) {
                    banner.style.animation = 'slideOutRight 0.5s ease';
                    setTimeout(() => {
                        banner.style.display = 'none';
                    }, 500);
                }
            }
            
            acceptAll() {
                this.preferences = {
                    essential: true,
                    performance: true,
                    personalization: true,
                    marketing: true
                };
                this.saveConsent();
                this.hideBanner();
                this.loadScripts();
            }
            
            acceptNecessary() {
                this.preferences = {
                    essential: true,
                    performance: false,
                    personalization: false,
                    marketing: false
                };
                this.saveConsent();
                this.hideBanner();
                this.loadEssentialScripts();
            }
            
            saveCustomPreferences() {
                this.preferences = {
                    essential: true,
                    performance: document.getElementById('performanceCookies').checked,
                    personalization: document.getElementById('personalizationCookies').checked,
                    marketing: document.getElementById('marketingCookies').checked
                };
                this.saveConsent();
                this.hideBanner();
                this.loadScripts();
            }
            
            saveConsent() {
                // Sauvegarder avec la date du jour
                const consentData = {
                    status: 'given',
                    timestamp: new Date().toISOString(),
                    date: new Date().toDateString()
                };
                localStorage.setItem('telex_cookie_consent', JSON.stringify(consentData));
                localStorage.setItem('telex_cookie_preferences', JSON.stringify(this.preferences));
                
                // Enregistrer le consentement côté serveur pour le dashboard admin
                this.recordConsent();
            }
            
            recordConsent() {
                // Envoyer les données de consentement au serveur
                fetch('/api/cookie-consent', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        preferences: this.preferences,
                        timestamp: new Date().toISOString(),
                        userAgent: navigator.userAgent,
                        consentType: this.getConsentType()
                    })
                }).catch(error => {
                    console.log('Erreur lors de l\'enregistrement du consentement:', error);
                });
            }
            
            getConsentType() {
                if (this.preferences.performance && this.preferences.personalization && this.preferences.marketing) {
                    return 'all';
                } else if (!this.preferences.performance && !this.preferences.personalization && !this.preferences.marketing) {
                    return 'essential';
                } else {
                    return 'partial';
                }
            }
            
            loadScripts() {
                // Charger les scripts selon les préférences
                if (this.preferences.performance) {
                    console.log('Chargement des scripts de performance...');
                    // Google Analytics, etc.
                }
                
                if (this.preferences.personalization) {
                    console.log('Chargement des scripts de personnalisation...');
                    // Scripts de personnalisation
                }
                
                if (this.preferences.marketing) {
                    console.log('Chargement des scripts de marketing...');
                    // Scripts de marketing/publicité
                }
                
                // Les scripts essentiels sont toujours chargés
                this.loadEssentialScripts();
            }
            
            loadEssentialScripts() {
                console.log('Chargement des scripts essentiels...');
                // Scripts nécessaires au fonctionnement du site
            }
            
            setupEventListeners() {
                // Bouton "Tout accepter"
                const acceptAllBtn = document.getElementById('acceptAllBtn');
                if (acceptAllBtn) {
                    acceptAllBtn.addEventListener('click', () => this.acceptAll());
                }
                
                // Bouton "Uniquement essentiel"
                const acceptNecessaryBtn = document.getElementById('acceptNecessaryBtn');
                if (acceptNecessaryBtn) {
                    acceptNecessaryBtn.addEventListener('click', () => this.acceptNecessary());
                }
                
                // Bouton "Personnaliser"
                const customizeBtn = document.getElementById('customizeBtn');
                if (customizeBtn) {
                    customizeBtn.addEventListener('click', () => {
                        const modal = new bootstrap.Modal(document.getElementById('cookieModal'));
                        modal.show();
                    });
                }
                
                // Bouton "Enregistrer les préférences"
                const savePreferencesBtn = document.getElementById('savePreferencesBtn');
                if (savePreferencesBtn) {
                    savePreferencesBtn.addEventListener('click', () => {
                        this.saveCustomPreferences();
                        const modal = bootstrap.Modal.getInstance(document.getElementById('cookieModal'));
                        modal.hide();
                    });
                }
                
                // Mettre à jour les switches dans la modal selon les préférences
                const modal = document.getElementById('cookieModal');
                if (modal) {
                    modal.addEventListener('show.bs.modal', () => {
                        document.getElementById('performanceCookies').checked = this.preferences.performance || false;
                        document.getElementById('personalizationCookies').checked = this.preferences.personalization || false;
                        document.getElementById('marketingCookies').checked = this.preferences.marketing || false;
                    });
                }
            }
        }
        
        // Animation CSS
        const style = document.createElement('style');
        style.textContent = `
            @keyframes slideUp {
                from {
                    transform: translateY(100%);
                    opacity: 0;
                }
                to {
                    transform: translateY(0);
                    opacity: 1;
                }
            }
            
            @keyframes slideDown {
                from {
                    transform: translateY(0);
                    opacity: 1;
                }
                to {
                    transform: translateY(100%);
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);
        
        // Initialiser la gestion des cookies
        document.addEventListener('DOMContentLoaded', function() {
            new CookieConsent();
            
            // Bouton de test pour afficher la bannière (à enlever en production)
            if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
                const testBtn = document.createElement('button');
                testBtn.innerHTML = '<i class="fas fa-cookie"></i> Test Bannière Consentement';
                testBtn.className = 'cookie-test-btn';
                testBtn.style.cssText = `
                    position: fixed;
                    top: 100px;
                    right: 20px;
                    background: #FF4757;
                    color: white;
                    border: none;
                    padding: 10px 15px;
                    border-radius: 8px;
                    z-index: 10000;
                    cursor: pointer;
                    font-size: 12px;
                    box-shadow: 0 4px 12px rgba(255,71,87,0.3);
                `;
                
                function shouldShowBanner() {
                    const consentData = localStorage.getItem('telex_cookie_consent');
                    const today = new Date().toDateString();
                    
                    if (!consentData) {
                        return true; // Premier visite
                    }
                    
                    try {
                        const parsed = JSON.parse(consentData);
                        const consentDate = new Date(parsed.timestamp).toDateString();
                        
                        // Afficher si c'est un nouveau jour
                        return consentDate !== today;
                    } catch (e) {
                        return true; // Erreur, afficher la bannière
                    }
                }
                
                const consentGiven = shouldShowBanner();
                if (consentGiven) {
                    testBtn.classList.remove('hidden');
                } else {
                    testBtn.classList.add('hidden');
                }
                
                testBtn.onclick = function() {
                    // Supprimer le consentement existant
                    localStorage.removeItem('telex_cookie_consent');
                    localStorage.removeItem('telex_cookie_preferences');
                    localStorage.removeItem('cookieConsent');
                    localStorage.removeItem('cookiePreferences');
                    
                    // Forcer l'affichage immédiat
                    const banner = document.getElementById('cookieConsent');
                    if (banner) {
                        banner.style.display = 'flex';
                        banner.style.visibility = 'visible';
                        banner.style.opacity = '1';
                        banner.style.position = 'fixed';
                        banner.style.bottom = '20px';
                        banner.style.right = '20px';
                        banner.style.zIndex = '9999';
                        console.log('Bannière forcée manuellement');
                        
                        // Cacher le bouton de test
                        testBtn.classList.add('hidden');
                    } else {
                        console.error('Bannière non trouvée même en forçage');
                        // Recharger si la bannière n'existe pas
                        window.location.reload();
                    }
                };
                document.body.appendChild(testBtn);
            }
        });
    </script>
</body>
</html>
