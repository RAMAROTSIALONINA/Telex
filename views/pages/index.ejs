    <!-- Script pour la gestion des cookies -->
    <script>
        // Gestion du consentement
        class CookieConsent {
            constructor() {
                // Vérifier si le consentement a été donné AUJOURD'HUI
                const consentData = localStorage.getItem('telex_cookie_consent');
                const today = new Date().toDateString();
                
                if (!consentData) {
                    this.consentGiven = false; // Premier visite
                } else {
                    try {
                        const parsed = JSON.parse(consentData);
                        const consentDate = new Date(parsed.timestamp).toDateString();
                        this.consentGiven = consentDate === today; // True seulement si même jour
                    } catch (e) {
                        this.consentGiven = false; // Erreur, afficher la bannière
                    }
                }
                
                this.preferences = JSON.parse(localStorage.getItem('telex_cookie_preferences') || '{}');
                this.init();
            }
            
            init() {
                if (!this.consentGiven) {
                    this.showBanner();
                }
                this.setupEventListeners();
            }
            
            showBanner() {
                const banner = document.getElementById('cookieConsent');
                if (banner) {
                    banner.style.display = 'flex';
                    // Force reflow so the transition fires
                    banner.offsetHeight;
                    banner.classList.add('visible');
                }
            }

            hideBanner() {
                const banner = document.getElementById('cookieConsent');
                if (banner) {
                    banner.classList.remove('visible');
                    setTimeout(() => {
                        banner.style.display = 'none';
                    }, 420);
                }
            }
            
            acceptAll() {
                this.preferences = {
                    essential: true,
                    performance: true,
                    personalization: true,
                    marketing: true
                };
                this.saveConsent();
                this.hideBanner();
                this.loadScripts();
            }
            
            acceptNecessary() {
                this.preferences = {
                    essential: true,
                    performance: false,
                    personalization: false,
                    marketing: false
                };
                this.saveConsent();
                this.hideBanner();
                this.loadEssentialScripts();
            }
            
            saveCustomPreferences() {
                this.preferences = {
                    essential: true,
                    performance: document.getElementById('performanceCookies').checked,
                    personalization: document.getElementById('personalizationCookies').checked,
                    marketing: document.getElementById('marketingCookies').checked
                };
                this.saveConsent();
                this.hideBanner();
                this.loadScripts();
            }
            
            saveConsent() {
                // Sauvegarder avec la date du jour
                const consentData = {
                    status: 'given',
                    timestamp: new Date().toISOString(),
                    date: new Date().toDateString()
                };
                localStorage.setItem('telex_cookie_consent', JSON.stringify(consentData));
                localStorage.setItem('telex_cookie_preferences', JSON.stringify(this.preferences));
                
                // Enregistrer le consentement côté serveur pour le dashboard admin
                this.recordConsent();
            }
            
            recordConsent() {
                // Envoyer les données de consentement au serveur
                fetch('/api/cookie-consent', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        preferences: this.preferences,
                        timestamp: new Date().toISOString(),
                        userAgent: navigator.userAgent,
                        consentType: this.getConsentType()
                    })
                }).catch(error => {
                    console.log('Erreur lors de l\'enregistrement du consentement:', error);
                });
            }
            
            getConsentType() {
                if (this.preferences.performance && this.preferences.personalization && this.preferences.marketing) {
                    return 'all';
                } else if (!this.preferences.performance && !this.preferences.personalization && !this.preferences.marketing) {
                    return 'essential';
                } else {
                    return 'partial';
                }
            }
            
            loadScripts() {
                // Charger les scripts selon les préférences
                if (this.preferences.performance) {
                    console.log('Chargement des scripts de performance...');
                    // Google Analytics, etc.
                }
                
                if (this.preferences.personalization) {
                    console.log('Chargement des scripts de personnalisation...');
                    // Scripts de personnalisation
                }
                
                if (this.preferences.marketing) {
                    console.log('Chargement des scripts de marketing...');
                    // Scripts de marketing/publicité
                }
                
                // Les scripts essentiels sont toujours chargés
                this.loadEssentialScripts();
            }
            
            loadEssentialScripts() {
                console.log('Chargement des scripts essentiels...');
                // Scripts nécessaires au fonctionnement du site
            }
            
            setupEventListeners() {
                // Bouton "Tout accepter"
                const acceptAllBtn = document.getElementById('acceptAllBtn');
                if (acceptAllBtn) {
                    acceptAllBtn.addEventListener('click', () => this.acceptAll());
                }
                
                // Bouton "Uniquement essentiel"
                const acceptNecessaryBtn = document.getElementById('acceptNecessaryBtn');
                if (acceptNecessaryBtn) {
                    acceptNecessaryBtn.addEventListener('click', () => this.acceptNecessary());
                }
                
                // Bouton "Personnaliser"
                const customizeBtn = document.getElementById('customizeBtn');
                if (customizeBtn) {
                    customizeBtn.addEventListener('click', () => {
                        const modal = new bootstrap.Modal(document.getElementById('cookieModal'));
                        modal.show();
                    });
                }
                
                // Bouton "Enregistrer les préférences"
                const savePreferencesBtn = document.getElementById('savePreferencesBtn');
                if (savePreferencesBtn) {
                    savePreferencesBtn.addEventListener('click', () => {
                        this.saveCustomPreferences();
                        const modal = bootstrap.Modal.getInstance(document.getElementById('cookieModal'));
                        modal.hide();
                    });
                }
                
                // Mettre à jour les switches dans la modal selon les préférences
                const modal = document.getElementById('cookieModal');
                if (modal) {
                    modal.addEventListener('show.bs.modal', () => {
                        document.getElementById('performanceCookies').checked = this.preferences.performance || false;
                        document.getElementById('personalizationCookies').checked = this.preferences.personalization || false;
                        document.getElementById('marketingCookies').checked = this.preferences.marketing || false;
                    });
                }
            }
        }
        
        // Animation CSS
        // Initialiser la gestion des cookies
        document.addEventListener('DOMContentLoaded', function() {
            new CookieConsent();
            
            // Bouton de test pour afficher la bannière (à enlever en production)
            if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
                const testBtn = document.createElement('button');
                testBtn.innerHTML = '<i class="fas fa-cookie"></i> Test Bannière Consentement';
                testBtn.className = 'cookie-test-btn';
                testBtn.style.cssText = `
                    position: fixed;
                    top: 100px;
                    right: 20px;
                    background: #FF4757;
                    color: white;
                    border: none;
                    padding: 10px 15px;
                    border-radius: 8px;
                    z-index: 10000;
                    cursor: pointer;
                    font-size: 12px;
                    box-shadow: 0 4px 12px rgba(255,71,87,0.3);
                `;
                
                function shouldShowBanner() {
                    const consentData = localStorage.getItem('telex_cookie_consent');
                    const today = new Date().toDateString();
                    
                    if (!consentData) {
                        return true; // Premier visite
                    }
                    
                    try {
                        const parsed = JSON.parse(consentData);
                        const consentDate = new Date(parsed.timestamp).toDateString();
                        
                        // Afficher si c'est un nouveau jour
                        return consentDate !== today;
                    } catch (e) {
                        return true; // Erreur, afficher la bannière
                    }
                }
                
                const consentGiven = shouldShowBanner();
                if (consentGiven) {
                    testBtn.classList.remove('hidden');
                } else {
                    testBtn.classList.add('hidden');
                }
                
                testBtn.onclick = function() {
                    // Supprimer le consentement existant
                    localStorage.removeItem('telex_cookie_consent');
                    localStorage.removeItem('telex_cookie_preferences');
                    localStorage.removeItem('cookieConsent');
                    localStorage.removeItem('cookiePreferences');
                    
                    // Forcer l'affichage immédiat
                    const banner = document.getElementById('cookieConsent');
                    if (banner) {
                        banner.style.display = 'flex';
                        banner.style.visibility = 'visible';
                        banner.style.opacity = '1';
                        banner.style.position = 'fixed';
                        banner.style.bottom = '20px';
                        banner.style.right = '20px';
                        banner.style.zIndex = '9999';
                        console.log('Bannière forcée manuellement');
                        
                        // Cacher le bouton de test
                        testBtn.classList.add('hidden');
                    } else {
                        console.error('Bannière non trouvée même en forçage');
                        // Recharger si la bannière n'existe pas
                        window.location.reload();
                    }
                };
                document.body.appendChild(testBtn);
            }
        });
    </script>
</body>
