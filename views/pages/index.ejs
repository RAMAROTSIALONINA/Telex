<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Accueil - Telex | Télévision Étudiante</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- CSS TELEX -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">

    <!-- Favicon -->
    <link rel="icon" href="/images/Telex.png" type="image/png">

    <!-- Styles section actualites accueil -->
    <style>
        /* === CARTES ACTUALITES ACCUEIL === */
        .news-home-card {
            background: #ffffff !important;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            border: 1px solid #e8e8e8;
            display: flex;
            flex-direction: column;
            height: 100%;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }
        .news-home-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 28px rgba(0,0,0,0.13);
        }
        .news-home-img {
            position: relative;
            width: 100%;
            aspect-ratio: 4 / 3;
            overflow: hidden;
            background: #f5f5f5;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .news-home-img img,
        .news-home-img video {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
            transition: transform 0.4s ease;
        }
        .news-home-card:hover .news-home-img img { transform: scale(1.03); }
        .news-home-placeholder {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #457B9D, #1D3557);
            color: white; font-size: 2rem;
        }
        .news-home-badge {
            position: absolute; top: 10px; left: 10px;
            background: #dc3545; color: white;
            padding: 4px 12px; border-radius: 20px;
            font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .news-home-body {
            padding: 10px 14px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
        }
        .news-home-date-bar {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            background: linear-gradient(transparent, rgba(0,0,0,0.62));
            color: #fff;
            font-size: 0.75rem;
            padding: 18px 10px 8px;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .news-home-link {
            font-size: 0.82rem;
            font-weight: 600;
            color: #dc3545;
            text-decoration: none;
            white-space: nowrap;
        }
        .news-home-link:hover { text-decoration: underline; }

        /* ===== BANNIÈRE COOKIES ===== */
        .cookie-consent-banner {
            position: fixed;
            bottom: 20px;
            left: 0;
            right: 0;
            margin: 0 auto;
            width: fit-content;
            max-width: 640px;
            min-width: 300px;
            background: linear-gradient(135deg, #22385B 0%, #457B9D 100%);
            color: white;
            padding: 12px 20px;
            z-index: 9999;
            box-shadow: 0 6px 24px rgba(0,0,0,0.3);
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 14px;
            pointer-events: auto;
            opacity: 0;
            transition: opacity 0.4s ease;
        }
        .cookie-consent-banner.visible {
            opacity: 1;
        }
        @media (max-width: 660px) {
            .cookie-consent-banner { left: 12px; right: 12px; width: auto; max-width: calc(100% - 24px); }
        }
        .cookie-consent-text { flex: 1; margin: 0; font-size: 0.76rem; line-height: 1.4; opacity: 0.92; }
        .cookie-link { color: #fff; text-decoration: underline; font-weight: 500; }
        .cookie-link:hover { opacity: 0.8; }
        .cookie-consent-buttons { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
        .btn-accept-all {
            background: #E63946; color: white; border: none;
            padding: 4px 12px; border-radius: 5px; font-size: 0.72rem; font-weight: 700;
            cursor: pointer; transition: background 0.2s ease; white-space: nowrap;
        }
        .btn-accept-all:hover { background: #c0303b; }
        .btn-accept-necessary {
            background: rgba(255,255,255,0.15); color: white;
            border: 1px solid rgba(255,255,255,0.3);
            padding: 4px 12px; border-radius: 5px; font-size: 0.72rem; font-weight: 600;
            cursor: pointer; transition: background 0.2s ease; white-space: nowrap;
        }
        .btn-accept-necessary:hover { background: rgba(255,255,255,0.25); }
        .btn-customize {
            background: transparent; color: rgba(255,255,255,0.6);
            border: none; font-size: 0.68rem; font-weight: 500;
            cursor: pointer; text-decoration: underline; white-space: nowrap; padding: 0;
        }
        .btn-customize:hover { color: #fff; }
        .cookie-category { border: 1px solid #e9ecef; border-radius: 8px; padding: 12px; margin-bottom: 12px; }
        .category-header { display: flex; justify-content: space-between; align-items: center; }
        .category-info h6 { margin: 0; font-weight: 600; }
        .category-info p  { margin: 4px 0 0; font-size: 0.82rem; }
        .cookie-test-btn.hidden { display: none !important; }

        @media (max-width: 600px) {
            .cookie-consent-banner { flex-direction: column; align-items: flex-start; padding: 14px 16px; gap: 10px; }
            .cookie-consent-buttons { flex-wrap: wrap; width: 100%; }
            .btn-accept-all, .btn-accept-necessary { flex: 1; text-align: center; }
        }

        /* === BAUME DE LA FOI — groupes === */
        .baume-group-label {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.09em;
            padding: 5px 14px;
            border-radius: 20px;
            margin-bottom: 0.85rem;
        }
        .baume-label-reflexion {
            background: rgba(245, 158, 11, 0.13);
            color: #b45309;
        }
        .baume-label-priere {
            background: rgba(99, 102, 241, 0.12);
            color: #4f46e5;
        }
        @media (min-width: 992px) {
            .baume-col-left  { border-right: 1px solid rgba(0,0,0,0.08); padding-right: 1.25rem; }
            .baume-col-right { padding-left: 1.25rem; }
        }

        /* === SCROLL REVEAL === */
        .reveal {
            opacity: 0;
            transform: translateY(32px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }
        .reveal.reveal-left  { transform: translateX(-44px); }
        .reveal.reveal-right { transform: translateX(44px); }
        .reveal.visible { opacity: 1; transform: none; }
        @media (prefers-reduced-motion: reduce) {
            .reveal, .reveal.reveal-left, .reveal.reveal-right {
                opacity: 1; transform: none; transition: none;
            }
        }

    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include('../partials/navbar') %>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="hero-title">
                        <span class="text-primary" data-translate="home.title">Telex</span><br>
                        <span data-translate="home.subtitle">La Voix Étudiante</span>
                    </h1>
                    <p class="hero-subtitle" data-translate="home.description">
                        Première télévision étudiante et média numérique 100 % indépendants.
                        Nous donnons la parole à la jeunesse, formons les talents de demain
                        et produisons des contenus audiovisuels qui inspirent et font réfléchir.
                    </p>
                    <div class="hero-buttons">
                        <a href="/programs" class="btn btn-primary btn-lg">
                            <i class="fas fa-play me-2"></i><span data-translate="home.see_programs">Voir nos programmes</span>
                        </a>
                        <a href="/about" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-info-circle me-2"></i><span data-translate="home.discover">Découvrir</span>
                        </a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div id="telexCarousel" class="carousel slide rounded shadow-lg overflow-hidden" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            <!-- Slide 1 : ENSEMBLE TELEX -->
                            <div class="carousel-item active" data-bs-interval="4500">
                                <img src="/images/logo&expression.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Ensemble Telex - La Voix Étudiante">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">L'aventure audiovisuelle étudiante en commun</p>
                                </div>
                            </div>
                            
                            <!-- Slide 2 : TELEX BAREA -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/micro.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="TELEX BAREA12 - L'Équipe">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">L'équipe dynamique derrière la caméra</p>
                                </div>
                            </div>
                            
                            <!-- Slide 3 : FEMME TELEX -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/femme%20telex.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Femme Telex - Talent Féminin">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">Le talent féminin au cœur de nos productions</p>
                                </div>
                            </div>
                            
                            <!-- Slide 4 : BAUME DE LA FOI -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/Hero.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Baume de la Foi - Spiritualité">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">La spiritualité dans nos émissions</p>
                                </div>
                            </div>
                            
                            <!-- Slide 5 : DÉBAT CAMPUS -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/Débat.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Débat Campus - Échange d'idées">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">Face-à-face d'idées sur les grands sujets de société</p>
                                </div>
                            </div>
                        </div>
                        <!-- Contrôles -->
                        <button class="carousel-control-prev" type="button" data-bs-target="#telexCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Précédent</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#telexCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Suivant</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Section Dernières Actualités -->
    <section class="section section-programs" id="section-news">
        <div class="container">
            <h2 class="section-title reveal" data-translate="home.latest_news">Dernières Actualités</h2>
            <p class="section-subtitle reveal" data-delay="100" data-translate="home.news_subtitle">Découvrez nos derniers articles et productions vidéo</p>
            
            <div class="row g-3">
                <% if (news && news.length > 0) { %>
                    <% news.slice(0, 8).forEach((article, index) => { %>
                    <div class="col-lg-3 col-md-6 col-sm-6 reveal" data-delay="<%= index * 60 %>">
                        <div class="news-home-card">
                            <div class="news-home-img">
                                <% if (article.image_url) { %>
                                    <img src="<%= article.image_url %>" alt="<%= article.title %>">
                                <% } else if (article.video_url) { %>
                                    <video preload="metadata">
                                        <source src="<%= article.video_url %>" type="video/mp4">
                                    </video>
                                <% } else { %>
                                    <div class="news-home-placeholder">
                                        <i class="fas fa-newspaper"></i>
                                    </div>
                                <% } %>
                                <% if (article.category) { %>
                                    <span class="news-home-badge"><%= article.category %></span>
                                <% } %>
                                <div class="news-home-date-bar">
                                    <i class="far fa-calendar"></i>
                                    <%= new Date(article.created_at).toLocaleDateString('fr-FR') %>
                                </div>
                            </div>
                            <div class="news-home-body">
                                <a href="/news/<%= article.id %>" class="news-home-link">Lire la suite →</a>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <!-- Articles par défaut - 5 dernières actualités -->
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Lancement de la nouvelle saison TELEX</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date().toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Information
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Nouveau tournage en cours</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 86400000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Production
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Interview exclusive</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 172800000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Interview
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Formation audiovisuelle</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 259200000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Éducation
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Prix du meilleur média étudiant</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 345600000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Récompense
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                <% } %>
            </div>
            
            <div class="row mt-4">
                <div class="col-12 text-center">
                    <a href="/news" class="btn btn-primary btn-lg">
                        <i class="fas fa-newspaper me-2"></i>Voir toutes les actualités
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Section À propos -->
    <section class="section section-about bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 reveal reveal-left">
                    <h2 class="section-title" data-translate="home.who_are_we">Qui sommes-nous ?</h2>
                    <p data-translate="home.about_text">
                        Telex est une télévision jeune, dynamique et engagée, 
                        portée par des étudiants et destinée à la jeunesse. 
                        Fondée en 2024, notre équipe compte plus de 50 étudiants 
                        bénévoles passionnés par l'audiovisuel.
                    </p>
                    <ul class="about-list">
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.student_led">100% étudiant</span></li>
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.professional_training">Formation professionnelle</span></li>
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.engaged_content">Contenus engagés</span></li>
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.active_community">Communauté active</span></li>
                    </ul>
                    <a href="/about" class="btn btn-outline-primary" data-translate="home.learn_more">En savoir plus sur nous</a>
                </div>
                <div class="col-lg-6 reveal reveal-right">
                    <img src="https://images.unsplash.com/photo-1523580494863-6f3031224c94?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                         alt="Studio TELEX" class="img-fluid rounded shadow">
                </div>
            </div>
        </div>
    </section>

    <section class="section section-programs" id="section-baume">
        <div class="container">
            <h2 class="section-title reveal" data-translate="home.baume_title">Baume de la Foi</h2>
            <p class="section-subtitle reveal" data-delay="100" data-translate="home.baume_subtitle">Découvrez les derniers contenus spirituels pour nourrir votre foi</p>
            
            <div class="row g-4">

                <!-- ── Groupe Réflexions ── -->
                <div class="col-lg-6 baume-col-left reveal" data-delay="0">
                    <div class="baume-group-label baume-label-reflexion">
                        <i class="fas fa-lightbulb"></i> Réflexions
                    </div>
                    <div class="row g-3">
                        <% if (reflexions && reflexions.length > 0) { %>
                            <% reflexions.slice(0, 2).forEach((r, i) => { %>
                            <div class="col-6">
                                <div class="news-home-card">
                                    <div class="news-home-img">
                                        <% if (r.image_url && r.image_url.trim() !== '') { %>
                                            <img src="<%= r.image_url %>" alt="<%= r.title %>">
                                        <% } else if (r.video_url && r.video_url.trim() !== '' && /\.(mp4|webm|ogg|mov|avi)$/i.test(r.video_url)) { %>
                                            <video preload="metadata" muted>
                                                <source src="<%= r.video_url %>" type="video/mp4">
                                            </video>
                                        <% } else { %>
                                            <img src="/images/Hero.png" alt="<%= r.title %>">
                                        <% } %>
                                        <span class="news-home-badge"><i class="fas fa-lightbulb me-1"></i>Réflexion</span>
                                        <div class="news-home-date-bar">
                                            <i class="far fa-calendar"></i>
                                            <%= new Date(r.publication_date || r.created_at).toLocaleDateString('fr-FR') %>
                                        </div>
                                    </div>
                                    <div class="news-home-body">
                                        <a href="/baume-de-la-foi#reflexions" class="news-home-link">Lire →</a>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                        <% } else { %>
                            <div class="col-12 text-center py-3">
                                <i class="fas fa-lightbulb fa-lg text-muted mb-2 d-block"></i>
                                <p class="text-muted small mb-0">Aucune réflexion disponible</p>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- ── Groupe Prières ── -->
                <div class="col-lg-6 baume-col-right reveal" data-delay="150">
                    <div class="baume-group-label baume-label-priere">
                        <i class="fas fa-pray"></i> Prières
                    </div>
                    <div class="row g-3">
                        <% if (prieres && prieres.length > 0) { %>
                            <% prieres.slice(0, 2).forEach((p, i) => { %>
                            <div class="col-6">
                                <div class="news-home-card">
                                    <div class="news-home-img">
                                        <% if (p.image_url && p.image_url.trim() !== '') { %>
                                            <img src="<%= p.image_url %>" alt="<%= p.title %>">
                                        <% } else if (p.video_url && p.video_url.trim() !== '' && /\.(mp4|webm|ogg|mov|avi)$/i.test(p.video_url)) { %>
                                            <video preload="metadata">
                                                <source src="<%= p.video_url %>" type="video/mp4">
                                            </video>
                                        <% } else if (p.video_url && p.video_url.trim() !== '') { %>
                                            <img src="<%= p.video_url %>" alt="<%= p.title %>">
                                        <% } else { %>
                                            <img src="/images/Pri%C3%A8re.png" alt="<%= p.title %>">
                                        <% } %>
                                        <span class="news-home-badge"><i class="fas fa-pray me-1"></i>Prière</span>
                                        <div class="news-home-date-bar">
                                            <i class="far fa-calendar"></i>
                                            <%= new Date(p.created_at).toLocaleDateString('fr-FR') %>
                                        </div>
                                    </div>
                                    <div class="news-home-body">
                                        <a href="/baume-de-la-foi#prieres" class="news-home-link">Lire →</a>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                        <% } else { %>
                            <div class="col-12 text-center py-3">
                                <i class="fas fa-pray fa-lg text-muted mb-2 d-block"></i>
                                <p class="text-muted small mb-0">Aucune prière disponible</p>
                            </div>
                        <% } %>
                    </div>
                </div>

            </div>
            
            <div class="row mt-4">
                <div class="col-12 text-center">
                    <a href="/baume-de-la-foi" class="btn btn-primary btn-lg">
                        <i class="fas fa-cross me-2"></i><span data-translate="home.see_all_reflections">Voir toutes les réflexions et prières</span>
                    </a>
                </div>
            </div>
        </div>
