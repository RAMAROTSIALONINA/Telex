<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Accueil - Telex | Télévision Étudiante</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- CSS TELEX -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    
    <!-- Favicon -->
    <link rel="icon" href="/images/Telex.png" type="image/png">
    
    <style>
        /* ===== STYLES POUR LE LOGO - INSPIRÉ DE BAUME-DE-LA-FOI ===== */
        .navbar .navbar-brand,
        .navbar-telex .navbar-brand,
        .navbar-baume .navbar-brand {
            color: #3AAFA9 !important;
            font-weight: 700;
            font-size: 1.8rem;
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
        }
        
        .navbar .navbar-brand:hover,
        .navbar-telex .navbar-brand:hover,
        .navbar-baume .navbar-brand:hover {
            color: #c1121f !important;
            transform: translateY(-1px);
        }
        
        .navbar .navbar-brand img,
        .navbar-telex .navbar-brand img,
        .navbar-baume .navbar-brand img {
            height: 60px;
            width: auto;
            max-width: 200px;
            margin-left: 0px !important;
            transform: scale(1);
            transform-origin: center;
        }

        /* ===== TOUS LES LIENS DU MENU ===== */
        .navbar .navbar-nav .nav-link,
        .navbar-telex .navbar-nav .nav-link,
        .navbar-baume .navbar-nav .nav-link {
            color: white !important;
            font-weight: 700 !important;
            font-size: 1rem !important;
            font-family: 'League Spartan', sans-serif !important;
            text-transform: uppercase !important;
            padding: 8px 12px !important;
            margin: 0 2px;
            border-radius: 8px;
            transition: all 0.3s ease;
            position: relative;
            white-space: nowrap;
        }

        .navbar .navbar-nav .nav-link i,
        .navbar-telex .navbar-nav .nav-link i,
        .navbar-baume .navbar-nav .nav-link i {
            color: white !important;
            margin-right: 8px;
            font-size: 1rem !important;
            transition: all 0.3s ease;
        }

        .navbar .navbar-nav .nav-link:hover,
        .navbar-telex .navbar-nav .nav-link:hover,
        .navbar-baume .navbar-nav .nav-link:hover {
            color: white !important;
            background: #dc3545 !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
        }

        .navbar .navbar-nav .nav-link.active,
        .navbar-telex .navbar-nav .nav-link.active,
        .navbar-baume .navbar-nav .nav-link.active {
            color: white !important;
            background: #dc3545 !important;
            font-weight: 600;
            border-radius: 8px;
        }

        /* Responsive pour mobile */
        @media (max-width: 768px) {
            .navbar .navbar-brand img,
            .navbar-telex .navbar-brand img,
            .navbar-baume .navbar-brand img {
                height: 50px;
                width: auto;
                max-width: 160px;
                margin-left: 0px !important;
                transform: scale(1);
            }
        }

        @media (max-width: 576px) {
            .navbar .navbar-brand img,
            .navbar-telex .navbar-brand img,
            .navbar-baume .navbar-brand img {
                height: 40px;
                width: auto;
                max-width: 130px;
                margin-left: 0px !important;
                transform: scale(1);
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-baume fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/Telex.png" alt="Logo Telex" class="logo-img">
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu" style="border: none; color: var(--baume-primary);">
                <i class="fas fa-bars"></i>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto">
                    <!-- Sélecteur de langue -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="languageDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-globe"></i>
                            <span class="ms-1"><%= currentLang === 'en' ? 'EN' : 'FR' %></span>
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item <%= currentLang === 'fr' ? 'active' : '' %>" 
                                   href="?lang=fr">
                                    <i class="fas fa-flag me-2"></i>Français
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item <%= currentLang === 'en' ? 'active' : '' %>" 
                                   href="?lang=en">
                                    <i class="fas fa-flag-usa me-2"></i>English
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/">
                            <i class="fas fa-home"></i>ACCUEIL
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">
                            <i class="fas fa-info-circle"></i>À PROPOS
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/programs">
                            <i class="fas fa-tv"></i>PROGRAMMES
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/gallery">
                            <i class="fas fa-images"></i>GALERIE
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/album">
                            <i class="fas fa-book"></i>ALBUM
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/baume-de-la-foi">
                            <i class="fas fa-cross"></i>BAUME DE LA FOI
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/news">
                            <i class="fas fa-newspaper"></i>ACTUALITÉS
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact">
                            <i class="fas fa-envelope"></i>CONTACT
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="hero-title">
                        <span class="text-primary" data-translate="home.title">Telex</span><br>
                        <span data-translate="home.subtitle">La Voix Étudiante</span>
                    </h1>
                    <p class="hero-subtitle" data-translate="home.description">
                        Première télévision étudiante et média numérique 100 % indépendants.
                        Nous donnons la parole à la jeunesse, formons les talents de demain
                        et produisons des contenus audiovisuels qui inspirent et font réfléchir.
                    </p>
                    <div class="hero-buttons">
                        <a href="/programs" class="btn btn-primary btn-lg">
                            <i class="fas fa-play me-2"></i><span data-translate="home.see_programs">Voir nos programmes</span>
                        </a>
                        <a href="/about" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-info-circle me-2"></i><span data-translate="home.discover">Découvrir</span>
                        </a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div id="telexCarousel" class="carousel slide rounded shadow-lg overflow-hidden" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            <!-- Slide 1 : ENSEMBLE TELEX -->
                            <div class="carousel-item active" data-bs-interval="4500">
                                <img src="/images/logo&expression.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Ensemble Telex - La Voix Étudiante">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">L'aventure audiovisuelle étudiante en commun</p>
                                </div>
                            </div>
                            
                            <!-- Slide 2 : TELEX BAREA -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/micro.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="TELEX BAREA12 - L'Équipe">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">L'équipe dynamique derrière la caméra</p>
                                </div>
                            </div>
                            
                            <!-- Slide 3 : FEMME TELEX -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/femme%20telex.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Femme Telex - Talent Féminin">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">Le talent féminin au cœur de nos productions</p>
                                </div>
                            </div>
                            
                            <!-- Slide 4 : BAUME DE LA FOI -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/Hero.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Baume de la Foi - Spiritualité">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">La spiritualité dans nos émissions</p>
                                </div>
                            </div>
                            
                            <!-- Slide 5 : DÉBAT CAMPUS -->
                            <div class="carousel-item" data-bs-interval="4500">
                                <img src="/images/Débat.png" 
                                     class="d-block w-100 carousel-img-small" 
                                     alt="Débat Campus - Échange d'idées">
                                <div class="carousel-caption d-none d-md-block">
                                    <p class="mt-2 mb-0">Face-à-face d'idées sur les grands sujets de société</p>
                                </div>
                            </div>
                        </div>
                        <!-- Contrôles -->
                        <button class="carousel-control-prev" type="button" data-bs-target="#telexCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Précédent</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#telexCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Suivant</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Section Programmes -->
    <section class="section section-programs" id="section-programs-main">
        <div class="container">
            <h2 class="section-title" data-translate="home.featured_programs">Nos Programmes Phares</h2>
            <p class="section-subtitle" data-translate="home.programs_subtitle">Explorez nos émissions, conçues par les étudiants et destinées aux étudiants</p>
            
            <div class="row">
                <% if (programs && programs.length > 0) { %>
                    <% programs.slice(0, 5).forEach((program, index) => { %>
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-icon">
                                <% if (program.program_type) { %>
                                    <% if (program.program_type.includes('Information') || program.program_type.includes('Actus')) { %>
                                        <i class="fas fa-newspaper"></i>
                                    <% } else if (program.program_type.includes('Débat')) { %>
                                        <i class="fas fa-comments"></i>
                                    <% } else if (program.program_type.includes('Culture')) { %>
                                        <i class="fas fa-film"></i>
                                    <% } else if (program.program_type.includes('Sport')) { %>
                                        <i class="fas fa-futbol"></i>
                                    <% } else if (program.program_type.includes('Jeunesse')) { %>
                                        <i class="fas fa-graduation-cap"></i>
                                    <% } else if (program.program_type.includes('Environnement')) { %>
                                        <i class="fas fa-leaf"></i>
                                    <% } else if (program.program_type.includes('Éducation')) { %>
                                        <i class="fas fa-chalkboard-teacher"></i>
                                    <% } else if (program.program_type.includes('Technologie')) { %>
                                        <i class="fas fa-microchip"></i>
                                    <% } else if (program.program_type.includes('Économie')) { %>
                                        <i class="fas fa-chart-line"></i>
                                    <% } else { %>
                                        <i class="fas fa-tv"></i>
                                    <% } %>
                                <% } else { %>
                                    <i class="fas fa-tv"></i>
                                <% } %>
                            </div>
                            <h3><%= program.title || 'Programme TELEX' %></h3>
                            <p><%= program.description ? (program.description.length > 80 ? program.description.substring(0, 80) + '...' : program.description) : 'Découvrez ce programme passionnant.' %></p>
                            <a href="/programs#program-<%= program.id %>" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <!-- Programmes par défaut si aucun programme en base de données -->
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-image">
                                <img src="/images/Débat.png" alt="Le Journal Campus" class="program-img">
                            </div>
                            <h3 data-translate="programs.default.journal_campus.title">Le Journal Campus</h3>
                            <p data-translate="programs.default.journal_campus.description">L'actualité étudiante décryptée chaque semaine.</p>
                            <a href="/programs#journal" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-image">
                                <img src="/images/micro.png" alt="Débat Campus" class="program-img">
                            </div>
                            <h3 data-translate="programs.default.debate_campus.title">Débat Campus</h3>
                            <p data-translate="programs.default.debate_campus.description">Face-à-face d'idées sur les grands sujets de société.</p>
                            <a href="/programs#debat" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-image">
                                <img src="/images/camera.png" alt="Culture Express" class="program-img">
                            </div>
                            <h3 data-translate="programs.default.culture_express.title">Culture Express</h3>
                            <p data-translate="programs.default.culture_express.description">Découverte de la scène culturelle étudiante.</p>
                            <a href="/programs#culture" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-image">
                                <img src="/images/femme telex.png" alt="Telex Sports" class="program-img">
                            </div>
                            <h3 data-translate="programs.default.telex_sports.title">Telex Sports</h3>
                            <p data-translate="programs.default.telex_sports.description">Toute l'actualité sportive universitaire.</p>
                            <a href="/programs#sports" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <div class="program-image">
                                <img src="/images/TELEX INTEGRATION.png" alt="Coulisses" class="program-img">
                            </div>
                            <h3 data-translate="programs.default.behind_scenes.title">Coulisses</h3>
                            <p data-translate="programs.default.behind_scenes.description">Les coulisses de la création audiovisuelle étudiante.</p>
                            <a href="/programs#coulisses" class="program-link" data-translate="common.learn_more">En savoir plus →</a>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Section À propos -->
    <section class="section section-about bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h2 class="section-title" data-translate="home.who_are_we">Qui sommes-nous ?</h2>
                    <p data-translate="home.about_text">
                        Telex est une télévision jeune, dynamique et engagée, 
                        portée par des étudiants et destinée à la jeunesse. 
                        Fondée en 2024, notre équipe compte plus de 50 étudiants 
                        bénévoles passionnés par l'audiovisuel.
                    </p>
                    <ul class="about-list">
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.student_led">100% étudiant</span></li>
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.professional_training">Formation professionnelle</span></li>
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.engaged_content">Contenus engagés</span></li>
                        <li><i class="fas fa-check text-success me-2"></i><span data-translate="home.active_community">Communauté active</span></li>
                    </ul>
                    <a href="/about" class="btn btn-outline-primary" data-translate="home.learn_more">En savoir plus sur nous</a>
                </div>
                <div class="col-lg-6">
                    <img src="https://images.unsplash.com/photo-1523580494863-6f3031224c94?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
                         alt="Studio TELEX" class="img-fluid rounded shadow">
                </div>
            </div>
        </div>
    </section>

    <!-- Section Dernières Actualités -->
    <section class="section section-programs" id="section-news">
        <div class="container">
            <h2 class="section-title" data-translate="home.latest_news">Dernières Actualités</h2>
            <p class="section-subtitle" data-translate="home.news_subtitle">Découvrez nos derniers articles et productions vidéo</p>
            
            <div class="row">
                <% if (news && news.length > 0) { %>
                    <% news.slice(0, 5).forEach((article, index) => { %>
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3 data-translate="news.default.title"><%= article.title.length > 30 ? article.title.substring(0, 30) + '...' : article.title %></h3>
                            <% if (article.image_url) { %>
                                <div class="news-thumbnail">
                                    <img src="<%= article.image_url %>" alt="<%= article.title %>" class="img-fluid rounded">
                                </div>
                            <% } else if (article.video_url) { %>
                                <div class="news-thumbnail">
                                    <video class="img-fluid rounded" controls preload="metadata">
                                        <source src="<%= article.video_url %>" type="video/mp4">
                                        Votre navigateur ne supporte pas les vidéos.
                                    </video>
                                </div>
                            <% } %>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(article.created_at).toLocaleDateString('fr-FR') || new Date().toLocaleDateString('fr-FR') %>
                                </span>
                                <% if (article.category) { %>
                                    <span class="news-category-small">
                                        <i class="fas fa-tag me-1"></i><%= article.category %>
                                    </span>
                                <% } %>
                            </div>
                            <a href="/news/<%= article.id %>" class="program-link" data-translate="common.read_more">Lire la suite →</a>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <!-- Articles par défaut - 5 dernières actualités -->
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Lancement de la nouvelle saison TELEX</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date().toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Information
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Nouveau tournage en cours</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 86400000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Production
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Interview exclusive</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 172800000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Interview
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Formation audiovisuelle</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 259200000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Éducation
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                    
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3>Prix du meilleur média étudiant</h3>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(Date.now() - 345600000).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-tag me-1"></i>Récompense
                                </span>
                            </div>
                            <a href="/news" class="program-link">Lire la suite →</a>
                        </div>
                    </div>
                <% } %>
            </div>
            
            <div class="row mt-4">
                <div class="col-12 text-center">
                    <a href="/news" class="btn btn-primary btn-lg">
                        <i class="fas fa-newspaper me-2"></i>Voir toutes les actualités
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Section Réflexions et Prières -->
    <section class="section section-programs" id="section-baume">
        <div class="container">
            <h2 class="section-title" data-translate="home.baume_title">Baume de la Foi</h2>
            <p class="section-subtitle" data-translate="home.baume_subtitle">Découvrez les derniers contenus spirituels pour nourrir votre foi</p>
            
            <div class="row g-5">
                <% if (reflexions && reflexions.length > 0) { %>
                    <% reflexions.forEach((reflexion, index) => { %>
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3><%= reflexion.title.length > 25 ? reflexion.title.substring(0, 25) + '...' : reflexion.title %></h3>
                            <% if (reflexion.image_url) { %>
                                <div class="news-thumbnail">
                                    <img src="<%= reflexion.image_url %>" alt="<%= reflexion.title %>" class="img-fluid rounded">
                                </div>
                            <% } else if (reflexion.video_url) { %>
                                <div class="news-thumbnail">
                                    <video class="img-fluid rounded" controls preload="metadata">
                                        <source src="<%= reflexion.video_url %>" type="video/mp4">
                                        Votre navigateur ne supporte pas les vidéos.
                                    </video>
                                </div>
                            <% } %>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(reflexion.publication_date || reflexion.created_at).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-lightbulb me-1"></i>Réflexion
                                </span>
                            </div>
                            <a href="/baume-de-la-foi#reflexions" class="program-link" data-translate="common.read_more">Lire la suite →</a>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-12 text-center">
                        <p>Aucune réflexion disponible pour le moment.</p>
                    </div>
                <% } %>
                
                <% if (prieres && prieres.length > 0) { %>
                    <% prieres.forEach((priere, index) => { %>
                    <div class="col-lg-2-4">
                        <div class="program-card">
                            <h3><%= priere.title.length > 25 ? priere.title.substring(0, 25) + '...' : priere.title %></h3>
                            <% if (priere.image_url && priere.image_url.trim() !== '') { %>
                                <div class="news-thumbnail">
                                    <img src="<%= priere.image_url %>" alt="<%= priere.title %>" class="img-fluid rounded">
                                </div>
                            <% } else if (priere.video_url && priere.video_url.trim() !== '') { %>
                                <% 
                                const isVideoFile = /\.(mp4|webm|ogg|mov|avi)$/i.test(priere.video_url);
                                %>
                                <% if (isVideoFile) { %>
                                    <div class="news-thumbnail">
                                        <video class="img-fluid rounded" controls preload="metadata">
                                            <source src="<%= priere.video_url %>" type="video/mp4">
                                            Votre navigateur ne supporte pas les vidéos.
                                        </video>
                                    </div>
                                <% } else { %>
                                    <div class="news-thumbnail">
                                        <img src="<%= priere.video_url %>" alt="<%= priere.title %>" class="img-fluid rounded">
                                    </div>
                                <% } %>
                            <% } else { %>
                                <div class="news-thumbnail">
                                    <img src="/images/Prière.png" alt="Prière par défaut" class="img-fluid rounded">
                                </div>
                            <% } %>
                            <div class="news-meta-small">
                                <span class="news-date-small">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(priere.created_at).toLocaleDateString('fr-FR') %>
                                </span>
                                <span class="news-category-small">
                                    <i class="fas fa-pray me-1"></i>Prière
