    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Script de recherche et interactions -->
    <script>
    // ===== VARIABLES GLOBALES =====
    let imageArticles = [];
    let videoArticles = [];
    let imageCurrentPage = 1;
    let videoCurrentPage = 1;
    let imageTotalPages = 1;
    let videoTotalPages = 1;
    const itemsPerPage = 12; // 12 articles par page pour correspondre à la grille
    let currentSearchTerm = '';
    let searchTimeout = null;
    let showAllArticles = false; // Variable pour gérer "Tout afficher"

    // ===== FONCTIONS GLOBALES UTILITAIRES =====
    
    // Fonction pour optimiser le chargement des images
    window.optimizeImageLoading = function(img) {
        img.loading = 'lazy'; // Chargement différé
        img.decoding = 'async'; // Décodage asynchrone
    };
    
    // Fonction pour gérer les erreurs de chargement d'images
    window.handleImageError = function(img) {
        console.warn('⚠️ Erreur de chargement d\'image:', img.src);
        img.src = '/images/Telex.png'; // Image par défaut
        img.onerror = null; // Éviter les boucles infinies
    };
    
    // Fonction pour gérer les erreurs de chargement de vidéos
    window.handleVideoError = function(video) {
        console.warn('⚠️ Erreur de chargement de vidéo:', video.src);
        video.style.display = 'none';
        
        // Afficher un message d'erreur si nécessaire
        const container = video.closest('.article-image-frame');
        if (container) {
            const errorMsg = document.createElement('div');
            errorMsg.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Erreur de chargement';
            errorMsg.style.cssText = `
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: rgba(230, 57, 70, 0.9);
                color: white;
                padding: 8px 12px;
                border-radius: 8px;
                font-size: 0.8rem;
                text-align: center;
                z-index: 100;
            `;
            container.appendChild(errorMsg);
        }
    };
    
    // Fonction pour gérer les erreurs de chargement d'images de vidéos
    window.handleVideoThumbnailError = function(img) {
        // Utiliser l'image par défaut
        img.src = '/images/Telex.png';
        img.onerror = null; // Éviter les boucles infinies
    };
    
    // ===== FILTRES PAR CATÉGORIE (VERSION OPTIMISÉE DÉJÀ DÉFINIE PLUS HAUT) =====

    // Initialisation principale au chargement de la page
    document.addEventListener('DOMContentLoaded', function() {
        
        // Initialiser le cache DOM
        initDomCache();
        
        // Initialiser les variables globales avec tous les articles
        imageArticles = document.querySelectorAll('.image-article-card');
        videoArticles = document.querySelectorAll('.video-article-card');
        
        
        // Forcer l'affichage de la pagination même au chargement initial
        setTimeout(() => {
            initImagePagination();
            initVideoPagination();
            
            // Forcer l'affichage si plus d'une page (même pour "Tout afficher")
            if (imageArticles.length > 12) {
                const paginationContainer = document.querySelector('#main-image-pagination');
                if (paginationContainer && !paginationContainer.classList.contains('visible')) {
                    paginationContainer.classList.add('visible');
                }
            }
            
            if (videoArticles.length > 12) {
                const paginationContainer = document.querySelector('#main-video-pagination');
                if (paginationContainer && !paginationContainer.classList.contains('visible')) {
                    paginationContainer.classList.add('visible');
                }
            }
        }, 100);
        
        // Préparer les données de recherche
        prepareSearchData();
        
        // Initialiser la recherche
        initSearch();
        
        // Système de rotation des images
        initHeroImageRotation();
        
    });

    // ===== FONCTIONS DE RECHERCHE =====
    function initSearch() {
        const searchInput = document.getElementById('searchInput');
        
        if (searchInput) {
            searchInput.removeAttribute('readonly');
            searchInput.removeAttribute('disabled');
            
            // Recherche en temps réel
            searchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(performSearch, 300);
            });
            
            // Recherche avec Entrée
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    performSearch();
                }
            });
        }
        
        // Préparer les données de recherche
        prepareSearchData();
    }

    function prepareSearchData() {
        // Utiliser les variables globales pour éviter les conflits
        const imageArticlesList = document.querySelectorAll('.image-article-card');
        const videoArticlesList = document.querySelectorAll('.video-article-card');
        
        imageArticlesList.forEach(article => {
            const title = article.querySelector('.article-card-title')?.textContent || '';
            const category = article.querySelector('.article-category-badge')?.textContent || '';
            article.dataset.title = title.toLowerCase();
            article.dataset.category = category.toLowerCase();
        });
        
        videoArticlesList.forEach(article => {
            const title = article.querySelector('.article-card-title')?.textContent || '';
            const category = article.querySelector('.article-category-badge')?.textContent || '';
            article.dataset.title = title.toLowerCase();
            article.dataset.category = category.toLowerCase();
        });
    }

    function performSearch() {
        const searchInput = document.getElementById('searchInput');
        if (!searchInput) return;
        
        const searchTerm = searchInput.value.trim().toLowerCase();
        currentSearchTerm = searchTerm;
        
        // Utiliser des noms différents pour éviter les conflits
        const imageArticlesList = document.querySelectorAll('.image-article-card');
        const videoArticlesList = document.querySelectorAll('.video-article-card');
        const allArticles = [...imageArticlesList, ...videoArticlesList];
        const noResults = document.getElementById('noResults');
        
        let visibleCount = 0;
        let imageVisibleCount = 0;
        let videoVisibleCount = 0;
        
        if (searchTerm === '') {
            // Réinitialiser
            allArticles.forEach(article => { article.style.display = 'block'; });
            imageVisibleCount = imageArticlesList.length;
            videoVisibleCount = videoArticlesList.length;
            visibleCount = imageVisibleCount + videoVisibleCount;
            
            document.querySelector('.news-images-section').style.display = 'block';
            document.querySelector('.news-videos-section').style.display = 'block';
            if (noResults) noResults.style.display = 'none';
            return;
        }
        
        // Recherche
        imageArticlesList.forEach(article => {
            const title = article.dataset.title || '';
            const category = article.dataset.category || '';
            
            if (title.includes(searchTerm) || category.includes(searchTerm)) {
                article.style.display = 'block';
                imageVisibleCount++;
            } else {
                article.style.display = 'none';
            }
        });
        
        videoArticlesList.forEach(article => {
            const title = article.dataset.title || '';
            const category = article.dataset.category || '';
            
            if (title.includes(searchTerm) || category.includes(searchTerm)) {
                article.style.display = 'block';
                videoVisibleCount++;
            } else {
                article.style.display = 'none';
            }
        });
        
        visibleCount = imageVisibleCount + videoVisibleCount;
        
        // Afficher/masquer les sections
        document.querySelector('.news-images-section').style.display = imageVisibleCount > 0 ? 'block' : 'none';
        document.querySelector('.news-videos-section').style.display = videoVisibleCount > 0 ? 'block' : 'none';
        
        if (noResults) {
            noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        }
    }

    // Fonction pour gérer les erreurs de chargement d'images
    function handleImageError(img) {
        console.warn('⚠️ Erreur de chargement d\'image:', img.src);
        img.src = '/images/Telex.png'; // Image par défaut
        img.onerror = null; // Éviter les boucles infinies
    }

    // Fonction pour gérer les erreurs de chargement de vidéos
    function handleVideoError(video) {
        console.warn('⚠️ Erreur de chargement de vidéo:', video.src);
        video.style.display = 'none';
        
        // Afficher un message d'erreur si nécessaire
        const container = video.closest('.article-image-frame');
        if (container) {
            const errorMsg = document.createElement('div');
            errorMsg.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Erreur de chargement';
            errorMsg.style.cssText = `
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: rgba(230, 57, 70, 0.9);
                color: white;
                padding: 8px 12px;
                border-radius: 8px;
                font-size: 0.8rem;
                text-align: center;
                z-index: 100;
            `;
            container.appendChild(errorMsg);
        }
    }

    // Fonction pour gérer les erreurs de chargement d'images de vidéos
    function handleVideoThumbnailError(img) {
        // Utiliser l'image par défaut
        img.src = '/images/Telex.png';
        img.onerror = null; // Éviter les boucles infinies
    }

    // Fonction pour optimiser le chargement des images
    function optimizeImageLoading(img) {
        img.loading = 'lazy'; // Chargement différé
        img.decoding = 'async'; // Décodage asynchrone
    }

    // ===== FILTRES PAR CATÉGORIE (VERSION OPTIMISÉE DÉJÀ DÉFINIE PLUS HAUT) =====

    function performAdvancedSearchWithCategory(category) {
        const searchTerm = document.getElementById('searchInput')?.value.toLowerCase().trim() || '';
        const categoryFilter = category; // Utiliser la catégorie passée en paramètre
        const dateFilter = 'all'; // Par défaut
        const sortFilter = 'recent'; // Par défaut
        
        // Utiliser des noms différents pour éviter les conflits
        const imageArticlesList = document.querySelectorAll('.image-article-card');
        const videoArticlesList = document.querySelectorAll('.video-article-card');
        const allArticles = [...imageArticlesList, ...videoArticlesList];
        
        let filteredArticles = [];
        
        // Filtrer par terme
        if (searchTerm) {
            filteredArticles = Array.from(allArticles).filter(article => {
                const title = article.dataset.title || '';
                const category = article.dataset.category || '';
                return title.includes(searchTerm) || category.includes(searchTerm);
            });
        } else {
            filteredArticles = Array.from(allArticles);
        }
        
        
        // Filtrer par catégorie
        if (categoryFilter !== 'all') {
            const normalizedFilter = categoryFilter.toLowerCase().trim();
            
            filteredArticles = filteredArticles.filter(article => {
                const articleCategory = (article.dataset.category || '').toLowerCase().trim();
                return articleCategory === normalizedFilter;
            });
        }
        
        
        // Trier par défaut (plus récent)
        filteredArticles.sort((a, b) => {
            const dateA = new Date(a.querySelector('.article-card-date')?.textContent || 0);
            const dateB = new Date(b.querySelector('.article-card-date')?.textContent || 0);
            return dateB - dateA;
        });
        
        
        // Afficher/Masquer
        allArticles.forEach(article => { article.style.display = 'none'; });
        
        filteredArticles.forEach((article, index) => {
            article.style.display = 'block';
        });
        
        updateSearchStats(filteredArticles.length);
    }

    window.toggleAdvancedSearch = function() {
        const advancedFilters = document.getElementById('advancedFilters');
        if (advancedFilters) {
            advancedFilters.style.display = advancedFilters.style.display === 'none' ? 'block' : 'none';
        }
    };

    function performAdvancedSearch() {
        const searchTerm = document.getElementById('searchInput')?.value.toLowerCase().trim() || '';
        
        
        // Utiliser des noms différents pour éviter les conflits
        const imageArticlesList = document.querySelectorAll('.image-article-card');
        const videoArticlesList = document.querySelectorAll('.video-article-card');
        const allArticles = [...imageArticlesList, ...videoArticlesList];
        
        
        let filteredArticles = [];
        
        // Filtrer par terme de recherche avec gestion d'erreurs
        if (searchTerm && searchTerm.length > 0) {
            filteredArticles = Array.from(allArticles).filter(article => {
                try {
                    const title = (article.dataset.title || '').toLowerCase();
                    const category = (article.dataset.category || '').toLowerCase();
                    const excerpt = (article.dataset.excerpt || '').toLowerCase();
                    
                    // Recherche dans titre, catégorie et extrait
                    return title.includes(searchTerm) || 
                           category.includes(searchTerm) || 
                           excerpt.includes(searchTerm);
                } catch (error) {
                    return false;
                }
            });
        } else {
            // Si pas de recherche, afficher tous les articles
            filteredArticles = Array.from(allArticles);
        }
        
        
        // Afficher les articles filtrés
        allArticles.forEach(article => {
            article.style.display = 'none';
        });
        
        filteredArticles.forEach(article => {
            article.style.display = 'block';
        });
        
        try {
            // Animation d'apparition progressive
            filteredArticles.forEach((article, index) => {
                article.style.opacity = '0';
                article.style.transform = 'translateY(20px)';
                
                setTimeout(() => {
                    article.style.opacity = '1';
                    article.style.transform = 'translateY(0)';
                }, index * 50);
            });
        } catch (error) {
            // Fallback simple en cas d'erreur
            allArticles.forEach(article => { article.style.display = 'none'; });
            filteredArticles.forEach(article => { article.style.display = 'block'; });
        }
        
        updateSearchStats(filteredArticles.length);
    }

    function updateSearchStats(count) {
        const searchStats = document.getElementById('searchStats');
        const resultsCount = document.getElementById('resultsCount');
        
        if (searchStats && resultsCount) {
            searchStats.style.display = count > 0 ? 'flex' : 'none';
            resultsCount.textContent = count;
        }
    }

    // ===== FONCTIONS DE RECHERCHE UTILITAIRES =====
    window.resetSearch = function() {
        const searchInput = document.getElementById('searchInput');
        if (searchInput) searchInput.value = '';
        
        // Réinitialiser les boutons de catégorie
        document.querySelectorAll('.category-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        
        // Activer le bouton "Tout afficher"
        const allBtn = document.querySelector('.category-btn[data-category="all"]');
        if (allBtn) {
            allBtn.classList.add('active');
        }
        
        // Afficher tous les articles
        const imageArticles = document.querySelectorAll('.image-article-card');
        const videoArticles = document.querySelectorAll('.video-article-card');
        const allArticles = [...imageArticles, ...videoArticles];
        
        allArticles.forEach(article => { article.style.display = 'block'; });
        
        // Masquer les stats de recherche
        const searchStats = document.getElementById('searchStats');
        if (searchStats) searchStats.style.display = 'none';
        
        if (searchInput) searchInput.focus();
    };

    window.clearSearch = function() {
        resetSearch();
    };

    // Fonction "Tout afficher" - affiche tous les articles avec pagination séparée
    window.showAllArticles = function() {
        showAllArticles = true;
        imageCurrentPage = 1; // Réinitialiser à la première page
        videoCurrentPage = 1; // Réinitialiser à la première page
        
        
        // Mettre à jour les variables globales avec les articles actuels
        imageArticles = document.querySelectorAll('.image-article-card');
        videoArticles = document.querySelectorAll('.video-article-card');
        
        // Réinitialiser les paginations
        initImagePagination();
        initVideoPagination();
        
        // Mettre à jour l'état des boutons
        document.querySelectorAll('.category-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        
        const allBtn = document.querySelector('.category-btn[data-category="all"]');
        if (allBtn) {
            allBtn.classList.add('active');
        }
        
        // Afficher les deux sections
        const imageSection = document.querySelector('.news-images-section');
        const videoSection = document.querySelector('.news-videos-section');
        if (imageSection) imageSection.style.display = 'block';
        if (videoSection) videoSection.style.display = 'block';
        
        // Afficher/masquer les paginations selon le nombre d'articles
        const imagePaginationContainer = document.querySelector('.carousel-pagination');
        const videoPaginationContainer = document.querySelector('.video-carousel-pagination');
        
        if (imagePaginationContainer) {
            imagePaginationContainer.style.display = imageArticles.length > 0 ? 'flex' : 'none';
        }
        
        if (videoPaginationContainer) {
            videoPaginationContainer.style.display = videoArticles.length > 3 ? 'flex' : 'none';
        }
        
        resetSearch();
    };

    // ===== PAGINATION =====
    function initImagePagination() {
        imageArticles = document.querySelectorAll('.image-article-card');
        
        if (imageArticles.length === 0) {
            return;
        }
        
        // Réinitialiser à la première page
        imageCurrentPage = 1;
        imageTotalPages = Math.ceil(imageArticles.length / itemsPerPage);
        
        
        // Masquer toutes les autres paginations potentielles
        document.querySelectorAll('.carousel-pagination').forEach(el => {
            if (el.id !== 'main-image-pagination') {
                el.style.display = 'none';
            }
        });
        
        // Afficher la première page
        displayImagePage();
        
        // Afficher la pagination seulement si plus d'une page
        if (imageTotalPages > 1) {
            const paginationContainer = document.querySelector('#main-image-pagination');
            if (paginationContainer) {
                paginationContainer.classList.add('visible');
            }
        } else {
        }
    }

    function initVideoPagination() {
        videoArticles = document.querySelectorAll('.video-article-card');
        
        if (videoArticles.length === 0) {
            return;
        }
        
        // Réinitialiser à la première page
        videoCurrentPage = 1;
        videoTotalPages = Math.ceil(videoArticles.length / itemsPerPage);
        
        
        // Masquer toutes les autres paginations potentielles
        document.querySelectorAll('.video-carousel-pagination').forEach(el => {
            if (el.id !== 'main-video-pagination') {
                el.style.display = 'none';
            }
        });
        
        // Afficher la première page
        displayVideoPage();
        
        // Afficher la pagination seulement si plus d'une page
        if (videoTotalPages > 1) {
            const paginationContainer = document.querySelector('#main-video-pagination');
            if (paginationContainer) {
                paginationContainer.classList.add('visible');
            }
        } else {
        }
    }

    window.changeImagePage = function(direction) {
        const totalPages = Math.ceil(imageArticles.length / itemsPerPage);
        
        if (direction === -1 && imageCurrentPage > 1) {
            imageCurrentPage--;
        } else if (direction === 1 && imageCurrentPage < totalPages) {
            imageCurrentPage++;
        } else {
            return;
        }
        
        displayImagePage();
    };

    window.changeVideoPage = function(direction) {
        const totalPages = Math.ceil(videoArticles.length / itemsPerPage);
        
        if (direction === -1 && videoCurrentPage > 1) {
            videoCurrentPage--;
        } else if (direction === 1 && videoCurrentPage < totalPages) {
            videoCurrentPage++;
        } else {
            return;
        }
        
        displayVideoPage();
    };

    function displayImagePage() {
        const startIndex = (imageCurrentPage - 1) * itemsPerPage;
        const endIndex = Math.min(startIndex + itemsPerPage, imageArticles.length);
        
        
        // Masquer tous les articles
        imageArticles.forEach(article => { 
            article.style.display = 'none'; 
        });
        
        // Afficher les articles de la page actuelle
        for (let i = startIndex; i < endIndex; i++) {
            if (imageArticles[i]) {
                imageArticles[i].style.display = 'block';
                // Animation d'apparition progressive
                setTimeout(() => {
                    imageArticles[i].style.opacity = '0';
                    imageArticles[i].style.transform = 'translateY(20px)';
                    setTimeout(() => {
                        imageArticles[i].style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                        imageArticles[i].style.opacity = '1';
                        imageArticles[i].style.transform = 'translateY(0)';
                    }, 50);
                }, (i - startIndex) * 50);
            }
        }
        
        updateImagePagination();
    }

    function displayVideoPage() {
        const startIndex = (videoCurrentPage - 1) * itemsPerPage;
        const endIndex = Math.min(startIndex + itemsPerPage, videoArticles.length);
        
        
        // Masquer toutes les vidéos
        videoArticles.forEach(article => { 
            article.style.display = 'none'; 
        });
        
        // Afficher les vidéos de la page actuelle
        for (let i = startIndex; i < endIndex; i++) {
            if (videoArticles[i]) {
                videoArticles[i].style.display = 'block';
                // Animation d'apparition progressive
                setTimeout(() => {
                    videoArticles[i].style.opacity = '0';
                    videoArticles[i].style.transform = 'translateY(20px)';
                    setTimeout(() => {
                        videoArticles[i].style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                        videoArticles[i].style.opacity = '1';
                        videoArticles[i].style.transform = 'translateY(0)';
                    }, 50);
                }, (i - startIndex) * 50);
            }
        }
        
        updateVideoPagination();
    }
        
    function updateImagePagination() {
        const totalPages = Math.ceil(imageArticles.length / itemsPerPage);
        
        
        // Debug: vérifier TOUS les éléments de pagination dans le DOM
        const allImagePaginations = document.querySelectorAll('.carousel-pagination');
        
        // Debug: vérifier si les éléments existent dans le DOM
        const paginationContainer = document.querySelector('#main-image-pagination');
        
        const currentPageEl = document.getElementById('imageCurrentPage');
        const totalPagesEl = document.getElementById('imageTotalPages');
        const prevBtn = document.getElementById('imagePrevBtn');
        const nextBtn = document.getElementById('imageNextBtn');
        
        
        if (!currentPageEl || !totalPagesEl || !prevBtn || !nextBtn) {
            // Forcer l'affichage du container si besoin
            if (paginationContainer) {
                paginationContainer.style.display = 'flex';
            }
            return;
        }
        
        currentPageEl.textContent = imageCurrentPage;
        totalPagesEl.textContent = totalPages;
        
        prevBtn.disabled = imageCurrentPage === 1;
        prevBtn.classList.toggle('disabled', imageCurrentPage === 1);
        
        nextBtn.disabled = imageCurrentPage === totalPages;
        nextBtn.classList.toggle('disabled', imageCurrentPage === totalPages);
        
    }

    function updateVideoPagination() {
        const totalPages = Math.ceil(videoArticles.length / itemsPerPage);
        
        const currentPageEl = document.getElementById('videoCurrentPage');
        const totalPagesEl = document.getElementById('videoTotalPages');
        const prevBtn = document.getElementById('videoPrevBtn');
        const nextBtn = document.getElementById('videoNextBtn');
        
        if (!currentPageEl || !totalPagesEl || !prevBtn || !nextBtn) return;
        
        currentPageEl.textContent = videoCurrentPage;
        totalPagesEl.textContent = totalPages;
        
        prevBtn.disabled = videoCurrentPage === 1;
        nextBtn.disabled = videoCurrentPage === totalPages;
    }

    // ===== ROTATION DES IMAGES HERO =====
    function initHeroImageRotation() {
        const leftImages = [
            '/images/11.png',
            '/images/2.png',
            '/images/3.png',
            '/images/4.png',
            '/images/5.png',
            '/images/Telex.png'
        ];
        
        const rightImages = [
            '/images/Telex.png',
            '/images/Telex11.png',
            '/images/11.png',
            '/images/logo ensemble.png',
            '/images/ensemble telex.png',
            '/images/TELEX BAREA.png'
        ];
        
        let leftImageIndex = 0;
        let rightImageIndex = 0;
        const heroLeftImage = document.getElementById('heroLeftImage');
        const heroRightImage = document.getElementById('heroRightImage');
        
        if (heroLeftImage && heroRightImage) {
            function changeLeftImage() {
                leftImageIndex = (leftImageIndex + 1) % leftImages.length;
                heroLeftImage.style.opacity = '0.3';
                
                setTimeout(() => {
                    heroLeftImage.src = leftImages[leftImageIndex];
                    heroLeftImage.style.opacity = '0.8';
                }, 500);
            }
            
            function changeRightImage() {
                rightImageIndex = (rightImageIndex + 1) % rightImages.length;
                heroRightImage.style.opacity = '0.3';
                
                setTimeout(() => {
                    heroRightImage.src = rightImages[rightImageIndex];
                    heroRightImage.style.opacity = '0.8';
                }, 500);
            }
            
            setInterval(changeLeftImage, 20000);
            setInterval(changeRightImage, 25000);
        }
    }
</script>
</body>
</html>