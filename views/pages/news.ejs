                                                        </div>
                                                        <!-- Timer 5 secondes -->
                                                        <div class="video-timer-5s">0:05</div>
                                                    </div>
                                                    <!-- Vidéo complète cachée -->
                                                    <iframe 
                                                        src="https://www.youtube.com/embed/<%= videoInfo.videoId %>?autoplay=1&mute=1&controls=1&showinfo=0&rel=0&modestbranding=1"
                                                        frameborder="0"
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                        allowfullscreen
                                                        class="video-embed-direct"
                                                        style="display: none;">
                                                    </iframe>
                                                </div>
                                            <% } else if (videoInfo.type === 'vimeo') { %>
                                                <!-- Preview 5 secondes Vimeo -->
                                                <div class="video-with-preview">
                                                    <!-- Mini-vidéo preview 5s en boucle -->
                                                    <div class="video-preview-5s">
                                                        <iframe 
                                                            src="https://player.vimeo.com/video/<%= videoInfo.videoId %>?autoplay=1&muted=1&controls=0&byline=0&portrait=0&title=0&loop=1&background=1#t=0,5"
                                                            frameborder="0"
                                                            allow="autoplay; fullscreen; picture-in-picture"
                                                            class="video-preview-iframe">
                                                        </iframe>
                                                        <!-- Overlay play cliquable -->
                                                        <div class="video-play-overlay-5s" 
                                                             onclick="this.parentElement.style.display='none'; this.parentElement.nextElementSibling.style.display='block';">
                                                            <i class="fas fa-play"></i>
                                                            <span>Lire la vidéo complète</span>
                                                        </div>
                                                        <!-- Badge plateforme -->
                                                        <div class="video-platform-badge">
                                                            <i class="fas fa-video"></i>
                                                            <span><%= videoInfo.platform %></span>
                                                        </div>
                                                        <!-- Timer 5 secondes -->
                                                        <div class="video-timer-5s">0:05</div>
                                                    </div>
                                                    <!-- Vidéo complète cachée -->
                                                    <iframe 
                                                        src="https://player.vimeo.com/video/<%= videoInfo.videoId %>?autoplay=1&muted=1&byline=0&portrait=0&title=0"
                                                        frameborder="0"
                                                        allow="autoplay; fullscreen; picture-in-picture"
                                                        allowfullscreen
                                                        class="video-embed-direct"
                                                        style="display: none;">
                                                    </iframe>
                                                </div>
                                            <% } else if (videoInfo.type === 'uploaded' || videoInfo.type === 'direct') { %>
                                                <!-- Preview 5 secondes vidéo uploadée -->
                                                <div class="video-with-preview">
                                                    <!-- Mini-vidéo preview 5s en boucle -->
