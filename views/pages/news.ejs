        /* ===== CORRECTIONS CRITIQUES DES 5 PROBLÈMES PRINCIPAUX ===== */
        
        /* 1. HIÉRARCHIE CLAIRE DES Z-INDEX */
        .news-section { z-index: 1; }
        .articles-carousel { z-index: 2; }
        .news-article-card { z-index: 3; }
        .article-image-frame { z-index: 4; }
        .article-image-container { z-index: 5; }
        .article-category-badge { z-index: 100; }
        .video-overlay-small { z-index: 50; }
        .video-platform-badge { z-index: 60; }
        .video-lightbox { z-index: 9999; }
        
        /* ===== VARIABLES CSS POUR LES CARTES ===== */
        :root {
            --card-image-height: 180px;
            --card-video-height: 200px;
        }

        /* ===== AMÉLIORATION DES CARTES D'ARTICLES - TITRE EN BAS DE L'IMAGE ===== */
        .news-article-card {
            position: relative;
            background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%); /* Fond subtil */
            border: 1px solid rgba(0,0,0,0.05); /* Bordure subtile */
            border-radius: 16px; /* Coins plus arrondis */
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.08); /* Ombre portée moderne */
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); /* Transition fluide */
            height: auto;
            display: flex;
            flex-direction: column; /* Structure verticale : image en haut, titre en bas */
            align-items: stretch;
            margin-bottom: 24px; /* Plus d'espace entre les cartes */
            cursor: pointer;
        }

        /* Effet de survol moderne */
        .news-article-card:hover {
            transform: translateY(-8px) scale(1.02); /* Lévèvement et zoom subtils */
            box-shadow: 0 16px 48px rgba(0,0,0,0.18), 0 4px 16px rgba(0,0,0,0.12); /* Ombre portée accentuée */
            border-color: rgba(0,0,0,0.1); /* Bordure visible au survol */
        }

        /* Conteneur de l'image/vidéo - en haut de la carte */
        .article-image-frame {
            position: relative;
            overflow: hidden;
            width: 100%;
            height: 300px;
            flex-shrink: 0;
            border-radius: 16px 16px 0 0;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.06);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Effet au survol sur le conteneur image */
        .news-article-card:hover .article-image-frame {
            transform: scale(1.02); /* Zoom subtil au survol */
            box-shadow: inset 0 2px 6px rgba(0,0,0,0.1); /* Ombre intérieure accentuée */
        }

        .article-image-container {
            position: relative;
            width: 100%;
            height: 100%;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Image de l'article - remplit tout le conteneur en haut */
        .article-image {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
            object-fit: contain;
            object-position: center;
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 16px 16px 0 0;
            display: block;
            filter: brightness(1.05) contrast(1.1);
        }

        /* Effet au survol sur l'image */
        .news-article-card:hover .article-image {
            transform: scale(1.05); /* Zoom subtil */
            filter: brightness(1.1) contrast(1.2) saturate(1.2); /* Amélioration des couleurs au survol */
        }

        /* Overlay pour les images */
        .image-overlay-small {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.7);
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        /* Overlay pour les vidéos */
        .video-overlay-small {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(230, 57, 70, 0.9);
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            opacity: 0.95;
            transition: all 0.3s ease;
        }

        .video-overlay-small:hover {
            transform: translate(-50%, -50%) scale(1.1);
            background: rgba(230, 57, 70, 1);
        }

        /* Contenu de la carte - en bas de l'image */
        .article-card-content {
            flex: 1;
            padding: 20px 24px; /* Padding plus généreux */
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            background: linear-gradient(135deg, rgba(255,255,255,0.9) 0%, rgba(248,249,250,0.95) 100%); /* Fond subtil */
            position: relative;
            overflow: hidden;
        }

        /* Ligne décorative subtile */
        .article-card-content::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.05) 50%, transparent 100%);
        }

        /* Titre de l'article - design moderne */
        .article-card-title {
            font-size: 1.15rem; /* Police légèrement plus grande */
            font-weight: 700; /* Plus gras */
            color: #1a1a2e; /* Couleur plus foncée pour meilleur contraste */
            line-height: 1.3; /* Ligne plus serrée */
            margin: 0 0 12px 0;
            display: -webkit-box;
            display: -moz-box;
            display: box;
            -webkit-line-clamp: 2;
            -moz-line-clamp: 2;
            line-clamp: 2;
            -webkit-box-orient: vertical;
            -moz-box-orient: vertical;
            box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
            min-height: 2.8em;
            position: relative;
            transition: all 0.3s ease;
            text-shadow: 0 1px 2px rgba(0,0,0,0.1); /* Ombre de texte subtile */
        }

        /* Effet au survol sur le titre */
        .news-article-card:hover .article-card-title {
            color: #0953b6; /* Couleur bleue au survol */
            transform: translateY(-2px); /* Légère élévation */
        }

        /* Badge de catégorie - positionné sur le côté gauche de l'image */
        .article-category-badge {
            position: absolute;
            top: 8px;
            left: 8px; /* Positionné en haut à gauche de l'image */
            display: inline-flex;
            align-items: center;
            gap: 2px; /* Espacement réduit */
            padding: 2px 6px; /* Padding réduit */
            border-radius: 12px; /* Plus arrondi mais plus petit */
            font-size: 0.45rem; /* Taille de police réduite */
            font-weight: 600; /* Un peu moins gras */
            text-transform: uppercase;
            letter-spacing: 0.5px; /* Espacement réduit */
            color: white;
            background: linear-gradient(135deg, rgba(230, 57, 70, 0.95) 0%, rgba(220, 53, 69, 0.98) 100%); /* Dégradé subtil */
            box-shadow: 0 2px 6px rgba(230, 57, 70, 0.3), 0 1px 2px rgba(0,0,0,0.1); /* Ombre portée réduite */
            border: 1px solid rgba(255,255,255,0.2); /* Bordure subtile */
            z-index: 10; /* Assure qu'il est au-dessus de l'image */
            position: relative;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: default;
        }

        /* Effet de brillance subtil avec :after */
        .article-category-badge::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s ease;
        }

        /* Effet au survol sur le badge - adapté à la taille réduite */
