<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Actualités - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    <style>
        /* PAGE ACTUALITÉS */
        .news-page {
            padding: 100px 0 60px;
            background: #f8f9fa;
        }
        .page-header { text-align: center; margin-bottom: 50px; }
        .page-header h1 { color: #1D3557; font-weight: 700; margin-bottom: 15px; }
        .page-header p { color: #6c757d; font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

        /* CAROUSEL */
        .articles-carousel { position: relative; margin: 0 auto 60px; max-width: 1200px; overflow: hidden; }
        .carousel-track { display: flex; transition: transform 0.5s ease; gap: 30px; padding: 10px 5px; }

        /* CARTE ARTICLE */
        .article-card {
            flex: 0 0 calc(33.333% - 20px);
            min-width: calc(33.333% - 20px);
            background: white; border-radius: 10px; overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            transition: all 0.3s ease; cursor: pointer; display: flex; flex-direction: column;
        }
        .article-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.12); }
        .article-image { height: 140px; overflow: hidden; position: relative; background: #f8f9fa; }
        .article-image img { width: 100% !important; height: 100% !important; object-fit: cover !important; border-radius: 10px 10px 0 0 !important; transition: transform 0.5s ease !important; }
        .article-card:hover .article-image img { transform: scale(1.05) !important; }
        .image-placeholder {
            height: 100%; background: linear-gradient(135deg, #457B9D, #1D3557);
            display: flex; align-items: center; justify-content: center; color: white; border-radius: 10px 10px 0 0;
        }
        .category-badge {
            position: absolute; top: 15px; left: 15px; background: #E63946; color: white;
            padding: 6px 15px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; z-index: 2;
        }
        .article-title {
            padding: 20px; font-size: 1.2rem; font-weight: 600; color: #1D3557; text-align: center;
            line-height: 1.4; flex-grow: 1; display: flex; align-items: center; justify-content: center; transition: color 0.3s ease;
        }
        .article-card:hover .article-title { color: #E63946; }

        /* PAGINATION */
        .carousel-pagination { display: flex; justify-content: center; gap: 10px; margin-top: 40px; }
        .pagination-dot { width: 12px; height: 12px; border-radius: 50%; background: #ddd; cursor: pointer; transition: all 0.3s ease; border: none; padding: 0; }
        .pagination-dot.active { background: #E63946; transform: scale(1.2); }

        /* BOUTONS NAV */
        .carousel-nav { display: flex; justify-content: center; gap: 20px; margin-top: 30px; }
        .nav-btn {
            width: 50px; height: 50px; border-radius: 50%; background: white; border: 2px solid #1D3557; color: #1D3557;
            display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.3s ease; font-size: 1.2rem;
        }
        .nav-btn:hover { background: #1D3557; color: white; }
        .nav-btn.disabled { opacity: 0.3; cursor: not-allowed; }

        /* NEWSLETTER */
        .newsletter-box { background: white; border-radius: 10px; padding: 40px; box-shadow: 0 5px 15px rgba(0,0,0,0.08); text-align: center; max-width: 600px; margin: 60px auto 0; }

        /* MESSAGE VIDE */
        .no-articles { text-align: center; padding: 60px 20px; }
        .no-articles i { font-size: 3.5rem; color: #dee2e6; margin-bottom: 20px; }

        /* RESPONSIVE */
        @media (max-width: 992px) { .article-card { flex: 0 0 calc(50% - 15px); min-width: calc(50% - 15px); } }
        @media (max-width: 768px) {
            .news-page { padding: 80px 0 40px; }
            .article-card { flex: 0 0 100%; min-width: 100%; }
            .article-image { height: 200px; }
        }
    </style>
</head>
<body class="news-page" data-page="news">
    
    <!-- Script de définition des fonctions globales (doit être chargé en premier) -->
    <script>
    // Définir toutes les fonctions globales immédiatement pour éviter les erreurs "not defined"
    
    // Fonctions de gestion des images
    window.optimizeImageLoading = function(img) {
        if (img) {
            img.loading = 'lazy';
            img.decoding = 'async';
        }
    };
    
    window.handleImageError = function(img) {
        if (img) {
                img.src = '/images/Telex.png';
            img.onerror = null;
        }
    };
    
    // Fonctions de gestion des vidéos
    window.handleVideoError = function(video) {
        if (video) {
                video.style.display = 'none';
            
            const container = video.closest('.article-image-frame');
            if (container) {
                const errorMsg = document.createElement('div');
                errorMsg.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Erreur de chargement';
                errorMsg.style.cssText = `
                    position: absolute;
                    top: 50%;
                    left: 50%;
                    transform: translate(-50%, -50%);
                    background: rgba(230, 57, 70, 0.9);
                    color: white;
                    padding: 8px 12px;
                    border-radius: 8px;
                    font-size: 0.8rem;
                    text-align: center;
                    z-index: 100;
                `;
                container.appendChild(errorMsg);
            }
        }
    };
    
    window.handleVideoThumbnailError = function(img) {
        if (img) {
                img.src = '/images/Telex.png';
            img.onerror = null;
        }
    };
    
    // Cache des éléments DOM pour éviter les requêtes répétées
    let domCache = {
        categoryBtns: null,
        imageArticles: null,
        videoArticles: null,
        imageSection: null,
        videoSection: null,
        imagePagination: null,
        videoPagination: null
    };
    
    // Initialiser le cache DOM
    function initDomCache() {
        domCache.categoryBtns = document.querySelectorAll('.category-btn');
        domCache.imageArticles = document.querySelectorAll('.image-article-card');
        domCache.videoArticles = document.querySelectorAll('.video-article-card');
        domCache.imageSection = document.querySelector('.news-images-section');
        domCache.videoSection = document.querySelector('.news-videos-section');
        domCache.imagePagination = document.querySelector('.carousel-pagination');
        domCache.videoPagination = document.querySelector('.video-carousel-pagination');
    }
    
    // Fonctions de filtrage et pagination optimisées
    window.filterByCategory = function(category) {
        
        // Utiliser le cache si disponible, sinon initialiser
        if (!domCache.categoryBtns) initDomCache();
        
        // Mettre à jour l'état actif des boutons (optimisé)
        domCache.categoryBtns.forEach(btn => {
            btn.classList.remove('active');
        });
        
        const activeBtn = document.querySelector(`.category-btn[data-category="${category}"]`);
        if (activeBtn) {
            activeBtn.classList.add('active');
        }
        
        if (category === 'all') {
            if (domCache.imageSection) domCache.imageSection.style.display = 'block';
            if (domCache.videoSection) domCache.videoSection.style.display = 'block';
            
            // Afficher tous les articles (optimisé)
            domCache.imageArticles.forEach(article => article.style.display = 'block');
            domCache.videoArticles.forEach(article => article.style.display = 'block');
            
            updatePaginationForFilteredArticles('all');
        } else {
            // Filtrer par catégorie (optimisé)
            const normalizedCategory = category.toLowerCase();
            
            domCache.imageArticles.forEach(article => {
                const articleCategory = (article.dataset.category || '').trim();
                const shouldShow = articleCategory === normalizedCategory;
                article.style.display = shouldShow ? 'block' : 'none';
            });
            
            domCache.videoArticles.forEach(article => {
                const articleCategory = (article.dataset.category || '').trim();
                article.style.display = articleCategory === normalizedCategory ? 'block' : 'none';
            });
            
            updatePaginationForFilteredArticles(category);
        }
    };
    
    // Fonction pour mettre à jour la pagination selon les articles filtrés (optimisée)
    function updatePaginationForFilteredArticles(category) {
        // Récupérer les articles visibles (optimisé)
        const visibleImageArticles = Array.from(domCache.imageArticles).filter(article => 
            article.style.display !== 'none'
        );
        const visibleVideoArticles = Array.from(domCache.videoArticles).filter(article => 
            article.style.display !== 'none'
        );
        
        
        // Réinitialiser les pages à 1 quand on filtre
        imageCurrentPage = 1;
        videoCurrentPage = 1;
        
        // Mettre à jour les variables globales
        imageArticles = visibleImageArticles;
        videoArticles = visibleVideoArticles;
        
        // Mettre à jour la pagination des images
        if (domCache.imagePagination) {
            if (visibleImageArticles.length > 0) {
                domCache.imagePagination.classList.add('visible');
                const totalPages = Math.ceil(visibleImageArticles.length / 12);
                imageTotalPages = totalPages;
                const currentPageEl = document.getElementById('imageCurrentPage');
                const totalPagesEl = document.getElementById('imageTotalPages');
                if (currentPageEl) currentPageEl.textContent = '1';
                if (totalPagesEl) totalPagesEl.textContent = totalPages;
            } else {
                domCache.imagePagination.classList.remove('visible');
            }
        }
        
        // Mettre à jour la pagination des vidéos
        if (domCache.videoPagination) {
            if (visibleVideoArticles.length > 0) {
                domCache.videoPagination.classList.add('visible');
                const totalPages = Math.ceil(visibleVideoArticles.length / 12);
                videoTotalPages = totalPages;
                const currentPageEl = document.getElementById('videoCurrentPage');
                const totalPagesEl = document.getElementById('videoTotalPages');
                if (currentPageEl) currentPageEl.textContent = '1';
                if (totalPagesEl) totalPagesEl.textContent = totalPages;
            } else {
                domCache.videoPagination.classList.remove('visible');
            }
        }
        
        // Afficher/masquer les sections selon les résultats
        if (domCache.imageSection) domCache.imageSection.style.display = visibleImageArticles.length > 0 ? 'block' : 'none';
        if (domCache.videoSection) domCache.videoSection.style.display = visibleVideoArticles.length > 0 ? 'block' : 'none';
    }
    
    // Fonctions de pagination (définies plus bas dans le code)
    
    window.showAllArticles = function() {
        filterByCategory('all');
    };
    
    // Fonctions de recherche
    window.performSearch = function() {
        // Fonction de recherche à implémenter
    };
    
    window.performAdvancedSearch = function() {
        // Fonction de recherche avancée à implémenter
    };
    
    window.clearSearch = function() {
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.value = '';
            filterByCategory('all');
        }
    };
    
    </script>
    <%- include('../partials/navbar') %>
    
    <section class="page-hero">
        <!-- Image décorative gauche -->
        <div class="hero-side-image hero-left-image">
            <img id="heroLeftImage" src="/images/11.png" alt="Logo Telex">
        </div>
        
        <!-- Image décorative droite -->
        <div class="hero-side-image hero-right-image">
            <img id="heroRightImage" src="/images/Telex.png" alt="Telex">
        </div>
        
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-4 col-md-5 mb-4 mb-md-0">
                    <div class="hero-image-wrapper">
                        <img src="/images/Présentation telex.png" alt="Présentation Telex" class="hero-camera-img" loading="lazy">
                    </div>
                </div>
                <div class="col-lg-8 col-md-7 text-center">
                    <h1 class="hero-title" style="color: #fff;">
                        Telex
                    </h1>
                    <p class="hero-subtitle" style="color: rgba(255, 255, 255, 0.95);">Découvrer les derniere actualité de notre television étudiant et media numerique</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Barre de navigation avec catégories et recherche -->
    <section class="navigation-bar">
        <div class="container">
            <div class="nav-content">
                <!-- Boutons de catégories rapides -->
                <div class="category-nav">
                    <div class="category-buttons-grid">
                        <button class="category-btn" data-category="politique" onclick="filterByCategory('politique')">
                            <i class="fas fa-landmark me-1"></i>Politique
                        </button>
                        <button class="category-btn" data-category="economie" onclick="filterByCategory('economie')">
                            <i class="fas fa-chart-line me-1"></i>Économie
                        </button>
                        <button class="category-btn" data-category="social" onclick="filterByCategory('social')">
                            <i class="fas fa-users me-1"></i>Social
                        </button>
                        <button class="category-btn" data-category="sport" onclick="filterByCategory('sport')">
                            <i class="fas fa-football-ball me-1"></i>Sport
                        </button>
                        <button class="category-btn" data-category="culturel" onclick="filterByCategory('culturel')">
                            <i class="fas fa-palette me-1"></i>Culturel
                        </button>
                        <button class="category-btn" data-category="annonce" onclick="filterByCategory('annonce')">
                            <i class="fas fa-bullhorn me-1"></i>Annonce
                        </button>
                        <button class="category-btn" data-category="autre" onclick="filterByCategory('autre')">
                            <i class="fas fa-ellipsis-h me-1"></i>Autre
                        </button>
                        <button class="category-btn category-btn-all" data-category="all" onclick="filterByCategory('all')">
                            <i class="fas fa-th me-1"></i>Tout afficher
                        </button>
                    </div>
                </div>
                
                <!-- Barre de recherche intégrée -->
                <div class="search-nav">
                    <div class="search-input-wrapper">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" 
                               id="searchInput" 
                               class="search-input" 
                               placeholder="Rechercher..." 
                               autocomplete="off"
                               spellcheck="false"
                               onkeyup="performAdvancedSearch()">
                        <button class="search-clear-btn" onclick="clearSearch()" style="display: none;">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="search-stats" id="searchStats" style="display: none;">
                <span class="stats-text">
                    <i class="fas fa-chart-bar me-1"></i>
                    <span id="resultsCount">0</span> résultat(s) trouvé(s)
                </span>
                <button class="reset-btn" onclick="resetSearch()">
                    <i class="fas fa-redo me-1"></i>Réinitialiser
                </button>
            </div>
        </div>
    </section>

    <div class="news-content">
        <div class="container">
            <!-- En-tête... -->
            
            <% 
            // Séparer les actualités : celles avec images vs celles avec vidéos
            const imageArticles = news.filter(article => !article.video_url && article.image_url);
            const videoArticles = news.filter(article => article.video_url);
            %>
            
            <% if (imageArticles && imageArticles.length > 0) { %>
            <section class="news-section news-images-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-image me-2"></i>
                        Actualités Illustrées
                    </h2>
                    <p class="section-subtitle">Découvrez nos dernières actualités avec images</p>
                </div>
                
                <!-- Contenu principal sans annonces latérales -->
                <div class="articles-carousel">
                    <!-- Grille d'articles avec 4 par ligne -->
                    <div class="articles-grid-12" id="imageArticlesGrid">
                        <% imageArticles.forEach(article => { %>
                        <div class="news-article-card image-article-card" 
                             onclick="window.location.href='/news/<%= article.slug %>'"
                             data-article-id="<%= article.id %>"
                             data-title="<%= article.title %>"
                             data-category="<%= (article.category || 'politique').trim().toLowerCase() %>"
                             data-debug-slug="<%= article.slug %>"
                             data-debug-id="<%= article.id %>">
                            
                            <!-- Image avec design inspiré des vidéos -->
                            <div class="article-image-frame">
                                <div class="article-image-container">
                                    <!-- Conteneur thumbnail style vidéo -->
                                    <div class="image-thumbnail-container">
                                        <!-- Image de l'article -->
                                        <img src="<%= article.image_url %>" 
                                             alt="<%= article.title %>"
                                             class="article-image"
                                             loading="lazy"
                                             onerror="handleImageError(this)"
                                             onload="optimizeImageLoading(this)">
                                        
                                        <!-- Overlay avec icône image -->
                                        <div class="image-overlay-small">
                                            <i class="fas fa-image"></i>
                                        </div>
                                        
                                        <!-- Badge type masqué -->
                                        <div class="image-type-badge" style="display: none;">
                                            <i class="fas fa-camera"></i>
                                            <span>Photo</span>
                                        </div>
                                    </div>
                                </div>
                                <!-- Badge de catégorie positionné sur l'image -->
                                <span class="article-category-badge" data-category="<%= article.category || 'politique' %>">
                                    <%= article.category || 'politique' %>
                                </span>
                            </div>
                            
                            <div class="article-card-content">
                                <h3 class="article-card-title">
                                    <%= article.title %>
                                </h3>
                                
                                <!-- Résumé d'article pour layout horizontal -->
                                <p class="article-card-excerpt">
                                    <%= article.excerpt || (article.content ? article.content.substring(0, 120) + '...' : '') %>
                                </p>
                                
                                <!-- Date de publication masquée -->
                                <div class="article-card-meta" style="display: none;">
                                    <span class="article-date">
                                        <i class="fas fa-calendar-alt me-1"></i>
                                        <%= new Date(article.created_at).toLocaleDateString('fr-FR') %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                </div>
            </section>
            <% } else { %>
            <section class="news-section news-images-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-image me-2"></i>
                        Actualités Illustrées
                    </h2>
                    <p class="section-subtitle">Aucune actualité avec images pour le moment</p>
                </div>
            </section>
            <% } %>
            
            <!-- Pagination Images - déplacée ici après la section images -->
            <% if (imageArticles && imageArticles.length > 0) { %>
            <div class="container mt-4">
                <div class="row">
                    <div class="col-12">
                        <!-- Texte explicatif pour la pagination des images -->
                        <div class="pagination-info-text text-center mb-4">
                            <div class="archive-intro">
                                <span class="archive-text">Consultez les archives complètes des actualités illustrées - Naviguez à travers toutes nos actualités</span>
                            </div>
                        </div>
                        
                        <div id="main-image-pagination" class="carousel-pagination">
                            <div class="pagination-info">
                                <span>Page</span>
                                <span id="imageCurrentPage">1</span>
                                <span>sur</span>
                                <span id="imageTotalPages">1</span>
                            </div>
                            <div class="pagination-controls">
                                <button id="imagePrevBtn" class="pagination-btn" onclick="changeImagePage(-1)">
                                    <i class="fas fa-chevron-left me-1"></i>
                                    Précédent
                                </button>
                                <button id="imageNextBtn" class="pagination-btn" onclick="changeImagePage(1)">
                                    Suivant
                                    <i class="fas fa-chevron-right ms-1"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>
            
            <!-- SECTION INFÉRIEURE : ACTUALITÉS VIDÉO -->
            <% if (videoArticles && videoArticles.length > 0) { %>
            <section class="news-section news-videos-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-video me-2"></i>
                        Actualités Vidéo
                    </h2>
                    <p class="section-subtitle">Regardez nos dernières actualités en format vidéo</p>
                </div>
                
                <div class="articles-carousel">
                    <!-- Grille d'articles vidéo avec 4 par ligne -->
                    <div class="articles-grid-12" id="videoArticlesGrid">
                        <% videoArticles.forEach(article => { %>
                        <div class="news-article-card video-article-card" 
                             onclick="window.location.href='/news/<%= article.slug %>'"
                             data-video-url="<%= article.video_url || '' %>"
                             data-article-id="<%= article.id %>"
                             data-title="<%= article.title %>"
                             data-debug-slug="<%= article.slug %>"
                             data-debug-id="<%= article.id %>"
                             data-category="<%= (article.category || 'politique').trim().toLowerCase() %>">
                            
                            <!-- Image/Video avec détection automatique -->
                            <div class="article-image-frame">
                                <div class="article-image-container">
                                    <% if (article.video_url) { %>
                                        <!-- Détection automatique de la source vidéo -->
                                        <% 
                                        // Fonction pour gérer les erreurs de chargement d'images
                                        function handleImageError(img) {
                                            img.src = '/images/Telex.png'; // Image par défaut
                                            img.onerror = null; // Éviter les boucles infinies
                                        }

                                        // Fonction pour gérer les erreurs de chargement de vidéos
                                        function handleVideoError(video) {
                                            // Cacher l'élément vidéo en erreur
                                            video.style.display = 'none';
                                            
                                            // Afficher un message d'erreur si nécessaire
                                            const container = video.closest('.article-image-frame');
                                            if (container) {
                                                const errorMsg = document.createElement('div');
                                                errorMsg.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Erreur de chargement';
                                                errorMsg.style.cssText = `
                                                    position: absolute;
                                                    top: 50%;
                                                    left: 50%;
                                                    transform: translate(-50%, -50%);
                                                    background: rgba(230, 57, 70, 0.9);
                                                    color: white;
                                                    padding: 8px 12px;
                                                    border-radius: 8px;
                                                    font-size: 0.8rem;
                                                    text-align: center;
                                                    z-index: 100;
                                                `;
                                                container.appendChild(errorMsg);
                                            }
                                        }

                                        // Fonction pour optimiser le chargement des images
                                        function optimizeImageLoading(img) {
                                            img.loading = 'lazy'; // Chargement différé
                                            img.decoding = 'async'; // Décodage asynchrone
                                        }

                                        // Fonction pour détecter le type de vidéo et générer la thumbnail
                                        function getVideoThumbnail(videoUrl) {
                                            if (!videoUrl) return {
                                                type: 'unknown',
                                                thumbnail: '',
                                                platform: 'Vidéo',
                                                videoId: ''
                                            };
                                            
                                            // YouTube
                                            if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
                                                let videoId = '';
                                                if (videoUrl.includes('youtube.com')) {
                                                    videoId = videoUrl.split('v=')[1]?.split('&')[0] || '';
                                                } else {
                                                    videoId = videoUrl.split('/').pop() || '';
                                                }
                                                return {
                                                    type: 'youtube',
                                                    thumbnail: `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`,
                                                    preview5s: `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`,
                                                    platform: 'YouTube',
                                                    videoId: videoId
                                                };
                                            }
                                            
                                            // Vimeo
                                            else if (videoUrl.includes('vimeo.com')) {
                                                const videoId = videoUrl.split('/').pop();
                                                return {
                                                    type: 'vimeo',
                                                    thumbnail: `https://vumbnail.com/${videoId}.jpg`,
                                                    preview5s: `https://vumbnail.com/${videoId}_large.jpg`,
                                                    platform: 'Vimeo',
                                                    videoId: videoId
                                                };
                                            }
                                            
                                            // Dailymotion
                                            else if (videoUrl.includes('dailymotion.com')) {
                                                const videoId = videoUrl.split('/').pop().split('_')[0];
                                                return {
                                                    type: 'dailymotion',
                                                    thumbnail: `https://www.dailymotion.com/thumbnail/video/${videoId}`,
                                                    platform: 'Dailymotion'
                                                };
                                            }
                                            
                                            // Vidéos uploadées
                                            else if (videoUrl.includes('/uploads/videos/')) {
                                                const videoFileName = videoUrl.split('/').pop();
                                                const thumbnailName = videoFileName.replace(/\.(mp4|webm|ogg|mov|avi|mkv)$/i, '.jpg');
                                                return {
                                                    type: 'uploaded',
                                                    thumbnail: article.image_url || '/images/Telex.png', // Utiliser l'image de l'article comme fallback
                                                    fallback: article.image_url || '/images/Telex.png',
                                                    platform: 'Telex'
                                                };
                                            }
                                            
                                            // Autres sources directes
                                            else if (videoUrl.match(/\.(mp4|webm|ogg|mov|avi|mkv)$/i)) {
                                                return {
                                                    type: 'direct',
                                                    thumbnail: article.image_url || '',
                                                    platform: 'Vidéo'
                                                };
                                            }
                                            
                                            // Sources inconnues
                                            return {
                                                type: 'unknown',
                                                thumbnail: article.image_url || '',
                                                platform: 'Vidéo'
                                            };
                                        }
                                        
                                        const videoInfo = getVideoThumbnail(article.video_url);
                                        %>
                                        
                                        <!-- Conteneur vidéo avec miniature 5 secondes -->
                                        <div class="video-thumbnail-container">
                                            <% if (videoInfo.type === 'youtube') { %>
