    <script>
    // Animation des chiffres - VERSION SIMPLIFIÉE COMPATIBLE CSS GLOBAL
    document.addEventListener('DOMContentLoaded', function() {
        console.log('🚀 Animation chiffres About Page - Version CSS Global');
        
        // Attendre que tout soit chargé
        setTimeout(function() {
            var statItems = document.querySelectorAll('.stat-item');
            var statNumbers = document.querySelectorAll('.stat-number');
            
            console.log('📊 Éléments trouvés:', statItems.length, 'cartes,', statNumbers.length, 'chiffres');
            
            if (statNumbers.length === 0) {
                console.log('❌ Aucun chiffre trouvé');
                return;
            }
            
            // Sauvegarder les valeurs finales
            var finalValues = Array.from(statNumbers).map(el => el.textContent);
            console.log('📋 Valeurs finales:', finalValues);
            
            // Initialiser les chiffres à 0
            statNumbers.forEach(function(element) {
                element.textContent = '0';
            });
            
            // Animation d'apparition des cartes (CSS)
            statItems.forEach(function(item, index) {
                setTimeout(function() {
                    item.classList.add('animate-in');
                    console.log('📋 Carte', index, 'apparue');
                }, index * 200);
            });
            
            // Animation des chiffres après l'apparition des cartes
            setTimeout(function() {
                animateNumbers(statNumbers, finalValues);
            }, 1000);
            
        }, 500);
        
        function animateNumbers(elements, finalValues) {
            console.log('🔢 Début animation des chiffres');
            
            elements.forEach(function(element, index) {
                setTimeout(function() {
                    animateSingleNumber(element, finalValues[index]);
                }, index * 300);
            });
        }
        
        function animateSingleNumber(element, finalText) {
            var isPlus = finalText.includes('+');
            var isK = finalText.includes('K');
            var finalNum = parseInt(finalText.replace(/[^0-9]/g, ''));
            
            if (isK) finalNum = finalNum * 1000;
            
            console.log('🎯 Animation 0 →', finalNum, '(', finalText, ')');
            
            // Ajouter la classe d'animation CSS
            element.classList.add('counting', 'animating');
            
            var current = 0;
            var steps = 40;
            var increment = finalNum / steps;
            var step = 0;
            
            var interval = setInterval(function() {
                step++;
                current = Math.min(increment * step, finalNum);
                
                var display = Math.floor(current);
                if (isK) display = Math.floor(display / 1000) + 'K';
                if (isPlus) display = display + '+';
                
                element.textContent = display;
                
                if (step >= steps) {
                    clearInterval(interval);
                    element.textContent = finalText;
                    element.classList.remove('counting', 'animating');
                    console.log('✅ Animation terminée:', finalText);
                    
                    // Effet de completion
                    element.style.transform = 'scale(1.1)';
                    setTimeout(function() {
                        element.style.transform = 'scale(1)';
                    }, 200);
                }
            }, 50);
        }
    });
    </script>
