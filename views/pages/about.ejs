<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>À Propos - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    <style>
        /* Styles spécifiques à la page About - THÈME BLEU */
        .page-hero {
            padding: 80px 0 40px;
            min-height: 280px;
            background: linear-gradient(135deg, #3498db 0%, #5dade2 100%);
            color: white;
            position: relative;
            overflow: hidden;
        }
        
        .hero-image-wrapper {
            position: relative;
            z-index: 2;
            text-align: center;
            animation: float 6s ease-in-out infinite;
        }
        
        .hero-camera-img {
            width: 100%;
            max-width: 320px;
            height: auto;
            border-radius: 20px;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
            filter: drop-shadow(0 0 20px rgba(52, 152, 219, 0.3));
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .hero-camera-img:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 35px 80px rgba(0, 0, 0, 0.4);
        }
        
        .hero-content-wrapper {
            position: relative;
            z-index: 2;
        }
        
        .hero-content-wrapper h1 {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 1rem;
            line-height: 1.1;
        }
        
        .hero-content-wrapper .lead {
            font-size: 1.4rem;
            opacity: 0.95;
            font-weight: 300;
        }
        
        .hero-content-wrapper .text-primary {
            color: var(--telex-red) !important;
        }
        
        /* Team Cards améliorées */
        .team-card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            height: 100%;
            position: relative;
        }
        
        .team-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
        }
        
        .team-image {
            height: 240px;
            overflow: hidden;
            position: relative;
        }
        
        .team-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }
        
        .team-card:hover .team-image img {
            transform: scale(1.1);
        }
        
        .team-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(transparent 40%, rgba(29, 53, 87, 0.9) 100%);
            display: flex;
            align-items: flex-end;
            padding: 20px;
            opacity: 0;
            transition: opacity 0.4s ease;
        }
        
        .team-card:hover .team-overlay {
            opacity: 1;
        }
        
        .team-overlay i {
            font-size: 2.5rem;
            color: white;
            margin-bottom: 10px;
        }
        
        .team-content {
            padding: 25px;
        }
        
        .team-content h4 {
            color: var(--telex-blue);
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 10px;
        }
        
        .team-count {
            color: var(--telex-red);
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .team-count::before {
            content: '';
            width: 8px;
            height: 8px;
            background: var(--telex-red);
            border-radius: 50%;
        }
        
        .team-description {
            color: #666;
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 20px;
        }
        
        .team-skills {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        
        .skill-tag {
            background: rgba(29, 53, 87, 0.08);
            color: var(--telex-blue);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .skill-tag:hover {
            background: var(--telex-blue);
            color: white;
            transform: translateY(-2px);
        }
        
        /* ===== ABOUT PAGE - UTILISE LE CSS GLOBAL ===== */
        
        /* Section Notre Histoire */
        .about-section h2 {
            color: var(--telex-blue);
            font-size: 2rem;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .about-section h2 i {
            color: var(--telex-red);
            font-size: 1.8rem;
        }
        
        .about-section p {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #555;
            margin-bottom: 25px;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .page-hero {
                padding: 60px 0 30px;
                min-height: 240px;
            }
            
            .hero-content-wrapper h1 {
                font-size: 2.2rem;
            }
            
            .hero-camera-img {
                max-width: 240px;
                margin-bottom: 25px;
            }
            
            .team-image {
                height: 200px;
            }
            
            .team-content {
                padding: 20px;
            }
        }
        
        @media (max-width: 576px) {
            .hero-content-wrapper h1 {
                font-size: 1.8rem;
            }
            
            .hero-camera-img {
                max-width: 200px;
            }
            
            .team-image {
                height: 180px;
            }
            
            .about-section h2 {
                font-size: 1.6rem;
            }
        }
        /* ===== NAVBAR UNIFIÉE - À GARDER DANS UN SEUL FICHIER ===== */

.navbar,
.navbar-telex {
    background: #051d40 !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
    z-index: 1030 !important;
    padding: 0.5rem 0;
}

.navbar .navbar-brand {
    color: #3AAFA9 !important;
    font-weight: 700;
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
}

.navbar .navbar-brand:hover {
    color: #c1121f !important;
    transform: translateY(-1px);
}

.navbar .navbar-brand img {
    height: 60px;
    width: auto;
    max-width: 200px;
    margin-left: 0px !important;
    transform: scale(1);
    transform-origin: center;
}

.navbar .navbar-nav .nav-link {
    color: white !important;
    font-weight: 700 !important;
            font-size: 0.9rem !important;
    font-family: 'League Spartan', sans-serif !important;
    text-transform: uppercase !important;
    padding: 8px 12px !important;
    margin: 0 2px;
    border-radius: 8px;
    transition: all 0.3s ease;
    position: relative;
    white-space: nowrap;
}

.navbar .navbar-nav .nav-link:hover {
    color: white !important;
    background: #dc3545 !important;
}

.navbar .navbar-nav .nav-link.active {
    color: white !important;
    background: #dc3545 !important;
    font-weight: 700;
}

.navbar .navbar-toggler {
    border: 1px solid rgba(255,255,255,0.3) !important;
}

.navbar .navbar-toggler i {
    color: white !important;
    font-size: 1.5rem;
}

@media (max-width: 991px) {
    .navbar .navbar-nav {
        padding: 1rem 0;
    }
    
    .navbar .navbar-nav .nav-link {
        text-align: center;
        padding: 12px !important;
    }
}
    </style>
</head>
<body>
