<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>À Propos - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    <style>
        /* ===== HERO À PROPOS — CENTRÉ ===== */
        body[data-page="about"] .page-hero {
            padding: 52px 0 0 !important;
            min-height: 0 !important;
            position: relative !important;
            overflow: hidden !important;
            flex-direction: column !important;
            justify-content: center !important;
            text-align: center !important;
        }
        .about-hero-eyebrow {
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
            margin-bottom: 12px;
            text-align: center;
        }
        body[data-page="about"] .page-hero h1 {
            font-size: clamp(1.8rem, 5vw, 2.8rem) !important;
            font-weight: 900 !important;
            color: #fff !important;
            letter-spacing: -0.03em !important;
            line-height: 1.1 !important;
            margin-bottom: 14px !important;
            text-align: center !important;
        }
        body[data-page="about"] .page-hero h1 span {
            color: rgba(255,255,255,0.45) !important;
        }
        body[data-page="about"] .page-hero .about-hero-sub {
            font-size: 1rem !important;
            color: rgba(255,255,255,0.7) !important;
            max-width: 520px !important;
            margin: 0 auto 10px !important;
            line-height: 1.65 !important;
            text-align: center !important;
        }
        body[data-page="about"] .page-hero .about-hero-intro {
            font-size: 0.88rem !important;
            color: rgba(255,255,255,0.5) !important;
            max-width: 560px !important;
            margin: 0 auto 56px !important;
            line-height: 1.7 !important;
            text-align: center !important;
        }
        .about-hero-wave {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 52px;
            display: block;
            pointer-events: none;
        }
        .hero-deco-left, .hero-deco-right {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            opacity: 0.18;
            pointer-events: none;
            z-index: 1;
            height: auto;
            display: block;
        }
        .hero-deco-left  { left: 28px;  max-width: 130px; }
        .hero-deco-right { right: 28px; max-width: 110px; }
        @media (max-width: 768px) {
            .hero-deco-left, .hero-deco-right { display: none; }
        }
        @media (max-width: 768px) {
            body[data-page="about"] .page-hero { padding: 36px 0 0 !important; }
            body[data-page="about"] .page-hero .about-hero-intro { margin-bottom: 44px !important; }
        }
        @media (max-width: 576px) {
            body[data-page="about"] .page-hero { padding: 28px 0 0 !important; }
        }
    </style>
</head>
<body data-page="about">
    <!-- Navigation -->
    <%- include('../partials/navbar') %>

    <!-- Hero Section — Centré sans image -->
    <section class="page-hero">
        <img src="/images/logo.png" alt="" class="hero-deco-left" aria-hidden="true">
        <img src="/images/drapeau.png" alt="" class="hero-deco-right" aria-hidden="true">
        <div class="container" style="display:flex;flex-direction:column;align-items:center;text-align:center;position:relative;z-index:2;">
            <div class="about-hero-eyebrow">Télévision Étudiante &middot; Madagascar</div>
            <h1 style="text-align:center;width:100%;">
                À propos <span>de Telex</span>
            </h1>
            <p class="about-hero-sub" style="text-align:center;">Découvrez notre histoire, notre équipe et notre vision</p>
            <p class="about-hero-intro" style="text-align:center;">
                Fondée par des étudiants passionnés, Telex est bien plus qu'une télévision étudiante. C'est un laboratoire d'innovation, une école de talents et un média numérique pour la jeunesse engagée.
            </p>
        </div>
        <svg class="about-hero-wave" viewBox="0 0 1440 52" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,26 C240,52 480,0 720,26 C960,52 1200,0 1440,26 L1440,52 L0,52 Z" fill="#ffffff"/>
        </svg>
    </section>

    <!-- Contenu principal -->
    <section class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-10 mx-auto">
                    <!-- Notre Histoire -->
                    <div class="about-section mb-5">
                        <h2><i class="fas fa-history text-primary me-3"></i><span data-translate="about.history_title">Notre Histoire</span></h2>
                        <p data-translate="about.history_paragraph1">
                            Telex est né en 2024 de la passion commune d'un groupe d'étudiants déterminés à créer une télévision étudiante et un média numérique à leur image : innovants, indépendants et engagés. En partant d'un simple projet d'association, nous avons construit pas à pas une véritable chaîne de télévision étudiante reconnue aujourd'hui comme la référence en matière d'audiovisuel étudiant.
                        </p>
                        <p data-translate="about.history_paragraph2">
                            Notre aventure a commencé avec une petite équipe de 10 passionnés et un studio improvisé. Aujourd'hui, nous comptons plus de 50 membres actifs, un studio professionnel et une audience grandissante. Chaque jour, nous repoussons les limites de la créativité étudiante pour offrir des contenus de qualité.
                        </p>
                    </div>

                    <!-- Notre Équipe -->
                    <div class="about-section mb-5">
                        <h2><i class="fas fa-users text-primary me-3"></i><span data-translate="about.team_title">Notre Équipe</span></h2>
                        <p data-translate="about.team_intro">
                            Notre force réside dans la diversité de nos profils. Journalistes, techniciens, monteurs, graphistes, communicants - tous étudiants et tous animés par la même passion pour l'audiovisuel. Chaque membre contribue avec ses compétences uniques pour créer des contenus exceptionnels.
                        </p>
                        
                        <div class="row mt-4">
                            <!-- Rédaction -->
                            <div class="col-md-6 mb-4">
                                <div class="team-card">
                                    <div class="team-image">
                                        <img src="<%= about.team_redaction_image || '/images/TELEX INTEGRATION.png' %>" alt="Équipe de rédaction Telex" class="img-fluid">
                                        <div class="team-overlay">
                                            <i class="fas fa-newspaper"></i>
                                        </div>
                                    </div>
                                    <div class="team-content">
                                        <h4 data-translate="about.team_redaction_title">Rédaction</h4>
                                        <p class="team-count" data-translate="about.team_redaction_count">2 journalistes et reporters</p>
                                        <p class="team-description" data-translate="about.team_redaction_description">
                                            Notre équipe éditoriale travaille sur l'écriture, les reportages et la vérification des informations.
                                        </p>
                                        <div class="team-skills">
                                            <% const redactionSkills = (about.team_redaction_skills || 'Journalisme, Reportage, Édition').split(','); %>
                                            <% redactionSkills.forEach(skill => { %>
                                                <span class="skill-tag"><%= skill.trim() %></span>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Technique -->
                            <div class="col-md-6 mb-4">
                                <div class="team-card">
                                    <div class="team-image">
                                        <img src="<%= about.team_technique_image || '/images/femme telex.png' %>" alt="Équipe technique Telex" class="img-fluid">
                                        <div class="team-overlay">
                                            <i class="fas fa-video"></i>
                                        </div>
                                    </div>
                                    <div class="team-content">
                                        <h4 data-translate="about.team_technique_title">Technique</h4>
                                        <p class="team-count" data-translate="about.team_technique_count">2 techniciens audiovisuels</p>
                                        <p class="team-description" data-translate="about.team_technique_description">
                                            Spécialistes de la prise de vue, du son et de l'éclairage pour une production de qualité professionnelle.
                                        </p>
                                        <div class="team-skills">
                                            <% const techniqueSkills = (about.team_technique_skills || 'Caméra, Son, Éclairage').split(','); %>
                                            <% techniqueSkills.forEach(skill => { %>
                                                <span class="skill-tag"><%= skill.trim() %></span>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Post-production -->
                            <div class="col-md-6 mb-4">
                                <div class="team-card">
                                    <div class="team-image">
                                        <img src="<%= about.team_postproduction_image || '/images/ordi_telex.png' %>" alt="Équipe post-production Telex" class="img-fluid">
                                        <div class="team-overlay">
                                            <i class="fas fa-edit"></i>
                                        </div>
                                    </div>
                                    <div class="team-content">
                                        <h4 data-translate="about.team_postproduction_title">Post-production</h4>
                                        <p class="team-count" data-translate="about.team_postproduction_count">3 monteurs vidéo</p>
                                        <p class="team-description" data-translate="about.team_postproduction_description">
                                            Experts en montage, étalonnage et effets spéciaux pour donner vie à nos contenus audiovisuels.
                                        </p>
                                        <div class="team-skills">
                                            <% const postproductionSkills = (about.team_postproduction_skills || 'Montage, Étalonnage, Motion Design').split(','); %>
                                            <% postproductionSkills.forEach(skill => { %>
                                                <span class="skill-tag"><%= skill.trim() %></span>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Communication -->
                            <div class="col-md-6 mb-4">
                                <div class="team-card">
                                    <div class="team-image">
                                        <img src="<%= about.team_communication_image || '/images/Présentation du Telex.png' %>" alt="Équipe communication Telex" class="img-fluid">
                                        <div class="team-overlay">
                                            <i class="fas fa-bullhorn"></i>
                                        </div>
                                    </div>
                                    <div class="team-content">
                                        <h4 data-translate="about.team_communication_title">Communication</h4>
                                        <p class="team-count" data-translate="about.team_communication_count">1 chargés de communication</p>
                                        <p class="team-description" data-translate="about.team_communication_description">
                                            Gestion des réseaux sociaux, relations presse et stratégie de diffusion pour maximiser notre audience.
                                        </p>
                                        <div class="team-skills">
                                            <% const communicationSkills = (about.team_communication_skills || 'Réseaux sociaux, Stratégie, Community').split(','); %>
                                            <% communicationSkills.forEach(skill => { %>
                                                <span class="skill-tag"><%= skill.trim() %></span>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Nos Chiffres -->
                    <div class="about-section">
                        <h2><i class="fas fa-chart-line text-primary me-3"></i><span data-translate="about.stats_title">Nos Chiffres</span></h2>
                        <div class="row text-center">
                            <div class="col-md-3 mb-4">
                                <div class="stat-item">
                                    <div class="stat-number"><%= about.stats_members_count || '50+' %></div>
                                    <div class="stat-label" data-translate="about.stats_members_label">Membres actifs</div>
                                </div>
                            </div>
                            <div class="col-md-3 mb-4">
                                <div class="stat-item">
                                    <div class="stat-number"><%= about.stats_hours_count || '200+' %></div>
                                    <div class="stat-label" data-translate="about.stats_hours_label">Heures de production</div>
                                </div>
                            </div>
                            <div class="col-md-3 mb-4">
                                <div class="stat-item">
                                    <div class="stat-number"><%= about.stats_views_count || '15K+' %></div>
                                    <div class="stat-label" data-translate="about.stats_views_label">Vues mensuelles</div>
                                </div>
                            </div>
                            <div class="col-md-3 mb-4">
                                <div class="stat-item">
                                    <div class="stat-number"><%= about.stats_programs_count || '4' %></div>
                                    <div class="stat-label" data-translate="about.stats_programs_label">Émissions régulières</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/location.js"></script>
    <script src="/js/simple-language.js"></script>
    
    <script>
    // Animation des chiffres - VERSION SIMPLIFIÉE COMPATIBLE CSS GLOBAL
    document.addEventListener('DOMContentLoaded', function() {
        console.log('🚀 Animation chiffres About Page - Version CSS Global');
        
        // Attendre que tout soit chargé
        setTimeout(function() {
            var statItems = document.querySelectorAll('.stat-item');
            var statNumbers = document.querySelectorAll('.stat-number');
            
            console.log('📊 Éléments trouvés:', statItems.length, 'cartes,', statNumbers.length, 'chiffres');
            
            if (statNumbers.length === 0) {
                console.log('❌ Aucun chiffre trouvé');
                return;
            }
            
            // Sauvegarder les valeurs finales
            var finalValues = Array.from(statNumbers).map(el => el.textContent);
            console.log('📋 Valeurs finales:', finalValues);
            
            // Initialiser les chiffres à 0
            statNumbers.forEach(function(element) {
                element.textContent = '0';
            });
            
            // Animation d'apparition des cartes (CSS)
            statItems.forEach(function(item, index) {
                setTimeout(function() {
                    item.classList.add('animate-in');
                    console.log('📋 Carte', index, 'apparue');
                }, index * 200);
            });
            
            // Animation des chiffres après l'apparition des cartes
            setTimeout(function() {
                animateNumbers(statNumbers, finalValues);
            }, 1000);
            
        }, 500);
        
        function animateNumbers(elements, finalValues) {
            console.log('🔢 Début animation des chiffres');
            
            elements.forEach(function(element, index) {
                setTimeout(function() {
                    animateSingleNumber(element, finalValues[index]);
                }, index * 300);
            });
        }
        
        function animateSingleNumber(element, finalText) {
            var isPlus = finalText.includes('+');
            var isK = finalText.includes('K');
            var finalNum = parseInt(finalText.replace(/[^0-9]/g, ''));
            
            if (isK) finalNum = finalNum * 1000;
            
            console.log('🎯 Animation 0 →', finalNum, '(', finalText, ')');
            
            // Ajouter la classe d'animation CSS
            element.classList.add('counting', 'animating');
            
            var current = 0;
            var steps = 40;
            var increment = finalNum / steps;
            var step = 0;
            
            var interval = setInterval(function() {
                step++;
                current = Math.min(increment * step, finalNum);
                
                var display = Math.floor(current);
                if (isK) display = Math.floor(display / 1000) + 'K';
                if (isPlus) display = display + '+';
                
                element.textContent = display;
                
                if (step >= steps) {
                    clearInterval(interval);
                    element.textContent = finalText;
                    element.classList.remove('counting', 'animating');
                    console.log('✅ Animation terminée:', finalText);
                    
                    // Effet de completion
                    element.style.transform = 'scale(1.1)';
                    setTimeout(function() {
                        element.style.transform = 'scale(1)';
                    }, 200);
                }
            }, 50);
        }
    });
    </script>
</body>
</html>