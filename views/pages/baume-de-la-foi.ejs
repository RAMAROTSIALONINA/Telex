                if (el && el.offsetTop <= scrollY) current = s.href;
            });
            document.querySelectorAll('.baume-cat-btn').forEach(btn => {
                btn.classList.toggle('active', btn.getAttribute('href') === current);
            });
        }, { passive: true });

        // Stocker les données pour éviter les problèmes de guillemets
        window.prieresData = <%- JSON.stringify(prieres || []) %>;
        window.reflexionsData = <%- JSON.stringify(reflexions || []) %>;
        
        // Initialisation de la modale
        let contentModal;
        
        document.addEventListener('DOMContentLoaded', function() {
            // Initialiser la modale Bootstrap
            contentModal = new bootstrap.Modal(document.getElementById('contentModal'));
            
            // Animation des cartes de témoignages - Style programme-card
            const temoignageCards = document.querySelectorAll('.temoignage-program-card');
            temoignageCards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
                card.style.animation = 'fadeInUp 0.6s ease forwards';
                card.style.opacity = '0';
            });
            
            // Formater toutes les vues avec K, M, B
            formatAllViews();
            
            // ===== SYSTÈME DE ROTATION AUTOMATIQUE DES CITATIONS =====
            const verses = [
                {
                    text: "Le Seigneur est proche de ceux qui ont le cœur brisé, il sauve ceux dont l'esprit est abattu.",
                    reference: "Psaumes 34:18"
                },
                {
                    text: "L'Éternel est ton refuge, une forteresse en temps de détresse.",
                    reference: "Psaumes 46:1"
                },
                {
                    text: "Rends-moi la joie de ton salut, et qu'un esprit de générosité me soutienne.",
                    reference: "Psaumes 51:12"
                },
                {
                    text: "Confie-toi à l'Éternel de tout ton cœur, et ne t'appuie pas sur ta propre intelligence.",
                    reference: "Proverbes 3:5"
                },
                {
                    text: "Car je connais les projets que j'ai formés pour vous, dit l'Éternel, projets de paix et non de malheur.",
                    reference: "Jérémies 29:11"
                },
                {
                    text: "N'ayez aucune crainte, car je suis avec toi; ne t'effraie pas, car je suis ton Dieu.",
                    reference: "Ésaïe 41:10"
                },
                {
                    text: "Le Seigneur est mon berger, je ne manquerai de rien.",
