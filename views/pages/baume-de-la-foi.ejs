<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Baume de la Foi - Réconfort Spirituel | Telex</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- CSS Principal de Telex -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Navigation -->
    <%- include('../partials/navbar') %>

    
    
    <!-- ===== IMAGES FLOTTANTES DÉPLACEMENT LENT ===== -->
    <div class="floating-images-container" style="position: fixed; top: 400px; left: 0; width: 100%; height: calc(100vh - 400px - 200px); pointer-events: none; z-index: 1;">
        <!-- Ligne verticale gauche -->
        <div style="position: absolute; top: 0; left: 0; width: 10px; height: 100%; background: #EAE3D6; z-index: -1;"></div>
        
        <!-- Ligne verticale droite -->
        <div style="position: absolute; top: 0; right: 0; width: 10px; height: 100%; background: #EAE3D6; z-index: -1;"></div>
    </div>

    <!-- ===== PRÉSENTATION BAUME DE LA FOI ===== -->
    <section class="py-0" style="background-color: white; position: relative; height: auto; overflow: hidden;">
        <!-- Image Hero.png en haut -->
        <div class="hero-image" style="text-align: center; margin-bottom: 20px;">
            <img src="/images/Hero.png" alt="Hero - Baume de la Foi" 
                 class="img-fluid" 
                 style="width: 100%; height: auto; max-height: 250px; object-fit: contain; display: block; margin: 0 auto;">
        </div>
        
        <!-- Image Baume de la foi -->
        <div class="presentation-image">
            <img src="/images/Baume de la foi.png" alt="Baume de la Foi - Espace d'inspiration spirituelle" 
                 class="img-fluid" 
                 style="width: 100%; height: auto; object-fit: contain; object-position: center; display: block; border: none; border-radius: 0; background-color: white;">
        </div>
    </section>

    <!-- ===== CATÉGORIES ===== -->
    <section class="py-1" style="background-color: white;">
        <div class="container">
            <div class="category-pills">
                <a href="#prieres" class="category-pill" style="background: white; color: red; border: 2px solid red;">
                    <i class="fas fa-pray"></i>
                    Prières
                </a>
                <a href="#reflexions" class="category-pill" style="background: white; color: red; border: 2px solid red;">
                    <i class="fas fa-lightbulb"></i>
                    Réflexions
                </a>
            </div>
        </div>
    </section>

    <!-- ===== PRIÈRES PUBLIÉES ===== -->
    <section id="prieres" class="py-5" style="position: relative; background-color: white; color: black; width: 100%; margin: 0; padding: 3rem 0;">
        <div class="container-fluid" style="max-width: 100%; padding: 0 3rem;">
            <!-- Image de la prière en plein écran -->
            <div class="row mb-5 justify-content-center">
                <div class="col-12">
                    <div class="prayer-image-container text-center">
                        <img src="/images/Prière.png" alt="La prière est un moment privilégié de communion avec Dieu" 
                             class="img-fluid prayer-full-image" 
                             style="width: 100%; height: auto; object-fit: cover;">
                    </div>
                </div>
            </div>

            <!-- Espacement avant les publications -->
            <div class="mb-4"></div>

            <!-- ===== CARROUSEL DE PRIÈRES ===== -->
            <div class="prieres-carousel-container position-relative mx-auto" style="max-width: 100%;">
                <!-- Boutons de navigation -->
                <button class="carousel-nav-btn carousel-prev-prieres" onclick="changePriereSlide(-1)" style="position: absolute; left: 20px; top: 50%; transform: translateY(-50%); z-index: 10; background: var(--baume-primary); color: white; border: none; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: all 0.3s ease;">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <button class="carousel-nav-btn carousel-next-prieres" onclick="changePriereSlide(1)" style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); z-index: 10; background: var(--baume-primary); color: white; border: none; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: all 0.3s ease;">
                    <i class="fas fa-chevron-right"></i>
                </button>

                <!-- Conteneur du carrousel -->
                <div class="carousel-wrapper" style="overflow: hidden; border-radius: 16px; width: 100%;">
                    <div id="prieresCarousel" class="carousel-track" style="display: flex; transition: transform 0.5s ease;">
                        <% if (prieres && prieres.length > 0) { %>
                            <% // Grouper les prières par 3 pour l'affichage horizontal en pleine largeur %>
                            <% for (let i = 0; i < prieres.length; i += 3) { %>
                                <div class="carousel-slide" style="min-width: 100%; padding: 0;">
                                    <div class="row g-0 h-100">
                                        <% for (let j = i; j < Math.min(i + 3, prieres.length); j++) { %>
                                            <% if (prieres[j]) { %>
                                                <% const priere = prieres[j]; %>
                                                <% const mediaUrl = priere.image_url || priere.video_url; %>
                                                <% const isVideo = (priere.media_type === 'video' || (priere.video_url && priere.video_url.match(/\.(mp4|webm|ogg|mov)$/i))) && !priere.image_url; %>
                                                <div class="col-4">
                                                    <div class="content-card" onclick="openPriereModal(<%= j %>)" style="height: 500px; width: 100%;">
                                                        
                                                        <!-- Affichage du média en pleine largeur -->
                                                        <% if (priere.video_url || priere.image_url) { %>
                                                        <div class="media-card" style="width: 100%; height: 100%;">
                                                            <% if (isVideo) { %>
                                                                <video muted loop playsinline preload="metadata" style="width: 100%; height: 100%; object-fit: cover;">
                                                                    <source src="<%= mediaUrl %>" type="video/mp4">
                                                                </video>
                                                            <% } else { %>
                                                                <img src="<%= mediaUrl %>" alt="<%= priere.title %>" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
                                                            <% } %>
                                                            
                                                            <!-- Badge média -->
                                                            <span class="media-badge">
                                                                <i class="fas fa-<%= isVideo ? 'video' : 'image' %>"></i>
                                                                <%= isVideo ? 'Vidéo' : 'Image' %>
                                                            </span>
                                                            
                                                            <!-- Badge référence biblique -->
                                                            <% if (priere.reference_biblique) { %>
                                                            <span class="reference-badge">
                                                                <i class="fas fa-bible"></i>
                                                                <%= priere.reference_biblique %>
                                                            </span>
                                                            <% } %>
                                                            
                                                            <!-- Titre en bas de l'image -->
                                                            <div class="card-title-overlay">
                                                                <h3>
                                                                    <i class="fas fa-dove"></i>
                                                                    <%= priere.title %>
                                                                </h3>
                                                            </div>
                                                        </div>
                                                        <% } else { %>
                                                        <!-- Si pas de média, afficher seulement le titre avec fond vert -->
                                                        <div class="media-card no-media">
                                                            <div class="card-title-overlay" style="position: relative; background: linear-gradient(to top, rgba(46,92,78,0.7) 0%, rgba(46,92,78,0.3) 100%);">
                                                                <h3>
                                                                    <i class="fas fa-dove"></i>
                                                                    <%= priere.title %>
                                                                </h3>
                                                            </div>
                                                            
                                                            <!-- Badge référence biblique -->
                                                            <% if (priere.reference_biblique) { %>
                                                            <span class="reference-badge">
                                                                <i class="fas fa-bible"></i>
                                                                <%= priere.reference_biblique %>
                                                            </span>
                                                            <% } %>
                                                        </div>
                                                        <% } %>
                                                        
                                                        <!-- Contenu caché (sera affiché dans la modale) -->
                                                        <div class="card-body-hidden">
                                                            <div class="hidden-content"><%= priere.content || '' %></div>
                                                            <% if (priere.reference_biblique) { %>
                                                            <div class="hidden-reference"><%= priere.reference_biblique %></div>
                                                            <% } %>
                                                            <div class="hidden-author"><%= priere.author || 'Baume de la Foi' %></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% } %>
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        <% } else { %>
                            <div class="carousel-slide" style="min-width: 100%; padding: 0;">
                                <div class="empty-state">
                                    <i class="fas fa-pray"></i>
                                    <h4>Aucune prière pour le moment</h4>
                                    <p>Revenez plus tard pour découvrir de nouvelles prières</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

    <!-- ===== QUIZ BIBLIQUE QUOTIDIEN ===== -->
    <section class="py-5" style="background: white;">
        <div class="container-fluid" style="max-width: 100%; padding: 0 3rem;">
            <!-- Image Quiz en plein écran -->
            <div class="row justify-content-center">
                <div class="col-12">
                    <div class="quiz-image-container text-center">
                        <img src="/images/Quiz.png" alt="Quiz Biblique Quotidien - Apprenez la Parole de Dieu de manière ludique" 
                             class="img-fluid quiz-full-image" 
                             style="width: 100%; height: auto; object-fit: cover;">
                    </div>
                </div>
            </div>
        </div>
    </section>
                        <!-- Quiz Header -->
                        <div class="quiz-header text-center mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-primary text-white px-3 py-2">
                                    <i class="fas fa-question-circle me-2"></i>Question <span id="currentQuestion">1</span>/5
                                </span>
                                <span class="badge bg-warning text-white px-3 py-2">
                                    <i class="fas fa-star me-2"></i>Score: <span id="quizScore" style="color: gold;">0</span>
                                </span>
                            </div>
                            <div class="progress mb-3" style="height: 8px;">
                                <div id="quizProgress" class="progress-bar bg-primary" role="progressbar" style="width: 20%; transition: width 0.3s ease;"></div>
                            </div>
                        </div>

                        <!-- Quiz Content -->
                        <div id="quizContent">
                            <!-- Question -->
                            <div class="question-container text-center mb-4">
                                <h3 class="question-text mb-4" style="font-size: 1.3rem; font-weight: 600; color: var(--baume-primary);"></h3>
                                
                                <!-- Options de réponse -->
                                <div class="options-container" style="max-width: 600px; margin: 0 auto;">
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <button class="answer-option w-100 text-start" onclick="selectAnswer(0)" style="padding: 1rem; border: 2px solid #e0e0e0; border-radius: 12px; background: white; transition: all 0.3s ease; font-size: 1rem;">
                                                <span class="option-letter me-3" style="font-weight: bold; color: var(--baume-primary);">A.</span>
                                                <span class="option-text"></span>
                                            </button>
                                        </div>
                                        <div class="col-12">
                                            <button class="answer-option w-100 text-start" onclick="selectAnswer(1)" style="padding: 1rem; border: 2px solid #e0e0e0; border-radius: 12px; background: white; transition: all 0.3s ease; font-size: 1rem;">
                                                <span class="option-letter me-3" style="font-weight: bold; color: var(--baume-primary);">B.</span>
                                                <span class="option-text"></span>
                                            </button>
                                        </div>
                                        <div class="col-12">
                                            <button class="answer-option w-100 text-start" onclick="selectAnswer(2)" style="padding: 1rem; border: 2px solid #e0e0e0; border-radius: 12px; background: white; transition: all 0.3s ease; font-size: 1rem;">
                                                <span class="option-letter me-3" style="font-weight: bold; color: var(--baume-primary);">C.</span>
                                                <span class="option-text"></span>
                                            </button>
                                        </div>
                                        <div class="col-12">
                                            <button class="answer-option w-100 text-start" onclick="selectAnswer(3)" style="padding: 1rem; border: 2px solid #e0e0e0; border-radius: 12px; background: white; transition: all 0.3s ease; font-size: 1rem;">
                                                <span class="option-letter me-3" style="font-weight: bold; color: var(--baume-primary);">D.</span>
                                                <span class="option-text"></span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Explication biblique (caché au début) -->
                            <div id="verseExplanation" class="verse-explanation mt-4 p-3" style="display: none; background: rgba(58, 175, 169, 0.1); border-radius: 12px; border-left: 4px solid var(--baume-primary);">
                                <h5 class="mb-2" style="color: var(--baume-primary);"><i class="fas fa-book-bible me-2"></i>Référence biblique</h5>
                                <p class="mb-1" style="font-style: italic; color: var(--baume-primary);"></p>
                                <p class="mb-0"></p>
                            </div>

                            <!-- Boutons de navigation -->
                            <div class="quiz-navigation d-flex justify-content-between align-items-center mt-4">
                                <button id="prevBtn" class="btn btn-outline-primary" onclick="previousQuestion()" disabled style="padding: 0.8rem 1.5rem; border-radius: 25px;">
                                    <i class="fas fa-arrow-left me-2"></i>Précédent
                                </button>
                                <button id="nextBtn" class="btn btn-primary" onclick="nextQuestion()" style="padding: 0.8rem 1.5rem; border-radius: 25px; background: var(--baume-gradient); border: none;">
                                    Suivant<i class="fas fa-arrow-right ms-2"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Quiz Results (caché au début) -->
                        <div id="quizResults" style="display: none;">
                            <div class="results-container text-center">
                                <div class="results-icon mb-3">
                                    <i class="fas fa-trophy" style="font-size: 4rem; color: gold;"></i>
                                </div>
                                <h3 class="results-title mb-3" style="color: var(--baume-primary); font-size: 2rem;">Quiz Terminé !</h3>
                                <div class="results-score mb-3">
                                    <h4 class="mb-2">Votre score : <span id="finalScore" style="color: var(--baume-accent); font-weight: bold;">0</span>/5</h4>
                                    <p id="resultsMessage" class="text-muted"></p>
                                </div>
                                <button class="btn btn-primary" onclick="restartQuiz()" style="padding: 1rem 2rem; border-radius: 25px; background: var(--baume-gradient); border: none;">
                                    <i class="fas fa-redo me-2"></i>Recommencer
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== RÉFLEXIONS PUBLIÉES ===== -->
<section id="reflexions" class="py-0" style="position: relative; background-color: white; color: black;">
    <!-- Image de la réflexion en plein écran responsive -->
    <div style="width: 100%; max-width: 100vw; height: auto; max-height: 60vh; overflow: hidden; margin: 0 auto;">
        <img src="/images/Reflexion.png" alt="La réflexion invite à prendre du recul et à méditer la Parole de Dieu" 
             style="width: 100%; height: auto; max-height: 60vh; object-fit: cover; display: block; border: none; border-radius: 0;">
    </div>

    <!-- Espacement avant les publications -->
    <div style="height: 30px; background-color: white;"></div>

    <!-- Publications de réflexions centrées -->
    <div class="container">
        <!-- ===== CARROUSEL DE RÉFLEXIONS ===== -->
        <div class="reflexions-carousel-container" style="display: flex; justify-content: center; align-items: center; width: 100%;">
            <!-- Indicateurs de position masqués -->
            <!-- <div class="reflexion-indicators" style="position: absolute; bottom: -40px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 2;">
                <span class="position-text" style="background: var(--baume-accent); color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: 600;">
                    Utilisez les flèches ou la molette
                </span>
            </div> -->

            <!-- Conteneur du carrousel centré -->
            <div class="carousel-wrapper" style="overflow: visible; border-radius: 16px; max-width: 1400px; margin: 0 auto; position: relative; z-index: 1; background: white; padding: 30px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <div id="reflexionsCarousel" class="carousel-track" style="display: flex; transition: transform 0.5s ease; overflow: hidden; white-space: nowrap; padding: 0 15px;">
                    <!-- Le contenu sera chargé par JavaScript avec pagination -->
                </div>
            </div>
        </div>

        <!-- Bouton Voir Plus en haut de l'image -->
        <div class="text-center mb-1">
                    </div>

        <!-- Image Témoignage de la foi après le bouton -->
        <div class="text-center mb-1">
            <img src="/images/Témoignage de la foi.png" alt="Témoignage de la foi" 
                 class="img-fluid" 
                 style="width: 100vw; height: 80vh; object-fit: contain; display: block; margin: 0 auto; position: relative; left: 50%; transform: translateX(-50%); max-width: none;">
        </div>
    </div>
</section>

    <!-- ===== FORMULAIRE DE TÉMOIGNAGE ===== -->
    <section class="py-2" style="background: white;">
        <div class="container">
            <div class="row">
                <!-- Formulaire de témoignage -->
                <div class="col-lg-12">
                    <div class="form-temoignage" id="temoignage-form">
                        <h2>Envoyez-nous un message</h2>
                        
                        <!-- Message de succès/erreur -->
                        <div id="temoignageMessageAlert" class="alert" style="display: none;"></div>
                        
                        <form action="/baume-de-la-foi/temoignage" method="POST">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="nom" class="form-label">Votre nom ou pseudonyme</label>
                                    <input type="text" class="form-control" id="nom" name="nom" required 
                                           placeholder="Ex: Marie">
                                    <small class="text-muted">Ce nom sera affiché publiquement avec votre témoignage</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="email" class="form-label">Votre email</label>
                                    <input type="email" class="form-control" id="email" name="email" required 
                                           placeholder="Ex: marie@example.com">
                                    <small class="text-muted">Votre email ne sera pas publié et servira uniquement à vous contacter si nécessaire</small>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="ville" class="form-label">Votre ville (optionnel)</label>
                                <input type="text" class="form-control" id="ville" name="ville" 
                                       placeholder="Ex: Paris">
                                <small class="text-muted">Partager votre ville peut encourager d'autres personnes de votre région</small>
                            </div>

                            <div class="mb-3">
                                <label for="temoignage" class="form-label">Votre témoignage</label>
                                <textarea class="form-control" id="temoignage" name="temoignage" rows="6" required 
                                          placeholder="Partagez comment Dieu a agi dans votre vie..."></textarea>
                                <div class="form-text">
                                    <span id="temoignageCharCount">0</span> caractères (minimum 10 caractères)
                                </div>
                                <small class="text-muted">Soyez sincère et authentique dans votre partage</small>
                            </div>

                            <div class="mb-4 form-check">
                                <input type="checkbox" class="form-check-input" id="consentement" name="consentement" required>
                                <label class="form-check-label" for="consentement">
                                    J'accepte que mon témoignage soit publié sur le site et je comprends qu'il sera visible par tous les visiteurs
                                </label>
                            </div>
                            <small class="form-text text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                Votre témoignage sera examiné par notre équipe avant publication
                            </small>

                            <button type="submit" class="btn-submit" id="temoignageSubmitBtn">
                                <i class="fas fa-paper-plane me-2"></i>Envoyer ici
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== TÉMOIGNAGES APPROUVÉS ===== -->
    <section class="py-4" style="background-color: white; position: relative;">
        <div class="container-fluid px-0">
            <!-- Image Témoignages de foi optimisée - sans espaces vides -->
            <div class="temoignages-optimized">
                <img src="/images/Témoignages de foi.png" alt="Témoignages de foi - Partages d'expériences spirituelles" 
                     class="temoignages-img">
            </div>
            
            <!-- Styles CSS optimisés - sans espaces vides -->
            <style>
                .temoignages-optimized {
                    width: 100%;
                    margin: -76px 0 20px 0; /* Marges minimales */
                    padding: 0;
                    overflow: hidden;
                    position: relative;
                    z-index: 10;
                }
                
                .temoignages-img {
                    width: 100%;
                    height: auto; /* Hauteur automatique basée sur le contenu */
                    object-fit: cover; /* Cover pour remplir sans bandes */
                    object-position: center 25%; /* Légèrement vers le haut */
                    display: block;
                    filter: brightness(1.02);
                    transition: all 0.4s ease;
                }
                
                .temoignages-optimized:hover .temoignages-img {
                    transform: scale(1.01);
                    filter: brightness(1.05) contrast(1.02);
                }
                
                /* Responsive ajusté */
                @media (max-width: 768px) {
                    .temoignages-optimized {
                        margin: -40px 0 15px 0;
                    }
                    .temoignages-img {
                        object-position: center 20%;
                    }
                }
                
                @media (max-width: 576px) {
                    .temoignages-optimized {
                        margin: -30px 0 10px 0;
                    }
                    .temoignages-img {
                        object-position: center 15%;
                    }
                }
                
                @media (max-width: 480px) {
                    .temoignages-optimized {
                        margin: -20px 0 8px 0;
                    }
                    .temoignages-img {
                        object-position: center 10%;
                    }
                }
            </style>
        
        <div class="container" style="margin-top: 30px;">
            <div class="section-header">
                <div class="section-title-wrapper" style="text-align: center;">
                </div>
            </div>
            
            <div id="temoignages-container" class="row">
                <!-- Les témoignages seront chargés dynamiquement avec le nouveau style -->
                <div class="col-12 text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Chargement...</span>
                    </div>
                    <p class="mt-3 text-muted">Chargement des témoignages...</p>
                </div>
            </div>
            
            <div class="text-center mt-4">
                <button class="btn btn-outline-secondary" onclick="loadMoreTemoignages()" style="border-color: var(--baume-primary); color: var(--baume-primary); box-shadow: 0 2px 8px rgba(46, 92, 78, 0.2);">
                    <i class="fas fa-plus-circle me-2"></i>Voir tous les témoignages
                </button>
            </div>
        </div>
