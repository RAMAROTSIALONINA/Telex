        #prieres .container-fluid {
            max-width: 100% !important;
            padding: 0 1rem !important;
        }

        #prieres .section-title-underline {
            margin: 0.5rem auto 0 !important;
        }

        #prieres .prayer-description {
            text-align: center;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            border: none;
            background-color: white;
        }

        /* Styles pour le carrousel en plein écran */
        #prieres .prieres-carousel-container {
            width: 100%;
            max-width: 100% !important;
            margin: 0 auto;
        }

        #prieres .carousel-wrapper {
            width: 100%;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        }

        #prieres .carousel-slide {
            width: 100%;
            padding: 0 !important;
        }

        #prieres .content-card {
            width: 100%;
            height: 500px !important;
            border-radius: 12px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            overflow: hidden;
            margin: 0 2px;
        }

        #prieres .content-card:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 15px 35px rgba(255, 107, 107, 0.2);
            z-index: 10;
        }

        #prieres .media-card {
            width: 100%;
            height: 100%;
            position: relative;
        }

        #prieres .media-card img,
        #prieres .media-card video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            transition: transform 0.6s ease;
        }

        #prieres .content-card:hover .media-card img,
        #prieres .content-card:hover .media-card video {
            transform: scale(1.08);
        }

        #prieres .card-title-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, 
                rgba(0,0,0,0.95) 0%, 
                rgba(0,0,0,0.7) 40%, 
                rgba(0,0,0,0.3) 70%, 
                transparent 100%);
            color: white;
            padding: 2rem 1rem 1rem 1rem;
            z-index: 4;
        }

        #prieres .card-title-overlay h3 {
            font-size: 1.3rem;
            font-weight: 700;
            margin: 0;
            line-height: 1.3;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        }

        #prieres .media-badge {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(10px);
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            z-index: 5;
        }

        #prieres .reference-badge {
            position: absolute;
            top: 1rem;
            left: 1rem;
            background: rgba(255, 255, 255, 0.95);
            color: var(--baume-primary);
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            z-index: 5;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);
        }

        /* Boutons de navigation améliorés */
        #prieres .carousel-nav-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            z-index: 15;
            background: rgba(255, 107, 107, 0.9) !important;
            backdrop-filter: blur(10px);
            border: none;
            border-radius: 50%;
            width: 60px !important;
            height: 60px !important;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
        }

        #prieres .carousel-nav-btn:hover {
            background: var(--baume-primary) !important;
            transform: translateY(-50%) scale(1.1);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
        }

        @media (max-width: 768px) {
            #prieres {
                margin-left: 0 !important;
                margin-right: 0 !important;
                padding-left: 0 !important;
                padding-right: 0 !important;
            }
            
            #prieres .container-fluid {
                padding: 0 0.5rem !important;
            }

            #prieres .content-card {
                height: 350px !important;
                margin: 0 1px;
            }

            #prieres .card-title-overlay {
                padding: 1.5rem 0.75rem 0.75rem 0.75rem;
            }

            #prieres .card-title-overlay h3 {
                font-size: 1rem;
            }

            #prieres .carousel-nav-btn {
                width: 40px !important;
                height: 40px !important;
            }

            #prieres .media-badge,
            #prieres .reference-badge {
                padding: 0.4rem 0.6rem;
                font-size: 0.7rem;
                top: 0.75rem;
            }

            #prieres .media-badge {
                right: 0.75rem;
            }

            #prieres .reference-badge {
                left: 0.75rem;
            }
        }

        @media (max-width: 576px) {
            #prieres .content-card {
                height: 300px !important;
            }

            #prieres .card-title-overlay h3 {
                font-size: 0.9rem;
            }

            #prieres .carousel-nav-btn {
                width: 35px !important;
                height: 35px !important;
            }
        }

        /* ===== ANIMATIONS ===== */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-in-up {
            animation: fadeInUp 0.6s ease forwards;
        }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com">
