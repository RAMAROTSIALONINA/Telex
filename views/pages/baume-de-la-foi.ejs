<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Baume de la Foi - Réconfort Spirituel | Telex</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    
    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS Principal de Telex -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">

    <style>
        :root {
            --baume-primary: #2E5C4E;
            --baume-accent: #3AAFA9;
            --baume-gradient: linear-gradient(135deg, #2E5C4E, #3AAFA9);
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include('../partials/navbar') %>

    
    
    <!-- ===== IMAGES FLOTTANTES DÉPLACEMENT LENT ===== -->
    <div class="floating-images-container" style="position: fixed; top: 400px; left: 0; width: 100%; height: calc(100vh - 400px - 200px); pointer-events: none; z-index: 1;">
        <!-- Ligne verticale gauche -->
        <div style="position: absolute; top: 0; left: 0; width: 10px; height: 100%; background: #EAE3D6; z-index: -1;"></div>
        
        <!-- Ligne verticale droite -->
        <div style="position: absolute; top: 0; right: 0; width: 10px; height: 100%; background: #EAE3D6; z-index: -1;"></div>
    </div>

    <!-- ===== PRÉSENTATION BAUME DE LA FOI ===== -->
    <section class="py-0" style="background-color: white; position: relative; height: auto; overflow: hidden;">
        <!-- Image Hero.png en haut -->
        <div class="hero-image" style="text-align: center; margin-bottom: 20px;">
            <img src="/images/Hero.png" alt="Hero - Baume de la Foi" 
                 class="img-fluid" 
                 style="width: 100%; height: auto; max-height: 250px; object-fit: contain; display: block; margin: 0 auto;">
        </div>
        
        <!-- Image Baume de la foi -->
        <div class="presentation-image">
            <img src="/images/Baume%20de%20la%20foi.png" alt="Baume de la Foi - Espace d'inspiration spirituelle" 
                 class="img-fluid" 
                 style="width: 100%; height: auto; object-fit: contain; object-position: center; display: block; border: none; border-radius: 0; background-color: white;">
        </div>
    </section>

    <!-- ===== NAVIGATION CATÉGORIES ===== -->
    <section style="background: white; border-bottom: 1px solid #f0f0f0; position: sticky; top: 70px; z-index: 100; width: 100%; max-width: 100vw; overflow: hidden;">
        <div class="container-fluid" style="padding: 0 12px;">
            <nav class="baume-category-nav">
                <a href="#prieres" class="baume-cat-btn active" onclick="setActiveNav(this)">
                    <i class="fas fa-pray"></i> Prières
                </a>
                <a href="#reflexions" class="baume-cat-btn" onclick="setActiveNav(this)">
                    <i class="fas fa-lightbulb"></i> Réflexions
                </a>
                <a href="#temoignage-form" class="baume-cat-btn" onclick="setActiveNav(this)">
                    <i class="fas fa-heart"></i> Témoignages
                </a>
            </nav>
        </div>
    </section>

    <!-- ===== PRIÈRES PUBLIÉES ===== -->
    <section id="prieres" style="background: #ffffff; padding: 3rem 0;">
        <div class="container-fluid" style="max-width: 100%; padding: 0 3rem;">

            <!-- Image bannière prières -->
            <div class="row mb-4 justify-content-center">
                <div class="col-12">
                    <div class="prayer-image-container text-center">
                        <img src="/images/Prière.png" alt="La prière est un moment privilégié de communion avec Dieu"
                             class="img-fluid prayer-full-image"
                             style="width: 100%; height: auto; object-fit: cover; border-radius: 12px;">
                    </div>
                </div>
            </div>

            <!-- Section header style TopChrétien -->
            <div class="baume-section-header">
                <div class="baume-section-title-wrap">
                    <div class="baume-section-accent"></div>
                    <span class="baume-section-label"><i class="fas fa-dove me-1"></i> Au quotidien</span>
                    <h2 class="baume-section-title">Prières</h2>
                    <span class="baume-section-subtitle">Des prières pour chaque moment de votre journée</span>
                </div>
            </div>

            <!-- ===== CARROUSEL DE PRIÈRES ===== -->
            <div class="prieres-carousel-container position-relative mx-auto" style="max-width: 100%;">
                <!-- Boutons de navigation -->
                <button class="carousel-nav-btn carousel-prev-prieres" onclick="changePriereSlide(-1)" style="position: absolute; left: 20px; top: 50%; transform: translateY(-50%); z-index: 10; background: var(--baume-primary); color: white; border: none; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: all 0.3s ease;">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <button class="carousel-nav-btn carousel-next-prieres" onclick="changePriereSlide(1)" style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); z-index: 10; background: var(--baume-primary); color: white; border: none; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: all 0.3s ease;">
                    <i class="fas fa-chevron-right"></i>
                </button>

                <!-- Conteneur du carrousel -->
                <div class="carousel-wrapper" style="overflow: hidden; border-radius: 16px; width: 100%;">
                    <div id="prieresCarousel" class="carousel-track" style="display: flex; transition: transform 0.5s ease;">
                        <% if (prieres && prieres.length > 0) { %>
                            <% // Grouper les prières par 3 pour l'affichage horizontal en pleine largeur %>
                            <% for (let i = 0; i < prieres.length; i += 3) { %>
                                <div class="carousel-slide" style="min-width: 100%; padding: 0;">
                                    <div class="row g-0 h-100">
                                        <% for (let j = i; j < Math.min(i + 3, prieres.length); j++) { %>
                                            <% if (prieres[j]) { %>
                                                <% const priere = prieres[j]; %>
                                                <% const mediaUrl = priere.image_url || priere.video_url; %>
                                                <% const isVideo = (priere.media_type === 'video' || (priere.video_url && priere.video_url.match(/\.(mp4|webm|ogg|mov)$/i))) && !priere.image_url; %>
                                                <div class="col-4">
                                                    <div class="content-card" onclick="openPriereModal(<%= j %>)" style="height: 280px; width: 100%;">
                                                        
                                                        <!-- Affichage du média en pleine largeur -->
                                                        <% if (priere.video_url || priere.image_url) { %>
                                                        <div class="media-card" style="width: 100%; height: 100%;">
                                                            <% if (isVideo) { %>
                                                                <video muted loop playsinline preload="metadata" style="width: 100%; height: 100%; object-fit: cover;">
                                                                    <source src="<%= mediaUrl %>" type="video/mp4">
                                                                </video>
                                                            <% } else { %>
                                                                <img src="<%= mediaUrl %>" alt="<%= priere.title %>" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
                                                            <% } %>
                                                            
                                                            <!-- Badge média -->
                                                            <span class="media-badge">
                                                                <i class="fas fa-<%= isVideo ? 'video' : 'image' %>"></i>
                                                                <%= isVideo ? 'Vidéo' : 'Image' %>
                                                            </span>
                                                            
                                                            <!-- Badge référence biblique -->
                                                            <% if (priere.reference_biblique) { %>
                                                            <span class="reference-badge">
                                                                <i class="fas fa-bible"></i>
                                                                <%= priere.reference_biblique %>
                                                            </span>
                                                            <% } %>
                                                            
                                                            <!-- Titre en bas de l'image -->
                                                            <div class="card-title-overlay">
                                                                <h3>
                                                                    <i class="fas fa-dove"></i>
                                                                    <%= priere.title %>
                                                                </h3>
                                                            </div>
                                                        </div>
                                                        <% } else { %>
                                                        <!-- Si pas de média, afficher seulement le titre avec fond vert -->
                                                        <div class="media-card no-media">
                                                            <div class="card-title-overlay" style="position: relative; background: linear-gradient(to top, rgba(46,92,78,0.7) 0%, rgba(46,92,78,0.3) 100%);">
                                                                <h3>
                                                                    <i class="fas fa-dove"></i>
                                                                    <%= priere.title %>
                                                                </h3>
                                                            </div>
                                                            
                                                            <!-- Badge référence biblique -->
                                                            <% if (priere.reference_biblique) { %>
                                                            <span class="reference-badge">
                                                                <i class="fas fa-bible"></i>
                                                                <%= priere.reference_biblique %>
                                                            </span>
                                                            <% } %>
                                                        </div>
                                                        <% } %>
                                                        
                                                        <!-- Contenu caché (sera affiché dans la modale) -->
                                                        <div class="card-body-hidden">
                                                            <div class="hidden-content"><%= priere.content || '' %></div>
                                                            <% if (priere.reference_biblique) { %>
                                                            <div class="hidden-reference"><%= priere.reference_biblique %></div>
                                                            <% } %>
                                                            <div class="hidden-author"><%= priere.author || 'Baume de la Foi' %></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% } %>
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        <% } else { %>
                            <div class="carousel-slide" style="min-width: 100%; padding: 0;">
                                <div class="empty-state">
                                    <i class="fas fa-pray"></i>
                                    <h4>Aucune prière pour le moment</h4>
                                    <p>Revenez plus tard pour découvrir de nouvelles prières</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

    <!-- ===== QUIZ BIBLIQUE QUOTIDIEN ===== -->
    <section id="quiz-section" style="background: #f0f4f8; padding: 3rem 0;">
        <div class="container">

            <!-- Section header -->
            <div class="baume-section-header">
                <div class="baume-section-title-wrap">
                    <div class="baume-section-accent"></div>
                    <span class="baume-section-label"><i class="fas fa-bible me-1"></i> Connaissance</span>
                    <h2 class="baume-section-title">Quiz Biblique du Jour</h2>
                    <span class="baume-section-subtitle">Testez votre connaissance de la Parole de Dieu</span>
                </div>
            </div>

            <!-- Bannière image -->
            <div style="width: 100%; overflow: hidden; border-radius: 14px; margin-bottom: 2rem; max-height: 200px;">
                <img src="/images/Quiz.png" alt="Quiz Biblique"
                     style="width: 100%; height: 200px; object-fit: cover; display: block;">
            </div>

            <!-- Carte quiz -->
            <div class="quiz-card">

                <!-- Quiz Header -->
                <div class="quiz-top-bar">
                    <div class="quiz-question-badge">
                        <i class="fas fa-question-circle"></i>
                        Question <span id="currentQuestion">1</span> / 5
                    </div>
                    <div class="quiz-score-badge">
                        <i class="fas fa-star"></i>
                        Score : <span id="quizScore">0</span>
                    </div>
                </div>

                <!-- Barre de progression + pastilles -->
                <div class="quiz-progress-wrap">
                    <div class="quiz-steps">
                        <span class="quiz-step active" id="step-0"></span>
                        <span class="quiz-step" id="step-1"></span>
                        <span class="quiz-step" id="step-2"></span>
                        <span class="quiz-step" id="step-3"></span>
                        <span class="quiz-step" id="step-4"></span>
                    </div>
                    <div class="quiz-progress-bar">
                        <div id="quizProgress" class="quiz-progress-fill" style="width: 20%;"></div>
                    </div>
                </div>

                <!-- Contenu quiz -->
                <div id="quizContent">
                    <div class="quiz-question-wrap">
                        <h3 class="quiz-question-text" id="questionText"></h3>
                    </div>

                    <!-- Options -->
                    <div class="quiz-options" id="quizOptions">
                        <button class="quiz-option" onclick="selectAnswer(0)">
                            <span class="quiz-option-letter">A</span>
                            <span class="quiz-option-text"></span>
                            <i class="quiz-option-icon fas fa-check"></i>
                        </button>
                        <button class="quiz-option" onclick="selectAnswer(1)">
                            <span class="quiz-option-letter">B</span>
                            <span class="quiz-option-text"></span>
                            <i class="quiz-option-icon fas fa-check"></i>
                        </button>
                        <button class="quiz-option" onclick="selectAnswer(2)">
                            <span class="quiz-option-letter">C</span>
                            <span class="quiz-option-text"></span>
                            <i class="quiz-option-icon fas fa-check"></i>
                        </button>
                        <button class="quiz-option" onclick="selectAnswer(3)">
                            <span class="quiz-option-letter">D</span>
                            <span class="quiz-option-text"></span>
                            <i class="quiz-option-icon fas fa-check"></i>
                        </button>
                    </div>

                    <!-- Feedback biblique -->
                    <div id="verseExplanation" class="quiz-verse-box" style="display:none;">
                        <div class="quiz-verse-result" id="quizVerseResult"></div>
                        <div class="quiz-verse-content">
                            <i class="fas fa-quote-left quiz-verse-icon"></i>
                            <p class="quiz-verse-text" id="quizVerseText"></p>
                            <span class="quiz-verse-ref" id="quizVerseRef"></span>
                        </div>
                    </div>

                    <!-- Navigation -->
                    <div class="quiz-navigation">
                        <button id="prevBtn" class="quiz-btn-secondary" onclick="previousQuestion()" disabled>
                            <i class="fas fa-arrow-left"></i> Précédent
                        </button>
                        <button id="nextBtn" class="quiz-btn-primary" onclick="nextQuestion()">
                            Suivant <i class="fas fa-arrow-right"></i>
                        </button>
                    </div>
                </div>

                <!-- Résultats -->
                <div id="quizResults" style="display:none;">
                    <div class="quiz-results-wrap">
                        <div id="quizResultIcon" class="quiz-result-icon">🏆</div>
                        <h3 class="quiz-result-title">Quiz Terminé !</h3>
                        <div class="quiz-result-score-ring">
                            <span id="finalScore">0</span>
                            <small>/5</small>
                        </div>
                        <p id="resultsMessage" class="quiz-result-message"></p>
                        <div class="quiz-result-stars" id="quizResultStars"></div>
                        <button class="quiz-btn-primary mt-3" onclick="restartQuiz()">
                            <i class="fas fa-redo me-2"></i> Recommencer
                        </button>
                    </div>
                </div>

            </div><!-- /.quiz-card -->
        </div>
    </section>

    <!-- ===== RÉFLEXIONS PUBLIÉES ===== -->
<section id="reflexions" style="background: #f8f9fa; padding: 3rem 0;">
    <!-- Image bannière réflexions -->
    <div style="width: 100%; max-width: 100%; overflow: hidden; margin-bottom: 2rem;">
        <img src="/images/Reflexion.png" alt="Réflexions spirituelles"
             style="width: 100%; height: auto; max-height: 45vh; object-fit: cover; display: block;">
    </div>

    <div class="container">
        <!-- Section header style TopChrétien -->
        <div class="baume-section-header">
            <div class="baume-section-title-wrap">
                <div class="baume-section-accent"></div>
                <span class="baume-section-label"><i class="fas fa-book-open me-1"></i> Méditation</span>
                <h2 class="baume-section-title">Réflexions</h2>
                <span class="baume-section-subtitle">Des textes pour nourrir votre foi et votre vie intérieure</span>
            </div>
        </div>
        <!-- ===== CARROUSEL DE RÉFLEXIONS ===== -->
        <div class="reflexions-carousel-container" style="display: flex; justify-content: center; align-items: center; width: 100%;">
            <!-- Indicateurs de position masqués -->
            <!-- <div class="reflexion-indicators" style="position: absolute; bottom: -40px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 2;">
                <span class="position-text" style="background: var(--baume-accent); color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: 600;">
                    Utilisez les flèches ou la molette
                </span>
            </div> -->

            <!-- Conteneur du carrousel centré -->
            <div class="carousel-wrapper" style="overflow: hidden; border-radius: 16px; width: 100%; max-width: 1400px; margin: 0 auto; position: relative; z-index: 1; background: transparent; padding: 10px 0; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <div id="reflexionsCarousel" class="carousel-track" style="display: flex; flex-wrap: nowrap; padding: 0 15px;">
                    <!-- Le contenu sera chargé par JavaScript avec pagination -->
                </div>
            </div>
        </div>

        <!-- Bouton Voir Plus en haut de l'image -->
        <div class="text-center mb-1">
                    </div>

        <!-- Image Témoignage de la foi après le bouton -->
        <div class="text-center mb-1">
            <img src="/images/T%C3%A9moignage%20de%20la%20foi.png" alt="Témoignage de la foi"
                 class="img-fluid"
                 style="width: 100%; height: auto; max-height: 80vh; object-fit: contain; display: block;">
        </div>
    </div>
</section>

    <!-- ===== FORMULAIRE DE TÉMOIGNAGE ===== -->
    <section style="background: white; padding: 3rem 0;" id="temoignage-section">
        <div class="container">

            <!-- Section header -->
            <div class="baume-section-header">
                <div class="baume-section-title-wrap">
                    <div class="baume-section-accent"></div>
                    <span class="baume-section-label"><i class="fas fa-heart me-1"></i> Communauté</span>
                    <h2 class="baume-section-title">Votre Témoignage</h2>
                    <span class="baume-section-subtitle">Partagez comment Dieu a agi dans votre vie</span>
                </div>
            </div>

            <div class="row">
                <!-- Formulaire de témoignage -->
                <div class="col-lg-12">
                    <div class="form-temoignage" id="temoignage-form">
                        <h2>Envoyez-nous un message</h2>
                        
                        <!-- Message de succès/erreur -->
                        <div id="temoignageMessageAlert" class="alert" style="display: none;"></div>
                        
                        <form action="/baume-de-la-foi/temoignage" method="POST">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="nom" class="form-label">Votre nom ou pseudonyme</label>
                                    <input type="text" class="form-control" id="nom" name="nom" required 
                                           placeholder="Ex: Marie">
                                    <small class="text-muted">Ce nom sera affiché publiquement avec votre témoignage</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="email" class="form-label">Votre email</label>
                                    <input type="email" class="form-control" id="email" name="email" required 
                                           placeholder="Ex: marie@example.com">
                                    <small class="text-muted">Votre email ne sera pas publié et servira uniquement à vous contacter si nécessaire</small>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="ville" class="form-label">Votre ville (optionnel)</label>
                                <input type="text" class="form-control" id="ville" name="ville" 
                                       placeholder="Ex: Paris">
                                <small class="text-muted">Partager votre ville peut encourager d'autres personnes de votre région</small>
                            </div>

                            <div class="mb-3">
                                <label for="temoignage" class="form-label">Votre témoignage</label>
                                <textarea class="form-control" id="temoignage" name="temoignage" rows="6" required 
                                          placeholder="Partagez comment Dieu a agi dans votre vie..."></textarea>
                                <div class="form-text">
                                    <span id="temoignageCharCount">0</span> caractères (minimum 10 caractères)
                                </div>
                                <small class="text-muted">Soyez sincère et authentique dans votre partage</small>
                            </div>

                            <div class="mb-4 form-check">
                                <input type="checkbox" class="form-check-input" id="consentement" name="consentement" required>
                                <label class="form-check-label" for="consentement">
                                    J'accepte que mon témoignage soit publié sur le site et je comprends qu'il sera visible par tous les visiteurs
                                </label>
                            </div>
                            <small class="form-text text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                Votre témoignage sera examiné par notre équipe avant publication
                            </small>

                            <button type="submit" class="btn-submit" id="temoignageSubmitBtn">
                                <i class="fas fa-paper-plane me-2"></i>Envoyer ici
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== TÉMOIGNAGES APPROUVÉS ===== -->
    <section class="py-4" style="background-color: white; position: relative;">
        <div class="container-fluid px-0">
            <!-- Image Témoignages de foi -->
            <div class="temoignages-optimized">
                <img src="/images/T%C3%A9moignages%20de%20foi.png" alt="Témoignages de foi - Partages d'expériences spirituelles"
                     class="temoignages-img">
            </div>
        
        <div class="container" style="margin-top: 30px;">
            <div class="section-header">
                <div class="section-title-wrapper" style="text-align: center;">
                </div>
            </div>
            
            <div id="temoignages-container" class="row">
                <!-- Les témoignages seront chargés dynamiquement avec le nouveau style -->
                <div class="col-12 text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Chargement...</span>
                    </div>
                    <p class="mt-3 text-muted">Chargement des témoignages...</p>
                </div>
            </div>
            
            <div class="text-center mt-4">
                <button class="btn btn-outline-secondary" onclick="loadMoreTemoignages()" style="border-color: var(--baume-primary); color: var(--baume-primary); box-shadow: 0 2px 8px rgba(46, 92, 78, 0.2);">
                    <i class="fas fa-plus-circle me-2"></i>Voir tous les témoignages
                </button>
            </div>
        </div>
    </section>

    <!-- ===== FOOTER TELEX ===== -->
    <%- include('../partials/footer') %>

    <!-- ===== MODALE POUR AFFICHER LE CONTENU ===== -->
    <div class="modal fade" id="contentModal" tabindex="-1" aria-labelledby="contentModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable baume-modal-dialog">
            <div class="modal-content baume-modal">

                <!-- En-tête colorée + image -->
                <div class="baume-modal-header">
                    <div class="baume-modal-type">
                        <i class="fas fa-dove me-2"></i>
                        <span id="modalType">Prière</span>
                    </div>
                    <button type="button" class="baume-modal-close" data-bs-dismiss="modal" aria-label="Fermer">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <div class="modal-body baume-modal-body">

                    <!-- Image / Vidéo (dans le corps scrollable) -->
                    <div id="modalMediaContainer" class="modal-media-container" style="display: none;">
                        <img id="modalImage" class="modal-media" src="" alt="" style="display: none;">
                        <video id="modalVideo" class="modal-media" controls style="display: none;">
