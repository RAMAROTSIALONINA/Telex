                }
                
                // Image droite prières
                const priereRightImg = document.querySelector('#prieres .hero-right-image img');
                if (priereRightImg) {
                    priereRightIndex = (priereRightIndex + 1) % priereRightImages.length;
                    priereRightImg.style.opacity = '0.3';
                    
                    setTimeout(() => {
                        priereRightImg.src = priereRightImages[priereRightIndex];
                        priereRightImg.style.opacity = '0.8';
                    }, 500);
                }
            }
            
            // Fonction pour scroller vers la section réflexions
            function scrollToReflexions(event) {
                event.preventDefault();
                const reflexionsSection = document.getElementById('reflexions');
                if (reflexionsSection) {
                    reflexionsSection.scrollIntoView({ 
                        behavior: 'smooth', 
                        block: 'start' 
                    });
                }
            }
            
            // Fonction pour basculer l'affichage complet des réflexions
            function toggleAllReflexions(button) {
                const carousel = document.getElementById('reflexionsCarousel');
                const btnText = button.querySelector('.btn-text');
                const btnIcon = button.querySelector('i');
                const isExpanded = carousel.classList.contains('show-all');
                
                if (!isExpanded) {
                    // Afficher toutes les réflexions
                    carousel.classList.add('show-all');
                    carousel.style.flexWrap = 'wrap';
                    carousel.style.transition = 'all 0.5s ease';
                    
                    // Mettre à jour le bouton
                    btnText.textContent = 'Afficher moins';
                    btnIcon.className = 'fas fa-compress me-2';
                    
                    // Désactiver la navigation du carrousel
                    const navButtons = document.querySelectorAll('.carousel-prev-reflexions, .carousel-next-reflexions');
                    navButtons.forEach(btn => btn.style.display = 'none');
                    
                    // Ajuster les slides pour afficher tout
                    const slides = carousel.querySelectorAll('.carousel-slide');
                    slides.forEach(slide => {
                        slide.style.minWidth = 'auto';
                        slide.style.flex = '0 0 calc(16.666% - 15px)'; // 6 par ligne
                        slide.style.margin = '0 7.5px 15px';
                    });
                    
                    // Pour mobile
                    if (window.innerWidth <= 768) {
                        slides.forEach(slide => {
                            slide.style.flex = '0 0 calc(50% - 15px)'; // 2 par ligne
                        });
                    }
                    if (window.innerWidth <= 576) {
                        slides.forEach(slide => {
                            slide.style.flex = '0 0 calc(50% - 15px)'; // 2 par ligne
                        });
                    }
                    
                } else {
                    // Revenir à l'affichage carrousel
                    carousel.classList.remove('show-all');
                    carousel.style.flexWrap = 'nowrap';
                    
                    // Mettre à jour le bouton
                    btnText.textContent = 'Voir toutes les réflexions';
                    btnIcon.className = 'fas fa-expand me-2';
                    
                    // Réactiver la navigation du carrousel
                    const navButtons = document.querySelectorAll('.carousel-prev-reflexions, .carousel-next-reflexions');
                    navButtons.forEach(btn => btn.style.display = 'flex');
                    
                    // Rétablir l'affichage carrousel
                    const slides = carousel.querySelectorAll('.carousel-slide');
                    slides.forEach(slide => {
                        slide.style.minWidth = '100%';
                        slide.style.flex = 'none';
                        slide.style.margin = '0';
                    });
                    
                    // Revenir à la première slide
                    currentReflexionSlide = 0;
                    updateCarousel(carousel, 0);
                }
                
                // Scroller vers le début de la section
                setTimeout(() => {
                    document.getElementById('reflexions').scrollIntoView({ 
                        behavior: 'smooth', 
                        block: 'start' 
                    });
                }, 300);
            }
            
            // Fonction pour changer les images de la section réflexions
            function changeReflexionImages() {
                // Image gauche réflexions
                const reflexionLeftImg = document.querySelector('#reflexions .hero-left-image img');
                if (reflexionLeftImg) {
                    reflexionLeftIndex = (reflexionLeftIndex + 1) % reflexionLeftImages.length;
                    reflexionLeftImg.style.opacity = '0.3';
                    
                    setTimeout(() => {
                        reflexionLeftImg.src = reflexionLeftImages[reflexionLeftIndex];
                        reflexionLeftImg.style.opacity = '0.8';
                    }, 500);
                }
                
                // Image droite réflexions
                const reflexionRightImg = document.querySelector('#reflexions .hero-right-image img');
                if (reflexionRightImg) {
                    reflexionRightIndex = (reflexionRightIndex + 1) % reflexionRightImages.length;
                    reflexionRightImg.style.opacity = '0.3';
                    
                    setTimeout(() => {
                        reflexionRightImg.src = reflexionRightImages[reflexionRightIndex];
                        reflexionRightImg.style.opacity = '0.8';
                    }, 500);
                }
            }
            
            // ROTATION AUTOMATIQUE - Seulement pour prières et réflexions, PAS pour hero
            // Hero section - IMAGES FIXES (pas de rotation)
            // setInterval(changeLeftImage, 20000);
            // setInterval(changeRightImage, 25000); // 5 secondes de décalage
            
            // Sections prières et réflexions - ROTATION AUTOMATIQUE ACTIVE
            setInterval(changePriereImages, 15000); // Changer toutes les 15 secondes pour les prières
            setInterval(changeReflexionImages, 18000); // Changer toutes les 18 secondes pour les réflexions
            
            // Validation du formulaire de témoignage
            const temoignageForm = document.querySelector('form[action="/baume-de-la-foi/temoignage"]');
            if (temoignageForm) {
                const submitBtn = document.getElementById('temoignageSubmitBtn');
                const temoignageTextarea = document.getElementById('temoignage');
                const charCount = document.getElementById('temoignageCharCount');
                const messageAlert = document.getElementById('temoignageMessageAlert');
                
                // Compteur de caractères
                temoignageTextarea.addEventListener('input', function() {
                    const length = this.value.length;
                    charCount.textContent = length;
                    
                    if (length < 10) {
                        charCount.style.color = '#dc3545';
                    } else if (length > 500) {
                        charCount.style.color = 'var(--baume-primary)';
                    } else {
                        charCount.style.color = '#28a745';
                    }
                });
                
                temoignageForm.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    
                    const formData = new FormData(this);
                    const data = Object.fromEntries(formData);
                    
                    // Validation côté client
                    if (!data.nom || !data.email || !data.temoignage) {
                        showAlert('Veuillez remplir tous les champs obligatoires.', 'danger');
                        return;
                    }
                    
                    if (data.temoignage.length < 10) {
                        showAlert('Le témoignage doit contenir au moins 10 caractères.', 'danger');
                        temoignageTextarea.classList.add('is-invalid');
                        return;
                    }
                    
                    if (!data.consentement) {
                        showAlert('Veuillez accepter les conditions de publication.', 'danger');
                        return;
                    }
                    
                    // Désactiver le bouton
                    const btnOriginalText = submitBtn.innerHTML;
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Envoi en cours...';
                    submitBtn.disabled = true;
                    
                    try {
                        const response = await fetch('/baume-de-la-foi/temoignage', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify(data)
                        });
                        
                        const result = await response.json();
                        
                        if (result.success) {
                            showAlert(result.message, 'success');
                            this.reset();
                            charCount.textContent = '0';
                        } else {
                            showAlert(result.message || 'Erreur lors de l\'envoi du témoignage.', 'danger');
                        }
                        
                    } catch (error) {
                        console.error('Erreur:', error);
                        showAlert('Erreur de connexion. Veuillez réessayer.', 'danger');
                        
                    } finally {
                        // Réactiver le bouton
                        submitBtn.innerHTML = btnOriginalText;
                        submitBtn.disabled = false;
                    }
                });
                
                function showAlert(message, type) {
                    messageAlert.textContent = message;
                    messageAlert.className = `alert alert-${type} alert-dismissible fade show`;
                    messageAlert.style.display = 'block';
                    
                    // Ajouter le bouton de fermeture
                    messageAlert.innerHTML = `
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    `;
                    
                    // Masquer automatiquement après 8 secondes
                    if (type === 'success') {
                        setTimeout(() => {
                            if (messageAlert.style.display !== 'none') {
                                messageAlert.style.display = 'none';
                            }
                        }, 8000);
                    }
                }
            }
            
            // Charger les témoignages
            loadTemoignages();
            
            // Charger les réflexions avec pagination
            loadReflexions();
            
            // Vérifier le message de succès
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('temoignage') === 'success') {
                showNotification('Votre témoignage a été soumis avec succès ! Il sera examiné et publié prochainement.', 'success');
                window.history.replaceState({}, document.title, window.location.pathname);
            }
            
            // Smooth scroll pour les ancres
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    e.preventDefault();
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        target.scrollIntoView({
                            behavior: 'smooth',
                            block: 'start'
                        });
                    }
                });
            });

            // Prévenir les clics droits sur les images (optionnel)
            document.querySelectorAll('.media-card img, .media-card video').forEach(media => {
                media.addEventListener('contextmenu', e => e.preventDefault());
            });
        });

        // Fonctions pour ouvrir les modales avec les données stockées
        function openPriereModal(index) {
            if (window.prieresData && window.prieresData[index]) {
                openContentModal(window.prieresData[index], 'priere');
            }
        }

        function openReflexionModal(index) {
            if (window.reflexionsData && window.reflexionsData[index]) {
                openContentModal(window.reflexionsData[index], 'reflexion');
            }
        }

        // Fonction pour ouvrir la modale avec le contenu
        function openContentModal(item, type) {
            
            // Définir le type
            document.getElementById('modalType').textContent = type === 'priere' ? 'Prière' : 'Réflexion';
            
            // Titre
            document.getElementById('modalTitle').textContent = item.title || '';
            
            // Catégorie (uniquement pour les prières)
            const categoryDiv = document.getElementById('modalCategory');
            if (type === 'priere' && item.category) {
                const categoryLabels = {
                    'comfort': 'Réconfort',
                    'healing': 'Guérison',
                    'protection': 'Protection',
                    'peace': 'Paix',
                    'hope': 'Espérance'
                };
                document.getElementById('modalCategoryText').textContent = categoryLabels[item.category] || item.category;
                categoryDiv.style.display = 'inline-flex';
            } else {
                categoryDiv.style.display = 'none';
            }
            
            // Référence biblique (pour les prières) ou Thème principal (pour les réflexions)
            const referenceDiv = document.getElementById('modalReference');
            
            if (type === 'priere') {
                // Pour les prières : afficher la référence biblique
                let referenceBiblique = item.reference_biblique || ''; // Référence par défaut vide
                if (referenceBiblique) {
                    document.getElementById('modalReferenceText').textContent = referenceBiblique;
                    // Changer l'icône en bible
                    document.querySelector('#modalReference i').className = 'fas fa-bible';
                    referenceDiv.style.display = 'flex';
                } else {
                    referenceDiv.style.display = 'none';
                }
            } else if (type === 'reflexion') {
                // Pour les réflexions : afficher la catégorie (toujours visible)
                const categoryDiv = document.getElementById('modalCategory');
                
                // Toujours afficher une catégorie pour les réflexions
                const categoryLabels = {
                    'faith': 'Foi et confiance',
                    'hope': 'Espérance et avenir',
                    'peace': 'Paix intérieure',
                    'perseverance': 'Persévérance',
                    'comfort': 'Réconfort divin'
                };
                
                // Utiliser la catégorie si disponible, sinon le thème, sinon une valeur par défaut
                const categoryText = categoryLabels[item.category] || categoryLabels[item.theme] || categoryLabels[item.theme] || 'Foi et confiance';
                document.getElementById('modalCategoryText').textContent = categoryText;
                categoryDiv.style.display = 'inline-flex';
                
                // Style spécial pour les réflexions - police élégante
                categoryDiv.style.background = 'linear-gradient(135deg, #9b59b6, #8b5cf6)';
                categoryDiv.style.border = '2px solid #e0e7ff';
                categoryDiv.style.boxShadow = '0 4px 15px rgba(155, 89, 182, 0.3)';
                categoryDiv.style.fontFamily = "'Georgia', 'Times New Roman', serif";
                
                // Cacher la section référence pour éviter le double affichage
                const referenceDiv = document.getElementById('modalReference');
                referenceDiv.style.display = 'none';
            }
            
            // Contenu
            document.getElementById('modalContent').textContent = item.content || '';
            
            // Auteur
            document.getElementById('modalAuthor').textContent = item.author || 'Baume de la Foi';
            
            // Média (image ou vidéo)
            const mediaContainer = document.getElementById('modalMediaContainer');
            const modalImage = document.getElementById('modalImage');
            const modalVideo = document.getElementById('modalVideo');
            
            if (item.image_url || item.video_url) {
                const mediaUrl = item.image_url || item.video_url;
                const isVideo = (item.media_type === 'video' || (item.video_url && item.video_url.match(/\.(mp4|webm|ogg|mov)$/i))) && !item.image_url;
                
                mediaContainer.style.display = 'block';
                
                if (isVideo) {
                    modalImage.style.display = 'none';
                    modalVideo.style.display = 'block';
                    const videoSource = modalVideo.querySelector('source');
                    videoSource.src = mediaUrl;
                    modalVideo.load();
                } else {
                    modalVideo.style.display = 'none';
                    modalImage.style.display = 'block';
                    modalImage.src = mediaUrl;
                    modalImage.alt = item.title || '';
                }
            } else {
                mediaContainer.style.display = 'none';
            }
            
            // Boutons de partage
            const shareText = encodeURIComponent((item.title || '') + ' - Baume de la Foi');
            const shareUrl  = encodeURIComponent(window.location.href);
            document.getElementById('shareWhatsApp').href  = `https://wa.me/?text=${shareText}%20${shareUrl}`;
            document.getElementById('shareFacebook').href = `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`;

            // Ouvrir la modale
            contentModal.show();
        }

        // Variables pour les témoignages
        const temoignagesPerPage = 6;
        
        // Variables pour les réflexions
        const reflexionsPerPage = 4; // 4 réflexions par page
        let currentReflexionPage = 1;
        let allReflexionsData = [];

        // Charger les témoignages
        async function loadTemoignages() {
            try {
                // Toujours charger TOUS les témoignages (approuvés et en attente) pour la vue publique
                const response = await fetch('/api/baume/temoignages');
                
                
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }
                
                const result = await response.json();
                
                if (result.success && result.data && result.data.length > 0) {
                    displayTemoignages(result.data);
                } else {
                    displayNoTemoignages();
                }
            } catch (error) {
                console.error('❌ Erreur lors du chargement des témoignages:', error);
                displayNoTemoignages();
            }
        }

        // Charger les réflexions avec pagination
        function loadReflexions() {
            
            try {
                // Utiliser les données déjà chargées dans window.reflexionsData
                const reflexions = window.reflexionsData || [];
                
                if (reflexions.length > 0) {
                    allReflexionsData = reflexions;
                    
                    // Vérifier si on est sur mobile
                    const isMobile = window.innerWidth <= 768;
                    
                    // Utiliser la pagination pour mobile et PC
                    displayReflexionsPaginated();
                    createReflexionsPagination(); // Créer la pagination sur mobile et PC
                } else {
                    displayNoReflexions();
                }
            } catch (error) {
                console.error('Erreur lors du chargement des réflexions:', error);
                displayNoReflexions();
            }
        }

        // Afficher les témoignages
        function displayTemoignages(temoignages) {
            
            const container = document.getElementById('temoignages-container');
            if (!container) {
                return;
            }
            
            // Vider le conteneur
            container.innerHTML = '';
            
            // Stocker TOUS les témoignages dans une variable globale pour le "Voir plus"
            window.allTemoignages = temoignages;
            
            // Filtrer uniquement les témoignages approuvés (is_approved = 1)
            const temoignagesApprouves = temoignages.filter(t => t.is_approved === 1);
            
            
            // Afficher uniquement les 12 premiers témoignages approuvés
            const temoignagesToShow = temoignagesApprouves.slice(0, 12);
            
            temoignagesToShow.forEach((temoignage, index) => {
                if (temoignage && temoignage.id) {
                    const temoignageCard = createTemoignageCard(temoignage);
                    container.appendChild(temoignageCard);
                } else {
                }
            });
            
            
            // Gérer l'affichage du bouton "voir plus"
            const loadMoreBtn = document.querySelector('button[onclick="loadMoreTemoignages()"]');
            if (loadMoreBtn) {
                const currentlyDisplayed = container.children.length;
                if (currentlyDisplayed >= temoignagesApprouves.length) {
                    // Masquer le bouton s'il y a tous les témoignages approuvés sont affichés
                    loadMoreBtn.style.display = 'none';
                } else {
                    // Afficher le bouton s'il y a encore des témoignages approuvés à afficher
                    loadMoreBtn.style.display = 'inline-flex';
                }
            } else {
            }
        }

        // Créer une carte de témoignage - Style inspiré des cartes programmes
        function createTemoignageCard(temoignage) {
            
            const col = document.createElement('div');
            col.className = 'col-md-6 col-lg-4 mb-4';
            
            const card = document.createElement('div');
            card.className = 'temoignage-program-card';
            
            // Créer une version courte du témoignage (première phrase complète)
            let shortContent;
            const sentences = temoignage.content.match(/[^.!?]+[.!?]+/g);
            if (sentences && sentences.length > 0) {
                shortContent = sentences[0].trim();
            } else {
                // Fallback : prendre les 100 premiers caractères
                shortContent = temoignage.content.substring(0, 100) + (temoignage.content.length > 100 ? '...' : '');
            }
            const fullContent = temoignage.content;
            
            // Limiter la longueur pour l'affichage dans la carte
            const displayContent = shortContent.length > 120 ? shortContent.substring(0, 120) + '...' : shortContent;
            
            card.innerHTML = `
                <div class="temoignage-icon">
                    <i class="fas fa-heart"></i>
                </div>
                <h3>${temoignage.author_name || 'Anonyme'}</h3>
                <div class="temoignage-date">
                    ${temoignage.ville ? temoignage.ville + ' • ' : ''}
                    ${new Date(temoignage.created_at).toLocaleDateString('fr-FR')}
                </div>
                <p>"${displayContent}"</p>
                <a href="#" class="temoignage-link" onclick="toggleTemoignageDetail(${temoignage.id}); return false;" 
                   id="detail-btn-${temoignage.id}"
                   data-short="${shortContent.replace(/"/g, '&quot;').replace(/'/g, '&#39;')}"
                   data-full="${fullContent.replace(/"/g, '&quot;').replace(/'/g, '&#39;')}"
                   data-short-raw="${shortContent.replace(/"/g, '&quot;').replace(/'/g, '&#39;')}"
                   data-full-raw="${fullContent.replace(/"/g, '&quot;').replace(/'/g, '&#39;')}">
                    Lire le témoignage complet →
                </a>
            `;
            
            col.appendChild(card);
            return col;
        }
        
        // Fonction pour basculer entre vue courte et vue détaillée - Style programme-card
        function toggleTemoignageDetail(temoignageId) {
            const buttonElement = document.getElementById(`detail-btn-${temoignageId}`);
            
            if (!buttonElement) return;
            
            // Récupérer les données depuis les attributs data-*
            const shortContent = buttonElement.getAttribute('data-short');
            const fullContent = buttonElement.getAttribute('data-full');
            
            // Vérifier l'état actuel en regardant le texte du bouton
            const buttonText = buttonElement.textContent.trim();
            
            // Trouver la carte parente
            const card = buttonElement.closest('.temoignage-program-card');
            const paragraph = card.querySelector('p');
            
            if (buttonText === 'Lire le témoignage complet →') {
                // Passer en mode détaillé
                paragraph.innerHTML = `"${fullContent}"`;
                buttonElement.innerHTML = '← Revenir au résumé';
                buttonElement.style.color = 'var(--baume-accent)';
            } else {
                // Revenir en mode court
                const displayContent = shortContent.length > 120 ? shortContent.substring(0, 120) + '...' : shortContent;
                paragraph.innerHTML = `"${displayContent}"`;
                buttonElement.innerHTML = 'Lire le témoignage complet →';
                buttonElement.style.color = '';
            }
        }

        // Afficher un message quand il n'y a pas de témoignages
        function displayNoTemoignages() {
            const container = document.getElementById('temoignages-container');
            if (!container) return;
            
            container.innerHTML = `
                <div class="col-12 text-center">
                    <div class="text-muted">
                        <i class="fas fa-heart" style="font-size: 3rem; opacity: 0.5;"></i>
                        <h4 class="mt-3">Aucun témoignage publié pour le moment</h4>
                        <p>Soyez le premier à partager votre expérience de foi !</p>
                    </div>
                </div>
            `;
        }

        // Animer les cartes de témoignages après chargement
        function animateTemoignageCards() {
            const temoignageCards = document.querySelectorAll('.temoignage-program-card');
            temoignageCards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
                card.style.animation = 'fadeInUp 0.6s ease forwards';
                card.style.opacity = '0';
            });
        }

        // Charger plus de témoignages
        function loadMoreTemoignages() {
            const container = document.getElementById('temoignages-container');
            if (!container || !window.allTemoignages) return;
            
            // Calculer combien de témoignages sont déjà affichés
            const currentlyDisplayed = container.children.length;
            
            // Afficher TOUS les témoignages restants d'un coup
            const remainingTemoignages = window.allTemoignages.slice(currentlyDisplayed);
            
            remainingTemoignages.forEach(temoignage => {
                if (temoignage && temoignage.id) {
                    const temoignageCard = createTemoignageCard(temoignage);
                    container.appendChild(temoignageCard);
                }
            });
            
            // Animer les nouvelles cartes ajoutées
            animateTemoignageCards();
            
            // Masquer le bouton car tous les témoignages sont maintenant affichés
            const loadMoreBtn = document.querySelector('button[onclick="loadMoreTemoignages()"]');
            if (loadMoreBtn) {
                loadMoreBtn.style.display = 'none';
            }
            
            // Message de confirmation
        }

        // Afficher toutes les réflexions pour mobile
        function displayAllReflexions() {
            const container = document.getElementById('reflexionsCarousel');
            
            if (!container) return;
            
            // Vider le conteneur
            container.innerHTML = '';
            
            if (allReflexionsData.length > 0) {
                
                // Utiliser flexbox en colonne pour afficher les cartes verticalement sur mobile
                container.className = 'carousel-track';
                container.style.cssText = 'display: flex; flex-direction: column; gap: 1rem; padding: 0 15px;';
                
                // Ajouter chaque réflexion (1 colonne sur mobile)
                allReflexionsData.forEach((reflexion, index) => {
                    if (reflexion) {
                        const reflexionCard = createReflexionCard(reflexion, index, 1);
                        reflexionCard.style.cssText = 'width: 100%; max-width: 100%; margin: 0; box-sizing: border-box;';
                        container.appendChild(reflexionCard);
                    }
                });
                
            } else {
            }
        }

        // Afficher les réflexions pour la page actuelle
        function displayReflexionsPaginated() {
            const container = document.getElementById('reflexionsCarousel');
            if (!container) return;
            
            // Calculer les réflexions à afficher pour cette page (5 par page)
            const startIndex = (currentReflexionPage - 1) * reflexionsPerPage;
            const endIndex = startIndex + reflexionsPerPage;
            const reflexionsToShow = allReflexionsData.slice(startIndex, endIndex);
            
            // Vider et reconstruire le conteneur
            container.innerHTML = '';
            
            // Vérifier si on est sur mobile pour adapter l'affichage
            const isMobile = window.innerWidth <= 768;
            
            if (isMobile) {
                // Sur mobile : afficher en colonne verticale
                container.className = 'carousel-track';
                container.style.cssText = 'display: flex; flex-direction: column; gap: 1rem; padding: 0 15px;';
                
                // Ajouter chaque réflexion en colonne (1 par ligne sur mobile)
                reflexionsToShow.forEach((reflexion, index) => {
                    if (reflexion) {
                        const reflexionCard = createReflexionCard(reflexion, startIndex + index, 1);
                        reflexionCard.style.cssText = 'width: 100%; max-width: 100%; margin: 0; box-sizing: border-box;';
                        container.appendChild(reflexionCard);
                    }
                });
            } else {
                // Sur PC/tablette : afficher en ligne horizontale avec pourcentages CSS
                const screenWidth = window.innerWidth;
                let cardsPerView;
                if (screenWidth >= 768) cardsPerView = 4;
                else cardsPerView = 2;

                container.className = 'carousel-track';
                // width: 100% sur le track pour que les % des enfants soient corrects
                container.style.cssText = 'display: flex; flex-wrap: nowrap; width: 100%; padding: 0; box-sizing: border-box;';

                // Ajouter chaque réflexion à la ligne
                reflexionsToShow.forEach((reflexion, index) => {
                    if (reflexion) {
                        const reflexionCard = createReflexionCard(reflexion, startIndex + index, cardsPerView);
                        container.appendChild(reflexionCard);
                    }
                });
            }
        }

        // Créer une carte de réflexion
        // cardsPerView : nombre de cartes à afficher sur la ligne (pour le calcul % CSS)
        function createReflexionCard(reflexion, globalIndex, cardsPerView) {
            const mediaUrl = reflexion.image_url || reflexion.video_url;
            const isVideo = (reflexion.media_type === 'video' || (reflexion.video_url && reflexion.video_url.match(/\.(mp4|webm|ogg|mov)$/i))) && !reflexion.image_url;

            // Largeur en % : chaque carte prend 1/n de la ligne, minus son padding interne (12px × 2)
            const n = (cardsPerView && cardsPerView > 0) ? cardsPerView : 4;
            const pct = (100 / n).toFixed(4);
            const widthStyle = `calc(${pct}% - 24px)`;

            const div = document.createElement('div');
            div.className = 'reflexion-single-line';
            div.style.cssText = `flex: 0 0 ${widthStyle}; width: ${widthStyle}; box-sizing: border-box; margin: 0 12px;`;

            div.innerHTML = `
                <div class="content-card-reflexion" onclick="incrementReflexionView('${reflexion.id || ''}'); openReflexionModal(${globalIndex})" style="height: 280px;">
                    <!-- Image en haut -->
                    <div class="reflexion-image-container">
                        ${reflexion.video_url || reflexion.image_url ? 
                            (isVideo ? 
                                `<video muted loop playsinline preload="metadata" class="reflexion-image">
                                    <source src="${mediaUrl}" type="video/mp4">
                                </video>` :
                                `<img src="${mediaUrl}" alt="${reflexion.title}" loading="lazy" class="reflexion-image">`
                            ) :
                            `<div class="reflexion-placeholder">
                                <i class="fas fa-lightbulb"></i>
                            </div>`
                        }
                    </div>
                    
                    <!-- Contenu en bas avec étiquette -->
                    <div class="reflexion-content">
                        <div class="reflexion-badge">
                            <i class="fas fa-book-open"></i>
                            RÉFLEXION
                        </div>
                        <h3 class="reflexion-title">${reflexion.title}</h3>
                        <div class="reflexion-author-row">
                            <div class="reflexion-author-avatar"><i class="fas fa-user"></i></div>
                            <span>${reflexion.author || 'Baume de la Foi'}</span>
                        </div>
                    </div>
                    
                    <!-- Contenu caché pour la modale -->
                    <div class="card-body-hidden">
                        <div class="hidden-content">${reflexion.content || ''}</div>
                        ${reflexion.reference_biblique ? `<div class="hidden-reference">${reflexion.reference_biblique}</div>` : ''}
                        <div class="hidden-author">${reflexion.author || 'Baume de la Foi'}</div>
                    </div>
                </div>
            `;
            
            return div;
        }

        // Créer la pagination pour les réflexions
        function createReflexionsPagination() {
            const totalPages = Math.ceil(allReflexionsData.length / reflexionsPerPage);
            
            if (totalPages <= 1) return; // Pas de pagination si une seule page
            
            // Créer le conteneur de pagination
            const paginationContainer = document.createElement('div');
            paginationContainer.className = 'reflexions-pagination';
            
            // Bouton précédent
            const prevBtn = document.createElement('button');
            prevBtn.innerHTML = '<i class="fas fa-chevron-left"></i> Précédent';
            prevBtn.className = 'btn-nav';
            prevBtn.onclick = () => changeReflexionPage(currentReflexionPage - 1);
            prevBtn.disabled = currentReflexionPage === 1;

            // Numéros de page
            const maxVisiblePages = 5;
            let startPage = Math.max(1, currentReflexionPage - 2);
            let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);
            if (endPage - startPage + 1 < maxVisiblePages) {
                startPage = Math.max(1, endPage - maxVisiblePages + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const pageBtn = document.createElement('button');
                pageBtn.textContent = i;
                pageBtn.className = 'btn-page' + (i === currentReflexionPage ? ' active' : '');
                pageBtn.onclick = () => changeReflexionPage(i);
                paginationContainer.appendChild(pageBtn);
            }

            // Bouton suivant
            const nextBtn = document.createElement('button');
            nextBtn.innerHTML = 'Suivant <i class="fas fa-chevron-right"></i>';
            nextBtn.className = 'btn-nav';
            nextBtn.onclick = () => changeReflexionPage(currentReflexionPage + 1);
            nextBtn.disabled = currentReflexionPage === totalPages;
            
            // Assembler la pagination
            paginationContainer.insertBefore(prevBtn, paginationContainer.firstChild);
            paginationContainer.appendChild(nextBtn);
            
            // Ajouter la pagination juste après le carrousel des réflexions uniquement
            const reflexionsCarousel = document.getElementById('reflexionsCarousel');
            if (reflexionsCarousel && reflexionsCarousel.parentNode) {
                reflexionsCarousel.parentNode.insertBefore(paginationContainer, reflexionsCarousel.nextSibling);
            }
        }

        // Changer de page de réflexions
        function changeReflexionPage(page) {
            const totalPages = Math.ceil(allReflexionsData.length / reflexionsPerPage);
            
            if (page < 1 || page > totalPages) return;
            
            currentReflexionPage = page;
            displayReflexionsPaginated();
            
            // Mettre à jour la pagination
            const paginationContainer = document.querySelector('.reflexions-pagination');
            if (paginationContainer) {
                paginationContainer.remove();
            }
            createReflexionsPagination();
            
            // Faire défiler vers le haut des réflexions
            document.getElementById('reflexions').scrollIntoView({ behavior: 'smooth' });
        }

        // Afficher un message quand il n'y a pas de réflexions
        function displayNoReflexions() {
            const container = document.getElementById('reflexionsCarousel');
            if (!container) return;
            
            container.innerHTML = `
                <div class="carousel-slide" style="min-width: 100%; padding: 0 15px;">
                    <div class="empty-state text-center">
                        <i class="fas fa-lightbulb" style="font-size: 3rem; opacity: 0.5;"></i>
                        <h4>Aucune réflexion pour le moment</h4>
                        <p>Revenez plus tard pour découvrir de nouvelles réflexions</p>
                    </div>
                </div>
            `;
        }

        // Afficher des notifications
        function showNotification(message, type = 'info') {
            // Map 'error' to Bootstrap 'danger' and ensure valid bs alert types
            const bsType = type === 'error' ? 'danger' : (type === 'success' ? 'success' : (type === 'info' ? 'info' : type));
            const iconName = bsType === 'success' ? 'check-circle' : (bsType === 'danger' ? 'exclamation-circle' : 'info-circle');

            const notification = document.createElement('div');
            notification.className = `alert alert-${bsType} alert-dismissible fade show position-fixed`;
            notification.style.cssText = `
                top: 20px;
                right: 20px;
                z-index: 9999;
                min-width: 300px;
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            `;

            notification.innerHTML = `
                <div class="d-flex align-items-center">
                    <i class="fas fa-${iconName} me-2"></i>
                    <div class="flex-grow-1">${message}</div>
                    <button type="button" class="btn-close ms-2" data-bs-dismiss="alert"></button>
                </div>
            `;

            document.body.appendChild(notification);

            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 5000);
        }
        
        // Activer la catégorie au scroll
        const sections = document.querySelectorAll('section[id]');
        const navItems = document.querySelectorAll('.category-pill');
        
        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                if (pageYOffset >= sectionTop - 200) {
                    current = section.getAttribute('id');
                }
            });
            
            navItems.forEach(item => {
                item.classList.remove('active');
                if (item.getAttribute('href') === '#' + current) {
                    item.classList.add('active');
                }
            });
        });

        // Gestionnaire d'erreur pour les images
        window.addEventListener('error', function(e) {
            if (e.target.tagName === 'IMG') {
                e.target.style.backgroundColor = 'var(--baume-primary)';
                e.target.style.objectFit = 'contain';
                e.target.src = 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%232E5C4E"/><text x="50" y="50" font-family="Arial" font-size="14" fill="white" text-anchor="middle" dominant-baseline="middle">Image non disponible</text></svg>';
            }
        }, true);

        // ===== ROTATION AUTOMATIQUE DES IMAGES DE PRÉSENTATION =====
        const presentationImages = [
            '/images/Baume4.png',
            '/images/Baume6.png',
            '/images/Baume7.png',
            '/images/Baume8.png'
        ];
        
        let currentImageIndex = 0;
        const presentationImageElement = document.getElementById('presentationImage');
        
        function rotatePresentationImage() {
            if (!presentationImageElement) return;
            
            // Fondu sortant
            presentationImageElement.style.opacity = '0';
            
            setTimeout(() => {
                // Changer l'image
                currentImageIndex = (currentImageIndex + 1) % presentationImages.length;
                presentationImageElement.src = presentationImages[currentImageIndex];
                
                // Fondu entrant
                setTimeout(() => {
                    presentationImageElement.style.opacity = '1';
                }, 100);
            }, 500);
        }
        
        // ===== ANIMATION DES IMAGES FLOTTANTES DÉPLACEMENT LENT =====
        const floatingLeftImage = document.querySelector('.floating-image-left');
        const floatingRightImage = document.querySelector('.floating-image-right');
        
        function animateFloatingImages() {
            if (!floatingLeftImage || !floatingRightImage) return;
            
            // Calculer la position actuelle
            const currentTopLeft = parseFloat(floatingLeftImage.style.top) || -10;
            const currentTopRight = parseFloat(floatingRightImage.style.top) || -10;
            
            // Déplacer lentement vers le bas (de -10% à 100%)
            const newTopLeft = Math.min(100, currentTopLeft + 0.5);
            const newTopRight = Math.min(100, currentTopRight + 0.6);
            
            floatingLeftImage.style.top = newTopLeft + '%';
            floatingRightImage.style.top = newTopRight + '%';
            
            // Réinitialiser quand on arrive en bas
            if (newTopLeft >= 100) {
                floatingLeftImage.style.top = '-10%';
            }
            if (newTopRight >= 100) {
                floatingRightImage.style.top = '-10%';
            }
        }
        
        // Démarrer l'animation toutes les 50ms pour un déplacement fluide
        setInterval(animateFloatingImages, 50);
        
        // ===== FONCTIONS POUR AFFICHER TOUTES LES PRIÈRES ET RÉFLEXIONS =====
        function showAllPrieres() {
            // Rediriger vers une page qui affiche toutes les prières
            window.location.href = '/baume-de-la-foi/prieres/toutes';
        }
        
        function showAllReflexions() {
            // Rediriger vers une page qui affiche toutes les réflexions
            window.location.href = '/baume-de-la-foi/reflexions/toutes';
        }
        
        // ===== GESTION DES CARROUSELS AVEC DÉFILEMENT AUTOMATIQUE =====
        let currentPriereSlide = 0;
        let currentReflexionSlide = 0;
        let autoSlideInterval;
        let isPaused = false;
        
        // Fonctions pour les carrousels
        function changePriereSlide(direction) {
            const carousel = document.getElementById('prieresCarousel');
            if (!carousel) return;
            
            const slides = carousel.querySelectorAll('.carousel-slide');
            if (slides.length === 0) return;
            
            currentPriereSlide += direction;
            
            // Boucle infinie
            if (currentPriereSlide < 0) {
                currentPriereSlide = slides.length - 1;
            } else if (currentPriereSlide >= slides.length) {
                currentPriereSlide = 0;
            }
            
            updateCarousel(carousel, currentPriereSlide);
            resetAutoSlide();
        }
        
        function changeReflexionSlide(direction) {
            const carousel = document.getElementById('reflexionsCarousel');
            if (!carousel) return;
            
            // Chercher les cartes de réflexions individuelles
            const slides = carousel.querySelectorAll('.content-card-reflexion');
            if (slides.length === 0) return;
            
            currentReflexionSlide += direction;
            
            // Boucle infinie
            if (currentReflexionSlide < 0) {
                currentReflexionSlide = slides.length - 1;
            } else if (currentReflexionSlide >= slides.length) {
                currentReflexionSlide = 0;
            }
            
            // Utiliser updateCarousel comme pour les réflexions
            updateCarousel(carousel, currentReflexionSlide);
            resetAutoSlide();
        }
        
        function updateCarousel(carousel, slideIndex) {
            // Adapter pour les réflexions en ligne unique
            if (carousel.id === 'reflexionsCarousel') {
                // Pour les réflexions : déplacement par article de 280px + 24px gap
                const articleWidth = 280 + 24; // 280px + 24px gap
                const offset = -slideIndex * articleWidth;
                carousel.style.transform = `translateX(${offset}px)`;
                carousel.style.transition = 'transform 0.5s ease';
            } else {
                // Pour les prières : système original en pourcentage
                const offset = -slideIndex * 100;
                carousel.style.transform = `translateX(${offset}%)`;
            }
        }
        
        function autoSlide() {
            if (!isPaused) {
                changePriereSlide(1);
                // Ne pas automatiquement changer les réflexions - navigation manuelle uniquement
            }
        }
        
        function resetAutoSlide() {
            clearInterval(autoSlideInterval);
            autoSlideInterval = setInterval(autoSlide, 5000); // 5 secondes
        }
        
        // Initialiser les carrousels
        document.addEventListener('DOMContentLoaded', function() {
            
            // Initialiser le carrousel de réflexions
            const reflexionCarousel = document.getElementById('reflexionsCarousel');
            if (reflexionCarousel) {
                currentReflexionSlide = 0; // Forcer l'initialisation
                reflexionCarousel.style.transform = 'translateX(0px)'; // Position initiale
                
                // Navigation au clavier (flèches gauche/droite)
                document.addEventListener('keydown', function(e) {
                    // Vérifier si le focus est sur ou près du carrousel
                    const rect = reflexionCarousel.getBoundingClientRect();
                    const isInCarouselArea = e.clientX >= rect.left && e.clientX <= rect.right && 
                                           e.clientY >= rect.top && e.clientY <= rect.bottom;
                    
                    if (isInCarouselArea || e.target.closest('#reflexions')) {
                        if (e.key === 'ArrowLeft') {
                            e.preventDefault();
                            changeReflexionSlide(-1);
                        } else if (e.key === 'ArrowRight') {
                            e.preventDefault();
                            changeReflexionSlide(1);
                        }
                    }
                });
            } else {
            }
            
            // Initialiser le carrousel de prières
            const priereCarousel = document.getElementById('prieresCarousel');
            if (priereCarousel) {
                currentPriereSlide = 0;
