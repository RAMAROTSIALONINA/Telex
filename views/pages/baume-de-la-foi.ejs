        // Obtenir 5 questions basées sur le jour actuel (rotation sur 6 semaines = 30 questions)
        function getDailyQuestions() {
            const today = new Date();
            const dayOfYear = Math.floor((today - new Date(today.getFullYear(), 0, 0)) / 86400000);
            const weekNumber = Math.floor(dayOfYear / 7) % 6; // Rotation sur 6 semaines
            const startQuestionIndex = weekNumber * 5;
            return allQuizQuestions.slice(startQuestionIndex, startQuestionIndex + 5);
        }
        
        const quizQuestions = getDailyQuestions();
        let currentQuestionIndex = 0;
        let score = 0;
        let selectedAnswerIndex = null;
        
        let answerLocked = false;

        function loadQuestion() {
            const question = quizQuestions[currentQuestionIndex];
            document.getElementById('currentQuestion').textContent = currentQuestionIndex + 1;
            document.getElementById('quizScore').textContent = score;
            document.getElementById('quizProgress').style.width = ((currentQuestionIndex + 1) / quizQuestions.length * 100) + '%';

            // Pastilles de progression
            document.querySelectorAll('.quiz-step').forEach((s, i) => {
                s.className = 'quiz-step' + (i < currentQuestionIndex ? ' done' : i === currentQuestionIndex ? ' active' : '');
            });

            // Question
            document.getElementById('questionText').textContent = question.question;

            // Options
            const options = document.querySelectorAll('.quiz-option');
            options.forEach((opt, i) => {
                opt.querySelector('.quiz-option-text').textContent = question.options[i];
                opt.className = 'quiz-option';
                opt.disabled = false;
            });

            // Cacher feedback
            document.getElementById('verseExplanation').style.display = 'none';
            document.getElementById('prevBtn').disabled = currentQuestionIndex === 0;
            document.getElementById('nextBtn').innerHTML = currentQuestionIndex === quizQuestions.length - 1
                ? '<i class="fas fa-check me-2"></i> Terminer'
                : 'Suivant <i class="fas fa-arrow-right"></i>';
            document.getElementById('nextBtn').disabled = false;

            selectedAnswerIndex = null;
            answerLocked = false;
        }

        function selectAnswer(index) {
            if (answerLocked) return;
            answerLocked = true;

            const question = quizQuestions[currentQuestionIndex];
            const isCorrect = index === question.correctAnswer;
            if (isCorrect) score++;

            // Feedback couleur sur toutes les options
            document.querySelectorAll('.quiz-option').forEach((opt, i) => {
                opt.disabled = true;
                if (i === question.correctAnswer) {
                    opt.classList.add('correct');
                } else if (i === index && !isCorrect) {
                    opt.classList.add('wrong');
                }
            });

            selectedAnswerIndex = index;
            document.getElementById('quizScore').textContent = score;

            // Afficher verset biblique
            const box = document.getElementById('verseExplanation');
            const resultEl = document.getElementById('quizVerseResult');
            resultEl.className = 'quiz-verse-result ' + (isCorrect ? 'correct' : 'wrong');
            resultEl.innerHTML = isCorrect
                ? '<i class="fas fa-check-circle"></i> Bonne réponse !'
                : `<i class="fas fa-times-circle"></i> La bonne réponse était : <strong>${question.options[question.correctAnswer]}</strong>`;
            document.getElementById('quizVerseText').textContent = `"${question.verse}"`;
            document.getElementById('quizVerseRef').textContent = question.reference;
            box.style.display = 'block';

            // Auto-avance après 2.5s
            setTimeout(() => {
                if (currentQuestionIndex < quizQuestions.length - 1) {
                    currentQuestionIndex++;
                    loadQuestion();
                } else {
                    showResults();
                }
            }, 2500);
        }

        function nextQuestion() {
            if (selectedAnswerIndex === null) {
                // Secouer visuellement pour indiquer qu'il faut choisir
                const opt = document.getElementById('quizOptions');
                opt.classList.add('shake');
                setTimeout(() => opt.classList.remove('shake'), 500);
                return;
            }
        }

        function previousQuestion() {
            if (currentQuestionIndex > 0) {
                currentQuestionIndex--;
                loadQuestion();
            }
        }

        function showResults() {
            document.getElementById('quizContent').style.display = 'none';
            document.getElementById('quizResults').style.display = 'block';
            document.getElementById('finalScore').textContent = score;

            const pct = (score / quizQuestions.length) * 100;
            let icon = '😔', msg = '';
            if (pct === 100)      { icon = '🏆'; msg = 'Excellent ! Parfaite connaissance biblique !'; }
            else if (pct >= 80)   { icon = '🎉'; msg = 'Très bien ! Grande connaissance de la Parole !'; }
            else if (pct >= 60)   { icon = '👍'; msg = 'Bien ! Continuez à étudier la Parole de Dieu !'; }
            else if (pct >= 40)   { icon = '📖'; msg = 'Pas mal ! Relisez votre Bible chaque jour.'; }
            else                   { icon = '🙏'; msg = 'Continuez à prier et étudier les Écritures !'; }

            document.getElementById('quizResultIcon').textContent = icon;
            document.getElementById('resultsMessage').textContent = msg;

            // Étoiles
            const stars = document.getElementById('quizResultStars');
            const starCount = Math.ceil(pct / 20);
            stars.innerHTML = Array.from({length: 5}, (_, i) =>
                `<i class="fas fa-star" style="color:${i < starCount ? '#f59e0b' : '#e5e7eb'}; font-size:1.6rem; margin:0 3px;"></i>`
            ).join('');
        }

        function getRandomQuestions(n) {
            const shuffled = [...allQuizQuestions].sort(() => Math.random() - 0.5);
            return shuffled.slice(0, n);
        }

        function restartQuiz() {
            currentQuestionIndex = 0;
            score = 0;
            selectedAnswerIndex = null;
            answerLocked = false;
            document.getElementById('quizContent').style.display = 'block';
            document.getElementById('quizResults').style.display = 'none';
            // Nouvelles questions aléatoires différentes à chaque recommencement
            const newQ = getRandomQuestions(5);
            quizQuestions.length = 0;
            quizQuestions.push(...newQ);
            loadQuestion();
        }
        
        // Initialiser le quiz au chargement
        document.addEventListener('DOMContentLoaded', function() {
            loadQuestion();
        });
        
        // Démarrer la rotation toutes les 4 secondes
        setInterval(rotatePresentationImage, 4000);

        // Recalculer la largeur des cartes réflexions au resize
        let reflexionResizeTimer;
        window.addEventListener('resize', function() {
            clearTimeout(reflexionResizeTimer);
            reflexionResizeTimer = setTimeout(function() {
                if (allReflexionsData && allReflexionsData.length > 0) {
                    displayReflexionsPaginated();
                }
            }, 200);
        });
