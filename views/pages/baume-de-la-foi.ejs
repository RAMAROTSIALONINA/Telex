        @media (max-width: 768px) {
            .temoignage-program-card {
                padding: 1.5rem;
                min-height: 250px;
            }
            
            .temoignage-icon {
                width: 60px;
                height: 60px;
                font-size: 1.5rem;
            }
        }

        /* Forcer le fond blanc pour les cartes de témoignages */
        .temoignage-card {
            background: white !important;
        }
        
        .temoignage-card .card-body {
            background: white !important;
        }
        
        .temoignage-card .card-text,
        .temoignage-card .card-text small {
            color: #333 !important;
            background: white !important;
        }
        
        .temoignage-card .rounded-circle {
            background: var(--baume-gradient) !important;
        }
        
        /* S'assurer que le conteneur a aussi un fond blanc */
        #temoignages-container {
            background: white !important;
        }
        
        /* ===== STYLES POUR LES RÉFLEXIONS ===== */ 

