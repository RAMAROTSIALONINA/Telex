    <!-- ===== IMAGES FLOTTANTES DÉPLACEMENT LENT ===== -->
    <div class="floating-images-container" style="position: fixed; top: 400px; left: 0; width: 100%; height: calc(100vh - 400px - 200px); pointer-events: none; z-index: 1;">
        <!-- Ligne verticale gauche -->
        <div style="position: absolute; top: 0; left: 0; width: 10px; height: 100%; background: #EAE3D6; z-index: -1;"></div>
        
        <!-- Ligne verticale droite -->
        <div style="position: absolute; top: 0; right: 0; width: 10px; height: 100%; background: #EAE3D6; z-index: -1;"></div>
    </div>

    <!-- ===== PRÉSENTATION BAUME DE LA FOI ===== -->
    <section class="py-0" style="background-color: white; position: relative; height: auto; overflow: hidden;">
        <!-- Image Hero.png en haut -->
        <div class="hero-image" style="text-align: center; margin-bottom: 20px; margin-top: 57px;">
            <img src="/images/Hero.png" alt="Hero - Baume de la Foi" 
                 class="img-fluid" 
                 style="width: 100%; height: auto; max-height: 250px; object-fit: contain; display: block; margin: 0 auto;">
        </div>
        
        <!-- Image Baume de la foi -->
        <div class="presentation-image">
            <img src="/images/Baume de la foi.png" alt="Baume de la Foi - Espace d'inspiration spirituelle" 
                 class="img-fluid" 
                 style="width: 100%; height: auto; object-fit: contain; object-position: center; display: block; border: none; border-radius: 0; background-color: white;">
        </div>
    </section>

    <!-- ===== CATÉGORIES ===== -->
    <section class="py-1" style="background-color: white;">
        <div class="container">
            <div class="category-pills">
                <a href="#prieres" class="category-pill" style="background: white; color: red; border: 2px solid red;">
                    <i class="fas fa-pray"></i>
                    Prières
                </a>
                <a href="#reflexions" class="category-pill" style="background: white; color: red; border: 2px solid red;">
                    <i class="fas fa-lightbulb"></i>
                    Réflexions
                </a>
            </div>
        </div>
    </section>

    <!-- ===== PRIÈRES PUBLIÉES ===== -->
    <section id="prieres" class="py-5" style="position: relative; background-color: white; color: black; width: 100%; margin: 0; padding: 3rem 0;">
        <div class="container-fluid" style="max-width: 100%; padding: 0 3rem;">
            <!-- Image de la prière en plein écran -->
            <div class="row mb-5 justify-content-center">
                <div class="col-12">
                    <div class="prayer-image-container text-center">
                        <img src="/images/Prière.png" alt="La prière est un moment privilégié de communion avec Dieu" 
                             class="img-fluid prayer-full-image" 
                             style="width: 100%; height: auto; object-fit: cover;">
                    </div>
                </div>
            </div>

            <!-- Espacement avant les publications -->
            <div class="mb-4"></div>

            <!-- ===== CARROUSEL DE PRIÈRES ===== -->
            <div class="prieres-carousel-container position-relative mx-auto" style="max-width: 100%;">
                <!-- Boutons de navigation -->
                <button class="carousel-nav-btn carousel-prev-prieres" onclick="changePriereSlide(-1)" style="position: absolute; left: 20px; top: 50%; transform: translateY(-50%); z-index: 10; background: var(--baume-primary); color: white; border: none; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: all 0.3s ease;">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <button class="carousel-nav-btn carousel-next-prieres" onclick="changePriereSlide(1)" style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); z-index: 10; background: var(--baume-primary); color: white; border: none; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: all 0.3s ease;">
                    <i class="fas fa-chevron-right"></i>
                </button>

                <!-- Conteneur du carrousel -->
                <div class="carousel-wrapper" style="overflow: hidden; border-radius: 16px; width: 100%;">
                    <div id="prieresCarousel" class="carousel-track" style="display: flex; transition: transform 0.5s ease;">
                        <% if (prieres && prieres.length > 0) { %>
                            <% // Grouper les prières par 3 pour l'affichage horizontal en pleine largeur %>
                            <% for (let i = 0; i < prieres.length; i += 3) { %>
                                <div class="carousel-slide" style="min-width: 100%; padding: 0;">
                                    <div class="row g-0 h-100">
                                        <% for (let j = i; j < Math.min(i + 3, prieres.length); j++) { %>
                                            <% if (prieres[j]) { %>
                                                <% const priere = prieres[j]; %>
                                                <% const mediaUrl = priere.image_url || priere.video_url; %>
                                                <% const isVideo = (priere.media_type === 'video' || (priere.video_url && priere.video_url.match(/\.(mp4|webm|ogg|mov)$/i))) && !priere.image_url; %>
                                                <div class="col-4">
                                                    <div class="content-card" onclick="openPriereModal(<%= j %>)" style="height: 500px; width: 100%;">
                                                        
                                                        <!-- Affichage du média en pleine largeur -->
                                                        <% if (priere.video_url || priere.image_url) { %>
                                                        <div class="media-card" style="width: 100%; height: 100%;">
                                                            <% if (isVideo) { %>
                                                                <video muted loop playsinline preload="metadata" style="width: 100%; height: 100%; object-fit: cover;">
                                                                    <source src="<%= mediaUrl %>" type="video/mp4">
                                                                </video>
                                                            <% } else { %>
                                                                <img src="<%= mediaUrl %>" alt="<%= priere.title %>" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
                                                            <% } %>
                                                            
                                                            <!-- Badge média -->
                                                            <span class="media-badge">
                                                                <i class="fas fa-<%= isVideo ? 'video' : 'image' %>"></i>
                                                                <%= isVideo ? 'Vidéo' : 'Image' %>
                                                            </span>
                                                            
                                                            <!-- Badge référence biblique -->
                                                            <% if (priere.reference_biblique) { %>
                                                            <span class="reference-badge">
                                                                <i class="fas fa-bible"></i>
                                                                <%= priere.reference_biblique %>
                                                            </span>
                                                            <% } %>
                                                            
                                                            <!-- Titre en bas de l'image -->
                                                            <div class="card-title-overlay">
                                                                <h3>
                                                                    <i class="fas fa-dove"></i>
                                                                    <%= priere.title %>
                                                                </h3>
                                                            </div>
                                                        </div>
                                                        <% } else { %>
                                                        <!-- Si pas de média, afficher seulement le titre avec fond vert -->
                                                        <div class="media-card no-media">
                                                            <div class="card-title-overlay" style="position: relative; background: linear-gradient(to top, rgba(46,92,78,0.7) 0%, rgba(46,92,78,0.3) 100%);">
                                                                <h3>
                                                                    <i class="fas fa-dove"></i>
                                                                    <%= priere.title %>
                                                                </h3>
                                                            </div>
                                                            
                                                            <!-- Badge référence biblique -->
                                                            <% if (priere.reference_biblique) { %>
                                                            <span class="reference-badge">
                                                                <i class="fas fa-bible"></i>
                                                                <%= priere.reference_biblique %>
                                                            </span>
                                                            <% } %>
                                                        </div>
                                                        <% } %>
                                                        
                                                        <!-- Contenu caché (sera affiché dans la modale) -->
                                                        <div class="card-body-hidden">
                                                            <div class="hidden-content"><%= priere.content || '' %></div>
                                                            <% if (priere.reference_biblique) { %>
                                                            <div class="hidden-reference"><%= priere.reference_biblique %></div>
                                                            <% } %>
                                                            <div class="hidden-author"><%= priere.author || 'Baume de la Foi' %></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% } %>
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        <% } else { %>
                            <div class="carousel-slide" style="min-width: 100%; padding: 0;">
                                <div class="empty-state">
                                    <i class="fas fa-pray"></i>
                                    <h4>Aucune prière pour le moment</h4>
                                    <p>Revenez plus tard pour découvrir de nouvelles prières</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

    <!-- ===== QUIZ BIBLIQUE QUOTIDIEN ===== -->
    <section class="py-5" style="background: white;">
        <div class="container-fluid" style="max-width: 100%; padding: 0 3rem;">
            <!-- Image Quiz en plein écran -->
            <div class="row justify-content-center">
                <div class="col-12">
                    <div class="quiz-image-container text-center">
                        <img src="/images/Quiz.png" alt="Quiz Biblique Quotidien - Apprenez la Parole de Dieu de manière ludique" 
                             class="img-fluid quiz-full-image" 
                             style="width: 100%; height: auto; object-fit: cover;">
                    </div>
                </div>
            </div>
        </div>
    </section>
                        <!-- Quiz Header -->
                        <div class="quiz-header text-center mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-primary text-white px-3 py-2">
                                    <i class="fas fa-question-circle me-2"></i>Question <span id="currentQuestion">1</span>/5
                                </span>
                                <span class="badge bg-warning text-white px-3 py-2">
                                    <i class="fas fa-star me-2"></i>Score: <span id="quizScore" style="color: gold;">0</span>
                                </span>
                            </div>
                            <div class="progress mb-3" style="height: 8px;">
                                <div id="quizProgress" class="progress-bar bg-primary" role="progressbar" style="width: 20%; transition: width 0.3s ease;"></div>
                            </div>
                        </div>

                        <!-- Quiz Content -->
                        <div id="quizContent">
                            <!-- Question -->
                            <div class="question-container text-center mb-4">
                                <h3 class="question-text mb-4" style="font-size: 1.3rem; font-weight: 600; color: var(--baume-primary);"></h3>
                                
                                <!-- Options de réponse -->
                                <div class="options-container" style="max-width: 600px; margin: 0 auto;">
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <button class="answer-option w-100 text-start" onclick="selectAnswer(0)" style="padding: 1rem; border: 2px solid #e0e0e0; border-radius: 12px; background: white; transition: all 0.3s ease; font-size: 1rem;">
                                                <span class="option-letter me-3" style="font-weight: bold; color: var(--baume-primary);">A.</span>
                                                <span class="option-text"></span>
                                            </button>
                                        </div>
                                        <div class="col-12">
                                            <button class="answer-option w-100 text-start" onclick="selectAnswer(1)" style="padding: 1rem; border: 2px solid #e0e0e0; border-radius: 12px; background: white; transition: all 0.3s ease; font-size: 1rem;">
                                                <span class="option-letter me-3" style="font-weight: bold; color: var(--baume-primary);">B.</span>
                                                <span class="option-text"></span>
                                            </button>
                                        </div>
                                        <div class="col-12">
                                            <button class="answer-option w-100 text-start" onclick="selectAnswer(2)" style="padding: 1rem; border: 2px solid #e0e0e0; border-radius: 12px; background: white; transition: all 0.3s ease; font-size: 1rem;">
                                                <span class="option-letter me-3" style="font-weight: bold; color: var(--baume-primary);">C.</span>
                                                <span class="option-text"></span>
                                            </button>
                                        </div>
                                        <div class="col-12">
                                            <button class="answer-option w-100 text-start" onclick="selectAnswer(3)" style="padding: 1rem; border: 2px solid #e0e0e0; border-radius: 12px; background: white; transition: all 0.3s ease; font-size: 1rem;">
                                                <span class="option-letter me-3" style="font-weight: bold; color: var(--baume-primary);">D.</span>
                                                <span class="option-text"></span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Explication biblique (caché au début) -->
                            <div id="verseExplanation" class="verse-explanation mt-4 p-3" style="display: none; background: rgba(58, 175, 169, 0.1); border-radius: 12px; border-left: 4px solid var(--baume-primary);">
                                <h5 class="mb-2" style="color: var(--baume-primary);"><i class="fas fa-book-bible me-2"></i>Référence biblique</h5>
                                <p class="mb-1" style="font-style: italic; color: var(--baume-primary);"></p>
                                <p class="mb-0"></p>
                            </div>

                            <!-- Boutons de navigation -->
                            <div class="quiz-navigation d-flex justify-content-between align-items-center mt-4">
                                <button id="prevBtn" class="btn btn-outline-primary" onclick="previousQuestion()" disabled style="padding: 0.8rem 1.5rem; border-radius: 25px;">
                                    <i class="fas fa-arrow-left me-2"></i>Précédent
                                </button>
                                <button id="nextBtn" class="btn btn-primary" onclick="nextQuestion()" style="padding: 0.8rem 1.5rem; border-radius: 25px; background: var(--baume-gradient); border: none;">
                                    Suivant<i class="fas fa-arrow-right ms-2"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Quiz Results (caché au début) -->
                        <div id="quizResults" style="display: none;">
                            <div class="results-container text-center">
                                <div class="results-icon mb-3">
                                    <i class="fas fa-trophy" style="font-size: 4rem; color: gold;"></i>
                                </div>
                                <h3 class="results-title mb-3" style="color: var(--baume-primary); font-size: 2rem;">Quiz Terminé !</h3>
                                <div class="results-score mb-3">
                                    <h4 class="mb-2">Votre score : <span id="finalScore" style="color: var(--baume-accent); font-weight: bold;">0</span>/5</h4>
