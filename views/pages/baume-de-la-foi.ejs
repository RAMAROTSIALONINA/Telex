            ];
            
            let currentVerseIndex = 0;
            const verseText = document.getElementById('verseText');
            const verseContent = document.getElementById('verseContent');
            const verseRef = document.getElementById('verseRef');
            
            // Vérifier si les éléments existent avant de continuer
            if (!verseText || !verseContent || !verseRef) {
            } else {
                // Fonction pour changer la citation
                function changeVerse() {
                    const verse = verses[currentVerseIndex];
                    
                    // Vérifications pour éviter les erreurs
                    if (!verseText || !verseContent || !verseRef) {
                        return;
                    }
                    
                    // Animation de fondu
                    verseText.style.opacity = '0';
                    
                    setTimeout(() => {
                        verseContent.textContent = verse.text;
                        verseRef.textContent = verse.reference;
                        verseText.style.opacity = '1';
                    }, 300);
                    
                    currentVerseIndex = (currentVerseIndex + 1) % verses.length;
                }
                
                // Changer la citation toutes les 30 secondes
                setInterval(changeVerse, 30000);
            }
            
            // ===== SYSTÈME DE ROTATION AUTOMATIQUE DES IMAGES LATÉRALES =====
            const leftImages = [
                '/images/11.png',
                '/images/2.png',
                '/images/3.png',
