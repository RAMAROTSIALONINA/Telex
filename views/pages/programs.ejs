                                <div class="program-info">
                                    <p><i class="far fa-clock me-2"></i><strong>Diffusion :</strong> Jeudi 18h</p>
                                    <p><i class="fas fa-user me-2"></i><strong>Expert :</strong> M. Randria</p>
                                    <p><i class="fas fa-hourglass-half me-2"></i><strong>Durée :</strong> 30 minutes</p>
                                </div>
                                <div class="program-actions">
                                    <a href="#" class="btn btn-primary disabled"><i class="fas fa-clock me-2"></i>Bientôt disponible</a>
                                    <button class="btn btn-outline-secondary" data-program-title="Travailler à Mada" onclick="showProgramInfo(this.dataset)"><i class="fas fa-info-circle me-2"></i>Détails</button>
