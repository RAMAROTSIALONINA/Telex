                                <div class="program-info">
                                    <p><i class="far fa-clock me-2"></i><strong>Diffusion :</strong> Vendredi 19h</p>
                                    <p><i class="fas fa-user me-2"></i><strong>Présentation :</strong> Léa & Jules</p>
                                    <p><i class="fas fa-hourglass-half me-2"></i><strong>Durée :</strong> 25 minutes</p>
                                </div>
                                <div class="program-actions">
                                    <a href="#" class="btn btn-primary disabled"><i class="fas fa-clock me-2"></i>Bientôt disponible</a>
                                    <button class="btn btn-outline-secondary" data-program-title="Culture & Identité" onclick="showProgramInfo(this.dataset)"><i class="fas fa-info-circle me-2"></i>Détails</button>
