                                <i class="fas fa-search me-2"></i>Rechercher
                            </button>
                        </div>
                        <div class="text-start mt-2">
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                Exemples: "info", "débat", "culture", "sport", "environnement"
                            </small>
