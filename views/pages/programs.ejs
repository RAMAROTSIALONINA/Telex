<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Programmes - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    
    <!-- STYLES NAVIGATION UNIFIÉS - AMÉLIORÉS -->
    <style>
        /* ===== NAVBAR UNIFIÉE - SIMPLIFIÉE ===== */
        .navbar-baume {
            margin-bottom: 0;
            padding-bottom: 0;
            border-bottom: none;
            box-shadow: none;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
        }
        
        body {
            padding-top: 0;
            margin-top: 0;
        }
        
        .navbar-baume .navbar-brand {
            color: #3AAFA9;
            font-weight: 700;
            font-size: 1.8rem;
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
        }

        .navbar-baume .navbar-brand:hover {
            color: #c1121f;
            transform: translateY(-1px);
        }

        .navbar-baume .navbar-brand img {
            height: 35px;
            width: auto;
            max-width: 140px;
            margin-right: 10px;
            margin-left: -8px;
            transform: scale(1.3);
            transform-origin: center;
        }

        .navbar-baume .navbar-nav .nav-link {
            color: white;
            font-weight: 600;
            font-size: 0.9rem;
            font-family: 'League Spartan', sans-serif;
            text-transform: uppercase;
            padding: 6px 12px;
            margin: 0 3px;
            border-radius: 6px;
            transition: all 0.3s ease;
            position: relative;
        }

        .navbar-baume .navbar-nav .nav-link i {
            color: white;
            margin-right: 6px;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

        .navbar-baume .navbar-nav .nav-link:hover {
            color: white;
            background: #dc3545;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
        }

        .navbar-baume .navbar-nav .nav-link:hover i {
            color: white;
            transform: scale(1.1);
        }

        .navbar-baume .navbar-nav .nav-link.active {
            color: white;
            background: #dc3545;
            font-weight: 600;
            border-radius: 8px;
        }

        .navbar-baume .navbar-nav .nav-link.active i {
            color: white;
        }

        .navbar-baume .navbar-toggler {
            border: 1px solid #3AAFA9;
            background: transparent;
            padding: 0.5rem 0.75rem;
        }

        .navbar-baume .navbar-toggler i {
            color: #3AAFA9;
            font-size: 1.5rem;
        }

        .navbar-baume .navbar-toggler:hover {
            background-color: rgba(58, 175, 169, 0.1);
        }

        .navbar-baume .navbar-toggler:hover i {
            color: #256a66;
        }

        .navbar-baume .dropdown-menu {
            border: 1px solid rgba(58, 175, 169, 0.2);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        .navbar-baume .dropdown-item {
            color: #3AAFA9;
            transition: all 0.3s ease;
        }

        .navbar-baume .dropdown-item:hover {
            background-color: #FFD700;
            color: white;
            padding-left: 1.8rem;
        }

        .navbar-baume .dropdown-item i {
            color: #3AAFA9;
            margin-right: 8px;
        }

        .navbar-baume .dropdown-item:hover i {
            color: white;
        }

        @media (max-width: 991.98px) {
            .navbar-baume .navbar-nav {
                padding: 0.8rem 0;
            }
            
            .navbar-baume .navbar-nav .nav-link {
                text-align: center;
                padding: 10px;
                margin: 3px 0;
                font-size: 0.85rem;
            }
            
            .navbar-baume .navbar-nav .nav-link i {
                margin-right: 6px;
                width: 18px;
                font-size: 0.85rem;
            }
        }

        @media (max-width: 576px) {
            .navbar-baume .navbar-brand {
                font-size: 1.2rem;
            }
            
            .navbar-baume .navbar-brand img {
                height: 25px;
                width: auto;
                max-width: 90px;
                transform: scale(1.2);
                transform-origin: center;
            }
        }
    </style>
    
    <style>
        /* ===== STYLES POUR LES PROGRAMMES ===== */
        :root {
            --telex-red: #E63946;
            --telex-blue: #1D3557;
            --telex-light: #A8DADC;
            
            /* Couleurs des 10 programmes principaux */
            --info-red: #dc2626;
            --info-red-light: #ef4444;
            --decryptage-yellow: #ca8a04;
            --decryptage-yellow-light: #fbbf24;
            --debat-pink: #db2777;
            --debat-pink-light: #ec4899;
            --societe-gray: #4b5563;
            --societe-gray-light: #6b7280;
            --education-blue: #0891b2;
            --education-blue-light: #06b6d4;
            --jeunesse-blue: #2563eb;
            --jeunesse-blue-light: #3b82f6;
            --environnement-green: #059669;
            --environnement-green-light: #10b981;
            --culture-violet: #7c3aed;
            --culture-violet-light: #8b5cf6;
            --economie-cyan: #06b6d4;
            --economie-cyan-light: #22d3ee;
            --sport-orange: #ea580c;
            --sport-orange-light: #f97316;
        }

        /* ===== HERO SECTION ===== */
        .page-hero {
            padding: 80px 0 40px;
            min-height: 280px;
            background: linear-gradient(135deg, #2F3F59 0%, #3A4E6B 100%);
            color: white;
            position: relative;
            overflow: hidden;
            margin-top: 0;
        }
        
        /* Images décoratives sur les côtés */
        .hero-side-image {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            z-index: 1;
            opacity: 0.8;
            transition: opacity 0.5s ease-in-out;
        }

        .hero-left-image {
            left: 30px;
            width: 150px;
            height: 150px;
        }

        .hero-right-image {
            right: 30px;
            width: 150px;
            height: 150px;
        }

        .hero-side-image img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            border-radius: 15px;
            box-shadow: 0 6px 25px rgba(0, 0, 0, 0.3);
            background: rgba(255, 255, 255, 0.1);
            padding: 5px;
            filter: brightness(1.1) contrast(1.2);
        }

        @media (max-width: 768px) {
            .hero-side-image {
                width: 100px;
                height: 100px;
                opacity: 0.7;
            }
            
            .hero-left-image {
                left: 15px;
            }
            
            .hero-right-image {
                right: 15px;
            }
            
            .page-hero {
                padding: 20px 0 15px;
                min-height: 140px;
            }
        }

        @media (max-width: 576px) {
            .hero-side-image {
                width: 80px;
                height: 80px;
                opacity: 0.6;
            }
            
            .hero-left-image {
                left: 10px;
            }
            
            .hero-right-image {
                right: 10px;
            }
            
            .page-hero {
                padding: 15px 0 10px;
                min-height: 120px;
            }
        }

        /* Barre de recherche */
        .search-container {
            max-width: 600px;
            margin: 0 auto 30px;
            position: relative;
            z-index: 1000;
            pointer-events: auto !important;
        }

        .search-container .input-group {
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            border-radius: 50px;
            overflow: hidden;
            position: relative;
            z-index: 100;
            pointer-events: auto !important;
        }

        .search-container .form-control {
            border: none;
            padding: 15px 20px;
            font-size: 1rem;
            background: rgba(255,255,255,0.95);
            border-radius: 50px 0 0 50px;
            transition: all 0.3s ease;
            pointer-events: auto !important;
            user-select: text !important;
            -webkit-user-select: text !important;
            -moz-user-select: text !important;
            -ms-user-select: text !important;
            position: relative;
            z-index: 101;
        }

        .search-container .form-control:focus {
            background: rgba(255,255,255,1);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
            outline: 2px solid rgba(59,130,246,0.3);
            transform: scale(1.02);
            z-index: 102;
        }

        .search-container .btn-telex {
            border-radius: 0 50px 50px 0;
            padding: 15px 25px;
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            border: none;
            color: white;
            font-weight: 600;
            transition: all 0.3s;
        }

        .search-container .btn-telex:hover {
            background: linear-gradient(135deg, #ff6b6b, var(--telex-red));
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(230,57,70,0.4);
        }

        .no-results {
            text-align: center;
            padding: 60px 20px;
            color: #6c757d;
            display: none;
            width: 100%;
        }

        .no-results i {
            font-size: 4rem;
            margin-bottom: 20px;
            color: #dee2e6;
        }

        .no-results h5 {
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        /* Cartes de programme */
        .program-card {
            transition: all 0.3s ease;
            display: block;
        }

        .program-card.hidden {
            display: none !important;
        }

        .program-card.clickable-program {
            cursor: pointer;
        }

        .program-card.clickable-program:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }

        .program-card.clickable-program:active {
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        /* ===== CARDS PROGRAMMES - HAUTEUR AUTOMATIQUE CORRIGÉE ===== */
        .program-detail-card {
            background: white;
            border-radius: 15px;
            padding: 1.5rem;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            height: auto;
            min-height: auto;
            max-height: none;
            display: flex;
            flex-direction: column;
            align-items: center;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .program-detail-card:hover {
            transform: translateY(-15px) scale(1.02);
            box-shadow: 0 20px 50px rgba(230, 57, 70, 0.3);
        }

        /* Titre et badge */
        .program-title-section {
            text-align: center;
            margin-bottom: 15px;
            padding: 12px;
            background: var(--telex-blue);
            border-radius: 12px;
            border-bottom: 3px solid var(--telex-red);
            flex-shrink: 0;
            width: 100%;
        }

        .program-title-section h3 {
            font-size: 1.3rem;
            font-weight: 700;
            color: white;
            margin-bottom: 8px;
            line-height: 1.3;
        }

        .program-title-section .program-badge {
            margin-bottom: 0;
        }

        /* Section média (image/vidéo) */
        .program-media-section {
            display: flex;
            justify-content: center;
            margin-bottom: 15px;
            position: relative;
            width: 100%;
            flex-shrink: 0;
        }

        .program-media-section .program-image-wrapper {
            width: 100%;
            height: 180px;
            margin: 0;
            flex-shrink: 0;
            overflow: hidden;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border: none !important;
            border-radius: 0 !important;
            outline: none !important;
            box-shadow: none !important;
            padding: 0;
        }

        .program-media-section .video-container {
            width: 100%;
            max-width: none;
            margin: 0;
            height: 180px;
            flex-shrink: 0;
            overflow: hidden;
            border: none;
            border-radius: 0;
        }

        .program-image {
            width: 100%;
            height: 100%;
            object-fit: contain;
            transition: transform 0.3s ease;
            border: none !important;
            border-radius: 0 !important;
            outline: none !important;
            box-shadow: none !important;
            display: block;
            margin: 0;
            max-width: 100%;
            max-height: 100%;
        }

        .program-detail-card:hover .program-image {
            transform: scale(1.05);
        }

        .program-video-player {
            width: 100%;
            height: 100%;
            background: transparent;
            border: none;
            object-fit: contain;
        }

        .program-video-player iframe,
        .program-video-player video {
            width: 100%;
            height: 100%;
            border: none;
            object-fit: contain;
        }

        .replay-badge {
            position: absolute;
            top: 8px;
            right: 8px;
            background: rgba(25,135,84,0.95);
            color: white;
            padding: 4px 8px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 600;
            z-index: 3;
            backdrop-filter: blur(4px);
        }

        /* Corps de la carte */
        .program-body {
            flex: 1;
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        /* Badge de diffusion */
        .broadcast-badge {
            margin-bottom: 12px;
            flex-shrink: 0;
        }

        /* Description */
        .program-description {
            margin-bottom: 12px;
            flex-shrink: 1;
        }

        .program-description p {
            color: #4a5568;
            line-height: 1.5;
            margin-bottom: 5px;
            font-size: 0.9rem;
            text-align: center;
        }

        /* Informations */
        .program-info {
            background: #f8fafc;
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 15px;
            flex-shrink: 1;
        }

        .program-info p {
            margin-bottom: 6px;
            font-size: 0.85rem;
            color: #475569;
            text-align: center;
        }

        .program-info p:last-child {
            margin-bottom: 0;
        }

        .program-info i {
            width: 20px;
            color: var(--telex-red);
        }

        /* Alertes */
        .alert {
            border-radius: 12px;
            padding: 10px 12px;
            margin-bottom: 12px;
            border: none;
            font-size: 0.85rem;
        }

        .alert-info {
            background: linear-gradient(135deg, #e0f2fe, #bae6fd);
            color: #075985;
        }

        .alert-secondary {
            background: linear-gradient(135deg, #f8f9fa, #e9ecef);
            color: #495057;
        }

        /* Boutons d'action - toujours en bas */
        .program-actions {
            display: flex;
            gap: 12px;
            margin-top: auto;
            flex-wrap: wrap;
            padding-top: 10px;
            flex-shrink: 0;
        }

        .program-actions .btn {
            flex: 1;
            padding: 10px 20px;
            font-size: 0.9rem;
            border-radius: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            border: none;
            color: white;
            font-weight: 600;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(59,130,246,0.4);
        }

        .btn-outline-secondary {
            background: transparent;
            color: #64748b;
            border: 2px solid #e2e8f0;
        }

        .btn-outline-secondary:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }

        .btn.disabled {
            opacity: 0.65;
            pointer-events: none;
        }

        /* Badges */
        .badge {
            padding: 6px 12px;
            font-size: 0.75rem;
            font-weight: 600;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .badge.bg-info { background-color: #0dcaf0 !important; color: #000; }
        .badge.bg-warning { background-color: #ffc107 !important; color: #000; }
        .badge.bg-success { background-color: #198754 !important; }
        .badge.bg-danger { background-color: #dc3545 !important; }
        .badge.bg-secondary { background-color: #6c757d !important; }

        /* Badges programmes */
        .program-badge {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 25px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: white;
            border: 2px solid rgba(255,255,255,0.2);
            cursor: default;
            pointer-events: none;
        }

        .badge-information { background: linear-gradient(135deg, #dc2626, #ef4444); }
        .badge-decryptage { background: linear-gradient(135deg, #ca8a04, #fbbf24); color: #000; }
        .badge-debats { background: linear-gradient(135deg, #FF8A65, #FFAB91); }
        .badge-societe { background: linear-gradient(135deg, #6b7280, #9ca3af); }
        .badge-education { background: linear-gradient(135deg, #0ea5e9, #38bdf8); }
        .badge-jeunesse { background: linear-gradient(135deg, #4CAF50, #66BB6A); }
        .badge-environnement { background: linear-gradient(135deg, #059669, #10b981); }
        .badge-culture { background: linear-gradient(135deg, #7c3aed, #a78bfa); }
        .badge-economie { background: linear-gradient(135deg, #0891b2, #06b6d4); }
        .badge-sport { background: linear-gradient(135deg, #ea580c, #f97316); }
        .badge-default { background: linear-gradient(135deg, #6b7280, #9ca3af); }

        /* Grille des programmes */
        .row {
            margin-left: -15px;
            margin-right: -15px;
        }

        .col-lg-6.mb-4.program-card {
            padding-left: 15px;
            padding-right: 15px;
            margin-bottom: 30px;
            flex: 0 0 50%;
            max-width: 50%;
        }

        .table {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }

        .table thead {
            background: var(--telex-blue);
            color: white;
        }

        .table-dark {
            background: var(--telex-blue);
        }

        .border-top {
            border-top: 2px solid #e2e8f0 !important;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .col-lg-6.mb-4.program-card {
                flex: 0 0 100%;
                max-width: 100%;
            }

            .program-detail-card {
                padding: 1.2rem;
            }

            .program-title-section h3 {
                font-size: 1.1rem;
            }

            .program-media-section .program-image-wrapper,
            .program-media-section .video-container {
                height: 160px;
            }

            .program-info p {
                font-size: 0.8rem;
                margin-bottom: 4px;
            }

            .program-actions .btn {
                padding: 8px 12px;
                font-size: 0.85rem;
            }
        }

        @media (max-width: 480px) {
            .program-detail-card {
                padding: 1rem;
            }

            .program-title-section {
                padding: 8px;
            }

            .program-title-section h3 {
                font-size: 1rem;
            }

            .program-media-section .program-image-wrapper,
            .program-media-section .video-container {
                height: 140px;
            }

            .program-info {
                padding: 8px;
            }

            .program-info p {
                font-size: 0.75rem;
            }

            .program-actions {
                flex-direction: column;
                gap: 8px;
            }

            .program-actions .btn {
                width: 100%;
                padding: 8px 12px;
                font-size: 0.8rem;
            }
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .program-detail-card {
            animation: fadeIn 0.5s ease-out;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-baume fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/Telex.png" alt="Logo Telex" class="logo-img">
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu" style="border: none; color: var(--baume-primary);">
                <i class="fas fa-bars"></i>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            <i class="fas fa-home"></i>Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">
                            <i class="fas fa-info-circle"></i>À propos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/programs">
                            <i class="fas fa-tv"></i>Programmes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/gallery">
                            <i class="fas fa-images"></i>Galerie
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/album">
                            <i class="fas fa-book"></i>Album
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/baume-de-la-foi">
                            <i class="fas fa-cross"></i>Baume de la Foi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/news">
                            <i class="fas fa-newspaper"></i>Actualités
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact">
                            <i class="fas fa-envelope"></i>Contact
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="page-hero">
        <div class="hero-side-image hero-left-image">
            <img id="heroLeftImage" src="/images/11.png" alt="Logo Telex">
        </div>
        
        <div class="hero-side-image hero-right-image">
            <img id="heroRightImage" src="/images/Telex.png" alt="Telex">
        </div>
        
        <div class="container">
            <div class="row align-items-center">
