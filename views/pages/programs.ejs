                <% } %>
            </div>

            <!-- Grille des programmes -->
            <div class="mt-5 pt-5 border-top">
                <h2 class="text-center mb-4">Grille des Programmes</h2>
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Jour</th>
                                <th>Heure</th>
                                <th>Émission</th>
                                <th>Type</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% 
                            const programSchedule = {};
                            const joursSemaine = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi', 'Dimanche'];
                            
                            joursSemaine.forEach(jour => {
                                programSchedule[jour] = [];
                            });
                            
                            const defaultPrograms = [
                                { jour: 'Lundi', heure: '12:00', emission: '1 notion en 3 minutes', type: 'Éducatif', typeClass: 'education' },
                                { jour: 'Lundi', heure: '18:00', emission: 'TELEX Actus', type: 'Information', typeClass: 'information' },
                                { jour: 'Mardi', heure: '20:00', emission: 'Décryptage & Reportages', type: 'Décryptage', typeClass: 'decryptage' },
                                { jour: 'Mercredi', heure: '18:00', emission: 'Zoom Écologie', type: 'Environnement', typeClass: 'environnement' },
                                { jour: 'Mercredi', heure: '20:00', emission: 'Face à Face', type: 'Débat', typeClass: 'debats' },
                                { jour: 'Jeudi', heure: '18:00', emission: 'Travailler à Mada', type: 'Économie', typeClass: 'economie' },
                                { jour: 'Jeudi', heure: '19:00', emission: 'À Cœur Ouvert', type: 'Sociétal', typeClass: 'societe' },
                                { jour: 'Vendredi', heure: '17:00', emission: 'La Question des Jeunes', type: 'Jeunesse', typeClass: 'jeunesse' },
                                { jour: 'Vendredi', heure: '19:00', emission: 'Culture & Identité', type: 'Culture', typeClass: 'culture' },
                                { jour: 'Samedi', heure: '17:00', emission: 'Telex Sports', type: 'Sport', typeClass: 'sport' }
                            ];
                            
                            let hasDbPrograms = false;
                            if (schedulePrograms && schedulePrograms.length > 0) {
                                schedulePrograms.forEach(program => {
                                    if (program.broadcast_type === 'scheduled' && program.schedule_time && program.program_date) {
                                        hasDbPrograms = true;
                                        const programDate = new Date(program.program_date);
                                        const jourIndex = programDate.getDay();
                                        const jourName = joursSemaine[jourIndex === 0 ? 6 : jourIndex - 1];
                                        
                                        let typeClass = 'default';
                                        let typeName = program.program_type || 'Programme';
                                        
                                        switch(program.program_type) {
                                            case 'Programme d\'Information': typeClass = 'information'; typeName = 'Information'; break;
                                            case 'Programme Décryptage & Reportages': typeClass = 'decryptage'; typeName = 'Décryptage'; break;
                                            case 'Programme Débats': typeClass = 'debats'; typeName = 'Débat'; break;
                                            case 'Programme Humain & Sociétal': typeClass = 'societe'; typeName = 'Sociétal'; break;
                                            case 'Programme Éducatif': typeClass = 'education'; typeName = 'Éducatif'; break;
                                            case 'Programme Jeunesse': typeClass = 'jeunesse'; typeName = 'Jeunesse'; break;
                                            case 'Programme Environnement': typeClass = 'environnement'; typeName = 'Environnement'; break;
                                            case 'Programme Culture & Identité': typeClass = 'culture'; typeName = 'Culture'; break;
                                            case 'Programme Économie & Travail': typeClass = 'economie'; typeName = 'Économie'; break;
                                            case 'Programme Sport': typeClass = 'sport'; typeName = 'Sport'; break;
                                        }
                                        
                                        programSchedule[jourName].push({
                                            title: program.title,
                                            time: program.schedule_time,
                                            type: typeName,
                                            typeClass: typeClass
                                        });
                                    }
                                });
                            }
                            
                            if (!hasDbPrograms) {
                                defaultPrograms.forEach(program => {
                                    programSchedule[program.jour].push({
                                        title: program.emission,
                                        time: program.heure,
                                        type: program.type,
                                        typeClass: program.typeClass
                                    });
                                });
                            }
                            
                            let hasPrograms = false;
                            joursSemaine.forEach(jour => {
                                if (programSchedule[jour] && programSchedule[jour].length > 0) {
                                    hasPrograms = true;
                                    programSchedule[jour].sort((a, b) => {
                                        const timeToMinutes = (timeStr) => {
                                            if (!timeStr) return 0;
                                            if (timeStr.includes(':')) {
                                                const [hours, minutes] = timeStr.split(':');
                                                return parseInt(hours) * 60 + parseInt(minutes || 0);
                                            } else if (timeStr.includes('h')) {
                                                const [hours, minutes] = timeStr.split('h');
                                                return parseInt(hours) * 60 + parseInt(minutes || 0);
                                            }
                                            return 0;
                                        };
                                        return timeToMinutes(a.time) - timeToMinutes(b.time);
                                    });
                                    
                                    programSchedule[jour].forEach(program => { %>
                                        <tr>
                                            <td><%= jour %></td>
                                            <td><%= program.time %></td>
                                            <td><%= program.title %></td>
                                            <td><span class="badge badge-<%= program.typeClass %>"><%= program.type %></span></td>
                                        </tr>
                                    <% });
                                }
                            });
                            
                            if (!hasPrograms) { %>
                                <tr>
                                    <td colspan="4" class="text-center text-muted">
                                        <i class="fas fa-calendar-alt me-2"></i>
                                        Aucun programme programmé pour le moment
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        async function incrementProgramView(programId) {
            try {
                const programCard = document.querySelector(`[data-program-id="${programId}"]`);
                if (programCard) {
                    programCard.style.transform = 'scale(0.98)';
                    setTimeout(() => {
                        programCard.style.transform = '';
                    }, 150);
                }
                
                const response = await fetch(`/api/programs/${programId}/view`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    const result = await response.json();
                    if (programCard) {
                        programCard.style.boxShadow = '0 8px 30px rgba(0, 123, 255, 0.3)';
                        setTimeout(() => {
                            programCard.style.boxShadow = '';
                        }, 300);
                    }
                }
            } catch (error) {
                console.error('Erreur:', error);
            }
        }

        // Forcer "Tout" actif par défaut au chargement
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.hero-cat-btn').forEach(b => b.classList.remove('active'));
            var btnTout = document.querySelector('.hero-cat-btn[onclick*="\'all\'"]');
            if (btnTout) btnTout.classList.add('active');
        });

        // Slideshow automatique
        (function() {
            var slides = document.querySelectorAll('.hero-slide');
            var dots   = document.querySelectorAll('.hero-dot');
            var current = 0;
            var timer;

            function goTo(idx) {
                slides[current].classList.remove('active');
                dots[current].classList.remove('active');
                current = (idx + slides.length) % slides.length;
                slides[current].classList.add('active');
                dots[current].classList.add('active');
            }

            window.goToSlide = function(idx) {
                clearInterval(timer);
                goTo(idx);
                timer = setInterval(function() { goTo(current + 1); }, 5000);
            };

            if (slides.length > 1) {
                timer = setInterval(function() { goTo(current + 1); }, 5000);
            }
        })();


        function filterCategory(cat, btn) {
            document.querySelectorAll('.hero-cat-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const si = document.getElementById('searchInput'); if (si) si.value = '';
            const cards = document.querySelectorAll('#programsList [data-type]');
            cards.forEach(card => {
                const type = card.dataset.type || '';
                const match = cat === 'all' || type.includes(cat);
                card.style.display = match ? '' : 'none';
            });
            const noResults = document.getElementById('noResults');
            const visible = [...cards].filter(c => c.style.display !== 'none');
            if (noResults) noResults.style.display = visible.length === 0 ? 'block' : 'none';
        }

        function searchPrograms() {
            const searchInput = document.getElementById('searchInput');
            if (!searchInput) return;
            
            const searchTerm = searchInput.value.toLowerCase().trim();
            const programCards = document.querySelectorAll('.program-card');
            const noResults = document.getElementById('noResults');
            let visibleCount = 0;
            
            if (searchTerm === '') {
                programCards.forEach(card => {
                    card.style.display = 'block';
                    visibleCount++;
                });
                if (noResults) noResults.style.display = 'none';
                return;
            }
            
            programCards.forEach(card => {
                const title = (card.getAttribute('data-title') || '').toLowerCase();
                const type = (card.getAttribute('data-type') || '').toLowerCase();
                const description = (card.getAttribute('data-description') || '').toLowerCase();
                
                const searchText = `${title} ${type} ${description}`;
                const matches = searchText.includes(searchTerm);
                
                if (matches) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });
            
            if (noResults) {
                noResults.style.display = visibleCount === 0 ? 'block' : 'none';
            }
        }

        function resetSearch() {
            const searchInput = document.getElementById('searchInput');
            if (searchInput) searchInput.value = '';
            
            const programCards = document.querySelectorAll('.program-card');
            programCards.forEach(card => {
                card.style.display = 'block';
            });
            
            const noResults = document.getElementById('noResults');
            if (noResults) noResults.style.display = 'none';
        }

        function showProgramInfo(dataset) {
            const old = document.getElementById('progDetailModal');
            if (old) old.remove();

            let formattedDate = '';
            if (dataset.programDate) {
                try {
                    formattedDate = new Date(dataset.programDate).toLocaleDateString('fr-FR', {
                        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
                    });
                } catch(e) { formattedDate = dataset.programDate; }
            }

            const imgSrc = dataset.programImage || '/images/programmes.png';
            const cat = (dataset.programType || '').replace('Programme ', '');

            const metaItems = [
                dataset.programPresenter ? { label: dataset.programType && dataset.programType.includes('Débat') ? 'Animation' : 'Présentation', value: dataset.programPresenter } : null,
                dataset.programSchedule ? { label: 'Heure', value: dataset.programSchedule } : null,
                formattedDate        ? { label: 'Date', value: formattedDate } : null,
                dataset.programDuration ? { label: 'Durée', value: dataset.programDuration } : null,
            ].filter(Boolean);

            const metaHTML = metaItems.length ? `
                <div class="prog-modal-meta">
                    ${metaItems.map(m => `
                        <div class="prog-modal-meta-item">
                            <div class="prog-modal-meta-label">${m.label}</div>
                            <div class="prog-modal-meta-value">${m.value}</div>
                        </div>`).join('')}
                </div>` : '';

            const backdrop = document.createElement('div');
            backdrop.className = 'prog-modal-backdrop';
            backdrop.id = 'progDetailModal';
            backdrop.innerHTML = `
                <div class="prog-modal" style="position:relative;">
                    <button class="prog-modal-close" onclick="document.getElementById('progDetailModal').remove()">✕</button>
                    <div class="prog-modal-img">
                        <img src="${imgSrc}" alt="${dataset.programTitle || ''}" onerror="this.src='/images/programmes.png'">
                        <div class="prog-modal-img-overlay"></div>
                    </div>
                    <div class="prog-modal-content">
                        ${cat ? `<div class="prog-modal-cat">${cat}</div>` : ''}
                        <h2 class="prog-modal-title">${dataset.programTitle || 'Programme Telex'}</h2>
                        <div class="prog-modal-section-label">Introduction</div>
                        <p class="prog-modal-desc">${dataset.programDescription || 'Découvrez ce programme passionnant sur Telex.'}</p>
                        ${metaHTML}
                        <div class="prog-modal-actions">
                            ${dataset.programVideo
                                ? `<a href="${dataset.programVideo}" class="prog-modal-btn-watch" target="_blank"><i class="fas fa-play me-2"></i>Regarder</a>`
                                : `<span class="prog-modal-btn-watch" style="background:#94a3b8;cursor:default;"><i class="fas fa-clock me-2"></i>Bientôt disponible</span>`}
                            <button class="prog-modal-btn-close" onclick="document.getElementById('progDetailModal').remove()">Fermer</button>
                        </div>
                    </div>
                </div>`;

            backdrop.addEventListener('click', function(e) {
                if (e.target === backdrop) backdrop.remove();
            });
            document.body.appendChild(backdrop);
        }


        function initSearch() {
            const searchInput = document.getElementById('searchInput');
            if (searchInput) {
                searchInput.addEventListener('input', () => searchPrograms());
                searchInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') searchPrograms(); });
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            initSearch();
            
            const programCards = document.querySelectorAll('.program-card');
            programCards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(30px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.6s ease-out';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 100);
            });
            
            const images = document.querySelectorAll('.program-image');
            images.forEach(img => {
                img.addEventListener('error', function() {
                    if (!this.src.includes('/images/programmes.png')) {
                        this.src = '/images/programmes.png';
                    }
                });
            });
        });

        window.searchPrograms = searchPrograms;
        window.resetSearch = resetSearch;
        window.showProgramInfo = showProgramInfo;
        window.toggleDescription = toggleDescription;
        window.incrementProgramView = incrementProgramView;
    </script>
</body>
</html>