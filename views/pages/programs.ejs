                    <div class="col-lg-6 mb-4 program-card" 
                         data-title="culture express identité histoire politique madagascar"
                         data-type="culture identite art"
                         data-description="découverte de la scène culturelle étudiante musique cinéma théâtre expositions les talents de demain">
                        <div class="program-detail-card">
