<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Programmes - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
    
    <!-- STYLES NAVIGATION UNIFIÉS - AMÉLIORÉS -->
    
    <style>
        /* ===== STYLES POUR LES PROGRAMMES ===== */

        /* ===== HERO SECTION — SLIDESHOW + CONTENU CENTRÉ ===== */
        .page-hero {
            display: flex;
            color: white;
            overflow: hidden;
            background: linear-gradient(135deg, #457B9D 0%, #22385B 100%);
            min-height: 160px;
        }

        /* ---- Slideshow gauche ---- */
        .hero-slideshow {
            width: 38%;
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
            min-height: 160px;
            background: #1e3050;
        }

        .hero-slide {
            position: absolute;
            inset: 0;
            opacity: 0;
            transition: opacity 1.2s ease;
        }

        .hero-slide.active { opacity: 1; }

        .hero-slide img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            position: relative;
            z-index: 1;
        }

        .hero-slide-caption {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 36px 16px 14px;
            background: linear-gradient(transparent, rgba(0,0,0,0.75));
            z-index: 2;
        }

        .hero-slide-name {
            font-size: 0.75rem;
            font-weight: 700;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            text-shadow: 0 1px 4px rgba(0,0,0,0.5);
        }

        .hero-slide-dots {
            position: absolute;
            bottom: 12px;
            left: 14px;
            display: flex;
            gap: 7px;
            z-index: 3;
        }

        .hero-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255,255,255,0.4);
            border: 1px solid rgba(255,255,255,0.6);
            transition: background 0.3s, transform 0.3s;
            cursor: pointer;
        }

        .hero-dot.active {
            background: #fff;
            border-color: #fff;
            transform: scale(1.25);
        }

        /* ---- Contenu droit centré ---- */
        .hero-content {
            flex: 1;
            padding: 14px 24px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            position: relative;
            gap: 0;
        }

        .hero-content::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
            background-size: 32px 32px;
            pointer-events: none;
        }

        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(220,53,69,0.25);
            border: 1px solid rgba(220,53,69,0.6);
            color: #ffaaad;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 4px 12px;
            border-radius: 20px;
            margin-bottom: 0.4rem;
            position: relative;
            z-index: 1;
        }

        .page-hero h1 {
            font-size: 1.6rem;
            font-weight: 900;
            line-height: 1.1;
            letter-spacing: -0.02em;
            margin-bottom: 0.2rem;
            position: relative;
            z-index: 1;
        }

        .page-hero h1 em {
            font-style: normal;
            color: #dc3545;
        }

        .hero-stats-row {
            display: flex;
            align-items: center;
            gap: 0;
            margin: 0.4rem 0 0.6rem;
            position: relative;
            z-index: 1;
        }

        .hero-stat-item {
            text-align: center;
            padding: 0 16px;
        }

        .hero-stat-item:not(:last-child) {
            border-right: 1px solid rgba(255,255,255,0.35);
        }

        .hero-stat-num {
            font-size: 1.5rem;
            font-weight: 900;
            color: #fff;
            line-height: 1;
            display: block;
        }

        .hero-stat-lbl {
            font-size: 0.55rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.09em;
            color: rgba(255,255,255,0.6);
            display: block;
            margin-top: 2px;
        }

        .hero-divider {
            width: 36px;
            height: 3px;
            background: #dc3545;
            border-radius: 2px;
            margin: 0 auto 0.5rem;
            display: block;
            position: relative;
            z-index: 1;
        }

        /* Séparateur avant filtres */
        .hero-cats-label {
            font-size: 0.6rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: rgba(255,255,255,0.3);
            margin-bottom: 0.5rem;
            position: relative;
            z-index: 1;
        }

        /* Filtres catégorie */
        .hero-cats {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            justify-content: center;
            position: relative;
            z-index: 1;
        }

        .hero-cat-btn {
            font-size: 0.72rem;
            font-weight: 600;
            padding: 5px 14px;
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.18);
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.7);
            cursor: pointer;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .hero-cat-btn:hover {
            background: rgba(220,53,69,0.2);
            border-color: rgba(220,53,69,0.5);
            color: #fff;
        }

        .hero-cat-btn.active {
            background: #dc3545;
            border-color: #dc3545;
            color: #fff;
            box-shadow: 0 3px 10px rgba(220,53,69,0.4);
        }

        @media (max-width: 991px) {
            .page-hero { flex-direction: column; }
            .hero-slideshow { width: 100%; height: 160px; }
            .hero-content { padding: 20px 24px 18px; }
            .page-hero h1 { font-size: 1.6rem; }
            .hero-stat-item { padding: 0 12px; }
            .hero-stat-num { font-size: 1.3rem; }
        }

        @media (max-width: 576px) {
            .hero-slideshow { height: 130px; }
            .hero-content { padding: 16px 16px 14px; }
            .page-hero h1 { font-size: 1.4rem; }
            .hero-cat-btn { font-size: 0.66rem; padding: 4px 10px; }
            .hero-stat-item { padding: 0 10px; }
            .hero-stat-num { font-size: 1.1rem; }
        }

        /* Barre de recherche */
        .search-container {
            max-width: 560px;
            margin: 0 0 30px;
        }

        .search-container .input-group {
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            border-radius: 50px;
            overflow: hidden;
        }

        .search-container .form-control {
            border: none;
            padding: 15px 20px;
            font-size: 1rem;
            background: rgba(255,255,255,0.95);
            border-radius: 50px 0 0 50px;
            transition: background 0.3s ease;
        }

        .search-container .form-control:focus {
            background: #fff;
            box-shadow: none;
            outline: none;
        }

        .search-container .btn-telex {
            border-radius: 0 50px 50px 0;
            padding: 15px 25px;
            background: linear-gradient(135deg, var(--telex-red), #ff6b6b);
            border: none;
            color: white;
            font-weight: 600;
            transition: all 0.3s;
        }

        .search-container .btn-telex:hover {
            background: linear-gradient(135deg, #ff6b6b, var(--telex-red));
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(230,57,70,0.4);
        }

        /* ===== MODAL DÉTAIL — STYLE CAPTURE 1 ===== */
        .prog-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
            animation: fadeInBackdrop 0.2s ease;
        }

        @keyframes fadeInBackdrop { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideUpModal { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }

        .prog-modal {
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            width: 100%;
            max-width: 520px;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideUpModal 0.28s ease;
            box-shadow: 0 24px 60px rgba(0,0,0,0.35);
        }

        .prog-modal-img {
            width: 100%;
            height: 230px;
            overflow: hidden;
            position: relative;
            background: #22385B;
        }

        .prog-modal-img img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
            background: #0d1e36;
        }

        .prog-modal-img-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(0,0,0,0.08) 0%, rgba(0,0,0,0.55) 100%);
        }

        .prog-modal-close {
            position: absolute;
            top: 12px;
            right: 14px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: rgba(0,0,0,0.45);
            border: none;
            color: #fff;
            font-size: 1.1rem;
            line-height: 1;
            cursor: pointer;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .prog-modal-content {
            padding: 20px 24px 24px;
        }

        .prog-modal-cat {
            font-size: 0.62rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: #457B9D;
            margin-bottom: 6px;
        }

        .prog-modal-title {
            font-size: 1.35rem;
            font-weight: 800;
            color: #1a1a2e;
            margin-bottom: 12px;
            line-height: 1.2;
            letter-spacing: -0.02em;
        }

        .prog-modal-section-label {
            font-size: 0.62rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            color: #94a3b8;
            margin-bottom: 6px;
            padding-top: 14px;
            border-top: 1px solid #f1f5f9;
        }

        .prog-modal-desc {
            font-size: 0.88rem;
            color: #475569;
            line-height: 1.7;
            margin-bottom: 0;
        }

        .prog-modal-meta {
            margin-top: 14px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .prog-modal-meta-item {
            background: #f8fafc;
            border-radius: 8px;
            padding: 8px 12px;
            border-left: 3px solid #E63946;
        }

        .prog-modal-meta-label {
            font-size: 0.6rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #94a3b8;
            margin-bottom: 2px;
        }

        .prog-modal-meta-value {
            font-size: 0.82rem;
            font-weight: 600;
            color: #1a1a2e;
        }

        .prog-modal-actions {
            margin-top: 18px;
            display: flex;
            gap: 10px;
        }

        .prog-modal-btn-watch {
            flex: 1;
            background: #22385B;
            color: #fff;
            border: none;
            padding: 10px 18px;
            border-radius: 8px;
            font-size: 0.83rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            display: block;
        }

        .prog-modal-btn-watch:hover { background: #1a2d4a; color: #fff; }

        .prog-modal-btn-close {
            padding: 10px 18px;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
            background: #fff;
            color: #64748b;
            font-size: 0.83rem;
            font-weight: 600;
            cursor: pointer;
        }

        .no-results {
            text-align: center;
            padding: 60px 20px;
            color: #6c757d;
            display: none;
            width: 100%;
        }

        .no-results i {
            font-size: 4rem;
            margin-bottom: 20px;
            color: #dee2e6;
        }

        .no-results h5 {
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        /* Cartes de programme */
        .program-card {
            transition: all 0.3s ease;
            display: block;
        }

        .program-card.hidden {
            display: none !important;
        }

        .program-card.clickable-program {
            cursor: pointer;
        }

        .program-card.clickable-program:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }

        .program-card.clickable-program:active {
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        /* ===== CARDS PROGRAMMES — OPTION A : IMAGE HERO ===== */
        .program-detail-card {
            background: #fff;
            border-radius: 10px;
            padding: 0;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border: none;
        }

        .program-detail-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 40px rgba(34,56,91,0.18);
        }

        .program-title-section { display: none; }

        /* Média — image pleine largeur avec overlay */
        .program-media-section {
            position: relative;
            width: 100%;
            height: 185px;
            flex-shrink: 0;
            overflow: hidden;
            background: #22385B;
        }

        /* Gradient overlay sur l'image */
        .program-media-section::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, transparent 35%, rgba(0,0,0,0.72) 100%);
            z-index: 1;
            pointer-events: none;
        }

        /* Overlay : badge en haut + titre en bas */
        .media-overlay {
            position: absolute;
            inset: 0;
            z-index: 2;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 10px 12px 12px;
            pointer-events: none;
        }

        .media-cat-badge {
            align-self: flex-start;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #fff;
            background: #E63946;
            padding: 3px 10px;
            border-radius: 20px;
        }

        .media-status-badge {
            align-self: flex-start;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .media-title-block { }

        .media-title-block h3 {
            font-size: 1rem;
            font-weight: 700;
            color: #fff;
            line-height: 1.25;
            margin: 0;
            text-shadow: 0 1px 6px rgba(0,0,0,0.7);
            letter-spacing: 0.01em;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .media-broadcast-label {
            display: none;
        }

        .program-media-section .program-image-wrapper {
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .program-media-section .video-container {
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .program-image {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
            transition: transform 0.4s ease;
            background: #0d1e36;
        }

        .program-detail-card:hover .program-image {
            transform: scale(1.05);
        }

        .program-video-player {
            width: 100%;
            height: 100%;
            border: none;
            display: block;
        }

        .replay-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(22,101,52,0.9);
            color: #fff;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.65rem;
            font-weight: 600;
            z-index: 3;
        }

        /* Corps minimaliste */
        .program-body {
            order: 2;
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 6px 14px 12px;
        }

        .broadcast-badge { display: none; }

        .program-description {
            flex: 1;
            margin-bottom: 10px;
        }

        .program-description p {
            color: #475569;
            line-height: 1.55;
            font-size: 0.82rem;
            text-align: left;
            margin: 0;
        }

        .program-info { display: none; }

        /* Boutons */
        .program-actions {
            display: flex;
            gap: 8px;
            padding-top: 0;
        }

        .program-actions .btn {
            flex: 1;
            padding: 8px 14px;
            font-size: 0.78rem;
            font-weight: 600;
            border-radius: 7px;
            letter-spacing: 0.03em;
        }

        .btn-primary {
            background: #22385B;
            border: none;
            color: #fff;
        }

        .btn-primary:hover {
            background: #1a2d4a;
            color: #fff;
        }

        .btn-outline-secondary {
            background: transparent;
            color: #64748b;
            border: 2px solid #e2e8f0;
        }

        .btn-outline-secondary:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }

        .btn.disabled {
            opacity: 0.65;
            pointer-events: none;
        }

        /* Badges */
        .badge {
            padding: 6px 12px;
            font-size: 0.75rem;
            font-weight: 600;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .badge.bg-info { background-color: #0dcaf0 !important; color: #000; }
        .badge.bg-warning { background-color: #ffc107 !important; color: #000; }
        .badge.bg-success { background-color: #198754 !important; }
        .badge.bg-danger { background-color: #dc3545 !important; }
        .badge.bg-secondary { background-color: #6c757d !important; }

        /* Badges programmes */
        .program-badge {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 25px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: white;
            border: 2px solid rgba(255,255,255,0.2);
            cursor: default;
            pointer-events: none;
        }

        .badge-information { background: linear-gradient(135deg, #dc2626, #ef4444); }
        .badge-decryptage { background: linear-gradient(135deg, #ca8a04, #fbbf24); color: #000; }
        .badge-debats { background: linear-gradient(135deg, #FF8A65, #FFAB91); }
        .badge-societe { background: linear-gradient(135deg, #6b7280, #9ca3af); }
        .badge-education { background: linear-gradient(135deg, #0ea5e9, #38bdf8); }
        .badge-jeunesse { background: linear-gradient(135deg, #4CAF50, #66BB6A); }
        .badge-environnement { background: linear-gradient(135deg, #059669, #10b981); }
        .badge-culture { background: linear-gradient(135deg, #7c3aed, #a78bfa); }
        .badge-economie { background: linear-gradient(135deg, #0891b2, #06b6d4); }
        .badge-sport { background: linear-gradient(135deg, #ea580c, #f97316); }
        .badge-default { background: linear-gradient(135deg, #6b7280, #9ca3af); }

        /* Grille des programmes */
        #programsList {
            row-gap: 1.5rem;
        }

        .table {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }

        .table thead {
            background: var(--telex-blue);
            color: white;
        }

        .table-dark {
            background: var(--telex-blue);
        }

        .border-top {
            border-top: 2px solid #e2e8f0 !important;
        }

        /* ===== RESPONSIVE CARTES ===== */

        /* Tablette : 2 colonnes, image un peu moins haute */
        @media (max-width: 768px) {
            .program-media-section { height: 165px; }
            .media-title-block h3 { font-size: 0.92rem; }
            .program-body { padding: 6px 12px 10px; }
            .program-actions .btn { padding: 7px 10px; font-size: 0.75rem; }
            .prog-modal { max-width: 100%; }
            .prog-modal-img { height: 190px; }
            .prog-modal-content { padding: 16px 18px 20px; }
            .prog-modal-title { font-size: 1.15rem; }
            .prog-modal-meta { grid-template-columns: 1fr 1fr; }
        }

        /* Mobile : 1 colonne, image réduite */
        @media (max-width: 576px) {
            .program-media-section { height: 180px; }
            .media-cat-badge { font-size: 0.6rem; padding: 2px 8px; }
            .media-title-block h3 { font-size: 0.88rem; }
            .media-overlay { padding: 8px 10px 10px; }
            .program-body { padding: 6px 10px 10px; }
            .program-description p { font-size: 0.78rem; }
            .program-actions .btn { font-size: 0.73rem; padding: 6px 8px; }
            .prog-modal-img { height: 160px; }
            .prog-modal-content { padding: 14px 16px 18px; }
            .prog-modal-title { font-size: 1.05rem; }
            .prog-modal-meta { grid-template-columns: 1fr; }
            .prog-modal-actions { flex-direction: column; }
        }

            .program-actions {
                flex-direction: column;
                gap: 8px;
            }

            .program-actions .btn {
                width: 100%;
                padding: 8px 12px;
                font-size: 0.8rem;
            }
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .program-detail-card {
            animation: fadeIn 0.5s ease-out;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include('../partials/navbar') %>

    <!-- Hero Section — Slideshow + Contenu centré -->
    <section class="page-hero">

        <!-- Slideshow gauche -->
        <div class="hero-slideshow">
            <div class="hero-slide active">
                <img src="/images/D%C3%A9bat.png" alt="Débat">
                <div class="hero-slide-caption"><span class="hero-slide-name">Débat</span></div>
            </div>
            <div class="hero-slide">
                <img src="/images/programmes.png" alt="Programmes">
                <div class="hero-slide-caption"><span class="hero-slide-name">Programmes</span></div>
            </div>
            <div class="hero-slide">
                <img src="/images/mirco2.png" alt="Micro">
                <div class="hero-slide-caption"><span class="hero-slide-name">Micro</span></div>
            </div>
            <div class="hero-slide">
                <img src="/images/TELEX%20INTEGRATION.png" alt="Intégration">
                <div class="hero-slide-caption"><span class="hero-slide-name">Intégration</span></div>
            </div>
            <!-- Indicateurs -->
            <div class="hero-slide-dots">
                <div class="hero-dot active" onclick="goToSlide(0)"></div>
                <div class="hero-dot" onclick="goToSlide(1)"></div>
                <div class="hero-dot" onclick="goToSlide(2)"></div>
                <div class="hero-dot" onclick="goToSlide(3)"></div>
            </div>
        </div>

        <!-- Contenu centré droite -->
        <div class="hero-content">
            <h1>Nos <em>Programmes</em></h1>

            <!-- Stats inline -->
            <div class="hero-stats-row">
                <div class="hero-stat-item">
                    <span class="hero-stat-num"><%= programs ? programs.length : 10 %></span>
                    <span class="hero-stat-lbl">Émissions</span>
                </div>
                <div class="hero-stat-item">
                    <span class="hero-stat-num">7</span>
                    <span class="hero-stat-lbl">Catégories</span>
                </div>
                <div class="hero-stat-item">
                    <span class="hero-stat-num">HD</span>
                    <span class="hero-stat-lbl">Qualité</span>
                </div>
            </div>

            <div class="hero-divider"></div>

            <div class="hero-cats-label">Filtrer par catégorie</div>

            <div class="hero-cats">
                <button class="hero-cat-btn active" onclick="filterCategory('all', this)">Tout</button>
                <button class="hero-cat-btn" onclick="filterCategory('information', this)">Info</button>
                <button class="hero-cat-btn" onclick="filterCategory('decryptage', this)">Décryptage</button>
                <button class="hero-cat-btn" onclick="filterCategory('débats', this)">Débats</button>
                <button class="hero-cat-btn" onclick="filterCategory('culture', this)">Culture</button>
                <button class="hero-cat-btn" onclick="filterCategory('environnement', this)">Environnement</button>
                <button class="hero-cat-btn" onclick="filterCategory('éducatif', this)">Éducatif</button>
            </div>
        </div>

    </section>

    <!-- Section Programmes -->
    <section class="section py-5">
        <div class="container">
            <div id="noResults" class="no-results">
                <i class="fas fa-search"></i>
                <h5>Aucun programme trouvé</h5>
                <p>Essayez d'autres mots-clés ou réinitialisez votre recherche</p>
                <button class="btn btn-outline-secondary mt-3" onclick="resetSearch()">
                    <i class="fas fa-times me-2"></i>Effacer la recherche
                </button>
            </div>

            <div class="row" id="programsList">
                <% if (programs && programs.length > 0) { %>
                    <% programs.forEach(program => { 
                        let programImage = '/images/programmes.png';
                        let badgeClass = 'default';
                        
                        switch(program.program_type) {
                            case 'Programme d\'Information':
                                programImage = '/images/micro.png';
                                badgeClass = 'information';
                                break;
                            case 'Programme Décryptage & Reportages':
                                programImage = '/images/programmes.png';
                                badgeClass = 'decryptage';
                                break;
                            case 'Programme Débats':
                                programImage = '/images/Débat.png';
                                badgeClass = 'debats';
                                break;
                            case 'Programme Humain & Sociétal':
                                programImage = '/images/femme%20telex.png';
                                badgeClass = 'societe';
                                break;
                            case 'Programme Éducatif':
                                programImage = '/images/programmes.png';
                                badgeClass = 'education';
                                break;
                            case 'Programme Jeunesse':
                                programImage = '/images/programmes.png';
                                badgeClass = 'jeunesse';
                                break;
                            case 'Programme Environnement':
                                programImage = '/images/programmes.png';
                                badgeClass = 'environnement';
                                break;
                            case 'Programme Culture & Identité':
                                programImage = '/images/femme%20telex.png';
                                badgeClass = 'culture';
                                break;
                            case 'Programme Économie & Travail':
                                programImage = '/images/TELEX BAREA12.png';
                                badgeClass = 'economie';
                                break;
                            case 'Programme Sport':
                                programImage = '/images/TELEX BAREA12.png';
                                badgeClass = 'sport';
                                break;
                        }

                        let broadcastBadge = '';
                        let broadcastMessage = '';
                        let showVideoPlayer = false;
                        let showReplayBadge = false;
                        let programDateTime = null;
                        let now = new Date();

                        if (program.video_url && program.video_url.trim() !== '') {
                            showVideoPlayer = true;
                        }

                        if (program.broadcast_type === 'scheduled') {
                            programDateTime = new Date(program.program_date + 'T' + program.schedule_time);
                            if (programDateTime > now) {
                                broadcastBadge = '<span class="badge bg-info"><i class="fas fa-calendar me-1"></i>Programmé</span>';
                                broadcastMessage = `Diffusion prévue le ${new Date(program.program_date).toLocaleDateString('fr-FR')} à ${program.schedule_time}`;
                            } else {
                                const oneHourLater = new Date(programDateTime.getTime() + 60 * 60 * 1000);
                                if (now >= programDateTime && now <= oneHourLater) {
                                    broadcastBadge = '<span class="badge bg-warning"><i class="fas fa-broadcast-tower me-1"></i>En cours</span>';
                                    broadcastMessage = 'Diffusion en cours';
                                } else {
                                    broadcastBadge = '<span class="badge bg-success"><i class="fas fa-check me-1"></i>Terminé</span>';
                                    broadcastMessage = 'Diffusion terminée';
                                    showVideoPlayer = true;
                                }
                            }
                        } else if (program.broadcast_type === 'live') {
                            const createdAt = new Date(program.created_at);
                            const oneDayAgo = new Date(now.getTime() - 24 * 60 * 60 * 1000);
                            
                            if (createdAt <= oneDayAgo) {
                                broadcastBadge = '<span class="badge bg-success"><i class="fas fa-video me-1"></i>Replay</span>';
                                broadcastMessage = 'Replay disponible';
                                showReplayBadge = true;
                            } else {
                                broadcastBadge = '<span class="badge bg-danger"><i class="fas fa-broadcast-tower me-1"></i>Live</span>';
                                broadcastMessage = 'Programme live';
                            }
                            showVideoPlayer = true;
                        } else {
                            broadcastBadge = '<span class="badge bg-secondary"><i class="fas fa-bullhorn me-1"></i>Annonce</span>';
                            broadcastMessage = 'Information à venir';
                            if (program.video_url && program.video_url.trim() !== '') {
                                showVideoPlayer = true;
                            }
                        }
                    %>
                    <div class="col-md-6 mb-4 program-card clickable-program" 
                         data-program-id="<%= program.id %>"
                         data-title="<%= (program.title || '').toLowerCase() %>"
                         data-type="<%= (program.program_type || '').toLowerCase() %>"
                         data-description="<%= (program.description || '').toLowerCase() %>"
                         onclick="incrementProgramView('<%= program.id %>')">
                        <div class="program-detail-card">

                            <div class="program-media-section">
                                <!-- Overlay : badge catégorie + titre -->
                                <div class="media-overlay">
                                    <span class="media-cat-badge">
                                        <%= program.program_type ? program.program_type.replace('Programme ', '') : 'Programme' %>
                                    </span>
                                    <div class="media-title-block">
                                        <div class="media-broadcast-label"><%- broadcastBadge %></div>
                                        <h3><%= program.title || 'Programme Telex' %></h3>
                                    </div>
                                </div>
                                <% if (program.video_url && program.video_url.trim() !== '') { %>
                                    <div class="video-container">
                                        <% if (program.video_url.includes('youtube.com') || program.video_url.includes('youtu.be')) { %>
                                        <iframe src="https://www.youtube.com/embed/<%= program.video_url.includes('youtu.be') ? program.video_url.split('youtu.be/')[1].split('?')[0] : program.video_url.split('v=')[1].split('&')[0] %>"
                                                frameborder="0" allowfullscreen class="program-video-player">
                                        </iframe>
                                        <% } else if (program.video_url.includes('vimeo.com')) { %>
                                        <iframe src="https://player.vimeo.com/video/<%= program.video_url.split('vimeo.com/')[1].split('?')[0] %>"
                                                frameborder="0" allowfullscreen class="program-video-player">
                                        </iframe>
                                        <% } else { %>
                                        <video class="program-video-player" controls preload="metadata" playsinline>
                                            <source src="<%= program.video_url %>" type="video/mp4">
                                        </video>
                                        <% } %>
                                    </div>
                                    <% if (showReplayBadge) { %>
                                    <div class="replay-badge"><i class="fas fa-redo-alt me-1"></i>Replay</div>
                                    <% } %>
                                <% } else { %>
                                    <div class="program-image-wrapper">
                                        <img src="<%= program.image_url || programImage %>"
                                             alt="<%= program.title || 'Programme' %>"
                                             class="program-image"
                                             onerror="this.src='/images/programmes.png';">
                                    </div>
                                <% } %>
                            </div>

                            <div class="program-body">
                                <div class="broadcast-badge"></div>
                                
                                <div class="program-description">
                                    <%
                                    const description = program.description || 'Découvrez ce programme passionnant sur Telex.';
                                    const shortDescription = description.length > 100 ? description.substring(0, 100) + '…' : description;
                                    %>
                                    <p><%= shortDescription %></p>
                                </div>
                                
                                <div class="program-info">
                                    <% if (program.schedule_time && program.broadcast_type === 'scheduled') { %>
                                    <p><i class="far fa-clock me-2"></i><strong>Diffusion :</strong> <%= program.schedule_time %></p>
                                    <% } %>
                                    <% if (program.program_date && program.broadcast_type === 'scheduled') { %>
                                    <p><i class="far fa-calendar me-2"></i><strong>Date :</strong> <%= new Date(program.program_date).toLocaleDateString('fr-FR') %></p>
                                    <% } %>
                                    <% if (program.presenter) { %>
                                    <p><i class="fas fa-user me-2"></i><strong><%= program.program_type === 'Programme Débats' ? 'Animation' : 'Présentation' %> :</strong> <%= program.presenter %></p>
                                    <% } %>
                                    <% if (program.duration) { %>
                                    <p><i class="fas fa-hourglass-half me-2"></i><strong>Durée :</strong> <%= program.duration %></p>
                                    <% } %>
                                </div>
                                
                                <div class="program-actions">
                                    <% if (program.video_url && showVideoPlayer) { %>
                                    <a href="<%= program.video_url %>" class="btn btn-primary" target="_blank">
                                        <i class="fas fa-play me-2"></i>Regarder
                                    </a>
                                    <% } else { %>
                                    <a href="#" class="btn btn-primary disabled">
                                        <i class="fas fa-clock me-2"></i>Bientôt disponible
                                    </a>
                                    <% } %>
                                    <button class="btn btn-outline-secondary" 
                                            data-program-title="<%= program.title || 'Programme' %>"
                                            data-program-description="<%= program.description || 'Découvrez ce programme passionnant sur Telex.' %>"
                                            data-program-type="<%= program.program_type || 'Programme' %>"
                                            data-program-presenter="<%= program.presenter || '' %>"
                                            data-program-schedule="<%= program.schedule_time || '' %>"
                                            data-program-date="<%= program.program_date || '' %>"
                                            data-program-duration="<%= program.duration || '' %>"
                                            data-program-video="<%= program.video_url || '' %>"
                                            data-program-image="<%= program.image_url || programImage %>"
                                            onclick="event.stopPropagation(); showProgramInfo(this.dataset)">
                                        <i class="fas fa-info-circle me-2"></i>Détails
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
