                    <div class="col-lg-6 mb-4 program-card" 
                         data-title="telex sports athlétisme"
                         data-type="sport"
                         data-description="couverture complète des événements sportifs universitaires interviews d'athlètes et analyses techniques">
                        <div class="program-detail-card">
                            <div class="program-title-section">
                                <h3>Telex Sports</h3>
                                <span class="program-badge badge-sport">⚽ SPORT</span>
                            </div>
                            <div class="program-media-section">
                                <div class="program-image-wrapper">
                                    <img src="/images/TELEX BAREA12.png" alt="Telex Sports" class="program-image">
                                </div>
                            </div>
                            <div class="program-body">
                                <div class="broadcast-badge">
                                    <span class="badge bg-info"><i class="fas fa-calendar me-1"></i>Programmé</span>
                                    <small class="text-muted ms-2">Diffusion prévue le samedi à 17h</small>
                                </div>
                                <div class="program-description">
                                    <p>Couverture complète des événements sportifs universitaires, interviews d'athlètes et analyses techniques.</p>
                                </div>
                                <div class="program-info">
                                    <p><i class="far fa-clock me-2"></i><strong>Diffusion :</strong> Samedi 17h</p>
                                    <p><i class="fas fa-user me-2"></i><strong>Présentation :</strong> Marc & Sophie</p>
                                    <p><i class="fas fa-hourglass-half me-2"></i><strong>Durée :</strong> 35 minutes</p>
                                </div>
                                <div class="program-actions">
                                    <a href="#" class="btn btn-primary disabled"><i class="fas fa-clock me-2"></i>Bientôt disponible</a>
                                    <button class="btn btn-outline-secondary" data-program-title="Telex Sports" onclick="showProgramInfo(this.dataset)"><i class="fas fa-info-circle me-2"></i>Détails</button>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- Grille des programmes -->
            <div class="mt-5 pt-5 border-top">
                <h2 class="text-center mb-4">Grille des Programmes</h2>
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Jour</th>
                                <th>Heure</th>
                                <th>Émission</th>
                                <th>Type</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% 
                            const programSchedule = {};
                            const joursSemaine = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi', 'Dimanche'];
                            
                            joursSemaine.forEach(jour => {
                                programSchedule[jour] = [];
                            });
                            
                            const defaultPrograms = [
                                { jour: 'Lundi', heure: '12:00', emission: '1 notion en 3 minutes', type: 'Éducatif', typeClass: 'education' },
                                { jour: 'Lundi', heure: '18:00', emission: 'TELEX Actus', type: 'Information', typeClass: 'information' },
                                { jour: 'Mardi', heure: '20:00', emission: 'Décryptage & Reportages', type: 'Décryptage', typeClass: 'decryptage' },
                                { jour: 'Mercredi', heure: '18:00', emission: 'Zoom Écologie', type: 'Environnement', typeClass: 'environnement' },
                                { jour: 'Mercredi', heure: '20:00', emission: 'Face à Face', type: 'Débat', typeClass: 'debats' },
                                { jour: 'Jeudi', heure: '18:00', emission: 'Travailler à Mada', type: 'Économie', typeClass: 'economie' },
                                { jour: 'Jeudi', heure: '19:00', emission: 'À Cœur Ouvert', type: 'Sociétal', typeClass: 'societe' },
                                { jour: 'Vendredi', heure: '17:00', emission: 'La Question des Jeunes', type: 'Jeunesse', typeClass: 'jeunesse' },
                                { jour: 'Vendredi', heure: '19:00', emission: 'Culture & Identité', type: 'Culture', typeClass: 'culture' },
                                { jour: 'Samedi', heure: '17:00', emission: 'Telex Sports', type: 'Sport', typeClass: 'sport' }
                            ];
                            
                            let hasDbPrograms = false;
                            if (schedulePrograms && schedulePrograms.length > 0) {
                                schedulePrograms.forEach(program => {
                                    if (program.broadcast_type === 'scheduled' && program.schedule_time && program.program_date) {
                                        hasDbPrograms = true;
                                        const programDate = new Date(program.program_date);
                                        const jourIndex = programDate.getDay();
                                        const jourName = joursSemaine[jourIndex === 0 ? 6 : jourIndex - 1];
                                        
                                        let typeClass = 'default';
                                        let typeName = program.program_type || 'Programme';
                                        
                                        switch(program.program_type) {
                                            case 'Programme d\'Information': typeClass = 'information'; typeName = 'Information'; break;
                                            case 'Programme Décryptage & Reportages': typeClass = 'decryptage'; typeName = 'Décryptage'; break;
                                            case 'Programme Débats': typeClass = 'debats'; typeName = 'Débat'; break;
                                            case 'Programme Humain & Sociétal': typeClass = 'societe'; typeName = 'Sociétal'; break;
                                            case 'Programme Éducatif': typeClass = 'education'; typeName = 'Éducatif'; break;
                                            case 'Programme Jeunesse': typeClass = 'jeunesse'; typeName = 'Jeunesse'; break;
                                            case 'Programme Environnement': typeClass = 'environnement'; typeName = 'Environnement'; break;
                                            case 'Programme Culture & Identité': typeClass = 'culture'; typeName = 'Culture'; break;
                                            case 'Programme Économie & Travail': typeClass = 'economie'; typeName = 'Économie'; break;
                                            case 'Programme Sport': typeClass = 'sport'; typeName = 'Sport'; break;
                                        }
                                        
                                        programSchedule[jourName].push({
                                            title: program.title,
                                            time: program.schedule_time,
                                            type: typeName,
                                            typeClass: typeClass
                                        });
                                    }
                                });
                            }
                            
                            if (!hasDbPrograms) {
                                defaultPrograms.forEach(program => {
                                    programSchedule[program.jour].push({
                                        title: program.emission,
                                        time: program.heure,
                                        type: program.type,
                                        typeClass: program.typeClass
                                    });
                                });
                            }
                            
                            let hasPrograms = false;
                            joursSemaine.forEach(jour => {
                                if (programSchedule[jour] && programSchedule[jour].length > 0) {
                                    hasPrograms = true;
                                    programSchedule[jour].sort((a, b) => {
                                        const timeToMinutes = (timeStr) => {
                                            if (!timeStr) return 0;
                                            if (timeStr.includes(':')) {
                                                const [hours, minutes] = timeStr.split(':');
                                                return parseInt(hours) * 60 + parseInt(minutes || 0);
                                            } else if (timeStr.includes('h')) {
                                                const [hours, minutes] = timeStr.split('h');
                                                return parseInt(hours) * 60 + parseInt(minutes || 0);
                                            }
                                            return 0;
                                        };
                                        return timeToMinutes(a.time) - timeToMinutes(b.time);
                                    });
                                    
                                    programSchedule[jour].forEach(program => { %>
                                        <tr>
                                            <td><%= jour %></td>
                                            <td><%= program.time %></td>
                                            <td><%= program.title %></td>
                                            <td><span class="badge badge-<%= program.typeClass %>"><%= program.type %></span></td>
                                        </tr>
                                    <% });
                                }
                            });
                            
                            if (!hasPrograms) { %>
                                <tr>
                                    <td colspan="4" class="text-center text-muted">
                                        <i class="fas fa-calendar-alt me-2"></i>
                                        Aucun programme programmé pour le moment
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        async function incrementProgramView(programId) {
            try {
                const programCard = document.querySelector(`[data-program-id="${programId}"]`);
                if (programCard) {
                    programCard.style.transform = 'scale(0.98)';
                    setTimeout(() => {
                        programCard.style.transform = '';
                    }, 150);
                }
                
                const response = await fetch(`/api/programs/${programId}/view`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    const result = await response.json();
                    if (programCard) {
                        programCard.style.boxShadow = '0 8px 30px rgba(0, 123, 255, 0.3)';
                        setTimeout(() => {
                            programCard.style.boxShadow = '';
                        }, 300);
                    }
                }
            } catch (error) {
                console.error('Erreur:', error);
            }
        }

        function searchPrograms() {
            const searchInput = document.getElementById('searchInput');
            if (!searchInput) return;
            
            const searchTerm = searchInput.value.toLowerCase().trim();
            const programCards = document.querySelectorAll('.program-card');
            const noResults = document.getElementById('noResults');
            let visibleCount = 0;
            
            if (searchTerm === '') {
                programCards.forEach(card => {
                    card.style.display = 'block';
                    visibleCount++;
                });
                if (noResults) noResults.style.display = 'none';
                return;
            }
            
            programCards.forEach(card => {
                const title = (card.getAttribute('data-title') || '').toLowerCase();
                const type = (card.getAttribute('data-type') || '').toLowerCase();
                const description = (card.getAttribute('data-description') || '').toLowerCase();
                
                const searchText = `${title} ${type} ${description}`;
                const matches = searchText.includes(searchTerm);
                
                if (matches) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });
            
            if (noResults) {
                noResults.style.display = visibleCount === 0 ? 'block' : 'none';
            }
        }

        function resetSearch() {
            const searchInput = document.getElementById('searchInput');
            if (searchInput) searchInput.value = '';
            
            const programCards = document.querySelectorAll('.program-card');
            programCards.forEach(card => {
                card.style.display = 'block';
            });
            
            const noResults = document.getElementById('noResults');
            if (noResults) noResults.style.display = 'none';
        }

        function showProgramInfo(dataset) {
            const oldModal = document.getElementById('programInfoModal');
            if (oldModal) oldModal.remove();
            
            const modal = document.createElement('div');
            modal.className = 'modal fade';
            modal.id = 'programInfoModal';
            modal.setAttribute('tabindex', '-1');
            modal.setAttribute('aria-hidden', 'true');
            
            let formattedDate = '';
            if (dataset.programDate) {
                try {
                    const date = new Date(dataset.programDate);
                    formattedDate = date.toLocaleDateString('fr-FR', { 
                        weekday: 'long', 
                        year: 'numeric', 
                        month: 'long', 
                        day: 'numeric' 
                    });
                } catch (e) {
                    formattedDate = dataset.programDate;
                }
            }
            
            modal.innerHTML = `
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-gradient text-white" style="background: linear-gradient(135deg, #1D3557, #A8DADC);">
                            <div class="d-flex align-items-center">
                                <img src="/images/Telex.png" alt="Telex" style="width: 40px; height: 40px; margin-right: 15px;">
                                <h5 class="modal-title mb-0">
                                    <i class="fas fa-tv me-2"></i>
                                    ${dataset.programTitle || 'Programme Telex'}
                                </h5>
                            </div>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fermer"></button>
                        </div>
                        <div class="modal-body">
                            <div class="text-center mb-4">
                                <img src="/images/Telex.png" alt="Telex" style="width: 80px; opacity: 0.8;">
                            </div>
                            <div class="row">
                                <div class="col-md-8">
                                    <h6 class="text-primary mb-3"><i class="fas fa-info-circle me-2"></i>Description</h6>
                                    <p class="lead">${dataset.programDescription || 'Découvrez ce programme passionnant sur Telex.'}</p>
                                    
                                    ${dataset.programType ? `
                                    <h6 class="text-primary mb-3"><i class="fas fa-tag me-2"></i>Type de programme</h6>
                                    <p><span class="badge bg-primary fs-6">${dataset.programType}</span></p>
                                    ` : ''}
                                    
                                    ${dataset.programPresenter ? `
                                    <h6 class="text-primary mb-3"><i class="fas fa-user me-2"></i>${dataset.programType && dataset.programType.includes('Débat') ? 'Animation' : 'Présentation'}</h6>
                                    <p>${dataset.programPresenter}</p>
                                    ` : ''}
                                </div>
                                <div class="col-md-4">
                                    <div class="card bg-light">
                                        <div class="card-body">
                                            <h6 class="card-title"><i class="fas fa-calendar-alt me-2"></i>Informations pratiques</h6>
                                            ${dataset.programSchedule ? `<p class="mb-2"><i class="far fa-clock me-2"></i><strong>Heure :</strong><br>${dataset.programSchedule}</p>` : ''}
                                            ${formattedDate ? `<p class="mb-2"><i class="far fa-calendar me-2"></i><strong>Date :</strong><br>${formattedDate}</p>` : ''}
                                            ${dataset.programDuration ? `<p class="mb-2"><i class="fas fa-hourglass-half me-2"></i><strong>Durée :</strong><br>${dataset.programDuration}</p>` : ''}
                                            ${dataset.programVideo ? `<div class="mt-3"><a href="${dataset.programVideo}" class="btn btn-primary btn-sm w-100" target="_blank"><i class="fas fa-play me-2"></i>Regarder</a></div>` : ''}
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>
                            <div class="text-center">
                                <p class="text-muted mb-0"><i class="fas fa-tv me-2"></i>Suivez <strong>TELEX</strong> sur nos réseaux sociaux pour ne manquer aucune actualité !</p>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-2"></i>Fermer</button>
                            ${dataset.programVideo ? `<a href="${dataset.programVideo}" class="btn btn-primary" target="_blank"><i class="fas fa-play me-2"></i>Regarder maintenant</a>` : ''}
                        </div>
                    </div>
                </div>
            `;
            
            document.body.appendChild(modal);
            const bootstrapModal = new bootstrap.Modal(modal);
            bootstrapModal.show();
            modal.addEventListener('hidden.bs.modal', () => modal.remove());
        }

        function toggleDescription(programId) {
            const descElement = document.getElementById(`desc-${programId}`);
            if (!descElement) return;
            
            const shortDesc = descElement.querySelector('.short-desc');
            const fullDesc = descElement.querySelector('.full-desc');
            const moreText = descElement.querySelector('.more-text');
            const lessText = descElement.querySelector('.less-text');
            
            if (fullDesc && fullDesc.classList.contains('d-none')) {
                shortDesc?.classList.add('d-none');
                fullDesc.classList.remove('d-none');
                moreText?.classList.add('d-none');
                lessText?.classList.remove('d-none');
            } else if (fullDesc) {
                shortDesc?.classList.remove('d-none');
                fullDesc.classList.add('d-none');
                moreText?.classList.remove('d-none');
                lessText?.classList.add('d-none');
            }
        }

        function initSearch() {
            const searchInput = document.getElementById('searchInput');
            if (searchInput) {
                searchInput.addEventListener('input', () => searchPrograms());
                searchInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') searchPrograms(); });
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            initSearch();
            
            const programCards = document.querySelectorAll('.program-card');
            programCards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(30px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.6s ease-out';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 100);
            });
            
            const images = document.querySelectorAll('.program-image');
            images.forEach(img => {
                img.addEventListener('error', function() {
                    if (!this.src.includes('/images/programmes.png')) {
                        this.src = '/images/programmes.png';
                    }
                });
            });
        });

        window.searchPrograms = searchPrograms;
        window.resetSearch = resetSearch;
        window.showProgramInfo = showProgramInfo;
        window.toggleDescription = toggleDescription;
        window.incrementProgramView = incrementProgramView;
    </script>
</body>
</html>