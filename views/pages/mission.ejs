<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mission - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-telex fixed-top">
        <div class="container">
            <!-- Logo Telex -->
            <a class="navbar-brand" href="/">
                <img src="/images/Telex.png" alt="Logo Telex" class="logo-img">
                <span class="logo-text">Telex</span>
            </a>
            
            <!-- Menu mobile -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                <i class="fas fa-bars"></i>
            </button>
            
            <!-- Menu -->
            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'home' ? 'active' : '' %>" href="/">
                            <i class="fas fa-home me-1"></i>Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'about' ? 'active' : '' %>" href="/about">
                            <i class="fas fa-info-circle me-1"></i>À propos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'mission' ? 'active' : '' %>" href="/mission">
                            <i class="fas fa-bullseye me-1"></i>Mission
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'programs' ? 'active' : '' %>" href="/programs">
                            <i class="fas fa-tv me-1"></i>Programmes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'gallery' ? 'active' : '' %>" href="/gallery">
                            <i class="fas fa-images me-1"></i>Galerie
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'news' ? 'active' : '' %>" href="/news">
                            <i class="fas fa-newspaper me-1"></i>Actualités
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'contact' ? 'active' : '' %>" href="/contact">
                            <i class="fas fa-envelope me-1"></i>Contact
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <section class="page-hero mission-hero">
    <div class="container">
        <div class="row align-items-stretch">
            <!-- Colonne pour l'image du micro agrandie -->
            <div class="col-lg-4 col-md-5">
                <div class="micro-hero-container">
                    <img src="/images/micro.png" alt="Micro Telex" class="mission-micro-large">
                    <div class="micro-glow"></div>
                </div>
            </div>
            <!-- Colonne pour le texte -->
            <div class="col-lg-8 col-md-7">
                <div class="mission-header-large d-flex flex-column justify-content-center h-100">
                    <h1 class="display-2 fw-bold mb-3">Telex</h1>
                    <p class="lead mb-4">Donner une voix à la créativité étudiante et former les talents de demain dans le monde de l'audiovisuel.</p>
                </div>
            </div>
        </div>
    </div>
</section>

    <section class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-10 mx-auto">
                    <!-- Notre Mission -->
                    <div class="mission-card mb-5">
                        <div class="mission-icon">
                            <i class="fas fa-bullseye"></i>
                        </div>
                        <h2>Notre Mission</h2>
                        <p class="lead">
                            Former les talents audiovisuels de demain tout en produisant 
                            des contenus de qualité qui reflètent les préoccupations 
                            et les aspirations de la jeunesse.
                        </p>
                    </div>

                    <!-- Nos Objectifs -->
                    <h3 class="mb-4">Nos Objectifs</h3>
                    <div class="row mb-5">
                        <div class="col-md-6 mb-4">
                            <div class="objective-card">
                                <h4><i class="fas fa-graduation-cap me-2"></i>Former</h4>
                                <p>100 étudiants par an aux métiers de l'audiovisuel</p>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="objective-card">
                                <h4><i class="fas fa-video me-2"></i>Produire</h4>
                                <p>52 émissions originales par an</p>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="objective-card">
                                <h4><i class="fas fa-users me-2"></i>Rassembler</h4>
                                <p>Une communauté de 10 000 jeunes engagés</p>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="objective-card">
                                <h4><i class="fas fa-globe me-2"></i>Diffuser</h4>
                                <p>Dans 50 établissements scolaires</p>
                            </div>
                        </div>
                    </div>

                    <!-- Nos Valeurs -->
                    <h3 class="mb-4">Nos Valeurs</h3>
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="value-card">
                                <div class="value-icon bg-primary">
                                    <i class="fas fa-lightbulb"></i>
                                </div>
                                <div>
                                    <h5>Innovation</h5>
                                    <p class="mb-0">Nous repoussons les limites créatives</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="value-card">
                                <div class="value-icon bg-success">
                                    <i class="fas fa-handshake"></i>
                                </div>
                                <div>
                                    <h5>Collaboration</h5>
                                    <p class="mb-0">Nous croyons à la force du collectif</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="value-card">
                                <div class="value-icon bg-warning">
                                    <i class="fas fa-shield-alt"></i>
                                </div>
                                <div>
                                    <h5>Responsabilité</h5>
                                    <p class="mb-0">Nous assumons nos engagements</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="value-card">
                                <div class="value-icon bg-info">
                                    <i class="fas fa-users"></i>
                                </div>
                                <div>
                                    <h5>Inclusion</h5>
                                    <p class="mb-0">Nous accueillons toutes les diversités</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer-telex">
        <div class="container">
            <div class="footer-bottom">
                <p>&copy; 2026 Telex - Tous droits réservés</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>