<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mission - Telex | Télévision Étudiante</title>
    <link rel="icon" href="/images/Telex.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/baume-navbar.css">
</head>
<body>
    <!-- Navigation - Version corrigée -->
<%- include('../partials/navbar') %>

    <section class="page-hero mission-hero">
        <!-- Image décorative gauche -->
        <div class="hero-side-image hero-left-image">
            <img id="heroLeftImage" src="/images/11.png" alt="Logo Telex">
        </div>
        
        <!-- Image décorative droite -->
        <div class="hero-side-image hero-right-image">
            <img id="heroRightImage" src="/images/Telex.png" alt="Telex">
        </div>
        
        <div class="container">
        <div class="row align-items-stretch">
            <!-- Colonne pour l'image du micro agrandie -->
            <div class="col-lg-4 col-md-5">
                <div class="micro-hero-container">
                    <img src="/images/micro.png" alt="Micro Telex" class="mission-micro-large">
                    <div class="micro-glow"></div>
                </div>
            </div>
            <!-- Colonne pour le texte -->
            <div class="col-lg-8 col-md-7">
                <div class="mission-header-large d-flex flex-column justify-content-center h-100">
                    <h1 class="display-2 fw-bold mb-3">Telex</h1>
                    <p class="lead mb-4">Donner une voix à la créativité étudiante et former les talents de demain dans le monde de l'audiovisuel.</p>
                </div>
            </div>
        </div>
    </div>
</section>

    <section class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-10 mx-auto">
                    <!-- Notre Mission -->
                    <div class="mission-card mb-5">
                        <div class="mission-icon">
                            <i class="fas fa-bullseye"></i>
                        </div>
                        <h2>Notre Mission</h2>
                        <p class="lead">
                            Former les talents audiovisuels de demain tout en produisant 
                            des contenus de qualité qui reflètent les préoccupations 
                            et les aspirations de la jeunesse.
                        </p>
                    </div>

                    <!-- Nos Objectifs -->
                    <h3 class="mb-4">Nos Objectifs</h3>
                    <div class="row mb-5">
                        <div class="col-md-6 mb-4">
                            <div class="objective-card">
                                <h4><i class="fas fa-graduation-cap me-2"></i>Former</h4>
                                <p>100 étudiants par an aux métiers de l'audiovisuel</p>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="objective-card">
                                <h4><i class="fas fa-video me-2"></i>Produire</h4>
                                <p>52 émissions originales par an</p>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="objective-card">
                                <h4><i class="fas fa-users me-2"></i>Rassembler</h4>
                                <p>Une communauté de 10 000 jeunes engagés</p>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="objective-card">
                                <h4><i class="fas fa-globe me-2"></i>Décrire et Diffuser</h4>
                                <p>Dans 50 établissements scolaires</p>
                            </div>
                        </div>
                    </div>

                    <!-- Nos Valeurs -->
                    <h3 class="mb-4">Nos Valeurs</h3>
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="value-card">
                                <div class="value-icon bg-primary">
                                    <i class="fas fa-lightbulb"></i>
                                </div>
                                <div>
                                    <h5>Innovation</h5>
                                    <p class="mb-0">Nous repoussons les limites créatives</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="value-card">
                                <div class="value-icon bg-success">
                                    <i class="fas fa-handshake"></i>
                                </div>
                                <div>
                                    <h5>Collaboration</h5>
                                    <p class="mb-0">Nous croyons à la force du collectif</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="value-card">
                                <div class="value-icon bg-warning">
                                    <i class="fas fa-shield-alt"></i>
                                </div>
                                <div>
                                    <h5>Collaboration et humanité</h5>
                                    <p class="mb-0">Agir ensemble avec respect et engagement.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="value-card">
                                <div class="value-icon bg-info">
                                    <i class="fas fa-users"></i>
                                </div>
                                <div>
                                    <h5>Inclusion</h5>
                                    <p class="mb-0">Nous accueillons toutes les diversités</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="value-card">
                                <div class="value-icon bg-danger">
                                    <i class="fas fa-balance-scale"></i>
                                </div>
                                <div>
                                    <h5>Valeur éthique</h5>
                                    <p class="mb-0">Intégrité et responsabilité dans toutes nos actions</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="value-card">
                                <div class="value-icon bg-secondary">
                                    <i class="fas fa-heart"></i>
                                </div>
                                <div>
                                    <h5>Relationnelle</h5>
                                    <p class="mb-0">Créer des liens forts et durables entre les étudiants</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    
    <script>
        // ===== SYSTÈME DE ROTATION AUTOMATIQUE DES IMAGES LATÉRALES =====
        document.addEventListener('DOMContentLoaded', function() {
            const leftImages = [
                '/images/11.png',
                '/images/2.png',
                '/images/3.png',
                '/images/4.png',
                '/images/5.png',
                '/images/Telex.png'
            ];
            
            const rightImages = [
                '/images/Telex.png',
                '/images/Telex11.png',
                '/images/11.png',
                '/images/logo ensemble.png',
                '/images/ensemble telex.png',
                '/images/TELEX BAREA.png'
            ];
            
            let leftImageIndex = 0;
            let rightImageIndex = 0;
            const heroLeftImage = document.getElementById('heroLeftImage');
            const heroRightImage = document.getElementById('heroRightImage');
            
            if (heroLeftImage && heroRightImage) {
                // Fonction pour changer l'image de gauche
                function changeLeftImage() {
                    leftImageIndex = (leftImageIndex + 1) % leftImages.length;
                    heroLeftImage.style.opacity = '0.3';
                    
                    setTimeout(() => {
                        heroLeftImage.src = leftImages[leftImageIndex];
                        heroLeftImage.style.opacity = '0.8';
                    }, 500);
                }
                
                // Fonction pour changer l'image de droite
                function changeRightImage() {
                    rightImageIndex = (rightImageIndex + 1) % rightImages.length;
                    heroRightImage.style.opacity = '0.3';
                    
                    setTimeout(() => {
                        heroRightImage.src = rightImages[rightImageIndex];
                        heroRightImage.style.opacity = '0.8';
                    }, 500);
                }
                
                // Changer les images toutes les 20 secondes (décalées pour éviter le changement simultané)
                setInterval(changeLeftImage, 20000);
                setInterval(changeRightImage, 25000); // 5 secondes de décalage
            }
        });
    </script>
</body>
</html>